<div class="res-page p-6">
    <div class="mb-5">
        <h1 class="text-2xl font-extrabold text-[#273F4F]">Laboratory Management</h1>
        <p class="text-gray-500 text-sm mt-1">Reserve a computer or view lab PC status.</p>
    </div>

    <!-- ── Tab Navigation ── -->
    <div
        style="background:#fff;border-radius:16px 16px 0 0;border:1px solid #E8E3DD;border-bottom:none;overflow:hidden;margin-bottom:0;">
        <div class="res-tab-bar">
            <button class="res-tab-btn active" onclick="switchTab('reservation')" id="tab-btn-reservation">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14" height="14">
                    <path fill-rule="evenodd"
                        d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z"
                        clip-rule="evenodd" />
                </svg>
                Lab Reservation
