        transform: none;
    }

    /* Reserve Form Modal */
    .resform-overlay {
        position: fixed;
        inset: 0;
        z-index: 300;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .resform-overlay.open {
        display: flex;
    }

    .resform-overlay.open .resform-card {
        animation: pcModalIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .resform-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.3);
        width: 100%;
        max-width: 480px;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
    }

    .resform-input {
        width: 100%;
        padding: 10px 13px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #F9F8F6;
        font-size: 13px;
        color: #1C2B35;
