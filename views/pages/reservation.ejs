                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                    Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var safeRes=(typeof reservations !=='undefined' && reservations) ? reservations : []; %>
                                <% if (safeRes.length> 0) { %>
                                    <% safeRes.forEach(function(r) { var rowStatus = String(r.status || '').toLowerCase(); %>
                                        <tr class="hover:bg-gray-50 res-row" id="row-<%= r.id %>" data-status="<%= r.status %>">
                                            <td class="px-4 py-3"><span
                                                    class="inline-block px-2 py-0.5 rounded-lg text-xs font-bold bg-[#273F4F]/10 text-[#273F4F]">Lab
                                                    <%= r.lab_room %></span></td>
                                            <td class="px-4 py-3"><span
                                                    class="inline-block px-2 py-0.5 rounded-lg text-xs font-bold bg-blue-50 text-blue-700">PC-
                                                    <%= String(r.computer_number||0).padStart(2,'0') %></span></td>
                                            <td class="px-4 py-3"><span
                                                    class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                                                    <%= r.purpose||'—' %>
                                                </span></td>
                                            <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
                                                <%= r.date %>
                                            </td>
                                            <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
