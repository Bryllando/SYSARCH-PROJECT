<div class="p-6">

    <div class="mb-6">
        <h1 class="text-2xl font-extrabold text-[#273F4F]">Reservation</h1>
        <p class="text-gray-500 text-sm mt-1">Reserve a laboratory slot in advance.</p>
    </div>

    <!-- Messages -->
    <% if (typeof messages !=='undefined' ) { %>
        <% messages.forEach(function(msg) { %>
            <div
                class="mb-4 p-3 rounded-xl flex items-center gap-3
                <%= msg.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
                <span class="font-medium text-sm">
                    <%= msg.text %>
                </span>
            </div>
            <% }) %>
                <% } %>

                    <!-- Side-by-side layout -->
                    <div class="flex gap-5" style="align-items:flex-start;">

                        <!-- LEFT: New Reservation Form -->
                        <div
                            class="flex-1 min-w-0 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

                            <!-- Card header -->
                            <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-[#5B0E14]"></div>
                                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">New Reservation
                                </h2>
                            </div>

                            <form action="/reservation" method="POST" class="px-6 py-5 space-y-5">

                                <!-- ID + Name row -->
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="space-y-1.5">
                                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide">
                                            ID Number <span
                                                class="font-normal text-gray-400 normal-case">(read-only)</span>
                                        </label>
                                        <input type="text" value="<%= user.id_number %>" disabled
                                            class="w-full px-3 py-2.5 bg-gray-600 border border-gray-200 rounded-lg text-sm text-gray-500 cursor-not-allowed">
                                    </div>
                                    <div class="space-y-1.5">
                                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide">
                                            Student Name <span
                                                class="font-normal text-gray-400 normal-case">(read-only)</span>
                                        </label>
                                        <input type="text"
                                            value="<%= user.first_name %> <%= user.middle_initial ? user.middle_initial + '. ' : '' %><%= user.last_name %>"
                                            disabled
                                            class="w-full px-3 py-2.5 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-500 cursor-not-allowed">
                                    </div>
                                </div>



                                <!-- Purpose -->
                                <div class="space-y-1.5">
                                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide">
                                        Purpose <span class="text-red-500">*</span>
                                    </label>
                                    <div class="relative">
                                        <select name="purpose" required
                                            class="w-full px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm text-gray-700 transition-all cursor-pointer">
                                            <option value="" disabled selected>Select purpose...</option>
                                            <option value="C Programming">C Programming</option>
                                            <option value="Java Programming">Java Programming</option>
                                            <option value="C# Programming">C# Programming</option>
                                            <option value="ASP.Net">ASP.Net</option>
                                            <option value="PHP Programming">PHP Programming</option>
                                            <option value="Database">Database</option>
                                            <option value="Research">Research</option>
                                            <option value="Other">Other</option>
                                        </select>
                                        <div
                                            class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                            </svg>
                                        </div>
                                    </div>
                                </div>

                                <!-- Laboratory -->
                                <div class="space-y-1.5">
                                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide">
                                        Laboratory <span class="text-red-500">*</span>
                                    </label>
                                    <div class="relative">
                                        <select name="lab_room" required
                                            class="w-full px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm text-gray-700 transition-all cursor-pointer">
                                            <option value="" disabled selected>Select laboratory...</option>
                                            <option value="524">Lab 524</option>
                                            <option value="526">Lab 526</option>
                                            <option value="528">Lab 528</option>
                                            <option value="530">Lab 530</option>
                                            <option value="Mac Lab">Mac Lab</option>
                                        </select>
                                        <div
                                            class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                            </svg>
                                        </div>
                                    </div>
                                </div>

                                <!-- Date -->
                                <div class="space-y-1.5">
                                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide">
                                        Date <span class="text-red-500">*</span>
                                    </label>
                                    <input type="date" name="date" required id="reservationDate"
                                        class="w-full px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm text-gray-700 transition-all">
                                </div>

                                <!-- Time Slot -->
                                <div class="space-y-1.5">
                                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide">
                                        Time Slot <span class="text-red-500">*</span>
                                        <span class="text-gray-400 font-normal normal-case ml-1">— start &amp;
                                            end</span>
                                    </label>
                                    <div class="flex items-center gap-3">
                                        <input type="time" id="timeStart" name="time_start" required
                                            class="flex-1 px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm text-gray-700 transition-all">
                                        <span class="text-xs text-gray-400 font-bold shrink-0">→</span>
                                        <input type="time" id="timeEnd" name="time_end" required
                                            class="flex-1 px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm text-gray-700 transition-all">
                                    </div>
                                    <input type="hidden" name="time_slot" id="timeSlotCombined">
                                    <p class="text-xs font-semibold text-[#5B0E14] hidden" id="timeSlotPreview"></p>
                                </div>

                                <!-- Remaining Sessions -->
                                <div class="flex items-center justify-between px-4 py-3 rounded-xl border border-yellow-200"
                                    style="background: linear-gradient(135deg, #FFFBEB, #FEF3C7);">
                                    <div class="flex items-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                            class="size-4 text-amber-500 shrink-0">
                                            <path fill-rule="evenodd"
                                                d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        <span class="text-sm font-semibold text-amber-800">Remaining Sessions</span>
                                    </div>
                                    <span class="text-2xl font-extrabold text-[#5B0E14]">
                                        <%= user.remaining_sessions ?? 30 %>
                                    </span>
                                </div>

                                <!-- Submit -->
                                <div class="pt-1">
                                    <button type="submit" class="btn-maroon py-3 text-sm w-full">
                                        Submit Reservation
                                    </button>
                                </div>

                            </form>
                        </div>

                        <!-- RIGHT: My Reservations Table -->
                        <div
                            class="flex-1 min-w-0 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

                            <!-- Card header -->
                            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between gap-3">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">My
                                        Reservations</h2>
                                </div>
                                <input type="text" id="searchInput" placeholder="Search..."
                                    class="border border-gray-200 rounded-lg px-3 py-1.5 text-xs text-gray-600 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#273F4F] bg-white w-36 transition-all">
                            </div>

                            <div class="overflow-x-auto">
                                <table class="w-full text-sm">
                                    <thead>
                                        <tr class="bg-gray-50 border-b border-gray-100">
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                #</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Lab</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Purpose</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Date</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Time</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Status</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-50" id="reservationBody">

                                        <% var safeReservations=(typeof reservations !=='undefined' && reservations) ?
                                            reservations : []; %>

                                            <% if (safeReservations.length> 0) { %>
                                                <% safeReservations.forEach(function(r, i) { %>
                                                    <tr class="hover:bg-gray-50 transition-colors reservation-row">
                                                        <td class="px-4 py-3 text-gray-400 text-xs font-mono">
                                                            <%= i + 1 %>
                                                        </td>
                                                        <td class="px-4 py-3">
                                                            <span
                                                                class="inline-block px-2 py-0.5 rounded-lg text-xs font-bold bg-[#273F4F]/10 text-[#273F4F]">
                                                                <%= r.lab_room %>
                                                            </span>
                                                        </td>
                                                        <td class="px-4 py-3">
                                                            <span
                                                                class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                                                                <%= r.purpose || '—' %>
                                                            </span>
                                                        </td>
                                                        <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
                                                            <%= r.date %>
                                                        </td>
                                                        <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
                                                            <%= r.time_slot %>
                                                        </td>
                                                        <td class="px-4 py-3">
                                                            <% if (r.status==='approved' ) { %>
                                                                <span
                                                                    class="inline-flex items-center gap-1 text-xs font-bold text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
                                                                    <span
                                                                        class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Approved
                                                                </span>
                                                                <% } else if (r.status==='rejected' ) { %>
                                                                    <span
                                                                        class="inline-flex items-center gap-1 text-xs font-bold text-red-700 bg-red-50 px-2.5 py-1 rounded-full">
                                                                        <span
                                                                            class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>Rejected
                                                                    </span>
                                                                    <% } else { %>
                                                                        <span
                                                                            class="inline-flex items-center gap-1 text-xs font-bold text-amber-700 bg-amber-50 px-2.5 py-1 rounded-full">
                                                                            <span
                                                                                class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>Pending
                                                                        </span>
                                                                        <% } %>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="6" class="px-6 py-16 text-center">
                                                                    <div class="flex flex-col items-center gap-3">
                                                                        <div
                                                                            class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                                                viewBox="0 0 24 24" fill="currentColor"
                                                                                class="size-7 text-gray-300">
                                                                                <path fill-rule="evenodd"
                                                                                    d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z"
                                                                                    clip-rule="evenodd" />
                                                                            </svg>
                                                                        </div>
                                                                        <p class="text-sm text-gray-400 font-medium">No
                                                                            reservations yet</p>
                                                                        <p class="text-xs text-gray-300">Fill out the
                                                                            form on the left to make one.</p>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            <% } %>

                                    </tbody>
                                </table>
                            </div>

                            <div class="px-6 py-3 border-t border-gray-100 text-xs text-gray-500">
                                Showing <span class="font-semibold text-gray-700">
                                    <%= safeReservations.length %>
                                </span>
                                reservation<%= safeReservations.length !==1 ? 's' : '' %>
                            </div>
                        </div>

                    </div>
</div>

<script>
    document.getElementById('reservationDate').min = new Date().toISOString().split('T')[0];

    function to12h(t) {
        if (!t) return '';
        const [h, m] = t.split(':').map(Number);
        const ampm = h >= 12 ? 'PM' : 'AM';
        const hour = h % 12 || 12;
        return `${String(hour).padStart(2, '0')}:${String(m).padStart(2, '0')} ${ampm}`;
    }

    function updateTimeSlot() {
        const start = document.getElementById('timeStart').value;
        const end = document.getElementById('timeEnd').value;
        const preview = document.getElementById('timeSlotPreview');
        const combined = document.getElementById('timeSlotCombined');
        if (start && end) {
            const label = `${to12h(start)} – ${to12h(end)}`;
            combined.value = label;
            preview.textContent = '⏰ ' + label;
            preview.classList.remove('hidden');
        } else {
            combined.value = '';
            preview.textContent = '';
            preview.classList.add('hidden');
        }
    }

    document.getElementById('timeStart').addEventListener('change', updateTimeSlot);
    document.getElementById('timeEnd').addEventListener('change', updateTimeSlot);

    document.getElementById('searchInput').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.reservation-row').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
</script>