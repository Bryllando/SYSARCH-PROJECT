                        <option>Research</option>
                        <option>Other</option>
                    </select>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;">
                <label
                    style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6B7280;">Date
                    <span style="color:#DC2626;">*</span></label>
                <input type="date" name="date" id="formDate"
                    style="width:100%;padding:10px 13px;border:1.5px solid #D6D0CA;border-radius:9px;background:#F9F8F6;font-size:13px;color:#1C2B35;outline:none;box-sizing:border-box;"
