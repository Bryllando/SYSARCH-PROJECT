                        class="text-amber-600">—</strong></span>
            </div>
            <div class="stat-chip">
                <div class="stat-dot" style="background:#3B82F6;"></div><span>Reserved: <strong id="stat-reserved"
                        class="text-blue-600">—</strong></span>
            </div>
            <div class="stat-chip">
                <div class="stat-dot" style="background:#DC2626;"></div><span>Defective: <strong id="stat-defect"
                        class="text-red-600">—</strong></span>
            </div>
        </div>

        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Click a lab to view and reserve a
            computer</p>
