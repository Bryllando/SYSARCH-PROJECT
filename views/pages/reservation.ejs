                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                PC</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Purpose</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Date</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Time</th>
                                            <th
                                                class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
