<% if (typeof user !=='undefined' && user && user.role==='admin' ) { %>
    <div id="scOverlay" class="sc-overlay" onclick="if(event.target===this) closeStatusModal()">
        <div class="sc-card">
            <div
                style="background:linear-gradient(135deg,#273F4F,#1a2d38);padding:18px 24px;display:flex;align-items:center;justify-content:space-between;">
                <span style="font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff;">Change PC
                    Status</span>
                <button onclick="closeStatusModal()"
                    style="width:30px;height:30px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.18);border-radius:8px;color:rgba(255,255,255,0.7);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;">✕</button>
            </div>
            <div
                style="padding:14px 24px;background:linear-gradient(135deg,#F9F8F6,#F0EDE8);border-bottom:1px solid #E8E3DD;display:flex;align-items:center;gap:12px;">
                <div
                    style="width:42px;height:36px;border-radius:9px;background:#E8EFF4;border:2px solid #C7D8E4;display:flex;align-items:center;justify-content:center;">
                    🖥</div>
                <div>
                    <div style="font-weight:800;color:#1C2B35;font-size:14px;" id="scPcNum">PC-01</div>
                    <div style="font-size:11px;color:#6B7280;" id="scPcLab">Lab 524</div>
                </div>
            </div>
            <div style="padding:20px 24px;display:flex;flex-direction:column;gap:0;">
                <p
                    style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6B7280;margin:0 0 10px;">
                    Set Status To:</p>
                <button class="sc-status-btn btn-avail" onclick="applyStatus('available')"><span
                        class="sc-dot"></span>Available</button>
                <button class="sc-status-btn btn-inuse" onclick="applyStatus('in_use')"><span class="sc-dot"></span>In
                    Use</button>
                <button class="sc-status-btn btn-defect" onclick="applyStatus('defective')"><span
                        class="sc-dot"></span>🔧 Defective / Maintenance</button>
                <button class="sc-status-btn btn-reserved" onclick="applyStatus('reserved')"><span
                        class="sc-dot"></span>Reserved</button>
            </div>
            <div style="padding:0 24px 20px;">
                <button onclick="closeStatusModal()"
                    style="width:100%;padding:11px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">Cancel</button>
            </div>
        </div>
    </div>
    <% } %>

        <script>
            const IS_ADMIN = '<%= typeof user !== "undefined" && user && user.role === "admin" ? "true" : "false" %>' === 'true';
            const RESERVATION_ENABLED = <%= reservationSettings && Number(reservationSettings.enabled) === 0 ? 'false' : 'true' %>;
            const RESERVATION_DISABLED_MESSAGE = <%- JSON.stringify((reservationSettings && reservationSettings.message) ? reservationSettings.message : 'Reservations are currently unavailable.') %>;

            // ── Initialize ──────────────────────────────────────────────────────────
            renderLabGrid();

            // ═══════════════════════════════════════════════════════════════
            //  RESERVATION TAB LOGIC
            // ═══════════════════════════════════════════════════════════════
            const LABS = [
                { id: 'lab524', room: '524', name: 'Lab 524', desc: 'General Purpose · 50 PCs' },
                { id: 'lab526', room: '526', name: 'Lab 526', desc: 'General Purpose · 50 PCs' },
                { id: 'lab528', room: '528', name: 'Lab 528', desc: 'General Purpose · 50 PCs' },
                { id: 'lab530', room: '530', name: 'Lab 530', desc: 'Multimedia Lab · 50 PCs' },
                { id: 'lab542', room: '542', name: 'Lab 542', desc: 'IT Laboratory · 50 PCs' },
                { id: 'lab544', room: '544', name: 'Lab 544', desc: 'Mac Laboratory · 50 PCs' },
            ];
            const PC_CACHE = {};

            async function fetchPcs(labRoom) {
                try {
                    const res = await fetch('/lab-computers/' + labRoom);
                    const data = await res.json();
                    const map = {};
                    data.forEach(pc => { map[pc.computer_number] = pc; });
                    PC_CACHE[labRoom] = map;
                    return map;
                } catch (e) { return {}; }
            }

            function getStats(labRoom) {
                const pcs = PC_CACHE[labRoom] || {};
                const c = { available: 0, in_use: 0, reserved: 0, defective: 0 };
                Object.values(pcs).forEach(p => { const s = p.status || 'available'; if (c[s] !== undefined) c[s]++; else c.available++; });
                return c;
            }

            async function renderLabGrid() {
                const grid = document.getElementById('labGrid');
                grid.innerHTML = LABS.map(lab => `
            <div class="lab-card" onclick="openPcModal('${lab.id}')">
                <div class="lab-card-arrow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor" width="12" height="12" style="color:#6B7280;"><path fill-rule="evenodd" d="M3.036 7.018a.75.75 0 0 1 .75-.75h7.19L8.53 3.822a.75.75 0 0 1 1.06-1.06l3.75 3.75a.75.75 0 0 1 0 1.06l-3.75 3.75a.75.75 0 0 1-1.06-1.06l2.447-2.447H3.786a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/></svg></div>
                <div class="lab-card-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#F1E194" width="22" height="22"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg></div>
                <p class="lab-card-name">${lab.name}</p><p class="lab-card-desc">${lab.desc}</p>
                <div class="lab-card-pills" id="pills-${lab.id}"><span style="font-size:10px;color:#C4BDB6;">Loading…</span></div>
            </div>`).join('');

                let tA = 0, tI = 0, tR = 0, tD = 0;
                await Promise.all(LABS.map(async lab => {
                    await fetchPcs(lab.room);
                    const s = getStats(lab.room);
                    tA += s.available; tI += s.in_use; tR += s.reserved; tD += s.defective;
                    const ph = [
                        s.available > 0 ? `<span class="lab-pill pill-avail"><span class="lab-pill-dot"></span>${s.available} Free</span>` : '',
                        s.in_use > 0 ? `<span class="lab-pill pill-inuse"><span class="lab-pill-dot"></span>${s.in_use} In Use</span>` : '',
                        s.defective > 0 ? `<span class="lab-pill pill-defect"><span class="lab-pill-dot"></span>${s.defective} Defect</span>` : '',
                    ].filter(Boolean).join('') || `<span style="font-size:10px;color:#C4BDB6;">All available</span>`;
                    const el = document.getElementById(`pills-${lab.id}`);
                    if (el) el.innerHTML = ph;
                }));
                document.getElementById('stat-avail').textContent = tA;
                document.getElementById('stat-inuse').textContent = tI;
                document.getElementById('stat-reserved').textContent = tR;
                document.getElementById('stat-defect').textContent = tD;
            }

            let currentLabId = null, selectedPcNum = null;

            function pcSvgR(color) { return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="${color}" width="20" height="20"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg>`; }

            function buildPcGridHtml(labRoom) {
                const pcs = PC_CACHE[labRoom] || {};
                let html = `<div class="pc-teacher-area">🖥 Teacher / Instructor Station</div>`;
                let pcNum = 1;
                for (let row = 0; row < 5; row++) {
                    html += `<div class="pc-row-label">Row ${String.fromCharCode(65 + row)}</div><div class="pc-grid-10">`;
                    for (let col = 0; col < 10 && pcNum <= 50; col++) {
                        const pc = pcs[pcNum] || { status: 'available' };
                        const status = pc.status || 'available';
                        const sc = status === 'available' ? 'pc-avail' : status === 'in_use' ? 'pc-inuse' : status === 'reserved' ? 'pc-reserved' : 'pc-defect';
                        const ic = status === 'available' ? '#059669' : status === 'in_use' ? '#D97706' : status === 'reserved' ? '#2563EB' : '#DC2626';
                        const lbl = status === 'available' ? 'Free' : status === 'in_use' ? 'In Use' : status === 'reserved' ? 'Reserved' : 'Defective';
                        const click = status === 'available' ? `onclick="selectPc(${pcNum})"` : '';
                        html += `<div class="pc-unit ${sc}" id="pc-unit-${pcNum}" ${click} title="PC-${String(pcNum).padStart(2, '0')} — ${lbl}">
                    <div class="pc-icon-wrap">${pcSvgR(ic)}<span class="pc-status-dot"></span></div>
                    <span class="pc-number">PC-${String(pcNum).padStart(2, '0')}</span>
                    <span class="pc-label">${lbl}</span>
                </div>`;
                        pcNum++;
                    }
                    html += `</div>`;
                }
                return html;
            }

            async function openPcModal(labId) {
                const lab = LABS.find(l => l.id === labId);
                currentLabId = labId; selectedPcNum = null;
                document.getElementById('selectedPcLabel').textContent = 'None';
                document.getElementById('btnReserve').disabled = true;
                document.getElementById('pcModalLabName').textContent = lab.name;
                document.getElementById('pcModalLabDesc').textContent = lab.desc;
                document.getElementById('pcModalBody').innerHTML = '<div style="text-align:center;padding:40px;color:#9CA3AF;">Loading PC layout…</div>';
                document.getElementById('pcModal').classList.add('open');
                await fetchPcs(lab.room);
                document.getElementById('pcModalBody').innerHTML = buildPcGridHtml(lab.room);
            }

            function closePcModal() { document.getElementById('pcModal').classList.remove('open'); currentLabId = null; selectedPcNum = null; }

            function selectPc(pcNum) {
                if (!currentLabId) return;
                document.querySelectorAll('.pc-unit').forEach(el => el.classList.remove('selected'));
                const el = document.getElementById(`pc-unit-${pcNum}`);
                if (el) el.classList.add('selected');
                selectedPcNum = pcNum;
                const lab = LABS.find(l => l.id === currentLabId);
                document.getElementById('selectedPcLabel').textContent = `PC-${String(pcNum).padStart(2, '0')} — ${lab.name}`;
                document.getElementById('btnReserve').disabled = false;
            }

            function openReserveForm() {
                if (!RESERVATION_ENABLED) { if (window.showAppToast) window.showAppToast('warning', RESERVATION_DISABLED_MESSAGE); return; }
                if (!selectedPcNum || !currentLabId) return;
                const lab = LABS.find(l => l.id === currentLabId);
                document.getElementById('formPcLabel').textContent = `PC-${String(selectedPcNum).padStart(2, '0')}`;
                document.getElementById('formLabLabel').textContent = lab.name;
                document.getElementById('formLabRoom').value = lab.room;
                document.getElementById('formPcNumber').value = selectedPcNum;
                document.getElementById('formDate').min = new Date().toISOString().split('T')[0];
                document.getElementById('resFormModal').classList.add('open');
            }

            function closeReserveForm() { document.getElementById('resFormModal').classList.remove('open'); }

            function to12h(t) { const [h, m] = t.split(':').map(Number); return `${String(h % 12 || 12).padStart(2, '0')}:${String(m).padStart(2, '0')} ${h >= 12 ? 'PM' : 'AM'}`; }

            function validateTimeRange() {
                const start = document.getElementById('formTimeStart').value, end = document.getElementById('formTimeEnd').value;
                const warn = document.getElementById('timeWarning'), prev = document.getElementById('timePreview'), slot = document.getElementById('formTimeSlot');
                if (!start || !end) { warn.style.display = 'none'; prev.style.display = 'none'; return; }
                const [sh, sm] = start.split(':').map(Number), [eh, em] = end.split(':').map(Number);
                const diff = (eh * 60 + em) - (sh * 60 + sm);
                if (diff <= 0) { warn.textContent = '⚠ End time must be after start time.'; warn.style.display = 'block'; prev.style.display = 'none'; slot.value = ''; return; }
                if (diff > 180) { warn.textContent = '⚠ Maximum sit-in time is 3 hours.'; warn.style.display = 'block'; prev.style.display = 'none'; slot.value = ''; return; }
                warn.style.display = 'none';
                const slotStr = `${to12h(start)} – ${to12h(end)}`;
                slot.value = slotStr; prev.textContent = `✓ ${slotStr} (${Math.floor(diff / 60)}h ${diff % 60}m)`; prev.style.display = 'block';
            }

            function submitReservation() {
                if (!RESERVATION_ENABLED) { if (window.showAppToast) window.showAppToast('warning', RESERVATION_DISABLED_MESSAGE); return; }
                if (!document.getElementById('formTimeSlot').value) { if (window.showAppToast) window.showAppToast('warning', 'Please set a valid time slot (max 3 hours).'); return; }
                const btn = document.getElementById('reserveSubmitBtn');
                if (btn) {
                    btn.disabled = true;
                    btn.style.opacity = '0.7';
                    btn.textContent = 'Submitting...';
                }
                document.getElementById('labResForm').submit();
            }

            function filterReservations() {
                const q = (document.getElementById('searchRes').value || '').toLowerCase(), status = document.getElementById('resFilterStatus').value;
                let count = 0;
                document.querySelectorAll('.res-row').forEach(r => {
                    const show = (!q || r.textContent.toLowerCase().includes(q)) && (!status || r.dataset.status === status);
                    r.style.display = show ? '' : 'none'; if (show) count++;
                });
                document.getElementById('visibleResCount').textContent = count;
            }

            function printReservations() {
                document.getElementById('printDate').textContent = new Date().toLocaleString();
                document.getElementById('printHeader').style.display = 'block';
                window.print();
                document.getElementById('printHeader').style.display = 'none';
            }

            // ═══════════════════════════════════════════════════════════════
            //  LAB COMPUTERS TAB LOGIC
            // ═══════════════════════════════════════════════════════════════
            const LC_LABS = [
                { room: '524', name: 'Lab 524', desc: 'General Purpose' }, { room: '526', name: 'Lab 526', desc: 'General Purpose' },
                { room: '528', name: 'Lab 528', desc: 'General Purpose' }, { room: '530', name: 'Lab 530', desc: 'Multimedia Lab' },
                { room: '542', name: 'Lab 542', desc: 'IT Laboratory' }, { room: '544', name: 'Lab 544', desc: 'Mac Laboratory' },
            ];
            let lcCurrentRoom = null, lcPcData = {}, lcInitialized = false;
            let scModalPcNum = null;

            async function initLabComputers() {
                lcInitialized = true;
                const tabs = document.getElementById('lcTabs');
                tabs.innerHTML = LC_LABS.map((lab, i) => `<button class="lc-tab ${i === 0 ? 'active' : ''}" id="lctab-${lab.room}" onclick="switchLcTab('${lab.room}')">${lab.name}</button>`).join('');
                await switchLcTab(LC_LABS[0].room);
            }

            async function switchLcTab(room) {
                LC_LABS.forEach(l => {
                    const t = document.getElementById('lctab-' + l.room);
                    if (t) t.classList.toggle('active', l.room === room);
                });
                lcCurrentRoom = room;
                document.getElementById('lcCurrentLabTitle').textContent = `${LC_LABS.find(l => l.room === room)?.name} · 50 PCs`;
                document.getElementById('lcGridBody').innerHTML = '<div style="text-align:center;padding:40px;color:#9CA3AF;font-size:13px;">Loading…</div>';
                try {
                    const res = await fetch('/lab-computers/' + room);
                    const data = await res.json();
                    lcPcData = {};
                    data.forEach(pc => { lcPcData[pc.computer_number] = pc; });
                    renderLcGrid();
                } catch (e) {
                    document.getElementById('lcGridBody').innerHTML = '<div style="text-align:center;padding:40px;color:#DC2626;font-size:13px;">Failed to load PCs.</div>';
                }
            }

            function pcSvgLC(color) { return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="${color}" width="20" height="20"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg>`; }

            function renderLcGrid() {
                let html = `<div class="lc-teacher">🖥 Teacher / Instructor Station</div>`;
                let pcNum = 1;
                for (let r = 0; r < 5; r++) {
                    html += `<div class="lc-row-label">Row ${String.fromCharCode(65 + r)}</div><div class="lc-pc-grid">`;
                    for (let c = 0; c < 10 && pcNum <= 50; c++) {
                        const pc = lcPcData[pcNum] || { status: 'available' };
                        const st = pc.status || 'available';
                        const cls = st === 'available' ? 'pc-avail' : st === 'in_use' ? 'pc-inuse' : st === 'reserved' ? 'pc-reserved' : 'pc-defect';
                        const ic = st === 'available' ? '#059669' : st === 'in_use' ? '#D97706' : st === 'reserved' ? '#2563EB' : '#DC2626';
                        const lbl = st === 'available' ? 'Free' : st === 'in_use' ? 'In Use' : st === 'reserved' ? 'Reserved' : 'Defective';
                        const clickAttr = IS_ADMIN ? `onclick="openStatusModal(${pcNum})" style="cursor:pointer;"` : '';
                        html += `<div class="lc-pc-unit ${cls}" id="lcpc-${pcNum}" ${clickAttr} title="PC-${String(pcNum).padStart(2, '0')} — ${lbl}">
                    <div class="lc-pc-icon-wrap">${pcSvgLC(ic)}<span class="lc-pc-dot"></span></div>
                    <span class="lc-pc-number">${String(pcNum).padStart(2, '0')}</span>
                    <span class="lc-pc-label">${lbl}</span>
                </div>`;
                        pcNum++;
                    }
                    html += `</div>`;
                }
                document.getElementById('lcGridBody').innerHTML = html;
            }

            // ── Admin Status Modal ──────────────────────────────────────────────────────
            function openStatusModal(pcNum) {
                if (!IS_ADMIN) return;
                scModalPcNum = pcNum;
                const lab = LC_LABS.find(l => l.room === lcCurrentRoom);
                document.getElementById('scPcNum').textContent = `PC-${String(pcNum).padStart(2, '0')}`;
                document.getElementById('scPcLab').textContent = `${lab?.name} — ${lab?.desc}`;
                document.getElementById('scOverlay').classList.add('open');
            }

            function closeStatusModal() {
                document.getElementById('scOverlay')?.classList.remove('open');
                scModalPcNum = null;
            }

            async function applyStatus(newStatus) {
                if (!scModalPcNum || !lcCurrentRoom) return;
                const pcNum = scModalPcNum;
                closeStatusModal();
                try {
                    const res = await fetch('/admin/lab-computers/status', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ lab_room: lcCurrentRoom, computer_number: pcNum, status: newStatus })
                    });
                    const data = await res.json();
                    if (data.success) {
                        if (!lcPcData[pcNum]) lcPcData[pcNum] = {};
                        lcPcData[pcNum].status = newStatus;
                        renderLcGrid();
                    }
                } catch (e) { console.error('Failed to update PC status', e); }
            }

            // ── Init ──────────────────────────────────────────────────────────────────
            renderLabGrid();
            document.addEventListener('keydown', e => {
                if (e.key !== 'Escape') return;
                closePcModal(); closeReserveForm(); closeStatusModal?.();
            });
            document.addEventListener('keydown', e => { if (e.key === 'Escape') closeStatusModal(); });
        </script>

        <script>
            // ── Reservation helpers (no reload) ─────────────────────────────
            function deleteReservation(id) {
                if (!confirm('Remove this reservation from your history?')) return;
                fetch(`/api/reservations/delete/${id}`, { method: 'DELETE', credentials: 'same-origin' })
                    .then(r => r.json().catch(() => ({})).then(b => ({ ok: r.ok, body: b })))
                    .then(({ ok, body }) => {
                        if (!ok || !body.success) throw new Error(body.message || 'Failed');
                        const row = document.getElementById(`row-${id}`);
                        if (row) row.remove();
                        if (window.showAppToast) window.showAppToast('success', 'Reservation removed from history.');
                        filterReservations();
                    })
                    .catch((e) => {
                        if (window.showAppToast) window.showAppToast('error', e.message || 'Failed to remove reservation.');
                        else alert(e.message || 'Failed to remove reservation.');
                    });
            }

            function renderStatusBadge(td, status) {
                const s = String(status || 'pending').toLowerCase();
                td.innerHTML =
                    s === 'approved'
                        ? `<span class="inline-flex items-center gap-1 text-xs font-bold text-green-700 bg-green-50 px-2.5 py-1 rounded-full"><span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Approved</span>`
                        : s === 'rejected'
                            ? `<span class="inline-flex items-center gap-1 text-xs font-bold text-red-700 bg-red-50 px-2.5 py-1 rounded-full"><span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>Rejected</span>`
                            : s === 'cancelled'
                                ? `<span class="inline-flex items-center gap-1 text-xs font-bold text-blue-700 bg-blue-50 px-2.5 py-1 rounded-full"><span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span>Cancelled</span>`
                                : s === 'expired'
                                    ? `<span class="inline-flex items-center gap-1 text-xs font-bold text-gray-700 bg-gray-100 px-2.5 py-1 rounded-full"><span class="w-1.5 h-1.5 bg-gray-500 rounded-full"></span>Expired</span>`
                                    : `<span class="inline-flex items-center gap-1 text-xs font-bold text-amber-700 bg-amber-50 px-2.5 py-1 rounded-full"><span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>Pending</span>`;
            }

            async function refreshReservationStatuses() {
                try {
                    const res = await fetch('/api/reservations/mine', { credentials: 'same-origin' });
                    const data = await res.json();
                    if (!data || !data.success) return;
                    (data.reservations || []).forEach((r) => {
                        const row = document.getElementById(`row-${r.id}`);
                        if (!row) return;
                        row.dataset.status = r.status;
                        const tds = row.querySelectorAll('td');
                        const statusTd = tds[5];
                        if (statusTd) renderStatusBadge(statusTd, r.status);

                        const actionTd = tds[6];
                        if (actionTd) {
                            if (String(r.status).toLowerCase() === 'pending') {
                                actionTd.innerHTML = `
                                    <form action="/reservation/${r.id}/cancel" method="POST" onsubmit="return confirm('Cancel this reservation request?')" style="margin:0;">
                                        <button type="submit"
                                            class="inline-flex items-center gap-1 text-xs font-bold text-red-700 bg-red-50 border border-red-200 px-2.5 py-1 rounded-full hover:bg-red-700 hover:text-white transition-all">
                                            Cancel
                                        </button>
                                    </form>
                                `;
                            } else {
                                actionTd.innerHTML = `
                                    <button type="button"
                                        class="inline-flex items-center gap-1 text-xs font-bold text-rose-700 bg-rose-50 border border-rose-200 px-2.5 py-1 rounded-full hover:bg-rose-700 hover:text-white transition-all"
                                        onclick="deleteReservation(${r.id})"
                                        title="Remove from your history"
                                    >🗑️ Delete</button>
                                `;
                            }
                        }
                    });
                    filterReservations();
                } catch (_) { }
            }

            // Poll lightly so status reflects after admin action without manual reload.
            refreshReservationStatuses();
            setInterval(refreshReservationStatuses, 15000);
        </script>