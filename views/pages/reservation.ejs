<script>
    // ── Tab switching ──────────────────────────────────────────────
    function switchResTab(tab) {
        document.getElementById('section-general').style.display = tab === 'general' ? 'block' : 'none';
        document.getElementById('section-lab').style.display = tab === 'lab' ? 'block' : 'none';
        document.getElementById('tab-general').classList.toggle('active', tab === 'general');
        document.getElementById('tab-lab').classList.toggle('active', tab === 'lab');
        if (tab === 'lab') renderLabGrid();
    }

    // ── General reservation form ────────────────────────────────────
    document.getElementById('reservationDate').min = new Date().toISOString().split('T')[0];
    function to12h(t) {
        if (!t) return '';
        const [h, m] = t.split(':').map(Number);
        const ampm = h >= 12 ? 'PM' : 'AM';
        return `${String(h % 12 || 12).padStart(2, '0')}:${String(m).padStart(2, '0')} ${ampm}`;
    }
    function updateTimeSlot() {
        const start = document.getElementById('timeStart').value;
        const end = document.getElementById('timeEnd').value;
        const preview = document.getElementById('timeSlotPreview');
        const combined = document.getElementById('timeSlotCombined');
        if (start && end) {
            const label = `${to12h(start)} – ${to12h(end)}`;
            combined.value = label;
            preview.textContent = '⏰ ' + label;
            preview.classList.remove('hidden');
        } else { combined.value = ''; preview.textContent = ''; preview.classList.add('hidden'); }
    }
    document.getElementById('timeStart').addEventListener('change', updateTimeSlot);
    document.getElementById('timeEnd').addEventListener('change', updateTimeSlot);

    // ── Search filters ──────────────────────────────────────────────
    document.getElementById('searchGeneral').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.general-row').forEach(r => { r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    document.getElementById('searchLab').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.lab-row').forEach(r => { r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });

    // ── Lab PC Grid ─────────────────────────────────────────────────
    const LABS = [
        { id: 'lab524', room: '524', name: 'Lab 524', desc: 'General Purpose Laboratory', rows: 4, cols: 5, totalPcs: 20 },
        { id: 'lab526', room: '526', name: 'Lab 526', desc: 'General Purpose Laboratory', rows: 4, cols: 5, totalPcs: 20 },
        { id: 'lab528', room: '528', name: 'Lab 528', desc: 'General Purpose Laboratory', rows: 4, cols: 5, totalPcs: 20 },
        { id: 'lab530', room: '530', name: 'Lab 530', desc: 'Multimedia Laboratory', rows: 3, cols: 5, totalPcs: 15 },
        { id: 'lab542', room: '542', name: 'Lab 542', desc: 'IT Laboratory', rows: 4, cols: 5, totalPcs: 20 },
        { id: 'lab544', room: '544', name: 'Lab 544', desc: 'Mac Laboratory', rows: 3, cols: 4, totalPcs: 12 },
    ];
    const PC_STATUS_STORE = {};

    function initLabPcs(labId, total) {
        if (!PC_STATUS_STORE[labId]) {
            const pcs = {};
            for (let i = 1; i <= total; i++) {
                const r = Math.random();
                pcs[i] = { status: r < 0.12 ? 'defective' : r < 0.3 ? 'in_use' : r < 0.42 ? 'reserved' : 'available' };
            }
            PC_STATUS_STORE[labId] = pcs;
        }
        return PC_STATUS_STORE[labId];
    }

    function getLabStats(labId, total) {
        const pcs = initLabPcs(labId, total);
        const c = { available: 0, in_use: 0, reserved: 0, defective: 0 };
        Object.values(pcs).forEach(p => c[p.status]++);
        return c;
    }

    let labGridRendered = false;
    function renderLabGrid() {
        if (labGridRendered) return;
        labGridRendered = true;
        const grid = document.getElementById('labGrid');
        let totalAvail = 0, totalInuse = 0, totalReserved = 0, totalDefect = 0;
        grid.innerHTML = LABS.map(lab => {
            const s = getLabStats(lab.id, lab.totalPcs);
            totalAvail += s.available; totalInuse += s.in_use; totalReserved += s.reserved; totalDefect += s.defective;
            const pills = [
                s.available > 0 ? `<span class="lab-pill pill-avail"><span class="lab-pill-dot"></span>${s.available} Available</span>` : '',
                s.in_use > 0 ? `<span class="lab-pill pill-inuse"><span class="lab-pill-dot"></span>${s.in_use} In Use</span>` : '',
                s.defective > 0 ? `<span class="lab-pill pill-defect"><span class="lab-pill-dot"></span>${s.defective} Defective</span>` : '',
            ].filter(Boolean).join('');
            return `<div class="lab-card" onclick="openPcModal('${lab.id}')">
                <div class="lab-card-arrow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor" width="12" height="12" style="color:#6B7280;"><path fill-rule="evenodd" d="M3.036 7.018a.75.75 0 0 1 .75-.75h7.19L8.53 3.822a.75.75 0 0 1 1.06-1.06l3.75 3.75a.75.75 0 0 1 0 1.06l-3.75 3.75a.75.75 0 0 1-1.06-1.06l2.447-2.447H3.786a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/></svg></div>
                <div class="lab-card-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#F1E194" width="24" height="24"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg></div>
                <p class="lab-card-name">${lab.name}</p>
                <p class="lab-card-desc">${lab.desc} · ${lab.totalPcs} PCs</p>
                <div class="lab-card-pills">${pills}</div>
            </div>`;
        }).join('');
        document.getElementById('stat-avail').textContent = totalAvail;
        document.getElementById('stat-inuse').textContent = totalInuse;
        document.getElementById('stat-reserved').textContent = totalReserved;
        document.getElementById('stat-defect').textContent = totalDefect;
    }

    let currentLabId = null, selectedPcNum = null;

    function pcSvg(color) {
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="${color}" width="24" height="24"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg>`;
    }

    function renderPcGrid(labId) {
        const lab = LABS.find(l => l.id === labId);
        const pcs = initLabPcs(labId, lab.totalPcs);
        const body = document.getElementById('pcModalBody');
        document.getElementById('pcModalLabName').textContent = lab.name;
        document.getElementById('pcModalLabDesc').textContent = `${lab.desc} · ${lab.totalPcs} computers`;
        let html = `<div class="pc-teacher-area">🖥 Teacher / Instructor Station</div>`;
        let pcNum = 1;
        for (let row = 0; row < lab.rows; row++) {
            html += `<div class="pc-row-label">Row ${String.fromCharCode(65 + row)}</div><div class="pc-grid">`;
            for (let col = 0; col < lab.cols && pcNum <= lab.totalPcs; col++) {
                const pc = pcs[pcNum];
                const sc = pc.status === 'available' ? 'pc-avail' : pc.status === 'in_use' ? 'pc-inuse' : pc.status === 'reserved' ? 'pc-reserved' : 'pc-defect';
                const ic = pc.status === 'available' ? '#059669' : pc.status === 'in_use' ? '#D97706' : pc.status === 'reserved' ? '#2563EB' : '#DC2626';
                const lbl = pc.status === 'available' ? 'Free' : pc.status === 'in_use' ? 'In Use' : pc.status === 'reserved' ? 'Reserved' : 'Defective';
                const click = pc.status === 'available' ? `onclick="selectPc(${pcNum})"` : '';
                html += `<div class="pc-unit ${sc}" id="pc-unit-${pcNum}" ${click} title="PC-${String(pcNum).padStart(2, '0')} — ${lbl}">
                    <div class="pc-icon-wrap">${pcSvg(ic)}<span class="pc-status-dot"></span></div>
                    <span class="pc-number">PC-${String(pcNum).padStart(2, '0')}</span>
                    <span class="pc-label">${lbl}</span>
                </div>`;
                pcNum++;
            }
            html += `</div>`;
        }
        body.innerHTML = html;
    }

    function openPcModal(labId) {
        currentLabId = labId; selectedPcNum = null;
        document.getElementById('selectedPcLabel').textContent = 'None';
        document.getElementById('btnReserve').disabled = true;
        renderPcGrid(labId);
        document.getElementById('pcModal').classList.add('open');
    }
    function closePcModal() { document.getElementById('pcModal').classList.remove('open'); currentLabId = null; selectedPcNum = null; }

    function selectPc(pcNum) {
        if (!currentLabId || PC_STATUS_STORE[currentLabId][pcNum].status !== 'available') return;
        document.querySelectorAll('.pc-unit').forEach(el => el.classList.remove('selected'));
        document.getElementById(`pc-unit-${pcNum}`).classList.add('selected');
        selectedPcNum = pcNum;
        const lab = LABS.find(l => l.id === currentLabId);
        document.getElementById('selectedPcLabel').textContent = `PC-${String(pcNum).padStart(2, '0')} — ${lab.name}`;
        document.getElementById('btnReserve').disabled = false;
    }

    function openReserveForm() {
        if (!selectedPcNum || !currentLabId) return;
        const lab = LABS.find(l => l.id === currentLabId);
        document.getElementById('formPcLabel').textContent = `PC-${String(selectedPcNum).padStart(2, '0')}`;
        document.getElementById('formLabLabel').textContent = lab.name;
        document.getElementById('formLabRoom').value = lab.room;
        document.getElementById('formPcNumber').value = selectedPcNum;
        document.getElementById('formDate').min = new Date().toISOString().split('T')[0];
        document.getElementById('resFormModal').classList.add('open');
    }
    function closeReserveForm() { document.getElementById('resFormModal').classList.remove('open'); }

    function validateTimeRange() {
        const start = document.getElementById('formTimeStart').value;
        const end = document.getElementById('formTimeEnd').value;
        const warn = document.getElementById('timeWarning');
        const preview = document.getElementById('timePreview');
        const slot = document.getElementById('formTimeSlot');
        if (!start || !end) { warn.style.display = 'none'; preview.style.display = 'none'; return; }
        const [sh, sm] = start.split(':').map(Number);
        const [eh, em] = end.split(':').map(Number);
        const diffMin = (eh * 60 + em) - (sh * 60 + sm);
        if (diffMin <= 0) { warn.textContent = '⚠ End time must be after start time.'; warn.style.display = 'block'; preview.style.display = 'none'; slot.value = ''; return; }
        if (diffMin > 180) { warn.textContent = '⚠ Maximum sit-in time is 3 hours.'; warn.style.display = 'block'; preview.style.display = 'none'; slot.value = ''; return; }
        warn.style.display = 'none';
        const slotStr = `${to12h(start)} – ${to12h(end)}`;
        slot.value = slotStr;
        preview.textContent = `✓ ${slotStr} (${Math.floor(diffMin / 60)}h ${diffMin % 60}m)`;
        preview.style.display = 'block';
    }

    function submitReservation() {
        if (!document.getElementById('formTimeSlot').value) { alert('Please set a valid time slot (max 3 hours).'); return; }
        document.getElementById('labResForm').submit();
    }

    document.addEventListener('keydown', e => {
        if (e.key !== 'Escape') return;
        closePcModal(); closeReserveForm();
    });
</script>