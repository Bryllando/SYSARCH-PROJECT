            </div>
        </div>
        <form action="/lab-reservation" method="POST"
            style="padding:20px 24px 0;display:flex;flex-direction:column;gap:14px;" id="labResForm">
            <input type="hidden" name="lab_room" id="formLabRoom">
            <input type="hidden" name="computer_number" id="formPcNumber">
