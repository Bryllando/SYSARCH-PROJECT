                <label
                    style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6B7280;">Time
                    Slot <span style="color:#DC2626;">*</span> <span
                        style="color:#9CA3AF;text-transform:none;font-weight:400;">(max 3 hours)</span></label>
                <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:center;">
                    <input type="time" name="time_start" id="formTimeStart"
