                    <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">My Reservations</h2>
                </div>
                <div class="flex items-center gap-3 flex-wrap">
                    <select id="resFilterStatus" onchange="filterReservations()"
                        class="border border-gray-200 rounded-lg px-3 py-1.5 text-xs text-gray-600 focus:outline-none focus:ring-1 focus:ring-[#273F4F] bg-white">
                        <option value="">All Status</option>
                        <option value="approved">Approved</option>
                        <option value="rejected">Rejected</option>
                        <option value="pending">Pending</option>
                        <option value="cancelled">Cancelled</option>
                        <option value="expired">Expired</option>
                    </select>
                    <input type="text" id="searchRes" placeholder="Search..." oninput="filterReservations()"
                        class="border border-gray-200 rounded-lg px-3 py-1.5 text-xs text-gray-600 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#273F4F] bg-white w-36">
                    <button onclick="printReservations()"
                        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-lg text-xs font-bold text-white hover:-translate-y-0.5 transition-all"
                        style="background:linear-gradient(135deg,#374151,#1f2937);">🖨 Print</button>
                </div>
            </div>
            <div id="printArea">
                <div id="printHeader" style="display:none;padding:16px 24px 0;">
                    <h2 style="font-size:18px;font-weight:800;color:#1C2B35;margin:0 0 4px;">My Lab Reservations</h2>
                    <p style="font-size:12px;color:#9CA3AF;margin:0 0 12px;">Printed: <span id="printDate"></span></p>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm" id="resTable">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-100">
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                    Lab</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                    PC</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                    Purpose</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                    Date</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                    Time</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                    Status</th>
