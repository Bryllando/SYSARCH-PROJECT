<style>
    /* ── Tabs ── */
    .res-tab-bar {
        display: flex;
        gap: 4px;
        margin-bottom: 20px;
        background: #fff;
        border-radius: 14px;
        padding: 6px;
        border: 1px solid #E8E3DD;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
        width: fit-content;
    }

    .res-tab {
        padding: 8px 20px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        background: transparent;
        color: #9CA3AF;
        font-family: inherit;
        transition: all 0.15s;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .res-tab.active {
        background: #273F4F;
        color: #fff;
        box-shadow: 0 2px 8px rgba(39, 63, 79, 0.2);
    }

    /* ── Lab PC grid (from lab-reservation.ejs) ── */
    .lab-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #E8E3DD;
        padding: 20px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
        position: relative;
        overflow: hidden;
    }

    .lab-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        border-radius: 16px 0 0 16px;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
    }

    .lab-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(39, 63, 79, 0.13);
        border-color: #5B0E14;
    }

    .lab-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
    }

    .lab-card-name {
        font-size: 18px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 2px;
    }

    .lab-card-desc {
        font-size: 11px;
        color: #9CA3AF;
        margin: 0 0 14px;
    }

    .lab-card-pills {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .lab-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 9px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 700;
        border: 1px solid;
    }

    .lab-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .pill-avail {
        background: #ECFDF5;
        color: #065F46;
        border-color: #A7F3D0;
    }

    .pill-avail .lab-pill-dot {
        background: #10B981;
    }

    .pill-inuse {
        background: #FFF7ED;
        color: #92400E;
        border-color: #FDE68A;
    }

    .pill-inuse .lab-pill-dot {
        background: #F59E0B;
        animation: pulse 1.5s infinite;
    }

    .pill-defect {
        background: #FEF2F2;
        color: #991B1B;
        border-color: #FECACA;
    }

    .pill-defect .lab-pill-dot {
        background: #DC2626;
    }

    .lab-card-arrow {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 28px;
        height: 28px;
        background: #F3F0EC;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s;
    }

    .lab-card:hover .lab-card-arrow {
        background: #5B0E14;
    }

    .lab-card:hover .lab-card-arrow svg {
        color: #F1E194;
    }

    @keyframes pulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8)
        }
    }

    /* PC Modal */
    .pcmodal-overlay {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .pcmodal-overlay.open {
        display: flex;
    }

    .pcmodal-overlay.open .pcmodal-card {
        animation: pcModalIn 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes pcModalIn {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(20px)
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0)
        }
    }

    .pcmodal-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 860px;
        max-height: 90vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .pcmodal-header {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

    .pcmodal-legend {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 24px;
        background: #F7F5F2;
        border-bottom: 1px solid #E8E3DD;
        flex-wrap: wrap;
    }

    .pcmodal-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #4B5563;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid;
    }

    .pcmodal-body {
        padding: 20px 24px;
        overflow-y: auto;
        flex: 1;
    }

    .pc-teacher-area {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        border-radius: 10px;
        padding: 10px 16px;
        text-align: center;
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .pc-row-label {
        font-size: 10px;
        font-weight: 700;
        color: #C4BDB6;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 14px 0 8px;
    }

    .pc-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
        margin-bottom: 4px;
    }

    .pc-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        cursor: pointer;
        padding: 10px 6px;
        border-radius: 12px;
        border: 2px solid transparent;
        transition: all 0.18s;
        position: relative;
    }

    .pc-unit:hover:not(.pc-inuse):not(.pc-defect):not(.pc-reserved) {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
        transform: translateY(-2px);
    }

    .pc-unit.selected {
        border-color: #5B0E14 !important;
        background: rgba(91, 14, 20, 0.1) !important;
    }

    .pc-unit.pc-inuse,
    .pc-unit.pc-defect,
    .pc-unit.pc-reserved {
        cursor: not-allowed;
    }

    .pc-unit.pc-inuse {
        opacity: 0.75;
    }

    .pc-unit.pc-defect {
        opacity: 0.55;
    }

    .pc-icon-wrap {
        width: 52px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border: 2px solid;
    }

    .pc-avail .pc-icon-wrap {
        background: #ECFDF5;
        border-color: #A7F3D0;
    }

    .pc-inuse .pc-icon-wrap {
        background: #FFF7ED;
        border-color: #FDE68A;
    }

    .pc-defect .pc-icon-wrap {
        background: #FEF2F2;
        border-color: #FECACA;
    }

    .pc-reserved .pc-icon-wrap {
        background: #EFF6FF;
        border-color: #BFDBFE;
    }

    .pc-status-dot {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    .pc-avail .pc-status-dot {
        background: #10B981;
    }

    .pc-inuse .pc-status-dot {
        background: #F59E0B;
        animation: pulse 1.5s infinite;
    }

    .pc-defect .pc-status-dot {
        background: #DC2626;
    }

    .pc-reserved .pc-status-dot {
        background: #3B82F6;
    }

    .pc-number {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .pc-avail .pc-number {
        color: #065F46
    }

    .pc-inuse .pc-number {
        color: #92400E
    }

    .pc-defect .pc-number {
        color: #991B1B
    }

    .pc-reserved .pc-number {
        color: #1D4ED8
    }

    .pc-label {
        font-size: 9px;
        font-weight: 600;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .pcmodal-footer {
        padding: 14px 24px;
        border-top: 1px solid #E8E3DD;
        background: #FAFAF9;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        flex-shrink: 0;
    }

    .btn-reserve {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
    }

    .btn-reserve:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .btn-reserve:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
    }

    /* Reserve Form Modal */
    .resform-overlay {
        position: fixed;
        inset: 0;
        z-index: 300;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .resform-overlay.open {
        display: flex;
    }

    .resform-overlay.open .resform-card {
        animation: pcModalIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .resform-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.3);
        width: 100%;
        max-width: 480px;
        overflow: hidden;
    }
</style>

<div class="p-6">
    <div class="mb-6">
        <h1 class="text-2xl font-extrabold text-[#273F4F]">Reservation</h1>
        <p class="text-gray-500 text-sm mt-1">Reserve a laboratory slot or a specific computer in advance.</p>
    </div>

    <!-- Messages -->
    <% if (typeof messages !=='undefined' ) { %>
        <% messages.forEach(function(msg) { %>
            <div
                class="mb-4 p-3 rounded-xl flex items-center gap-3 <%= msg.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
                <span class="font-medium text-sm">
                    <%= msg.text %>
                </span>
            </div>
            <% }) %>
                <% } %>

                    <!-- Tab Bar -->
                    <div class="res-tab-bar">
                        <button class="res-tab active" id="tab-general" onclick="switchResTab('general')">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14"
                                height="14">
                                <path fill-rule="evenodd"
                                    d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Z"
                                    clip-rule="evenodd" />
                            </svg>
                            Room Reservation
                        </button>
                        <button class="res-tab" id="tab-lab" onclick="switchResTab('lab')">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14"
                                height="14">
                                <path clip-rule="evenodd"
                                    d="M1 3.25A2.25 2.25 0 0 1 3.25 1h9.5A2.25 2.25 0 0 1 15 3.25v7.5A2.25 2.25 0 0 1 12.75 13h-2.33a3.5 3.5 0 0 1 .58 1.677A.75.75 0 0 1 10.25 15.5H5.75a.75.75 0 0 1-.745-.823A3.5 3.5 0 0 1 5.58 13H3.25A2.25 2.25 0 0 1 1 10.75v-7.5Z"
                                    fill-rule="evenodd" />
                            </svg>
                            Lab Computer Reservation
                        </button>
                    </div>

                    <!-- ══ TAB 1: GENERAL RESERVATION ══ -->
                    <div id="section-general">
                        <div class="flex gap-5" style="align-items:flex-start;">

                            <!-- LEFT: New Reservation Form -->
                            <div
                                class="flex-1 min-w-0 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                                <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full bg-[#5B0E14]"></div>
                                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">New Room
                                        Reservation</h2>
                                </div>
                                <form action="/reservation" method="POST" class="px-6 py-5 space-y-5">
                                    <div class="grid grid-cols-2 gap-4">
                                        <div class="space-y-1.5">
                                            <label
                                                class="block text-xs font-bold text-gray-500 uppercase tracking-wide">ID
                                                Number <span
                                                    class="font-normal text-gray-400 normal-case">(read-only)</span></label>
                                            <input type="text" value="<%= user.id_number %>" disabled
                                                class="w-full px-3 py-2.5 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-500 cursor-not-allowed">
                                        </div>
                                        <div class="space-y-1.5">
                                            <label
                                                class="block text-xs font-bold text-gray-500 uppercase tracking-wide">Student
                                                Name <span
                                                    class="font-normal text-gray-400 normal-case">(read-only)</span></label>
                                            <input type="text"
                                                value="<%= user.first_name %> <%= user.middle_initial ? user.middle_initial + '. ' : '' %><%= user.last_name %>"
                                                disabled
                                                class="w-full px-3 py-2.5 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-500 cursor-not-allowed">
                                        </div>
                                    </div>
                                    <div class="space-y-1.5">
                                        <label
                                            class="block text-xs font-bold text-gray-700 uppercase tracking-wide">Purpose
                                            <span class="text-red-500">*</span></label>
                                        <div class="relative">
                                            <select name="purpose" required
                                                class="w-full px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm text-gray-700 cursor-pointer">
                                                <option value="" disabled selected>Select purpose...</option>
                                                <option>C Programming</option>
                                                <option>Java Programming</option>
                                                <option>C# Programming</option>
                                                <option>ASP.Net</option>
                                                <option>PHP Programming</option>
                                                <option>Database</option>
                                                <option>Research</option>
                                                <option>Other</option>
                                            </select>
                                            <div
                                                class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                    stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="space-y-1.5">
                                        <label
                                            class="block text-xs font-bold text-gray-700 uppercase tracking-wide">Laboratory
                                            <span class="text-red-500">*</span></label>
                                        <div class="relative">
                                            <select name="lab_room" required
                                                class="w-full px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm text-gray-700 cursor-pointer">
                                                <option value="" disabled selected>Select laboratory...</option>
                                                <option value="524">Lab 524</option>
                                                <option value="526">Lab 526</option>
                                                <option value="528">Lab 528</option>
                                                <option value="530">Lab 530</option>
                                                <option value="Mac Lab">Mac Lab</option>
                                            </select>
                                            <div
                                                class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                    stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="space-y-1.5">
                                        <label
                                            class="block text-xs font-bold text-gray-700 uppercase tracking-wide">Date
                                            <span class="text-red-500">*</span></label>
                                        <input type="date" name="date" required id="reservationDate"
                                            class="w-full px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm text-gray-700">
                                    </div>
                                    <div class="space-y-1.5">
                                        <label
                                            class="block text-xs font-bold text-gray-700 uppercase tracking-wide">Time
                                            Slot <span class="text-red-500">*</span> <span
                                                class="text-gray-400 font-normal normal-case ml-1">— start &amp;
                                                end</span></label>
                                        <div class="flex items-center gap-3">
                                            <input type="time" id="timeStart" name="time_start" required
                                                class="flex-1 px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm text-gray-700">
                                            <span class="text-xs text-gray-400 font-bold shrink-0">→</span>
                                            <input type="time" id="timeEnd" name="time_end" required
                                                class="flex-1 px-3 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm text-gray-700">
                                        </div>
                                        <input type="hidden" name="time_slot" id="timeSlotCombined">
                                        <p class="text-xs font-semibold text-[#5B0E14] hidden" id="timeSlotPreview"></p>
                                    </div>
                                    <div class="flex items-center justify-between px-4 py-3 rounded-xl border border-yellow-200"
                                        style="background:linear-gradient(135deg,#FFFBEB,#FEF3C7);">
                                        <div class="flex items-center gap-2">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"
                                                fill="currentColor" class="size-4 text-amber-500 shrink-0">
                                                <path fill-rule="evenodd"
                                                    d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z"
                                                    clip-rule="evenodd" />
                                            </svg>
                                            <span class="text-sm font-semibold text-amber-800">Remaining Sessions</span>
                                        </div>
                                        <span class="text-2xl font-extrabold text-[#5B0E14]">
                                            <%= user.remaining_sessions ?? 30 %>
                                        </span>
                                    </div>
                                    <div class="pt-1">
                                        <button type="submit" class="btn-maroon py-3 text-sm w-full">Submit
                                            Reservation</button>
                                    </div>
                                </form>
                            </div>

                            <!-- RIGHT: My General Reservations Table -->
                            <div
                                class="flex-1 min-w-0 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                                <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between gap-3">
                                    <div class="flex items-center gap-2">
                                        <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                                        <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">My Room
                                            Reservations</h2>
                                    </div>
                                    <input type="text" id="searchGeneral" placeholder="Search..."
                                        class="border border-gray-200 rounded-lg px-3 py-1.5 text-xs text-gray-600 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#273F4F] bg-white w-36">
                                </div>
                                <div class="overflow-x-auto">
                                    <table class="w-full text-sm">
                                        <thead>
                                            <tr class="bg-gray-50 border-b border-gray-100">
                                                <th
                                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                    #</th>
                                                <th
                                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                    Lab</th>
                                                <th
                                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                    Purpose</th>
                                                <th
                                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                    Date</th>
                                                <th
                                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                    Time</th>
                                                <th
                                                    class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                                    Status</th>
                                            </tr>
                                        </thead>
                                        <tbody id="generalBody">
                                            <% var safeReservations=(typeof reservations !=='undefined' && reservations)
                                                ? reservations : []; %>
                                                <% if (safeReservations.length> 0) { %>
                                                    <% safeReservations.forEach(function(r, i) { %>
                                                        <tr class="hover:bg-gray-50 transition-colors general-row">
                                                            <td class="px-4 py-3 text-gray-400 text-xs font-mono">
                                                                <%= i + 1 %>
                                                            </td>
                                                            <td class="px-4 py-3"><span
                                                                    class="inline-block px-2 py-0.5 rounded-lg text-xs font-bold bg-[#273F4F]/10 text-[#273F4F]">
                                                                    <%= r.lab_room %>
                                                                </span></td>
                                                            <td class="px-4 py-3"><span
                                                                    class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                                                                    <%= r.purpose || '—' %>
                                                                </span></td>
                                                            <td
                                                                class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
                                                                <%= r.date %>
                                                            </td>
                                                            <td
                                                                class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
                                                                <%= r.time_slot %>
                                                            </td>
                                                            <td class="px-4 py-3">
                                                                <% if (r.status==='approved' ) { %><span
                                                                        class="inline-flex items-center gap-1 text-xs font-bold text-green-700 bg-green-50 px-2.5 py-1 rounded-full"><span
                                                                            class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Approved</span>
                                                                    <% } else if (r.status==='rejected' ) { %><span
                                                                            class="inline-flex items-center gap-1 text-xs font-bold text-red-700 bg-red-50 px-2.5 py-1 rounded-full"><span
                                                                                class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>Rejected</span>
                                                                        <% } else { %><span
                                                                                class="inline-flex items-center gap-1 text-xs font-bold text-amber-700 bg-amber-50 px-2.5 py-1 rounded-full"><span
                                                                                    class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>Pending</span>
                                                                            <% } %>
                                                            </td>
                                                        </tr>
                                                        <% }) %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="6"
                                                                        class="px-6 py-12 text-center text-sm text-gray-400 font-medium">
                                                                        No room reservations yet.</td>
                                                                </tr>
                                                                <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ══ TAB 2: LAB COMPUTER RESERVATION ══ -->
                    <div id="section-lab" style="display:none;">

                        <!-- Stats -->
                        <div class="flex gap-3 mb-5 flex-wrap">
                            <div
                                class="flex items-center gap-10 px-5 py-3 bg-white rounded-2xl border border-gray-100 shadow-sm flex-wrap gap-y-2">
