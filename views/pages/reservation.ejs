                                                <% } else { %>
                                                    <button
                                                        type="button"
                                                        class="inline-flex items-center gap-1 text-xs font-bold text-rose-700 bg-rose-50 border border-rose-200 px-2.5 py-1 rounded-full hover:bg-rose-700 hover:text-white transition-all"
                                                        onclick="deleteReservation(<%= r.id %>)"
                                                        title="Remove from your history"
                                                    >
                                                        🗑️ Delete
                                                    </button>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7"
                                                        class="px-6 py-12 text-center text-sm text-gray-400">No
                                                        reservations yet. Select a lab above to reserve a PC.</td>
                                                </tr>
                                                <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div
                class="px-6 py-3 border-t border-gray-100 flex items-center justify-between text-xs text-gray-400 no-print">
                <span>Showing <strong id="visibleResCount" class="text-gray-600">
