        </div>
        <div
            style="margin:0;padding:14px 24px;background:linear-gradient(135deg,#F9F8F6,#F0EDE8);border-bottom:1px solid #E8E3DD;display:flex;align-items:center;gap:12px;">
            <div
                style="width:42px;height:36px;border-radius:9px;background:#ECFDF5;border:2px solid #A7F3D0;display:flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#059669" width="18" height="18">
                    <path clip-rule="evenodd"
                        d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z"
                        fill-rule="evenodd" />
                </svg>
            </div>
            <div>
                <div style="font-size:14px;font-weight:800;color:#1C2B35;" id="formPcLabel">PC-01</div>
