    .lc-tab:hover {
        border-color: #273F4F;
        color: #273F4F;
    }

    .lc-tab.active {
        background: #273F4F;
        border-color: #273F4F;
        color: #F1E194;
    }

    .lc-grid-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        border: 1px solid #E8E3DD;
    }

    .lc-grid-head {
        padding: 14px 20px;
        background: #F7F5F2;
        border-bottom: 1px solid #E8E3DD;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .lc-legend {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }

    .lc-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #4B5563;
    }

    .lc-legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid;
    }

    .lc-grid-body {
        padding: 20px 24px;
    }

    .lc-teacher {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        border-radius: 10px;
        padding: 10px 16px;
        text-align: center;
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .lc-row-label {
        font-size: 10px;
        font-weight: 700;
        color: #C4BDB6;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 14px 0 8px;
    }

    .lc-pc-grid {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 8px;
        margin-bottom: 4px;
    }

    .lc-pc-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        padding: 8px 4px;
        border-radius: 10px;
        border: 2px solid transparent;
        transition: all 0.18s;
        position: relative;
        user-select: none;
    }

    .lc-pc-icon-wrap {
        width: 42px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border: 2px solid;
    }

    .pc-avail .lc-pc-icon-wrap {
        background: #ECFDF5;
        border-color: #A7F3D0;
    }

    .pc-inuse .lc-pc-icon-wrap {
        background: #FFF7ED;
        border-color: #FDE68A;
    }

    .pc-defect .lc-pc-icon-wrap {
        background: #FEF2F2;
        border-color: #FECACA;
    }

    .pc-reserved .lc-pc-icon-wrap {
        background: #EFF6FF;
        border-color: #BFDBFE;
    }

    .lc-pc-dot {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    .pc-avail .lc-pc-dot {
        background: #10B981;
    }

    .pc-inuse .lc-pc-dot {
        background: #F59E0B;
        animation: lcPulse 1.5s infinite;
    }

    .pc-defect .lc-pc-dot {
        background: #DC2626;
    }

    .pc-reserved .lc-pc-dot {
        background: #3B82F6;
    }

    @keyframes lcPulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8)
        }
    }

    .lc-pc-number {
        font-size: 9px;
        font-weight: 700;
    }

    .pc-avail .lc-pc-number {
        color: #065F46;
    }

    .pc-inuse .lc-pc-number {
        color: #92400E;
    }

    .pc-defect .lc-pc-number {
        color: #991B1B;
    }

    .pc-reserved .lc-pc-number {
        color: #1D4ED8;
    }

    .lc-pc-label {
        font-size: 7.5px;
        font-weight: 600;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    /* Admin status change for lab computers tab */
    .lc-pc-unit {
        cursor: pointer;
    }

    .lc-pc-unit:hover .lc-pc-icon-wrap {
        transform: translateY(-1px);
    }

    /* PC Grid Modal (for reservation) */
    .pcmodal-overlay {
