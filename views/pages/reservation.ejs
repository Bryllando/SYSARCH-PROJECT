<div class="p-6 max-w-3xl mx-auto space-y-6">

    <div class="mb-2">
        <h1 class="text-2xl font-extrabold text-[#273F4F]">Reservation</h1>
        <p class="text-gray-500 text-sm mt-1">Reserve a laboratory slot in advance.</p>
    </div>

    <!-- ── Success / Error messages ── -->
    <% if (typeof messages !=='undefined' ) { %>
        <% messages.forEach(function(msg) { %>
            <div
                class="p-3 rounded-xl flex items-center gap-3
                <%= msg.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
                <span class="font-medium text-sm">
                    <%= msg.text %>
                </span>
            </div>
            <% }) %>
                <% } %>

                    <!-- ── Reservation Form Card ── -->
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

                        <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-2">
                            <div class="w-2 h-2 rounded-full bg-[#5B0E14]"></div>
                            <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">New Reservation</h2>
                        </div>

                        <form action="/reservation" method="POST" class="p-6 space-y-5">

                            <!-- Read-only student info row -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-500">ID Number <span
                                            class="font-normal text-gray-400">(read-only)</span></label>
                                    <input type="text" value="<%= user.id_number %>" disabled
                                        class="w-full p-3 bg-gray-100 border border-gray-200 rounded-xl text-sm text-gray-500 cursor-not-allowed">
                                </div>

                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-500">Student Name <span
                                            class="font-normal text-gray-400">(read-only)</span></label>
                                    <input type="text"
                                        value="<%= user.first_name %> <%= user.middle_initial ? user.middle_initial + '. ' : '' %><%= user.last_name %>"
                                        disabled
                                        class="w-full p-3 bg-gray-100 border border-gray-200 rounded-xl text-sm text-gray-500 cursor-not-allowed">
                                </div>

                            </div>

                            <!-- Remaining sessions info badge -->
                            <div class="flex items-center gap-3 px-4 py-3 rounded-xl"
                                style="background: linear-gradient(135deg, #FFF8DC, #FFF3C4);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                    class="size-5 text-[#5B0E14] shrink-0">
                                    <path fill-rule="evenodd"
                                        d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z"
                                        clip-rule="evenodd" />
                                </svg>
                                <p class="text-sm text-[#5B0E14] font-semibold">
                                    Remaining Sessions:
                                    <span class="font-extrabold text-lg ml-1">
                                        <%= user.remaining_sessions ?? 30 %>
                                    </span>
                                </p>
                            </div>

                            <!-- Purpose -->
                            <div class="space-y-1">
                                <label class="block text-sm font-bold text-gray-700">Purpose <span
                                        class="text-red-500">*</span></label>
                                <div class="relative">
                                    <select name="purpose" required
                                        class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm transition-all">
                                        <option value="" disabled selected>Select purpose...</option>
                                        <option value="C Programming">C Programming</option>
                                        <option value="Java Programming">Java Programming</option>
                                        <option value="C# Programming">C# Programming</option>
                                        <option value="ASP.Net">ASP.Net</option>
                                        <option value="PHP Programming">PHP Programming</option>
                                        <option value="Database">Database</option>
                                        <option value="Research">Research</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                        </svg>
                                    </div>
                                </div>
                            </div>

                            <!-- Lab Room -->
                            <div class="space-y-1">
                                <label class="block text-sm font-bold text-gray-700">Laboratory <span
                                        class="text-red-500">*</span></label>
                                <div class="relative">
                                    <select name="lab_room" required
                                        class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm transition-all">
                                        <option value="" disabled selected>Select laboratory...</option>
                                        <option value="524">Lab 524</option>
                                        <option value="526">Lab 526</option>
                                        <option value="528">Lab 528</option>
                                        <option value="530">Lab 530</option>
                                        <option value="Mac Lab">Mac Lab</option>
                                    </select>
                                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                        </svg>
                                    </div>
                                </div>
                            </div>

                            <!-- Date & Time Slot -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700">Date <span
                                            class="text-red-500">*</span></label>
                                    <input type="date" name="date" required id="reservationDate"
                                        class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm transition-all">
                                </div>

                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700">Time Slot <span
                                            class="text-red-500">*</span></label>
                                    <div class="relative">
                                        <select name="time_slot" required
                                            class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm transition-all">
                                            <option value="" disabled selected>Select time slot...</option>
                                            <option value="07:00 AM - 08:00 AM">07:00 AM – 08:00 AM</option>
                                            <option value="08:00 AM - 09:00 AM">08:00 AM – 09:00 AM</option>
                                            <option value="09:00 AM - 10:00 AM">09:00 AM – 10:00 AM</option>
                                            <option value="10:00 AM - 11:00 AM">10:00 AM – 11:00 AM</option>
                                            <option value="11:00 AM - 12:00 PM">11:00 AM – 12:00 PM</option>
                                            <option value="12:00 PM - 01:00 PM">12:00 PM – 01:00 PM</option>
                                            <option value="01:00 PM - 02:00 PM">01:00 PM – 02:00 PM</option>
                                            <option value="02:00 PM - 03:00 PM">02:00 PM – 03:00 PM</option>
                                            <option value="03:00 PM - 04:00 PM">03:00 PM – 04:00 PM</option>
                                            <option value="04:00 PM - 05:00 PM">04:00 PM – 05:00 PM</option>
                                            <option value="05:00 PM - 06:00 PM">05:00 PM – 06:00 PM</option>
                                            <option value="06:00 PM - 07:00 PM">06:00 PM – 07:00 PM</option>
                                        </select>
                                        <div
                                            class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                            </svg>
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <!-- Submit -->
                            <div class="pt-2">
                                <button type="submit" class="btn-maroon py-3 text-base">
                                    Submit Reservation
                                </button>
                            </div>

                        </form>
                    </div>

                    <!-- ── My Reservations Table ── -->
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

                        <div
                            class="px-6 py-4 border-b border-gray-100 flex items-center justify-between flex-wrap gap-3">
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">My Reservations
                                </h2>
                            </div>
                            <div class="relative">
                                <input type="text" id="searchInput" placeholder="Search..."
                                    class="border border-gray-200 rounded-lg pl-8 pr-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-[#273F4F] w-40">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                    class="size-3.5 text-gray-400 absolute left-2.5 top-1/2 -translate-y-1/2">
                                    <path fill-rule="evenodd"
                                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                                        clip-rule="evenodd" />
                                </svg>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-100">
                                        <th
                                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                            #</th>
                                        <th
                                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                            Laboratory</th>
                                        <th
                                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                            Purpose</th>
                                        <th
                                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                            Date</th>
                                        <th
                                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                            Time Slot</th>
                                        <th
                                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                            Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50" id="reservationBody">

                                    <% var safeReservations=(typeof reservations !=='undefined' && reservations) ?
                                        reservations : []; %>

                                        <% if (safeReservations.length> 0) { %>
                                            <% safeReservations.forEach(function(r, i) { %>
                                                <tr class="hover:bg-gray-50 transition-colors reservation-row">
                                                    <td class="px-4 py-3 text-gray-400 text-xs font-mono">
                                                        <%= i + 1 %>
                                                    </td>
                                                    <td class="px-4 py-3">
                                                        <span
                                                            class="inline-block px-2 py-0.5 rounded-lg text-xs font-bold bg-[#273F4F]/10 text-[#273F4F]">
                                                            <%= r.lab_room %>
                                                        </span>
                                                    </td>
                                                    <td class="px-4 py-3">
                                                        <span
                                                            class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                                                            <%= r.purpose || '—' %>
                                                        </span>
                                                    </td>
                                                    <td class="px-4 py-3 text-gray-600 text-xs">
                                                        <%= r.date %>
                                                    </td>
                                                    <td class="px-4 py-3 text-gray-600 text-xs">
                                                        <%= r.time_slot %>
                                                    </td>
                                                    <td class="px-4 py-3">
                                                        <% if (r.status==='approved' ) { %>
                                                            <span
                                                                class="inline-flex items-center gap-1 text-xs font-bold text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
                                                                <span
                                                                    class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Approved
                                                            </span>
                                                            <% } else if (r.status==='rejected' ) { %>
                                                                <span
                                                                    class="inline-flex items-center gap-1 text-xs font-bold text-red-700 bg-red-50 px-2.5 py-1 rounded-full">
                                                                    <span
                                                                        class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>Rejected
                                                                </span>
                                                                <% } else { %>
                                                                    <span
                                                                        class="inline-flex items-center gap-1 text-xs font-bold text-amber-700 bg-amber-50 px-2.5 py-1 rounded-full">
                                                                        <span
                                                                            class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>Pending
                                                                    </span>
                                                                    <% } %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="6" class="px-4 py-12 text-center">
                                                                <div class="flex flex-col items-center gap-3">
                                                                    <div
                                                                        class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                                            viewBox="0 0 24 24" fill="currentColor"
                                                                            class="size-7 text-gray-300">
                                                                            <path fill-rule="evenodd"
                                                                                d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z"
                                                                                clip-rule="evenodd" />
                                                                        </svg>
                                                                    </div>
                                                                    <p class="text-sm text-gray-400 font-medium">No
                                                                        reservations yet</p>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% } %>

                                </tbody>
                            </table>
                        </div>

                        <div class="px-6 py-4 border-t border-gray-100 text-xs text-gray-500">
                            Showing <%= safeReservations.length %> reservation<%= safeReservations.length !==1 ? 's'
                                    : '' %>
                        </div>
                    </div>

</div>

<script>
    // Set minimum date to today
    document.getElementById('reservationDate').min = new Date().toISOString().split('T')[0];

    // Search filter
    document.getElementById('searchInput').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.reservation-row').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
</script>