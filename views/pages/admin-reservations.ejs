<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .res-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .res-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .res-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .res-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .res-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .res-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .res-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    /* Stats */
    .res-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        flex-wrap: wrap;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Toolbar */
    .res-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 32px;
        border-bottom: 1px solid #E2DDD8;
        background: #F0EDE8;
    }

    .res-filter-select {
        padding: 8px 14px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }

    .res-filter-select:focus {
        border-color: #273F4F;
    }

    .res-search-wrap {
        position: relative;
    }

    .res-search-wrap input {
        padding: 8px 14px 8px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 200px;
        font-family: 'DM Sans', sans-serif;
    }

    .res-search-wrap input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    .btn-print-res {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 14px;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 700;
        background: #374151;
        color: #fff;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s, transform 0.1s;
    }

    .btn-print-res:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    /* Table */
    .res-table-wrap {
        padding: 0 32px 32px;
    }

    .res-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        border: 1px solid #E8E3DD;
    }

    table.res-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .res-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .res-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .res-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .res-table tbody tr:last-child {
        border-bottom: none;
    }

    .res-table tbody tr:hover {
        background: #FAF9F7;
    }

    .res-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .name-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .name-text {
        font-size: 13px;
        font-weight: 600;
        color: #1C2B35;
        white-space: nowrap;
    }

    .badge-id {
        font-family: monospace;
        font-size: 11px;
        color: #4B5563;
        background: #F3F0EC;
        padding: 3px 8px;
        border-radius: 5px;
    }

    .badge-course {
        display: inline-flex;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
    }

    .badge-lab {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #1C2B35;
        color: #F1E194;
        white-space: nowrap;
    }

    .badge-pc {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-pill .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .status-pending {
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
    }

    .status-pending .dot {
        background: #D97706;
        animation: pulse 1.5s infinite;
    }

    .status-approved {
        background: #ECFDF5;
        color: #065F46;
        border: 1px solid #A7F3D0;
    }

    .status-approved .dot {
        background: #059669;
    }

    .status-rejected {
        background: #FEF2F2;
        color: #991B1B;
        border: 1px solid #FECACA;
    }

    .status-rejected .dot {
        background: #DC2626;
    }

    @keyframes pulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8);
        }
    }

    .btn-approve {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #059669, #047857);
        border: none;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-approve:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .btn-reject {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        color: #DC2626;
        background: #FEF2F2;
        border: 1.5px solid #FECACA;
        cursor: pointer;
        transition: all 0.15s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-reject:hover {
        background: #DC2626;
        color: #fff;
        border-color: #DC2626;
        transform: translateY(-1px);
    }

    .res-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }

    /* ── Print Styles ── */
    @media print {

        .res-header,
        .res-toolbar,
        .stat-card,
        .res-stats,
        aside,
        header,
        footer,
        .btn-approve,
        .btn-reject,
        form[action] {
            display: none !important;
        }

        .res-table-wrap {
            padding: 0 !important;
        }

        .res-table-card {
            border: none !important;
            box-shadow: none !important;
            border-radius: 0 !important;
        }

        .res-page {
            background: white !important;
        }

        body {
            background: white !important;
        }

        #print-header-area {
            display: block !important;
        }

        .res-table th,
        .res-table td {
            font-size: 11px !important;
            padding: 8px 10px !important;
        }

        /* Hide actions column when printing */
        .res-table th:last-child,
        .res-table td:last-child {
            display: none !important;
        }
    }

    #print-header-area {
        display: none;
        padding: 16px 0 12px;
        border-bottom: 2px solid #273F4F;
        margin-bottom: 12px;
    }
</style>

<div class="res-page">

    <!-- Print Header (only shows when printing) -->
    <div id="print-header-area">
        <h2 style="font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:#1C2B35;margin:0 0 4px;">
            CCS Lab PC Reservations Report
        </h2>
        <p style="font-size:12px;color:#6B7280;margin:0;">
            Generated: <span id="print-date-label"></span> &nbsp;|&nbsp;
            Filter: <span id="print-filter-label">All</span> &nbsp;|&nbsp;
            Total: <span id="print-count-label">0</span> records
        </p>
    </div>

    <!-- Header -->
    <div class="res-header">
        <div class="res-header-inner">
            <div>
                <p class="res-eyebrow">Admin Panel</p>
                <h1>Lab PC Reservations</h1>
                <p>Manage computer seat reservations for the laboratories</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= reservations ? reservations.length : 0 %> total
            </span>
        </div>
    </div>

    <% var allRes=(typeof reservations !=='undefined' && reservations) ? reservations : []; var
        pending=allRes.filter(r=> r.status === 'pending').length;
        var approved = allRes.filter(r => r.status === 'approved').length;
        var rejected = allRes.filter(r => r.status === 'rejected').length;
        %>

        <!-- Stats -->
        <div class="res-stats">
            <div class="stat-card">
                <div class="stat-icon" style="background:#FEF3C7;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#D97706" width="18" height="18">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.25V5Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <div class="stat-val" style="color:#D97706;">
                        <%= pending %>
                    </div>
                    <div class="stat-label">Pending</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#ECFDF5;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#059669" width="18" height="18">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <div class="stat-val" style="color:#059669;">
                        <%= approved %>
                    </div>
                    <div class="stat-label">Approved</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#FEF2F2;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#DC2626" width="18" height="18">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <div class="stat-val" style="color:#DC2626;">
                        <%= rejected %>
                    </div>
                    <div class="stat-label">Rejected</div>
                </div>
            </div>
            <div class="stat-card" style="border-left:3px solid #273F4F;">
                <div class="stat-icon" style="background:#E8EFF4;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#273F4F" width="18" height="18">
                        <path clip-rule="evenodd"
                            d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z"
                            fill-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <div class="stat-val" style="color:#273F4F;">
                        <%= allRes.length %>
                    </div>
                    <div class="stat-label">Total</div>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="res-toolbar">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                <select id="statusFilter" class="res-filter-select" onchange="filterTable()">
                    <option value="">All Status</option>
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                </select>
                <select id="labFilter" class="res-filter-select" onchange="filterTable()">
                    <option value="">All Labs</option>
                    <option value="524">Lab 524</option>
                    <option value="526">Lab 526</option>
                    <option value="528">Lab 528</option>
                    <option value="530">Lab 530</option>
                    <option value="542">Lab 542</option>
                    <option value="544">Lab 544</option>
                </select>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                <div class="res-search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                        style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#9CA3AF;width:14px;height:14px;">
                        <path fill-rule="evenodd"
                            d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                            clip-rule="evenodd" />
                    </svg>
                    <input type="text" id="searchInput" placeholder="Search..." oninput="filterTable()">
                </div>
                <!-- ── PRINT BUTTON ── -->
                <button class="btn-print-res" onclick="printReservations()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13"
                        height="13">
                        <path fill-rule="evenodd"
                            d="M4.25 1.5A.75.75 0 0 1 5 .75h6a.75.75 0 0 1 .75.75V3h.5A2.25 2.25 0 0 1 14.5 5.25v4.5A2.25 2.25 0 0 1 12.25 12H12v1.25A1.75 1.75 0 0 1 10.25 15h-4.5A1.75 1.75 0 0 1 4 13.25V12h-.25A2.25 2.25 0 0 1 1.5 9.75v-4.5A2.25 2.25 0 0 1 3.75 3h.5V1.5ZM5.5 3h5V2.25h-5V3Zm-.75 7.5v2.75c0 .138.112.25.25.25h5.5a.25.25 0 0 0 .25-.25V10.5h-6Zm7-5.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"
                            clip-rule="evenodd" />
                    </svg>
                    Print
                </button>
            </div>
        </div>

        <!-- Table -->
        <div class="res-table-wrap">
            <div class="res-table-card" id="printArea">
                <div style="overflow-x:auto;">
                    <table class="res-table">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>ID Number</th>
                                <th>Course</th>
                                <th>Lab</th>
                                <th>PC</th>
                                <th>Purpose</th>
                                <th>Date</th>
                                <th>Time Slot</th>
                                <th>Status</th>
                                <th style="text-align:center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="resBody">
                            <% if (allRes.length> 0) { %>
                                <% allRes.forEach(function(r) { var initials=(r.first_name ? r.first_name[0] : '' ) +
                                    (r.last_name ? r.last_name[0] : '' ); %>
                                    <tr class="res-row" data-status="<%= r.status %>" data-lab="<%= r.lab_room %>">
                                        <td>
                                            <div class="name-cell">
                                                <div class="name-avatar">
                                                    <%= initials.toUpperCase() %>
                                                </div>
                                                <span class="name-text">
                                                    <%= r.last_name %>, <%= r.first_name %>
                                                </span>
                                            </div>
                                        </td>
                                        <td><span class="badge-id">
                                                <%= r.id_number %>
                                            </span></td>
                                        <td><span class="badge-course">
                                                <%= r.course %>
                                            </span></td>
                                        <td><span class="badge-lab">
                                                <%= r.lab_room %>
                                            </span></td>
                                        <td><span class="badge-pc">PC-<%= String(r.computer_number||0).padStart(2,'0')
                                                    %></span></td>
                                        <td style="font-size:12px;color:#4B5563;">
                                            <%= r.purpose || '—' %>
                                        </td>
                                        <td style="font-size:12px;color:#4B5563;white-space:nowrap;">
                                            <%= r.date %>
                                        </td>
                                        <td style="font-size:11px;color:#9CA3AF;white-space:nowrap;">
                                            <%= r.time_slot %>
                                        </td>
                                        <td>
                                            <% if (r.status==='approved' ) { %>
                                                <span class="status-pill status-approved"><span
                                                        class="dot"></span>Approved</span>
                                                <% } else if (r.status==='rejected' ) { %>
                                                    <span class="status-pill status-rejected"><span
                                                            class="dot"></span>Rejected</span>
                                                    <% } else { %>
                                                        <span class="status-pill status-pending"><span
                                                                class="dot"></span>Pending</span>
                                                        <% } %>
                                        </td>
                                        <td>
                                            <% if (r.status==='pending' ) { %>
                                                <div
                                                    style="display:flex;align-items:center;justify-content:center;gap:8px;">
                                                    <form action="/admin/reservations/<%= r.id %>/approve" method="POST"
                                                        style="margin:0;"
                                                        onsubmit="return confirm('Approve? PC-<%= r.computer_number %> will be marked reserved.')">
                                                        <button type="submit" class="btn-approve">✓ Approve</button>
                                                    </form>
                                                    <form action="/admin/reservations/<%= r.id %>/reject" method="POST"
                                                        style="margin:0;"
                                                        onsubmit="return confirm('Reject this reservation?')">
                                                        <button type="submit" class="btn-reject">✕ Reject</button>
                                                    </form>
                                                </div>
                                                <% } else { %>
                                                    <div
                                                        style="text-align:center;font-size:11px;color:#C4BDB6;font-style:italic;">
                                                        Processed</div>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="10"
                                                    style="padding:56px 24px;text-align:center;color:#9CA3AF;font-size:13px;">
                                                    No lab computer reservations yet.
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="res-table-footer">
                    <span>Showing <strong id="rowCount" style="color:#1C2B35;">
                            <%= allRes.length %>
                        </strong> records</span>
                    <span>Students receive notifications on status change</span>
                </div>
            </div>
        </div>
</div>

<script>
    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('statusFilter').value;
        const lab = document.getElementById('labFilter').value;
        let count = 0;
        document.querySelectorAll('.res-row').forEach(row => {
            const show = (!q || row.textContent.toLowerCase().includes(q))
                && (!status || row.dataset.status === status)
                && (!lab || row.dataset.lab === lab);
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        document.getElementById('rowCount').textContent = count;
    }

    function printReservations() {
        // Update print header info
        const statusEl = document.getElementById('statusFilter');
        const statusText = statusEl.options[statusEl.selectedIndex].text;
        const visibleCount = document.getElementById('rowCount').textContent;

        document.getElementById('print-date-label').textContent = new Date().toLocaleString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });
        document.getElementById('print-filter-label').textContent = statusText || 'All';
        document.getElementById('print-count-label').textContent = visibleCount;

        window.print();
    }
</script>