<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .res-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .res-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .res-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .res-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .res-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .res-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .res-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    /* Stats */
    .res-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        flex-wrap: wrap;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Toolbar */
    .res-toolbar {
        padding: 14px 32px;
        border-bottom: 1px solid #E2DDD8;
        background: #F0EDE8;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .res-toolbar-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        width: 100%;
    }

    .res-toolbar-left,
    .res-toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        min-width: 0;
    }

    .res-toolbar-left { flex: 1 1 auto; }
    .res-toolbar-right { justify-content: flex-end; }

    .res-setting-form {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin: 0;
    }

    .res-setting-message {
        min-width: 240px;
        max-width: 320px;
        flex: 1 1 260px;
    }

    .res-filter-select {
        padding: 8px 14px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }

    .res-filter-select:focus {
        border-color: #273F4F;
    }

    .res-search-wrap {
        position: relative;
    }

    .res-search-wrap input {
        padding: 8px 14px 8px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 200px;
        font-family: 'DM Sans', sans-serif;
    }

    .res-search-wrap input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    .btn-print-res {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 14px;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 700;
        background: #374151;
        color: #fff;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s, transform 0.1s;
    }

    .btn-print-res:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .res-filter-select,
    .btn-print-res,
    .res-search-wrap input {
        height: 34px;
        box-sizing: border-box;
    }

    .res-search-wrap input {
        width: 210px;
    }

    @media (max-width: 1024px) {
        .res-toolbar-row {
            flex-direction: column;
            align-items: stretch;
        }
        .res-toolbar-left,
        .res-toolbar-right {
            width: 100%;
            justify-content: flex-start;
        }
        .res-search-wrap input {
            width: 100%;
            min-width: 180px;
        }
    }

    /* Table */
    .res-table-wrap {
        padding: 0 32px 32px;
    }

    .res-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        border: 1px solid #E8E3DD;
    }

    table.res-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .res-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .res-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .res-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .res-table tbody tr:last-child {
        border-bottom: none;
    }

    .res-table tbody tr:hover {
        background: #FAF9F7;
    }

    .res-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .name-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .name-text {
        font-size: 13px;
        font-weight: 600;
        color: #1C2B35;
        white-space: nowrap;
    }

    .badge-id {
        font-family: monospace;
        font-size: 11px;
        color: #4B5563;
        background: #F3F0EC;
        padding: 3px 8px;
        border-radius: 5px;
    }

    .badge-course {
        display: inline-flex;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
    }

    .badge-lab {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #1C2B35;
        color: #F1E194;
        white-space: nowrap;
    }

    .badge-pc {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #E8E3DD;
        color: #4B5563;
        white-space: nowrap;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-pill .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .status-pending {
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
    }

    .status-pending .dot {
        background: #D97706;
        animation: pulse 1.5s infinite;
    }

    .status-approved {
        background: #ECFDF5;
        color: #065F46;
        border: 1px solid #A7F3D0;
    }

    .status-approved .dot {
        background: #059669;
    }

    .status-rejected {
        background: #FEF2F2;
        color: #991B1B;
        border: 1px solid #FECACA;
    }

    .status-rejected .dot {
        background: #DC2626;
    }

    .status-completed {
        background: #EEF2FF;
        color: #3730A3;
        border: 1px solid #C7D2FE;
    }

    .status-completed .dot {
        background: #4F46E5;
    }

    .status-cancelled {
        background: #F3F4F6;
        color: #4B5563;
        border: 1px solid #E5E7EB;
    }

    .status-cancelled .dot {
        background: #6B7280;
    }

    .status-expired {
        background: #FFF7ED;
        color: #9A3412;
        border: 1px solid #FED7AA;
    }

    .status-expired .dot {
        background: #EA580C;
    }

    @keyframes pulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8);
        }
    }

    .pcmodal-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .pcmodal-overlay.open {
        display: flex !important;
    }

    .pcmodal-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 400px;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
    }

    .pcmodal-header {
        background: linear-gradient(135deg, #273F4F, #1a2d38);
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .pcmodal-header-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .pcmodal-header-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: rgba(241, 225, 148, 0.15);
        border: 1px solid rgba(241, 225, 148, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pcmodal-header-title {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 2px;
    }

    .pcmodal-header-sub {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .pcmodal-close {
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 9px;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 600;
    }

    .lc-pc-unit:hover {
        transform: translateY(-2px);
    }
    .lc-pc-unit.pc-avail:hover {
        border-color: #059669;
        background: rgba(5, 150, 105, 0.07);
    }
    .lc-pc-unit.pc-inuse:hover {
        border-color: #D97706;
        background: rgba(217, 119, 6, 0.07);
    }
    .lc-pc-unit.pc-defect:hover {
        border-color: #DC2626;
        background: rgba(220, 38, 38, 0.07);
    }
    .lc-pc-unit.pc-reserved:hover {
        border-color: #2563EB;
        background: rgba(37, 99, 235, 0.07);
    }

    @keyframes lcPulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    .lc-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #4B5563;
    }
    .lc-legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid;
    }

    .btn-approve {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #059669, #047857);
        border: none;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-approve:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .btn-reject {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        color: #DC2626;
        background: #FEF2F2;
        border: 1.5px solid #FECACA;
        cursor: pointer;
        transition: all 0.15s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-reject:hover {
        background: #DC2626;
        color: #fff;
        border-color: #DC2626;
        transform: translateY(-1px);
    }

    .btn-sitin {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #0F3E7D, #2A5AA0);
        border: none;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-sitin:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .res-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }

    /* ── Print Styles ── */
    @media print {

        .res-header,
        .res-toolbar,
        .stat-card,
        .res-stats,
        aside,
        header,
        footer,
        .btn-approve,
        .btn-reject,
        form[action],
        .res-tabs {
            display: none !important;
        }

        .res-tab-content:not(.active) {
            display: none !important;
        }

        .res-table-wrap {
            padding: 0 !important;
        }

        .res-table-card {
            border: none !important;
            box-shadow: none !important;
            border-radius: 0 !important;
        }

        .res-page {
            background: white !important;
        }

        body {
            background: white !important;
        }

        #print-header-area {
            display: block !important;
        }

        .res-table th,
        .res-table td {
            font-size: 11px !important;
            padding: 8px 10px !important;
        }

        /* Hide actions column when printing */
        .res-table th:last-child,
        .res-table td:last-child {
            display: none !important;
        }
    }

    #print-header-area {
        display: none;
        padding: 16px 0 12px;
        border-bottom: 2px solid #273F4F;
        margin-bottom: 12px;
    }

    /* Tab buttons */
    .res-tabs {
        display: flex;
        gap: 8px;
        padding: 12px 32px;
        background: #F0EDE9;
        border-bottom: 1px solid #E2DDD8;
    }

    .res-tab-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: 1.5px solid #E8E3DD;
        background: #fff;
        color: #6B7280;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .res-tab-btn:hover {
        border-color: #273F4F;
        color: #273F4F;
    }

    .res-tab-btn.active {
        background: #273F4F;
        color: #fff;
        border-color: #273F4F;
    }

    .res-tab-content {
        display: none;
    }

    .res-tab-content.active {
        display: block;
    }
</style>

<div class="res-page">

    <!-- Print Header (only shows when printing) -->
    <div id="print-header-area">
        <h2 style="font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:#1C2B35;margin:0 0 4px;">
            <span id="print-title-text">CCS Lab PC Reservations Report</span>
        </h2>
        <p style="font-size:12px;color:#6B7280;margin:0;">
            Generated: <span id="print-date-label"></span> &nbsp;|&nbsp;
            Filter: <span id="print-filter-label">All</span> &nbsp;|&nbsp;
            Total: <span id="print-count-label">0</span> records
        </p>
    </div>

    <!-- Header -->
    <div class="res-header">
        <div class="res-header-inner">
            <div>
                <p class="res-eyebrow">Admin Panel</p>
                <h1>Lab PC Reservations & Computers</h1>
                <p>Manage computer seat reservations and lab computer status</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= reservations ? reservations.length : 0 %> total
            </span>
        </div>
    </div>
    <% const isHistoryView = (typeof reservationViewMode !== 'undefined' && reservationViewMode === 'history'); %>

    <% var allRes=(typeof reservations !=='undefined' && reservations) ? reservations : []; var
        pending=allRes.filter(r=> r.status === 'pending').length;
        var approved = allRes.filter(r => r.status === 'approved').length;
        var rejected = allRes.filter(r => r.status === 'rejected').length;
        %>

        <!-- Tabs -->
        <div class="res-tabs">
            <button class="res-tab-btn active" onclick="switchTab('reservations')">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                    <path fill-rule="evenodd"
                        d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z"
                        clip-rule="evenodd" />
                </svg>
                Reservations
            </button>
            <button class="res-tab-btn" onclick="switchTab('computers')">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                    <path fill-rule="evenodd"
                        d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z"
                        clip-rule="evenodd" />
                </svg>
                Lab Computers
            </button>
        </div>

        <!-- Reservations Tab Content -->
        <div id="tab-reservations" class="res-tab-content active">
            <div class="res-toolbar">
                <div class="res-toolbar-row">
                    <div class="res-toolbar-left">
                        <a href="/admin/reservations"
                            class="btn-print-res"
                            style="text-decoration:none;background:<%= isHistoryView ? '#6B7280' : '#1C2B35' %>;">
                            Active List
                        </a>
                        <a href="/admin/reservations?view=history"
                            class="btn-print-res"
                            style="text-decoration:none;background:<%= isHistoryView ? '#5B0E14' : '#6B7280' %>;">
                            View History
                        </a>
                        <form action="/admin/reservation-settings" method="POST" class="res-setting-form">
                            <input type="hidden" name="enabled" value="<%= reservationSettings && Number(reservationSettings.enabled) === 1 ? 0 : 1 %>">
                            <input type="hidden" name="message" value="<%= reservationSettings ? reservationSettings.message : '' %>">
                            <button type="submit" class="btn-print-res" style="background:<%= reservationSettings && Number(reservationSettings.enabled) === 1 ? '#991B1B' : '#065F46' %>;">
                                <%= reservationSettings && Number(reservationSettings.enabled) === 1 ? 'Disable Reservations' : 'Enable Reservations' %>
                            </button>
                        </form>
                    </div>
                </div>
                <!-- Row 2: Filters + Search + Secondary Actions -->
                <div class="res-toolbar-row">
                    <div class="res-toolbar-left">
                        <select id="statusFilter" class="res-filter-select" onchange="filterTable()">
                            <option value="">All Status</option>
                            <% if (!isHistoryView) { %>
                                <option value="pending">Pending</option>
                                <option value="approved">Approved</option>
                            <% } else { %>
                                <option value="rejected">Rejected</option>
                                <option value="cancelled">Cancelled</option>
                                <option value="expired">Expired</option>
                                <option value="completed">Completed</option>
                                <option value="done">Completed (Legacy)</option>
                                <option value="deleted">Deleted</option>
                            <% } %>
                        </select>
                        <select id="labFilter" class="res-filter-select" onchange="filterTable()">
                            <option value="">All Labs</option>
                            <option value="524">Lab 524</option>
                            <option value="526">Lab 526</option>
                            <option value="528">Lab 528</option>
                            <option value="530">Lab 530</option>
                            <option value="542">Lab 542</option>
                            <option value="544">Lab 544</option>
                        </select>
                    </div>
                    <div class="res-toolbar-right">
                        <form action="/admin/reservations/auto-expire" method="POST" style="margin:0;" id="autoExpireForm">
                            <button id="autoExpireBtn" type="button" class="btn-print-res" style="background:#92400E;" onclick="showConfirmModal({title:'Auto-Expire Reservations',message:'Auto-expire all overdue pending/approved reservations?',type:'warning',confirmText:'Auto-Expire',onConfirm:()=>{const b=document.getElementById('autoExpireBtn');b.disabled=true;b.textContent='Processing...';document.getElementById('autoExpireForm').submit();}})">
                                Auto-Expire
                            </button>
                        </form>
                        <% if (isHistoryView) { %>
                        <form action="/admin/reservations/delete-history" method="POST" style="margin:0;" id="deleteHistoryForm">
                            <button type="button" class="btn-print-res" style="background:#7F1D1D;" onclick="showConfirmModal({title:'Delete Reservation History',message:'Delete all rejected/completed/expired reservation history? This cannot be undone.',type:'danger',confirmText:'Delete All',onConfirm:()=>{document.getElementById('deleteHistoryForm').submit();}})">
                                Delete All History
                            </button>
                        </form>
                        <% } %>
                        <div class="res-search-wrap">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#9CA3AF;width:14px;height:14px;">
                                <path fill-rule="evenodd"
                                    d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                                    clip-rule="evenodd" />
                            </svg>
                            <input type="text" id="searchInput" placeholder="Search..." oninput="filterTable()">
                        </div>
                        <!-- ── EXPORT CSV BUTTON ── -->
                        <button class="btn-print-res" onclick="exportReservationsCSV()" style="background:#065F46;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                                <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.44A1.5 1.5 0 0 0 8.878 2H4Zm1 5.75A.75.75 0 0 1 5.75 7h4.5a.75.75 0 0 1 0 1.5h-4.5A.75.75 0 0 1 5 7.75Zm0 3a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/>
                            </svg>
                            Export CSV
                        </button>
                        <!-- ── PRINT BUTTON ── -->
                        <button class="btn-print-res" onclick="printReservations()">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                                <path fill-rule="evenodd"
                                    d="M4.25 1.5A.75.75 0 0 1 5 .75h6a.75.75 0 0 1 .75.75V3h.5A2.25 2.25 0 0 1 14.5 5.25v4.5A2.25 2.25 0 0 1 12.25 12H12v1.25A1.75 1.75 0 0 1 10.25 15h-4.5A1.75 1.75 0 0 1 4 13.25V12h-.25A2.25 2.25 0 0 1 1.5 9.75v-4.5A2.25 2.25 0 0 1 3.75 3h.5V1.5ZM5.5 3h5V2.25h-5V3Zm-.75 7.5v2.75c0 .138.112.25.25.25h5.5a.25.25 0 0 0 .25-.25V10.5h-6Zm7-5.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"
                                    clip-rule="evenodd" />
                            </svg>
                            Print
                        </button>
                    </div>
                </div>
            </div>

            <!-- Table -->
            <div class="res-table-wrap">
                <div class="res-table-card" id="printArea">
                    <div style="overflow-x:auto;">
                        <table class="res-table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>ID Number</th>
                                    <th>Course</th>
                                    <th>Lab</th>
                                    <th>PC</th>
                                    <th>Purpose</th>
                                    <th>Date</th>
                                    <th>Time Slot</th>
                                    <th>Status</th>
                                    <th style="text-align:center;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="resBody">
                                <% if (allRes.length> 0) { %>
                                    <% allRes.forEach(function(r) { var initials=(r.first_name ? r.first_name[0] : '' )
                                        + (r.last_name ? r.last_name[0] : '' ); %>
                                        <tr class="res-row" data-status="<%= r.status %>" data-lab="<%= r.lab_room %>">
                                            <td>
                                                <div class="name-cell">
                                                    <div class="name-avatar">
                                                        <%= initials.toUpperCase() %>
                                                    </div>
                                                    <span class="name-text">
                                                        <%= r.last_name %>, <%= r.first_name %>
                                                    </span>
                                                </div>
                                            </td>
                                            <td><span class="badge-id">
                                                    <%= r.id_number %>
                                                </span></td>
                                            <td><span class="badge-course">
                                                    <%= r.course %>
                                                </span></td>
                                            <td><span class="badge-lab">
                                                    <%= r.lab_room %>
                                                </span></td>
                                            <td><span class="badge-pc">
                                                    <%= r.computer_number ? 'PC-' +
                                                        String(r.computer_number).padStart(2,'0') : '—' %>
                                                </span></td>
                                            <td style="font-size:12px;color:#4B5563;">
                                                <%= r.purpose || '—' %>
                                            </td>
                                            <td style="font-size:12px;color:#4B5563;white-space:nowrap;">
                                                <%= r.date %>
                                            </td>
                                            <td style="font-size:11px;color:#9CA3AF;white-space:nowrap;">
                                                <%= r.time_slot %>
                                            </td>
                                            <td>
                                                <% if (r.status==='approved' ) { %>
                                                    <span class="status-pill status-approved"><span
                                                            class="dot"></span>Approved</span>
                                                    <% } else if (r.status==='rejected' ) { %>
                                                        <span class="status-pill status-rejected"><span
                                                                class="dot"></span>Rejected</span>
                                                        <% } else if (r.status==='cancelled' ) { %>
                                                            <span class="status-pill status-cancelled"><span
                                                                    class="dot"></span>Cancelled</span>
                                                            <% } else if (r.status==='expired' ) { %>
                                                                <span class="status-pill status-expired"><span
                                                                        class="dot"></span>Expired</span>
                                                            <% } else if (r.status==='completed' || r.status==='done' ) { %>
                                                                <span class="status-pill status-completed"><span
                                                                        class="dot"></span>Completed</span>
                                                            <% } else if (r.status==='deleted' ) { %>
                                                                <span class="status-pill status-cancelled"><span
                                                                        class="dot"></span>Deleted</span>
                                                        <% } else { %>
                                                            <span class="status-pill status-pending"><span
                                                                    class="dot"></span>Pending</span>
                                                            <% } %>
                                            </td>
                                            <td>
                                                <% if (r.status==='pending' ) { %>
                                                    <div
                                                        style="display:flex;align-items:center;justify-content:center;gap:8px;">
                                                        <form action="/admin/reservations/<%= r.id %>/approve"
                                                            method="POST" style="margin:0;" id="approveForm-<%= r.id %>">
                                                            <button type="button" class="btn-approve" onclick="showConfirmModal({title:'Approve Reservation',message:'Approve this reservation? PC-<%= r.computer_number %> will be marked as reserved.',type:'success',confirmText:'✓ Approve',onConfirm:()=>{document.getElementById('approveForm-<%= r.id %>').submit();}})">✓ Approve</button>
                                                        </form>
                                                        <form action="/admin/reservations/<%= r.id %>/reject"
                                                            method="POST" style="margin:0;" id="rejectForm-<%= r.id %>">
                                                            <button type="button" class="btn-reject" onclick="showConfirmModal({title:'Reject Reservation',message:'Reject this reservation? The student will be notified.',type:'danger',confirmText:'✕ Reject',onConfirm:()=>{document.getElementById('rejectForm-<%= r.id %>').submit();}})">✕ Reject</button>
                                                        </form>
                                                    </div>
                                                <% } else if (r.status==='approved') { %>
                                                    <div
                                                        style="display:flex;align-items:center;justify-content:center;gap:8px;">
                                                        <a href="/admin/reservations/<%= r.id %>/sit-in"
                                                            class="btn-sitin"
                                                            style="text-decoration:none;">
                                                            Sit-In
                                                        </a>
                                                    </div>
                                                    <% } else { %>
                                                        <div style="display:flex;align-items:center;justify-content:center;gap:8px;">
                                                            <span
                                                                style="text-align:center;font-size:11px;color:#C4BDB6;font-style:italic;">
                                                                Archived
                                                            </span>
                                                            <form action="/admin/reservations/<%= r.id %>/delete<%= isHistoryView ? '?view=history' : '' %>"
                                                                method="POST" style="margin:0;" id="deleteResForm-<%= r.id %>">
                                                                <button type="button" class="btn-reject" onclick="showConfirmModal({title:'Delete Reservation',message:'Delete this reservation from active views?',type:'danger',confirmText:'Delete',onConfirm:()=>{document.getElementById('deleteResForm-<%= r.id %>').submit();}})">Delete</button>
                                                            </form>
                                                        </div>
                                                        <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="10"
                                                        style="padding:56px 24px;text-align:center;color:#9CA3AF;font-size:13px;">
                                                        No lab computer reservations yet.
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <div class="res-table-footer">
                        <span>Showing <strong id="rowCount" style="color:#1C2B35;">
                                <%= allRes.length %>
                            </strong> records</span>
                        <span>Students receive notifications on status change</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lab Computers Tab Content -->
        <div id="tab-computers" class="res-tab-content">
            <div class="res-toolbar">
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <select id="labComputerFilter" class="res-filter-select" onchange="switchLabComputer()">
                        <option value="">Select Lab</option>
                        <option value="524">Lab 524</option>
                        <option value="526">Lab 526</option>
                        <option value="528">Lab 528</option>
                        <option value="530">Lab 530</option>
                        <option value="542">Lab 542</option>
                        <option value="544">Lab 544</option>
                    </select>
                </div>
                <div class="lc-legend" style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
                    <div class="lc-legend-item">
                        <div class="lc-legend-dot" style="background:#10B981;border-color:#A7F3D0;"></div>Available
                    </div>
                    <div class="lc-legend-item">
                        <div class="lc-legend-dot" style="background:#F59E0B;border-color:#FDE68A;"></div>In Use
                    </div>
                    <div class="lc-legend-item">
                        <div class="lc-legend-dot" style="background:#DC2626;border-color:#FECACA;"></div>Defective
                    </div>
                    <div class="lc-legend-item">
                        <div class="lc-legend-dot" style="background:#3B82F6;border-color:#BFDBFE;"></div>Reserved
                    </div>
                    <span style="font-size:11px;color:#9CA3AF;font-style:italic;margin-left:8px;">Click any PC to change
                        status</span>
                </div>
            </div>

            <div class="res-table-wrap">
                <div class="res-table-card">
                    <div class="lc-grid-body" id="lcGridBody" style="padding:20px 24px;">
                        <div style="text-align:center;padding:60px 24px;color:#C4BDB6;">
                            <div style="font-size:32px;margin-bottom:12px;">🖥</div>
                            <p style="font-size:14px;font-weight:700;color:#4B5563;margin:0 0 4px;">Select a laboratory
                                from the dropdown above</p>
                            <p style="font-size:12px;color:#9CA3AF;margin:0;">Click any PC to change its status</p>
                        </div>
                    </div>
                    <div class="res-table-footer">
                        <span id="computersCount">Select a lab to view</span>
                        <span>Manage lab computer status</span>
                    </div>
                </div>
            </div>
        </div>
</div>

<!-- Status Change Modal -->
<div id="scOverlay" class="pcmodal-overlay" onclick="if(event.target===this) closeStatusModal()">
    <div class="pcmodal-card" style="max-width:400px;">
        <div class="pcmodal-header" style="background:linear-gradient(135deg,#273F4F,#1a2d38);">
            <div class="pcmodal-header-left">
                <div class="pcmodal-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#F1E194" width="20" height="20">
                        <path clip-rule="evenodd"
                            d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z"
                            fill-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="pcmodal-header-title"
                        style="font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff;margin:0 0 2px;">
                        Change PC Status</p>
                    <p class="pcmodal-header-sub" style="font-size:11px;color:rgba(255,255,255,0.5);margin:0;"
                        id="scPcLab">Lab</p>
                </div>
            </div>
            <button class="pcmodal-close" onclick="closeStatusModal()">✕</button>
        </div>
        <div
            style="padding:14px 24px;background:#F7F5F2;border-bottom:1px solid #E8E3DD;display:flex;align-items:center;gap:12px;">
            <div
                style="width:42px;height:36px;border-radius:9px;background:#E8EFF4;border:2px solid #C7D8E4;display:flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#273F4F" width="18" height="18">
                    <path clip-rule="evenodd"
                        d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z"
                        fill-rule="evenodd" />
                </svg>
            </div>
            <div>
                <div style="font-weight:800;color:#1C2B35;font-size:14px;" id="scPcNum">PC-01</div>
                <div style="font-size:11px;color:#6B7280;" id="scPcLab2">Lab</div>
            </div>
        </div>
        <div style="padding:20px 24px;display:flex;flex-direction:column;gap:10px;">
            <p
                style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6B7280;margin:0 0 6px;">
                Set Status To:</p>
            <button class="sc-status-btn btn-avail" onclick="applyStatus('available')"
                style="display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:12px;border:2px solid #A7F3D0;cursor:pointer;transition:all 0.15s;font-size:13px;font-weight:700;background:#fff;color:#065F46;font-family:'DM Sans',sans-serif;text-align:left;width:100%;">
                <span style="width:12px;height:12px;border-radius:50%;background:#10B981;flex-shrink:0;"></span>
                Available
                <span class="sc-current-badge" id="scBadgeAvail"
                    style="display:none;margin-left:auto;font-size:10px;font-weight:700;padding:3px 8px;border-radius:999px;background:rgba(0,0,0,0.06);color:#6B7280;">Current</span>
            </button>
            <button class="sc-status-btn btn-inuse" onclick="applyStatus('in_use')"
                style="display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:12px;border:2px solid #FDE68A;cursor:pointer;transition:all 0.15s;font-size:13px;font-weight:700;background:#fff;color:#92400E;font-family:'DM Sans',sans-serif;text-align:left;width:100%;">
                <span style="width:12px;height:12px;border-radius:50%;background:#F59E0B;flex-shrink:0;"></span>
                In Use
                <span class="sc-current-badge" id="scBadgeInuse"
                    style="display:none;margin-left:auto;font-size:10px;font-weight:700;padding:3px 8px;border-radius:999px;background:rgba(0,0,0,0.06);color:#6B7280;">Current</span>
            </button>
            <button class="sc-status-btn btn-defect" onclick="applyStatus('defective')"
                style="display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:12px;border:2px solid #FECACA;cursor:pointer;transition:all 0.15s;font-size:13px;font-weight:700;background:#fff;color:#991B1B;font-family:'DM Sans',sans-serif;text-align:left;width:100%;">
                <span style="width:12px;height:12px;border-radius:50%;background:#DC2626;flex-shrink:0;"></span>
                🔧 Defective / Maintenance
                <span class="sc-current-badge" id="scBadgeDefect"
                    style="display:none;margin-left:auto;font-size:10px;font-weight:700;padding:3px 8px;border-radius:999px;background:rgba(0,0,0,0.06);color:#6B7280;">Current</span>
            </button>
            <button class="sc-status-btn btn-reserved" onclick="applyStatus('reserved')"
                style="display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:12px;border:2px solid #BFDBFE;cursor:pointer;transition:all 0.15s;font-size:13px;font-weight:700;background:#fff;color:#1D4ED8;font-family:'DM Sans',sans-serif;text-align:left;width:100%;">
                <span style="width:12px;height:12px;border-radius:50%;background:#3B82F6;flex-shrink:0;"></span>
                Reserved
                <span class="sc-current-badge" id="scBadgeReserved"
                    style="display:none;margin-left:auto;font-size:10px;font-weight:700;padding:3px 8px;border-radius:999px;background:rgba(0,0,0,0.06);color:#6B7280;">Current</span>
            </button>
        </div>
        <div style="padding:0 24px 20px;">
            <button onclick="closeStatusModal()"
                style="width:100%;padding:11px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">Cancel</button>
        </div>
    </div>
</div>

<script>
    const LABS = [
        { room: '524', name: 'Lab 524', desc: 'General Purpose' },
        { room: '526', name: 'Lab 526', desc: 'General Purpose' },
        { room: '528', name: 'Lab 528', desc: 'General Purpose' },
        { room: '530', name: 'Lab 530', desc: 'Multimedia Lab' },
        { room: '542', name: 'Lab 542', desc: 'IT Laboratory' },
        { room: '544', name: 'Lab 544', desc: 'Mac Laboratory' },
    ];

    let currentLabRoom = null;
    let currentPcData = {};
    let modalPcNum = null;
    let modalCurrentStatus = null;

    // Tab switching
    function switchTab(tabName) {
        document.querySelectorAll('.res-tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.res-tab-content').forEach(content => content.classList.remove('active'));

        // Find the clicked button by matching tab name text
        document.querySelectorAll('.res-tab-btn').forEach(btn => {
            if (btn.textContent.trim().toLowerCase().includes(tabName)) btn.classList.add('active');
        });
        document.getElementById('tab-' + tabName).classList.add('active');

        if (tabName === 'computers') {
            const labSelect = document.getElementById('labComputerFilter');
            if (labSelect.value) {
                loadLabComputersGrid(labSelect.value);
            }
        }
    }

    function switchLabComputer() {
        const lab = document.getElementById('labComputerFilter').value;
        if (lab) {
            loadLabComputersGrid(lab);
        }
    }

    function pcSvg(color) {
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="${color}" width="20" height="20"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg>`;
    }

    async function loadLabComputersGrid(labRoom) {
        currentLabRoom = labRoom;
        const lab = LABS.find(l => l.room === labRoom);
        const gridBody = document.getElementById('lcGridBody');

        gridBody.innerHTML = '<div style="text-align:center;padding:40px;color:#9CA3AF;font-size:13px;">Loading PC layout…</div>';

        try {
            const res = await fetch('/lab-computers/' + labRoom);
            const data = await res.json();
            currentPcData = {};
            data.forEach(pc => { currentPcData[pc.computer_number] = pc; });
            renderPcGrid(lab);
        } catch (e) {
            gridBody.innerHTML = '<div style="text-align:center;padding:40px;color:#DC2626;font-size:13px;">Failed to load PCs. Please refresh.</div>';
        }
    }

    function renderPcGrid(lab) {
        const rows = 5, cols = 10, total = 50;
        let html = `<div class="pc-teacher-area" style="background:linear-gradient(135deg,#1C2B35,#273F4F);border-radius:10px;padding:10px 16px;text-align:center;font-size:11px;font-weight:700;color:rgba(255,255,255,0.8);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:20px;">🖥 Teacher / Instructor Station</div>`;
        let pcNum = 1;

        for (let r = 0; r < rows; r++) {
            html += `<div class="pc-row-label" style="font-size:10px;font-weight:700;color:#C4BDB6;text-align:center;text-transform:uppercase;letter-spacing:0.08em;margin:14px 0 8px;">Row ${String.fromCharCode(65 + r)}</div><div class="pc-grid" style="display:grid;grid-template-columns:repeat(10,1fr);gap:8px;margin-bottom:4px;">`;
            for (let c = 0; c < cols && pcNum <= total; c++) {
                const pc = currentPcData[pcNum] || { status: 'available' };
                const st = pc.status || 'available';
                const cls = st === 'available' ? 'pc-avail' : st === 'in_use' ? 'pc-inuse' : st === 'reserved' ? 'pc-reserved' : 'pc-defect';
                const ic = st === 'available' ? '#059669' : st === 'in_use' ? '#D97706' : st === 'reserved' ? '#2563EB' : '#DC2626';
                const lbl = st === 'available' ? 'Free' : st === 'in_use' ? 'In Use' : st === 'reserved' ? 'Reserved' : 'Defective';
                const emoji = st === 'defect' ? '🔧' : '';
                html += `<div class="lc-pc-unit ${cls}" id="lcpc-${pcNum}" onclick="openStatusModal(${pcNum}); return true;" style="display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;padding:8px 4px;border-radius:10px;border:2px solid transparent;transition:all 0.18s;position:relative;" title="PC-${String(pcNum).padStart(2, '0')} — ${lbl}">
                    <div class="lc-pc-icon-wrap" style="width:42px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;position:relative;border:2px solid;${st === 'available' ? 'background:#ECFDF5;border-color:#A7F3D0;' : st === 'in_use' ? 'background:#FFF7ED;border-color:#FDE68A;' : st === 'reserved' ? 'background:#EFF6FF;border-color:#BFDBFE;' : 'background:#FEF2F2;border-color:#FECACA;'}">${pcSvg(ic)}<span class="lc-pc-dot" style="position:absolute;top:-4px;right:-4px;width:10px;height:10px;border-radius:50%;border:2px solid #fff;${st === 'available' ? 'background:#10B981;' : st === 'in_use' ? 'background:#F59E0B;animation:lcPulse 1.5s infinite;' : st === 'reserved' ? 'background:#3B82F6;' : 'background:#DC2626;'}"></span></div>
                    <span class="lc-pc-number" style="font-size:9px;font-weight:700;${st === 'available' ? 'color:#065F46;' : st === 'in_use' ? 'color:#92400E;' : st === 'reserved' ? 'color:#1D4ED8;' : 'color:#991B1B;'}">${String(pcNum).padStart(2, '0')}</span>
                    <span class="lc-pc-label" style="font-size:7.5px;font-weight:600;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.04em;">${emoji}${lbl}</span>
                </div>`;
                pcNum++;
            }
            html += `</div>`;
        }

        document.getElementById('lcGridBody').innerHTML = html;
        document.getElementById('computersCount').textContent = '50 computers in ' + lab.name;
    }

    function openStatusModal(pcNum) {
        modalPcNum = pcNum;
        const pc = currentPcData[pcNum] || { status: 'available' };
        modalCurrentStatus = pc.status || 'available';

        const lab = LABS.find(l => l.room === currentLabRoom);
        document.getElementById('scPcNum').textContent = 'PC-' + String(pcNum).padStart(2, '0');
        document.getElementById('scPcLab').textContent = lab.name + ' — ' + lab.desc;
        document.getElementById('scPcLab2').textContent = lab.name + ' — ' + lab.desc;

        ['Avail', 'Inuse', 'Defect', 'Reserved'].forEach(function(n) {
            var badgeEl = document.getElementById('scBadge' + n);
            if (badgeEl) badgeEl.style.display = 'none';
        });
        var map = { available: 'Avail', in_use: 'Inuse', defective: 'Defect', reserved: 'Reserved' };
        var badge = document.getElementById('scBadge' + (map[modalCurrentStatus] || 'Avail'));
        if (badge) badge.style.display = 'inline-block';

        var overlay = document.getElementById('scOverlay');
        overlay.classList.add('open');
    }

    function closeStatusModal() {
        document.getElementById('scOverlay').classList.remove('open');
        if (modalPcNum && currentLabRoom) {
            loadLabComputersGrid(currentLabRoom);
        }
        modalPcNum = null;
    }

    async function applyStatus(newStatus) {
        if (!modalPcNum || !currentLabRoom) return;
        const pcNum = modalPcNum;
        closeStatusModal();

        try {
            const res = await fetch('/admin/lab-computers/status', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lab_room: currentLabRoom, computer_number: pcNum, status: newStatus })
            });
            const data = await res.json();
            if (data.success) {
                await loadLabComputersGrid(currentLabRoom);
            } else {
                if (window.showAppToast) window.showAppToast('error', 'Failed to update: ' + (data.error || 'Unknown error'));
            }
        } catch (e) {
            if (window.showAppToast) window.showAppToast('error', 'Error updating PC status');
        }
    }

    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('statusFilter').value;
        const lab = document.getElementById('labFilter').value;
        let count = 0;
        document.querySelectorAll('.res-row').forEach(row => {
            const show = (!q || row.textContent.toLowerCase().includes(q))
                && (!status || row.dataset.status === status)
                && (!lab || row.dataset.lab === lab);
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        document.getElementById('rowCount').textContent = count;
    }

    function printReservations() {
        const reservationsTab = document.getElementById('tab-reservations').classList.contains('active');

        if (reservationsTab) {
            const statusEl = document.getElementById('statusFilter');
            const statusText = statusEl.options[statusEl.selectedIndex].text;
            const visibleCount = document.getElementById('rowCount').textContent;

            document.getElementById('print-title-text').textContent = 'CCS Lab PC Reservations Report';
            document.getElementById('print-date-label').textContent = new Date().toLocaleString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
            document.getElementById('print-filter-label').textContent = statusText || 'All';
            document.getElementById('print-count-label').textContent = visibleCount;
        } else {
            const labSelect = document.getElementById('labComputerFilter');
            const labText = labSelect.options[labSelect.selectedIndex].text;
            const computersCount = document.getElementById('computersCount').textContent;

            document.getElementById('print-title-text').textContent = 'CCS Lab Computers Status';
            document.getElementById('print-date-label').textContent = new Date().toLocaleString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
            document.getElementById('print-filter-label').textContent = labText;
            document.getElementById('print-count-label').textContent = computersCount;
        }

        window.print();
    }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeStatusModal(); });

    function exportReservationsCSV() {
        const rows = document.querySelectorAll('.res-row');
        const visible = Array.from(rows).filter(r => r.style.display !== 'none');
        if (!visible.length) {
            if (window.showAppToast) window.showAppToast('warning', 'No visible reservations to export.');
            return;
        }

        const headers = ['Student', 'ID Number', 'Lab', 'PC', 'Purpose', 'Date', 'Time', 'Status'];
        const csvRows = [headers.join(',')];

        visible.forEach(row => {
            const cells = row.querySelectorAll('td');
            const student = (cells[0] ? cells[0].textContent.replace(/\s+/g, ' ').trim() : '').replace(/,/g, ';');
            const idNum = (cells[1] ? cells[1].textContent.trim() : '');
            const lab = (cells[2] ? cells[2].textContent.trim() : '');
            const pc = (cells[3] ? cells[3].textContent.trim() : '');
            const purpose = (cells[4] ? cells[4].textContent.trim() : '').replace(/,/g, ';');
            const date = (cells[5] ? cells[5].textContent.trim() : '');
            const time = (cells[6] ? cells[6].textContent.trim() : '');
            const status = (cells[7] ? cells[7].textContent.trim() : '');
            csvRows.push([student, idNum, lab, pc, purpose, date, time, status].map(v => '"' + v + '"').join(','));
        });

        const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'reservations_' + new Date().toISOString().slice(0, 10) + '.csv';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        if (window.showAppToast) window.showAppToast('success', 'CSV exported successfully.');
    }
</script>