<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@700;800&display=swap');

    .hist-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .hist-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .hist-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .hist-header::after {
        content: '';
        position: absolute;
        bottom: -50px;
        left: 15%;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(91, 14, 20, 0.15);
        pointer-events: none;
    }

    .hist-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .hist-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .hist-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .hist-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    .hist-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        background: #F0EDE8;
        flex-wrap: wrap;
    }

    .hist-stat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .hist-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .hist-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .hist-stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .hist-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 32px;
        background: #F0EDE8;
        border-bottom: 1px solid #E2DDD8;
    }

    .hist-filter-select {
        padding: 8px 14px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
    }

    .hist-filter-select:focus {
        border-color: #273F4F;
    }

    .hist-search-wrap {
        position: relative;
    }

    .hist-search-wrap svg {
        position: absolute;
        left: 11px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        pointer-events: none;
        width: 14px;
        height: 14px;
    }

    .hist-search-wrap input {
        padding: 8px 14px 8px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 200px;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .hist-search-wrap input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    .hist-table-wrap {
        padding: 0 32px 32px;
        background: #F0EDE8;
    }

    .hist-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
        border: 1px solid #E8E3DD;
    }

    table.hist-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .hist-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .hist-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .hist-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .hist-table tbody tr:last-child {
        border-bottom: none;
    }

    .hist-table tbody tr:hover {
        background: #FAF9F7;
    }

    .hist-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .badge-purpose {
        display: inline-flex;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .badge-lab {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #1C2B35;
        color: #F1E194;
        white-space: nowrap;
    }

    .badge-pc {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .pill-active {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #ECFDF5;
        color: #065F46;
        border: 1px solid #A7F3D0;
        white-space: nowrap;
    }

    .pill-done {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #F3F4F6;
        color: #6B7280;
        border: 1px solid #E5E7EB;
        white-space: nowrap;
    }

    @keyframes livePulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8)
        }
    }

    .hist-empty {
        padding: 72px 24px;
        text-align: center;
    }

    .hist-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }

    /* Delete button styles */
    .btn-delete-row {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #FEF2F2;
        color: #DC2626;
        border: 1px solid #FECACA;
        cursor: pointer;
        transition: all 0.15s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-delete-row:hover {
        background: #DC2626;
        color: #fff;
        border-color: #DC2626;
    }

    .btn-delete-all {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        background: #FEF2F2;
        color: #DC2626;
        border: 1.5px solid #FECACA;
        cursor: pointer;
        transition: all 0.15s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-delete-all:hover {
        background: #DC2626;
        color: #fff;
        border-color: #DC2626;
    }

    /* Date filter styles */
    .hist-date-input {
        padding: 8px 12px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
    }

    .hist-date-input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    /* Confirm Modal */
    .hist-confirm-overlay {
        position: fixed;
        inset: 0;
        z-index: 9998;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .hist-confirm-overlay.open {
        display: flex;
    }

    .hist-confirm-overlay.open .hist-confirm-card {
        animation: histDlIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .hist-confirm-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.2);
        padding: 32px;
        max-width: 380px;
        width: 100%;
        font-family: 'DM Sans', sans-serif;
        text-align: center;
    }

    .hist-confirm-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FEE2E2, #FECACA);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .hist-confirm-title {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 8px;
    }

    .hist-confirm-sub {
        font-size: 13px;
        color: #6B7280;
        margin: 0 0 24px;
        line-height: 1.6;
    }

    .hist-confirm-actions {
        display: flex;
        gap: 10px;
    }

    .hist-confirm-cancel {
        flex: 1;
        padding: 11px;
        border-radius: 10px;
        border: 1.5px solid #E5E7EB;
        background: #F9FAFB;
        font-size: 13px;
        font-weight: 700;
        color: #374151;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .hist-confirm-cancel:hover { background: #F3F4F6; }

    .hist-confirm-delete {
        flex: 1;
        padding: 11px;
        border-radius: 10px;
        border: none;
        background: linear-gradient(135deg, #DC2626, #B91C1C);
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .hist-confirm-delete:hover { background: linear-gradient(135deg, #B91C1C, #991B1B); }

    /* Export button styles */
    .hist-export-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
    }

    .hist-export-btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .hist-export-btn.csv { background: #059669; color: #fff; }
    .hist-export-btn.excel { background: #1D6F42; color: #fff; }
    .hist-export-btn.pdf { background: #DC2626; color: #fff; }
    .hist-export-btn.print { background: #374151; color: #fff; }

    /* Behavior rating badges (shared with sitin) */
    .rating-badge { display:inline-flex;align-items:center;gap:4px;padding:4px 9px;border-radius:6px;font-size:11px;font-weight:700;white-space:nowrap;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:opacity 0.15s; }
    .rating-badge:hover { opacity: 0.8; }
    .btn-rate-hist { display:inline-flex;align-items:center;gap:4px;padding:4px 9px;border-radius:6px;font-size:11px;font-weight:700;background:#FFF8F0;color:#92400E;border:1.5px solid #FDE68A;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.15s;white-space:nowrap; }
    .btn-rate-hist:hover { background:#F59E0B;border-color:#F59E0B;color:#fff; }
    .r5{background:#ECFDF5;color:#065F46;} .r4{background:#F0FDF4;color:#166534;} .r3{background:#F3F4F6;color:#374151;} .r2{background:#FFF7ED;color:#92400E;} .r1{background:#FEF2F2;color:#991B1B;}
    .rate-popover{position:fixed;z-index:99999;background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.22),0 4px 16px rgba(0,0,0,.08);border:1px solid #E8E3DD;padding:16px;width:260px;display:none;animation:ratePopIn .18s cubic-bezier(.34,1.56,.64,1) both;}
    .rate-popover.open{display:block;}
    @keyframes ratePopIn{from{opacity:0;transform:scale(.92) translateY(6px);}to{opacity:1;transform:scale(1) translateY(0);}}
    .rate-popover-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#9CA3AF;margin:0 0 12px;}
    .rate-option{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;border:1.5px solid transparent;cursor:pointer;transition:all .12s;margin-bottom:5px;background:#FAFAF9;}
    .rate-option:last-child{margin-bottom:0;} .rate-option:hover{background:#F3F0EC;border-color:#E2DDD8;} .rate-option.active{border-color:currentColor;}
    .rate-option-emoji{font-size:16px;} .rate-option-text{flex:1;} .rate-option-label{font-size:12px;font-weight:700;color:#1C2B35;} .rate-option-sub{font-size:10px;color:#9CA3AF;margin-top:1px;} .rate-option-score{font-size:18px;font-weight:800;line-height:1;}

    .hist-export-group {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Download overlay */
    .hist-dl-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
    }

    .hist-dl-overlay.open { display: flex; }

    .hist-dl-overlay.open .hist-dl-card {
        animation: histDlIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes histDlIn {
        from { opacity: 0; transform: scale(0.88) translateY(12px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .hist-dl-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
        padding: 36px 48px;
        text-align: center;
        min-width: 280px;
        font-family: 'DM Sans', sans-serif;
    }

    .hist-dl-spinner {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        border: 4px solid #E8E3DD;
        border-top-color: #273F4F;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 16px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .hist-dl-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg, #059669, #34D399);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .hist-dl-title {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 6px;
    }

    .hist-dl-sub {
        font-size: 13px;
        color: #9CA3AF;
        margin: 0;
    }

    /* Print styles */
    @media print {
        .hist-toolbar,
        .hist-header,
        .hist-export-group,
        #histDlOverlay,
        header, aside, footer {
            display: none !important;
        }
        .hist-table-wrap {
            padding: 0 !important;
        }
        .hist-table-card {
            border: none !important;
            box-shadow: none !important;
        }
        .hist-page {
            background: white !important;
        }
        body {
            background: white !important;
        }
    }
</style>

<!-- External libraries for export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

<div class="hist-page">

    <!-- Header -->
    <div class="hist-header">
        <div class="hist-header-inner">
            <div>
                <p class="hist-eyebrow">Admin Panel</p>
                <h1>Student Sit-in History</h1>
                <p>Complete record of all laboratory sessions</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= sessions ? sessions.length : 0 %> total records
            </span>
        </div>
    </div>

    <% var safeSessions=(typeof sessions !=='undefined' && sessions) ? sessions : []; var
        doneSessions=safeSessions.filter(s=> s.status === 'completed').length;
        var activeSessions = safeSessions.filter(s => s.status === 'active').length;
        %>

        <!-- Toolbar -->
        <div class="hist-toolbar">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                <select id="statusFilter" class="hist-filter-select">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="completed">Completed</option>
                </select>
                <select id="labFilter" class="hist-filter-select">
                    <option value="">All Labs</option>
                    <option value="524">Lab 524</option>
                    <option value="526">Lab 526</option>
                    <option value="528">Lab 528</option>
                    <option value="530">Lab 530</option>
                    <option value="542">Lab 542</option>
                    <option value="544">Lab 544</option>
                </select>
                <select id="behaviorFilter" class="hist-filter-select">
                    <option value="">All Behavior</option>
                    <option value="5">⭐ Excellent (5)</option>
                    <option value="4">👍 Good (4)</option>
                    <option value="3">😐 Neutral (3)</option>
                    <option value="2">⚠️ Poor (2)</option>
                    <option value="1">🚫 Disruptive (1)</option>
                    <option value="0">Unrated</option>
                </select>
                <!-- Date Range Filter -->
                <div style="display:flex;align-items:center;gap:6px;">
                    <input type="date" id="dateFrom" class="hist-date-input" title="From date">
                    <span style="font-size:11px;color:#9CA3AF;font-weight:600;">to</span>
                    <input type="date" id="dateTo" class="hist-date-input" title="To date">
                    <button onclick="clearDateFilter()" id="clearDateBtn"
                        style="display:none;padding:6px 10px;border-radius:7px;border:1.5px solid #E5E7EB;background:#F9FAFB;font-size:11px;font-weight:700;color:#6B7280;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.15s;"
                        title="Clear date filter">✕ Clear</button>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                <div class="hist-search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd"
                            d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                            clip-rule="evenodd" />
                    </svg>
                    <input type="text" id="searchInput" placeholder="Search sessions...">
                </div>
                <!-- Delete All -->
                <button class="btn-delete-all" onclick="openDeleteAllModal()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                        <path fill-rule="evenodd" d="M5 3.25V4H2.75a.75.75 0 0 0 0 1.5h.3l.815 8.15A1.5 1.5 0 0 0 5.357 15h5.285a1.5 1.5 0 0 0 1.493-1.35l.815-8.15h.3a.75.75 0 0 0 0-1.5H11v-.75A2.25 2.25 0 0 0 8.75 1h-1.5A2.25 2.25 0 0 0 5 3.25Zm2.25-.75a.75.75 0 0 0-.75.75V4h3v-.75a.75.75 0 0 0-.75-.75h-1.5ZM6.05 6a.75.75 0 0 1 .787.713l.275 5.5a.75.75 0 0 1-1.498.075l-.275-5.5A.75.75 0 0 1 6.05 6Zm3.9 0a.75.75 0 0 1 .712.787l-.275 5.5a.75.75 0 0 1-1.498-.075l.275-5.5a.75.75 0 0 1 .786-.712Z" clip-rule="evenodd" />
                    </svg>
                    Delete All History
                </button>
                <div class="hist-export-group">
                    <button class="hist-export-btn csv" onclick="histExportCSV()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm1 5.75a.75.75 0 0 0 0 1.5h6a.75.75 0 0 0 0-1.5H5Zm0 3a.75.75 0 0 0 0 1.5h6a.75.75 0 0 0 0-1.5H5Z" clip-rule="evenodd" />
                        </svg>
                        CSV
                    </button>
                    <button class="hist-export-btn excel" onclick="histExportExcel()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm4.75 6.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
                        </svg>
                        Excel
                    </button>
                    <button class="hist-export-btn pdf" onclick="histExportPDF()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm.75 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z" clip-rule="evenodd" />
                        </svg>
                        PDF
                    </button>
                    <button class="hist-export-btn print" onclick="histPrintReport()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4.25 1.5A.75.75 0 0 1 5 .75h6a.75.75 0 0 1 .75.75V3h.5A2.25 2.25 0 0 1 14.5 5.25v4.5A2.25 2.25 0 0 1 12.25 12H12v1.25A1.75 1.75 0 0 1 10.25 15h-4.5A1.75 1.75 0 0 1 4 13.25V12h-.25A2.25 2.25 0 0 1 1.5 9.75v-4.5A2.25 2.25 0 0 1 3.75 3h.5V1.5ZM5.5 3h5V2.25h-5V3Zm-.75 7.5v2.75c0 .138.112.25.25.25h5.5a.25.25 0 0 0 .25-.25V10.5h-6Zm7-5.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" clip-rule="evenodd" />
                        </svg>
                        Print
                    </button>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="hist-table-wrap">
            <div class="hist-table-card">
                <div style="overflow-x:auto;">
                    <table class="hist-table">
                        <thead>
                            <tr>
                                <th>ID Number</th>
                                <th>Student Name</th>
                                <th>Course</th>
                                <th>Purpose</th>
                                <th>Lab</th>
                                <th>PC</th>
                                <th>Time In</th>
                                <th>Time Out</th>
                                <th>Date</th>
                                <th>Behavior</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="histBody">
                            <% if (safeSessions.length > 0) { %>
                                <% safeSessions.forEach(function(s) {
                                    var dateStr = s.time_in ? new Date(s.time_in).toISOString().split('T')[0] : '';
                                %>
                                    <tr class="hist-row"
                                        data-status="<%= s.status %>"
                                        data-lab="<%= s.lab_room || '' %>"
                                        data-date="<%= dateStr %>"
                                        data-behavior="<%= s.behavior_rating || '0' %>"
                                        data-id="<%= s.id %>">

                                        <td style="font-family:monospace;font-size:12px;color:#4B5563;white-space:nowrap;">
                                            <%= s.id_number || '—' %>
                                        </td>
                                        <td style="font-size:12px;font-weight:600;color:#1C2B35;white-space:nowrap;">
                                            <%= s.last_name %>, <%= s.first_name %>
                                        </td>
                                        <td>
                                            <span style="display:inline-flex;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;">
                                                <%= s.course %>
                                            </span>
                                        </td>
                                        <td><span class="badge-purpose"><%= s.purpose || '—' %></span></td>
                                        <td><span class="badge-lab"><%= s.lab_room || '—' %></span></td>
                                        <td>
                                            <% if (s.computer_number) { %>
                                                <span class="badge-pc">PC-<%= String(s.computer_number).padStart(2,'0') %></span>
                                            <% } else { %>
                                                <span style="font-size:11px;color:#D1D5DB;">—</span>
                                            <% } %>
                                        </td>
                                        <td style="font-size:12px;color:#4B5563;white-space:nowrap;font-variant-numeric:tabular-nums;">
                                            <%= s.time_in ? new Date(s.time_in).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) : '—' %>
                                        </td>
                                        <td style="font-size:12px;white-space:nowrap;font-variant-numeric:tabular-nums;">
                                            <% if (s.time_out) { %>
                                                <span style="color:#4B5563;">
                                                    <%= new Date(s.time_out).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %>
                                                </span>
                                            <% } else { %>
                                                <span style="display:inline-flex;align-items:center;gap:4px;color:#059669;font-weight:600;font-size:11px;">
                                                    <span style="width:6px;height:6px;border-radius:50%;background:#10B981;animation:livePulse 1.5s ease-in-out infinite;flex-shrink:0;"></span>
                                                    Still In
                                                </span>
                                            <% } %>
                                        </td>
                                        <td style="font-size:12px;color:#4B5563;white-space:nowrap;">
                                            <%= dateStr ? new Date(s.time_in).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) : '—' %>
                                        </td>
                                        <td>
                                            <% var br = s.behavior_rating; var rMeta = {5:{lbl:'Excellent',emoji:'⭐',cls:'r5'},4:{lbl:'Good',emoji:'👍',cls:'r4'},3:{lbl:'Neutral',emoji:'😐',cls:'r3'},2:{lbl:'Poor',emoji:'⚠️',cls:'r2'},1:{lbl:'Disruptive',emoji:'🚫',cls:'r1'}}; %>
                                            <% if (br) { %>
                                                <button id="hrate-btn-<%= s.id %>" class="rating-badge <%= rMeta[br].cls %>" onclick="openHistRatePopover(event, <%= s.id %>, <%= br %>)" title="Click to change rating">
                                                    <%= rMeta[br].emoji %> <%= rMeta[br].lbl %>
                                                </button>
                                            <% } else { %>
                                                <button id="hrate-btn-<%= s.id %>" class="btn-rate-hist" onclick="openHistRatePopover(event, <%= s.id %>, null)" title="Rate behavior">
                                                    ⭐ Rate
                                                </button>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (s.status === 'active') { %>
                                                <span class="pill-active">
                                                    <span style="width:5px;height:5px;border-radius:50%;background:#10B981;animation:livePulse 1.5s ease-in-out infinite;"></span>
                                                    Active
                                                </span>
                                            <% } else { %>
                                                <span class="pill-done">
                                                    <span style="width:5px;height:5px;border-radius:50%;background:#9CA3AF;"></span>
                                                    Done
                                                </span>
                                            <% } %>
                                        </td>
                                        <!-- Action: Remove -->
                                        <td>
                                            <button class="btn-delete-row" onclick="openDeleteRowModal(<%= s.id %>, '<%= s.last_name %>, <%= s.first_name %>')">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="11" height="11">
                                                    <path fill-rule="evenodd" d="M5 3.25V4H2.75a.75.75 0 0 0 0 1.5h.3l.815 8.15A1.5 1.5 0 0 0 5.357 15h5.285a1.5 1.5 0 0 0 1.493-1.35l.815-8.15h.3a.75.75 0 0 0 0-1.5H11v-.75A2.25 2.25 0 0 0 8.75 1h-1.5A2.25 2.25 0 0 0 5 3.25Zm2.25-.75a.75.75 0 0 0-.75.75V4h3v-.75a.75.75 0 0 0-.75-.75h-1.5ZM6.05 6a.75.75 0 0 1 .787.713l.275 5.5a.75.75 0 0 1-1.498.075l-.275-5.5A.75.75 0 0 1 6.05 6Zm3.9 0a.75.75 0 0 1 .712.787l-.275 5.5a.75.75 0 0 1-1.498-.075l.275-5.5a.75.75 0 0 1 .786-.712Z" clip-rule="evenodd" />
                                                </svg>
                                                Remove
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="11">
                                        <div class="hist-empty">
                                            <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#F3F0EC,#E8E3DD);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#C4BDB6" width="28" height="28">
                                                    <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z" clip-rule="evenodd" />
                                                </svg>
                                            </div>
                                            <p style="font-size:15px;font-weight:700;color:#4B5563;margin:0 0 6px;">No sit-in history yet</p>
                                            <p style="font-size:12px;color:#9CA3AF;margin:0;">Session records will appear here once students sit in.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="hist-table-footer">
                    <span>Showing <strong id="visibleCount" style="color:#1C2B35;">
                            <%= safeSessions.length %>
                        </strong>
                        of <strong style="color:#1C2B35;">
                            <%= safeSessions.length %>
                        </strong> records</span>
                    <span>CCS Laboratory Sit-in Monitoring System</span>
                </div>
            </div>
        </div>

</div>

<!-- ── Confirm Delete Single Row Modal ── -->
<div id="histConfirmRowModal" class="hist-confirm-overlay" onclick="if(event.target===this) closeDeleteRowModal()">
    <div class="hist-confirm-card">
        <div class="hist-confirm-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#DC2626" width="26" height="26">
                <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058l-.346-9Zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058l.345-9Z" clip-rule="evenodd" />
            </svg>
        </div>
        <p class="hist-confirm-title">Remove Record?</p>
        <p class="hist-confirm-sub" id="histConfirmRowSubtext">This sit-in session record will be permanently removed from the history.</p>
        <div class="hist-confirm-actions">
            <button class="hist-confirm-cancel" onclick="closeDeleteRowModal()">Cancel</button>
            <form id="histDeleteRowForm" method="POST" style="flex:1;">
                <button type="submit" class="hist-confirm-delete" style="width:100%;">Yes, Remove</button>
            </form>
        </div>
    </div>
</div>

<!-- ── Confirm Delete All Modal ── -->
<div id="histConfirmAllModal" class="hist-confirm-overlay" onclick="if(event.target===this) closeDeleteAllModal()">
    <div class="hist-confirm-card">
        <div class="hist-confirm-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#DC2626" width="26" height="26">
                <path fill-rule="evenodd" d="M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003ZM12 8.25a.75.75 0 0 1 .75.75v3.75a.75.75 0 0 1-1.5 0V9a.75.75 0 0 1 .75-.75Zm0 8.25a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
            </svg>
        </div>
        <p class="hist-confirm-title">Delete All History?</p>
        <p class="hist-confirm-sub">This will <strong>permanently delete all</strong> sit-in session records. This action cannot be undone.</p>
        <div class="hist-confirm-actions">
            <button class="hist-confirm-cancel" onclick="closeDeleteAllModal()">Cancel</button>
            <form action="/admin/history/delete-all" method="POST" style="flex:1;">
                <button type="submit" class="hist-confirm-delete" style="width:100%;">Yes, Delete All</button>
            </form>
        </div>
    </div>
</div>

<!-- Download Overlay -->
<div id="histDlOverlay" class="hist-dl-overlay">
    <div class="hist-dl-card">
        <div id="histDlSpinner" class="hist-dl-spinner"></div>
        <div id="histDlIcon" class="hist-dl-icon" style="display:none;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="white" width="22" height="22">
                <path fill-rule="evenodd"
                    d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                    clip-rule="evenodd" />
            </svg>
        </div>
        <p class="hist-dl-title" id="histDlTitle">Preparing Export...</p>
        <p class="hist-dl-sub" id="histDlSub">Please wait a moment</p>
    </div>
</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const labFilter = document.getElementById('labFilter');
    const dateFrom = document.getElementById('dateFrom');
    const dateTo = document.getElementById('dateTo');
    const clearDateBtn = document.getElementById('clearDateBtn');
    const countEl = document.getElementById('visibleCount');

    // ── Delete Single Row Modal ──
    let _deleteRowId = null;
    function openDeleteRowModal(id, name) {
        _deleteRowId = id;
        document.getElementById('histConfirmRowSubtext').textContent =
            'Remove session record for "' + name + '"? This cannot be undone.';
        document.getElementById('histDeleteRowForm').action = '/admin/history/' + id + '/delete';
        document.getElementById('histConfirmRowModal').classList.add('open');
    }
    function closeDeleteRowModal() {
        document.getElementById('histConfirmRowModal').classList.remove('open');
    }

    // ── Delete All Modal ──
    function openDeleteAllModal() {
        document.getElementById('histConfirmAllModal').classList.add('open');
    }
    function closeDeleteAllModal() {
        document.getElementById('histConfirmAllModal').classList.remove('open');
    }

    // ── ESC closes modals ──
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            closeDeleteRowModal();
            closeDeleteAllModal();
        }
    });

    // ── Date filter clear ──
    function clearDateFilter() {
        dateFrom.value = '';
        dateTo.value = '';
        clearDateBtn.style.display = 'none';
        applyFilters();
    }

    dateFrom.addEventListener('change', () => {
        clearDateBtn.style.display = (dateFrom.value || dateTo.value) ? 'inline-flex' : 'none';
        applyFilters();
    });
    dateTo.addEventListener('change', () => {
        clearDateBtn.style.display = (dateFrom.value || dateTo.value) ? 'inline-flex' : 'none';
        applyFilters();
    });

    // Build data array for export
    var histAllRows = [];
    (function() {
        var rows = document.querySelectorAll('.hist-row');
        rows.forEach(function(r) {
            histAllRows.push({
                el: r,
                cells: Array.from(r.querySelectorAll('td')).map(function(td) { return td.textContent.trim(); })
            });
        });
    })();

    function histGetVisibleData() {
        var headers = ['ID Number', 'Name', 'Course', 'Purpose', 'Lab', 'PC', 'Time In', 'Time Out', 'Date', 'Status'];
        var rows = [];
        histAllRows.forEach(function(r) {
            if (r.el.style.display !== 'none') {
                rows.push(r.cells);
            }
        });
        return { headers: headers, rows: rows };
    }

    function histShowDownload(format, doExport) {
        var overlay = document.getElementById('histDlOverlay');
        var spinner = document.getElementById('histDlSpinner');
        var icon = document.getElementById('histDlIcon');
        var title = document.getElementById('histDlTitle');
        var sub = document.getElementById('histDlSub');

        spinner.style.display = 'block';
        icon.style.display = 'none';
        title.textContent = 'Preparing ' + format + ' Export...';
        sub.textContent = 'Collecting visible records';
        overlay.classList.add('open');

        setTimeout(function() {
            title.textContent = 'Downloading ' + format + '...';
            sub.textContent = 'Starting download';
            doExport();

            setTimeout(function() {
                spinner.style.display = 'none';
                icon.style.display = 'flex';
                title.textContent = 'Download Complete!';
                sub.textContent = format + ' file saved successfully';

                setTimeout(function() {
                    overlay.classList.remove('open');
                }, 1200);
            }, 600);
        }, 900);
    }

    function histExportCSV() {
        histShowDownload('CSV', function() {
            var d = histGetVisibleData();
            var csv = [d.headers.join(',')];
            d.rows.forEach(function(r) {
                csv.push(r.map(function(c) { return '"' + c.replace(/"/g, '""') + '"'; }).join(','));
            });
            var blob = new Blob([csv.join('\n')], { type: 'text/csv;charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url; a.download = 'student-reports-' + new Date().toISOString().split('T')[0] + '.csv';
            document.body.appendChild(a); a.click();
            document.body.removeChild(a); URL.revokeObjectURL(url);
        });
    }

    function histExportExcel() {
        histShowDownload('Excel', function() {
            var d = histGetVisibleData();
            var wsData = [d.headers].concat(d.rows);
            var ws = XLSX.utils.aoa_to_sheet(wsData);
            ws['!cols'] = [14, 20, 14, 18, 10, 10, 12, 12, 14, 12].map(function(w) { return { wch: w }; });
            var wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Student Reports');
            XLSX.writeFile(wb, 'student-reports-' + new Date().toISOString().split('T')[0] + '.xlsx');
        });
    }

    function histExportPDF() {
        histShowDownload('PDF', function() {
            var d = histGetVisibleData();
            var jsPDF = window.jspdf.jsPDF;
            var doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });

            doc.setFontSize(16);
            doc.setFont('helvetica', 'bold');
            doc.text('CCS Student Sit-in Reports', 14, 16);
            doc.setFontSize(9);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(120);
            doc.text('Generated: ' + new Date().toLocaleString(), 14, 22);
            doc.text('Total records: ' + d.rows.length, 14, 27);

            doc.autoTable({
                head: [d.headers],
                body: d.rows,
                startY: 32,
                styles: { fontSize: 8, cellPadding: 2 },
                headStyles: { fillColor: [39, 63, 79], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [248, 249, 250] },
                columnStyles: {
                    0: { cellWidth: 22 },
                    1: { cellWidth: 30 },
                    2: { cellWidth: 16 },
                    3: { cellWidth: 20 },
                    4: { cellWidth: 12 },
                    5: { cellWidth: 10 },
                    6: { cellWidth: 14 },
                    7: { cellWidth: 14 },
                    8: { cellWidth: 16 },
                    9: { cellWidth: 12 }
                }
            });

            doc.save('student-reports-' + new Date().toISOString().split('T')[0] + '.pdf');
        });
    }

    function histPrintReport() {
        window.print();
    }

    function applyFilters() {
        const q = searchInput.value.toLowerCase();
        const status = statusFilter.value;
        const lab = labFilter.value;
        const from = dateFrom.value ? new Date(dateFrom.value) : null;
        const to = dateTo.value ? new Date(dateTo.value + 'T23:59:59') : null;
        let count = 0;

        document.querySelectorAll('.hist-row').forEach(row => {
            const matchQ = !q || row.textContent.toLowerCase().includes(q);
            const matchStatus = !status || row.dataset.status === status;
            const matchLab = !lab || row.dataset.lab === lab;

            let matchDate = true;
            if (from || to) {
                const rowDate = row.dataset.date ? new Date(row.dataset.date) : null;
                if (!rowDate) {
                    matchDate = false;
                } else {
                    if (from && rowDate < from) matchDate = false;
                    if (to && rowDate > to) matchDate = false;
                }
            }

            const show = matchQ && matchStatus && matchLab && matchDate;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        countEl.textContent = count;
    }

    // \u2500\u2500 Override applyFilters with behavior filter support \u2500\u2500
    const behaviorFilter = document.getElementById('behaviorFilter');
    behaviorFilter.addEventListener('change', applyFilters);

    applyFilters = function() {
        const q = searchInput.value.toLowerCase();
        const status = statusFilter.value;
        const lab = labFilter.value;
        const beh = behaviorFilter.value;
        const from = dateFrom.value ? new Date(dateFrom.value) : null;
        const to = dateTo.value ? new Date(dateTo.value + 'T23:59:59') : null;
        let count = 0;

        document.querySelectorAll('.hist-row').forEach(row => {
            const matchQ = !q || row.textContent.toLowerCase().includes(q);
            const matchStatus = !status || row.dataset.status === status;
            const matchLab = !lab || row.dataset.lab === lab;
            const matchBeh = !beh || (beh === '0' ? !row.dataset.behavior || row.dataset.behavior === '0' : row.dataset.behavior === beh);

            let matchDate = true;
            if (from || to) {
                const rowDate = row.dataset.date ? new Date(row.dataset.date) : null;
                if (!rowDate) matchDate = false;
                else {
                    if (from && rowDate < from) matchDate = false;
                    if (to && rowDate > to) matchDate = false;
                }
            }

            const show = matchQ && matchStatus && matchLab && matchBeh && matchDate;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        countEl.textContent = count;
    };

    // Re-wire all filter inputs to the updated applyFilters
    searchInput.addEventListener('input', applyFilters);
    statusFilter.addEventListener('change', applyFilters);
    labFilter.addEventListener('change', applyFilters);

    // ── History Behavior Rating Popover ──
    const HIST_RATINGS = [
        { score: 5, emoji: '⭐', label: 'Excellent',  sub: 'Fully focused, working on task',       cls: 'r5', color: '#065F46' },
        { score: 4, emoji: '👍', label: 'Good',       sub: 'Mostly productive, minor distraction',  cls: 'r4', color: '#166534' },
        { score: 3, emoji: '😐', label: 'Neutral',    sub: 'Mixed activity, unclear intent',      cls: 'r3', color: '#374151' },
        { score: 2, emoji: '⚠️', label: 'Poor',       sub: 'Mostly gaming or off-task browsing',  cls: 'r2', color: '#92400E' },
        { score: 1, emoji: '🚫', label: 'Disruptive', sub: 'Violating lab rules or misleading',   cls: 'r1', color: '#991B1B' },
    ];

    let histRatePopSid = null;
    const histRatePop = document.createElement('div');
    histRatePop.className = 'rate-popover';
    histRatePop.innerHTML = `
        <p class="rate-popover-title">Rate Behavior</p>
        ${HIST_RATINGS.map(r => `
            <div class="rate-option" data-score="${r.score}" onclick="submitHistRating(${r.score})" style="color:${r.color};">
                <span class="rate-option-emoji">${r.emoji}</span>
                <div class="rate-option-text">
                    <div class="rate-option-label">${r.label}</div>
                    <div class="rate-option-sub">${r.sub}</div>
                </div>
                <span class="rate-option-score">${r.score}</span>
            </div>
        `).join('')}
    `;
    document.body.appendChild(histRatePop);

    function openHistRatePopover(event, sessionId, currentRating) {
        event.stopPropagation();
        histRatePopSid = sessionId;
        histRatePop.querySelectorAll('.rate-option').forEach(opt => {
            opt.classList.toggle('active', parseInt(opt.dataset.score) === currentRating);
        });
        const btn = event.currentTarget;
        const rect = btn.getBoundingClientRect();
        
        histRatePop.style.visibility = 'hidden';
        histRatePop.classList.add('open');
        const pw = histRatePop.offsetWidth || 260;
        const ph = histRatePop.offsetHeight || 330;
        histRatePop.style.visibility = 'visible';
        
        let top = rect.bottom + 6;
        let left = rect.left;
        
        if (left + pw > window.innerWidth - 12) left = window.innerWidth - pw - 12;
        if (left < 12) left = 12;

        if (top + ph > window.innerHeight - 12) {
            top = rect.top - ph - 6;
            if (top < 12) top = 12;
        }

        histRatePop.style.top  = top + 'px';
        histRatePop.style.left = left + 'px';
    }

    document.addEventListener('click', e => { if (!histRatePop.contains(e.target)) histRatePop.classList.remove('open'); });
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeDeleteRowModal(); closeDeleteAllModal(); histRatePop.classList.remove('open'); }
    });

    async function submitHistRating(score) {
        const sid = histRatePopSid;
        histRatePop.classList.remove('open');
        histRatePopSid = null;
        if (!sid) return;
        try {
            const res = await fetch(`/admin/sitin/${sid}/rate`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ rating: score })
            });
            const data = await res.json();
            if (!data.success) throw new Error(data.error);
            const r = HIST_RATINGS.find(x => x.score === score);
            const btn = document.getElementById(`hrate-btn-${sid}`);
            if (btn && r) {
                btn.className = `rating-badge ${r.cls}`;
                btn.textContent = `${r.emoji} ${r.label}`;
                btn.setAttribute('onclick', `openHistRatePopover(event, ${sid}, ${score})`);
                // update data attribute for filter
                btn.closest('tr').dataset.behavior = score;
            }
        } catch (err) {
            if (window.showAppToast) window.showAppToast('error', 'Failed to save rating. Please try again.');
        }
    }
</script>