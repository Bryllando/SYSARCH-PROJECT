<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@700;800&display=swap');

    .hist-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .hist-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .hist-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .hist-header::after {
        content: '';
        position: absolute;
        bottom: -50px;
        left: 15%;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(91, 14, 20, 0.15);
        pointer-events: none;
    }

    .hist-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .hist-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .hist-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .hist-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    .hist-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        background: #F0EDE8;
        flex-wrap: wrap;
    }

    .hist-stat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .hist-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .hist-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .hist-stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .hist-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 32px;
        background: #F0EDE8;
        border-bottom: 1px solid #E2DDD8;
    }

    .hist-filter-select {
        padding: 8px 14px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
    }

    .hist-filter-select:focus {
        border-color: #273F4F;
    }

    .hist-search-wrap {
        position: relative;
    }

    .hist-search-wrap svg {
        position: absolute;
        left: 11px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        pointer-events: none;
        width: 14px;
        height: 14px;
    }

    .hist-search-wrap input {
        padding: 8px 14px 8px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 200px;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .hist-search-wrap input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    .hist-table-wrap {
        padding: 0 32px 32px;
        background: #F0EDE8;
    }

    .hist-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
        border: 1px solid #E8E3DD;
    }

    table.hist-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .hist-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .hist-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .hist-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .hist-table tbody tr:last-child {
        border-bottom: none;
    }

    .hist-table tbody tr:hover {
        background: #FAF9F7;
    }

    .hist-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .badge-purpose {
        display: inline-flex;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .badge-lab {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #1C2B35;
        color: #F1E194;
        white-space: nowrap;
    }

    .badge-pc {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .pill-active {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #ECFDF5;
        color: #065F46;
        border: 1px solid #A7F3D0;
        white-space: nowrap;
    }

    .pill-done {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #F3F4F6;
        color: #6B7280;
        border: 1px solid #E5E7EB;
        white-space: nowrap;
    }

    @keyframes livePulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8)
        }
    }

    .hist-empty {
        padding: 72px 24px;
        text-align: center;
    }

    .hist-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }

    /* Export button styles */
    .hist-export-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
    }

    .hist-export-btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .hist-export-btn.csv { background: #059669; color: #fff; }
    .hist-export-btn.excel { background: #1D6F42; color: #fff; }
    .hist-export-btn.pdf { background: #DC2626; color: #fff; }
    .hist-export-btn.print { background: #374151; color: #fff; }

    .hist-export-group {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Download overlay */
    .hist-dl-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
    }

    .hist-dl-overlay.open { display: flex; }

    .hist-dl-overlay.open .hist-dl-card {
        animation: histDlIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes histDlIn {
        from { opacity: 0; transform: scale(0.88) translateY(12px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .hist-dl-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
        padding: 36px 48px;
        text-align: center;
        min-width: 280px;
        font-family: 'DM Sans', sans-serif;
    }

    .hist-dl-spinner {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        border: 4px solid #E8E3DD;
        border-top-color: #273F4F;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 16px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .hist-dl-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg, #059669, #34D399);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .hist-dl-title {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 6px;
    }

    .hist-dl-sub {
        font-size: 13px;
        color: #9CA3AF;
        margin: 0;
    }

    /* Print styles */
    @media print {
        .hist-toolbar,
        .hist-header,
        .hist-export-group,
        #histDlOverlay,
        header, aside, footer {
            display: none !important;
        }
        .hist-table-wrap {
            padding: 0 !important;
        }
        .hist-table-card {
            border: none !important;
            box-shadow: none !important;
        }
        .hist-page {
            background: white !important;
        }
        body {
            background: white !important;
        }
    }
</style>

<!-- External libraries for export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

<div class="hist-page">

    <!-- Header -->
    <div class="hist-header">
        <div class="hist-header-inner">
            <div>
                <p class="hist-eyebrow">Admin Panel</p>
                <h1>Student Sit-in History</h1>
                <p>Complete record of all laboratory sessions</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= sessions ? sessions.length : 0 %> total records
            </span>
        </div>
    </div>

    <% var safeSessions=(typeof sessions !=='undefined' && sessions) ? sessions : []; var
        doneSessions=safeSessions.filter(s=> s.status === 'done').length;
        var activeSessions = safeSessions.filter(s => s.status === 'active').length;
        %>

        <!-- Toolbar -->
        <div class="hist-toolbar">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                <select id="statusFilter" class="hist-filter-select">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="done">Completed</option>
                </select>
                <select id="labFilter" class="hist-filter-select">
                    <option value="">All Labs</option>
                    <option value="524">Lab 524</option>
                    <option value="526">Lab 526</option>
                    <option value="528">Lab 528</option>
                    <option value="530">Lab 530</option>
                    <option value="542">Lab 542</option>
                    <option value="544">Lab 544</option>
                </select>
            </div>
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                <div class="hist-search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd"
                            d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                            clip-rule="evenodd" />
                    </svg>
                    <input type="text" id="searchInput" placeholder="Search sessions...">
                </div>
                <div class="hist-export-group">
                    <button class="hist-export-btn csv" onclick="histExportCSV()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm1 5.75a.75.75 0 0 0 0 1.5h6a.75.75 0 0 0 0-1.5H5Zm0 3a.75.75 0 0 0 0 1.5h6a.75.75 0 0 0 0-1.5H5Z" clip-rule="evenodd" />
                        </svg>
                        CSV
                    </button>
                    <button class="hist-export-btn excel" onclick="histExportExcel()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm4.75 6.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
                        </svg>
                        Excel
                    </button>
                    <button class="hist-export-btn pdf" onclick="histExportPDF()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm.75 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z" clip-rule="evenodd" />
                        </svg>
                        PDF
                    </button>
                    <button class="hist-export-btn print" onclick="histPrintReport()">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M4.25 1.5A.75.75 0 0 1 5 .75h6a.75.75 0 0 1 .75.75V3h.5A2.25 2.25 0 0 1 14.5 5.25v4.5A2.25 2.25 0 0 1 12.25 12H12v1.25A1.75 1.75 0 0 1 10.25 15h-4.5A1.75 1.75 0 0 1 4 13.25V12h-.25A2.25 2.25 0 0 1 1.5 9.75v-4.5A2.25 2.25 0 0 1 3.75 3h.5V1.5ZM5.5 3h5V2.25h-5V3Zm-.75 7.5v2.75c0 .138.112.25.25.25h5.5a.25.25 0 0 0 .25-.25V10.5h-6Zm7-5.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" clip-rule="evenodd" />
                        </svg>
                        Print
                    </button>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="hist-table-wrap">
            <div class="hist-table-card">
                <div style="overflow-x:auto;">
                    <table class="hist-table">
                        <thead>
                            <tr>
                                <th>ID Number</th>
                                <th>Student Name</th>
                                <th>Course</th>
                                <th>Purpose</th>
                                <th>Lab</th>
                                <th>PC</th>
                                <th>Time In</th>
                                <th>Time Out</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="histBody">
                            <% if (safeSessions.length> 0) { %>
                                <% safeSessions.forEach(function(s) { %>
                                    <tr class="hist-row" data-status="<%= s.status %>"
                                        data-lab="<%= s.lab_room || '' %>">

                                        <!-- ★ Fixed: use s.id_number, s.last_name, s.first_name (from JOIN) not user.xxx ★ -->
                                        <td
                                            style="font-family:monospace;font-size:12px;color:#4B5563;white-space:nowrap;">
                                            <%= s.id_number || '—' %>
                                        </td>
                                        <td style="font-size:12px;font-weight:600;color:#1C2B35;white-space:nowrap;">
                                            <%= s.last_name %>, <%= s.first_name %>
                                        </td>
                                        <td>
                                            <span
                                                style="display:inline-flex;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;">
                                                <%= s.course %>
                                            </span>
                                        </td>
                                        <td><span class="badge-purpose">
                                                <%= s.purpose || '—' %>
                                            </span></td>
                                        <td><span class="badge-lab">
                                                <%= s.lab_room || '—' %>
                                            </span></td>
                                        <td>
                                            <% if (s.computer_number) { %>
                                                <span class="badge-pc">PC-<%= String(s.computer_number).padStart(2,'0')
                                                        %></span>
                                                <% } else { %>
                                                    <span style="font-size:11px;color:#D1D5DB;">—</span>
                                                    <% } %>
                                        </td>
                                        <td
                                            style="font-size:12px;color:#4B5563;white-space:nowrap;font-variant-numeric:tabular-nums;">
                                            <%= s.time_in ? new
                                                Date(s.time_in).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
                                                : '—' %>
                                        </td>
                                        <td
                                            style="font-size:12px;white-space:nowrap;font-variant-numeric:tabular-nums;">
                                            <% if (s.time_out) { %>
                                                <span style="color:#4B5563;">
                                                    <%= new
                                                        Date(s.time_out).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
                                                        %>
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        style="display:inline-flex;align-items:center;gap:4px;color:#059669;font-weight:600;font-size:11px;">
                                                        <span
                                                            style="width:6px;height:6px;border-radius:50%;background:#10B981;animation:livePulse 1.5s ease-in-out infinite;flex-shrink:0;"></span>
                                                        Still In
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td style="font-size:12px;color:#4B5563;white-space:nowrap;">
                                            <%= s.time_in ? new
                                                Date(s.time_in).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'})
                                                : '—' %>
                                        </td>
                                        <td>
                                            <% if (s.status==='active' ) { %>
                                                <span class="pill-active">
                                                    <span
                                                        style="width:5px;height:5px;border-radius:50%;background:#10B981;animation:livePulse 1.5s ease-in-out infinite;"></span>
                                                    Active
                                                </span>
                                                <% } else { %>
                                                    <span class="pill-done">
                                                        <span
                                                            style="width:5px;height:5px;border-radius:50%;background:#9CA3AF;"></span>
                                                        Done
                                                    </span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="10">
                                                    <div class="hist-empty">
                                                        <div
                                                            style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#F3F0EC,#E8E3DD);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                                fill="#C4BDB6" width="28" height="28">
                                                                <path fill-rule="evenodd"
                                                                    d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z"
                                                                    clip-rule="evenodd" />
                                                            </svg>
                                                        </div>
                                                        <p
                                                            style="font-size:15px;font-weight:700;color:#4B5563;margin:0 0 6px;">
                                                            No sit-in history yet</p>
                                                        <p style="font-size:12px;color:#9CA3AF;margin:0;">Session
                                                            records will appear here once students sit in.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="hist-table-footer">
                    <span>Showing <strong id="visibleCount" style="color:#1C2B35;">
                            <%= safeSessions.length %>
                        </strong>
                        of <strong style="color:#1C2B35;">
                            <%= safeSessions.length %>
                        </strong> records</span>
                    <span>CCS Laboratory Sit-in Monitoring System</span>
                </div>
            </div>
        </div>

</div>

<!-- Download Overlay -->
<div id="histDlOverlay" class="hist-dl-overlay">
    <div class="hist-dl-card">
        <div id="histDlSpinner" class="hist-dl-spinner"></div>
        <div id="histDlIcon" class="hist-dl-icon" style="display:none;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="white" width="22" height="22">
                <path fill-rule="evenodd"
                    d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                    clip-rule="evenodd" />
            </svg>
        </div>
        <p class="hist-dl-title" id="histDlTitle">Preparing Export...</p>
        <p class="hist-dl-sub" id="histDlSub">Please wait a moment</p>
    </div>
</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const labFilter = document.getElementById('labFilter');
    const countEl = document.getElementById('visibleCount');

    // Build data array for export
    var histAllRows = [];
    (function() {
        var rows = document.querySelectorAll('.hist-row');
        rows.forEach(function(r) {
            histAllRows.push({
                el: r,
                cells: Array.from(r.querySelectorAll('td')).map(function(td) { return td.textContent.trim(); })
            });
        });
    })();

    function histGetVisibleData() {
        var headers = ['ID Number', 'Name', 'Course', 'Purpose', 'Lab', 'PC', 'Time In', 'Time Out', 'Date', 'Status'];
        var rows = [];
        histAllRows.forEach(function(r) {
            if (r.el.style.display !== 'none') {
                rows.push(r.cells);
            }
        });
        return { headers: headers, rows: rows };
    }

    function histShowDownload(format, doExport) {
        var overlay = document.getElementById('histDlOverlay');
        var spinner = document.getElementById('histDlSpinner');
        var icon = document.getElementById('histDlIcon');
        var title = document.getElementById('histDlTitle');
        var sub = document.getElementById('histDlSub');

        spinner.style.display = 'block';
        icon.style.display = 'none';
        title.textContent = 'Preparing ' + format + ' Export...';
        sub.textContent = 'Collecting visible records';
        overlay.classList.add('open');

        setTimeout(function() {
            title.textContent = 'Downloading ' + format + '...';
            sub.textContent = 'Starting download';
            doExport();

            setTimeout(function() {
                spinner.style.display = 'none';
                icon.style.display = 'flex';
                title.textContent = 'Download Complete!';
                sub.textContent = format + ' file saved successfully';

                setTimeout(function() {
                    overlay.classList.remove('open');
                }, 1200);
            }, 600);
        }, 900);
    }

    function histExportCSV() {
        histShowDownload('CSV', function() {
            var d = histGetVisibleData();
            var csv = [d.headers.join(',')];
            d.rows.forEach(function(r) {
                csv.push(r.map(function(c) { return '"' + c.replace(/"/g, '""') + '"'; }).join(','));
            });
            var blob = new Blob([csv.join('\n')], { type: 'text/csv;charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url; a.download = 'student-reports-' + new Date().toISOString().split('T')[0] + '.csv';
            document.body.appendChild(a); a.click();
            document.body.removeChild(a); URL.revokeObjectURL(url);
        });
    }

    function histExportExcel() {
        histShowDownload('Excel', function() {
            var d = histGetVisibleData();
            var wsData = [d.headers].concat(d.rows);
            var ws = XLSX.utils.aoa_to_sheet(wsData);
            ws['!cols'] = [14, 20, 14, 18, 10, 10, 12, 12, 14, 12].map(function(w) { return { wch: w }; });
            var wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Student Reports');
            XLSX.writeFile(wb, 'student-reports-' + new Date().toISOString().split('T')[0] + '.xlsx');
        });
    }

    function histExportPDF() {
        histShowDownload('PDF', function() {
            var d = histGetVisibleData();
            var jsPDF = window.jspdf.jsPDF;
            var doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });

            doc.setFontSize(16);
            doc.setFont('helvetica', 'bold');
            doc.text('CCS Student Sit-in Reports', 14, 16);
            doc.setFontSize(9);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(120);
            doc.text('Generated: ' + new Date().toLocaleString(), 14, 22);
            doc.text('Total records: ' + d.rows.length, 14, 27);

            doc.autoTable({
                head: [d.headers],
                body: d.rows,
                startY: 32,
                styles: { fontSize: 8, cellPadding: 2 },
                headStyles: { fillColor: [39, 63, 79], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [248, 249, 250] },
                columnStyles: {
                    0: { cellWidth: 22 },
                    1: { cellWidth: 30 },
                    2: { cellWidth: 16 },
                    3: { cellWidth: 20 },
                    4: { cellWidth: 12 },
                    5: { cellWidth: 10 },
                    6: { cellWidth: 14 },
                    7: { cellWidth: 14 },
                    8: { cellWidth: 16 },
                    9: { cellWidth: 12 }
                }
            });

            doc.save('student-reports-' + new Date().toISOString().split('T')[0] + '.pdf');
        });
    }

    function histPrintReport() {
        window.print();
    }

    function applyFilters() {
        const q = searchInput.value.toLowerCase();
        const status = statusFilter.value;
        const lab = labFilter.value;
        let count = 0;
        document.querySelectorAll('.hist-row').forEach(row => {
            const matchQ = !q || row.textContent.toLowerCase().includes(q);
            const matchStatus = !status || row.dataset.status === status;
            const matchLab = !lab || row.dataset.lab === lab;
            const show = matchQ && matchStatus && matchLab;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        countEl.textContent = count;
    }

    searchInput.addEventListener('input', applyFilters);
    statusFilter.addEventListener('change', applyFilters);
    labFilter.addEventListener('change', applyFilters);
</script>