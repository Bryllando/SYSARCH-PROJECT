<div class="min-h-screen bg-gray-50">

    <% var allSessions=(typeof sessions !=='undefined' && sessions) ? sessions : []; var
        activeSessions=allSessions.filter(s=> s.status === 'active').length;
        var doneSessions = allSessions.filter(s => s.status === 'done').length;
        %>

        <!-- ── Header ── -->
        <div class="relative overflow-hidden px-8 py-7" style="background: linear-gradient(135deg, #1C2B35, #273F4F);">
            <div class="absolute -right-10 -top-10 w-44 h-44 rounded-full opacity-10 bg-white"></div>
            <div class="absolute -left-6 -bottom-8 w-32 h-32 rounded-full opacity-5 bg-white"></div>
            <div class="relative z-10 flex flex-wrap items-end justify-between gap-4">
                <div>
                    <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: rgba(241,225,148,0.7);">
                        Admin Panel</p>
                    <h1 class="text-3xl font-extrabold text-white tracking-tight">Sit-in History</h1>
                    <p class="text-sm mt-1" style="color: rgba(255,255,255,0.5);">Complete log of all student laboratory
                        sessions</p>
                </div>
                <span class="text-xs font-bold px-3 py-1.5 rounded-full border"
                    style="background: rgba(241,225,148,0.12); color: #F1E194; border-color: rgba(241,225,148,0.25);">
                    <%= allSessions.length %> total records
                </span>
            </div>
        </div>

        <!-- ── Stats ── -->
        <div class="flex flex-wrap gap-3 px-8 py-4 bg-gray-50 border-b border-gray-200">
            <div
                class="flex flex-1 min-w-28 items-center gap-3 bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0"
                    style="background: linear-gradient(135deg,#EFF6FF,#DBEAFE);">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#1D4ED8" class="size-5">
                        <path fill-rule="evenodd"
                            d="M3 6a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm4.5 7.5a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0v-2.25a.75.75 0 0 1 .75-.75Zm3.75-1.5a.75.75 0 0 0-1.5 0v4.5a.75.75 0 0 0 1.5 0V12Zm2.25-3a.75.75 0 0 1 .75.75v6.75a.75.75 0 0 1-1.5 0V9.75A.75.75 0 0 1 13.5 9Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-extrabold" style="color:#273F4F;">
                        <%= allSessions.length %>
                    </p>
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Total</p>
                </div>
            </div>
            <div
                class="flex flex-1 min-w-28 items-center gap-3 bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0"
                    style="background: linear-gradient(135deg,#ECFDF5,#D1FAE5);">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#059669" class="size-5">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-green-600">
                        <%= doneSessions %>
                    </p>
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Completed</p>
                </div>
            </div>
            <div
                class="flex flex-1 min-w-28 items-center gap-3 bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0"
                    style="background: linear-gradient(135deg,#ECFDF5,#DCFCE7);">
                    <div class="w-2 h-2 rounded-full bg-green-500" style="animation: pulse 1.5s ease-in-out infinite;">
                    </div>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-green-600">
                        <%= activeSessions %>
                    </p>
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Active</p>
                </div>
            </div>
        </div>

        <!-- ── Toolbar ── -->
        <div class="flex flex-wrap items-center justify-between gap-3 px-8 py-4 bg-gray-50 border-b border-gray-200">
            <div class="flex items-center gap-2 flex-wrap">
                <select id="statusFilter"
                    class="cursor-pointer rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 outline-none">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="done">Completed</option>
                </select>
                <select id="labFilter"
                    class="cursor-pointer rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 outline-none">
                    <option value="">All Labs</option>
                    <option value="524">Lab 524</option>
                    <option value="526">Lab 526</option>
                    <option value="528">Lab 528</option>
                    <option value="530">Lab 530</option>
                    <option value="Mac Lab">Mac Lab</option>
                </select>
            </div>
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-3.5 text-gray-400"
                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                <input type="text" id="searchInput" placeholder="Search sessions..."
                    class="rounded-xl border border-gray-300 bg-white py-2 pl-9 pr-4 text-xs text-gray-700 outline-none w-56 focus:border-gray-500">
            </div>
        </div>

        <!-- ── Table ── -->
        <div class="px-8 pb-8 pt-4">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm border-collapse">
                        <thead>
                            <tr class="bg-gray-50 border-b-2 border-gray-100">
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    #</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Student</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    ID Number</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Course</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Purpose</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Lab</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Time In</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Time Out</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Date</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Status</th>
                            </tr>
                        </thead>
                        <tbody id="historyBody" class="divide-y divide-gray-50">
                            <% if (allSessions.length> 0) { %>
                                <% allSessions.forEach(function(s, idx) { var initials=(s.first_name ? s.first_name[0]
                                    : '' ) + (s.last_name ? s.last_name[0] : '' ); %>
                                    <tr class="history-row hover:bg-gray-50 transition-colors"
                                        data-status="<%= s.status %>" data-lab="<%= s.lab_room %>">
                                        <td class="px-4 py-3 text-xs font-mono text-gray-400">#<%= s.id %>
                                        </td>
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-2.5">
                                                <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-xs font-bold"
                                                    style="background: linear-gradient(135deg,#273F4F,#5B0E14); color:#F1E194;">
                                                    <%= initials.toUpperCase() %>
                                                </div>
                                                <div class="text-xs font-semibold text-gray-800 whitespace-nowrap">
                                                    <%= s.last_name %>, <%= s.first_name %>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3">
                                            <span
                                                class="rounded-md bg-gray-100 px-2 py-1 font-mono text-xs text-gray-600">
                                                <%= s.id_number %>
                                            </span>
                                        </td>
                                        <td class="px-4 py-3">
                                            <span
                                                class="rounded-md bg-blue-50 px-2 py-1 text-xs font-bold text-blue-700">
                                                <%= s.course %>
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-xs text-gray-600 whitespace-nowrap">
                                            <%= s.purpose || '—' %>
                                        </td>
                                        <td class="px-4 py-3">
                                            <span class="rounded-md px-2 py-1 text-xs font-bold"
                                                style="background:#1C2B35; color:#F1E194;">
                                                <%= s.lab_room || '—' %>
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-xs text-gray-600 whitespace-nowrap font-mono">
                                            <%= s.time_in ? new Date(s.time_in).toLocaleTimeString('en-US',
                                                {hour:'2-digit', minute:'2-digit'}) : '—' %>
                                        </td>
                                        <td class="px-4 py-3 text-xs whitespace-nowrap font-mono">
                                            <% if (s.time_out) { %>
                                                <span class="text-gray-600">
                                                    <%= new Date(s.time_out).toLocaleTimeString('en-US',
                                                        {hour:'2-digit', minute:'2-digit'}) %>
                                                </span>
                                                <% } else { %>
                                                    <span class="text-green-600 font-medium">Still in</span>
                                                    <% } %>
                                        </td>
                                        <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">
                                            <%= s.time_in ? new Date(s.time_in).toLocaleDateString('en-US',
                                                {year:'numeric', month:'short', day:'numeric'}) : '—' %>
                                        </td>
                                        <td class="px-4 py-3">
                                            <% if (s.status==='active' ) { %>
                                                <span
                                                    class="inline-flex items-center gap-1.5 rounded-md border border-green-200 bg-green-50 px-2.5 py-1 text-xs font-bold text-green-600">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"
                                                        style="animation: pulse 1.5s infinite;"></span>
                                                    Active
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        class="inline-flex items-center gap-1.5 rounded-md border border-gray-200 bg-gray-50 px-2.5 py-1 text-xs font-bold text-gray-500">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                                                        Done
                                                    </span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="10" class="px-4 py-20 text-center">
                                                    <div class="flex flex-col items-center gap-3">
                                                        <div
                                                            class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                                fill="currentColor" class="size-7 text-gray-300">
                                                                <path fill-rule="evenodd"
                                                                    d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z"
                                                                    clip-rule="evenodd" />
                                                            </svg>
                                                        </div>
                                                        <p class="text-sm font-semibold text-gray-400">No sit-in history
                                                            found</p>
                                                        <p class="text-xs text-gray-300">Session records will appear
                                                            here once students log in.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
                <!-- Footer -->
                <div
                    class="flex items-center justify-between bg-gray-50 border-t border-gray-100 px-5 py-3 text-xs text-gray-400">
                    <span>Showing <strong id="visibleCount" class="text-gray-600">
                            <%= allSessions.length %>
                        </strong> of <strong>
                            <%= allSessions.length %>
                        </strong> records</span>
                    <span>CCS Laboratory Sit-in Monitoring System</span>
                </div>
            </div>
        </div>

</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const labFilter = document.getElementById('labFilter');
    const countEl = document.getElementById('visibleCount');

    function applyFilters() {
        const q = searchInput.value.toLowerCase();
        const status = statusFilter.value;
        const lab = labFilter.value;
        let count = 0;

        document.querySelectorAll('.history-row').forEach(row => {
            const matchQ = row.textContent.toLowerCase().includes(q);
            const matchStatus = !status || row.dataset.status === status;
            const matchLab = !lab || row.dataset.lab === lab;
            const show = matchQ && matchStatus && matchLab;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });

        countEl.textContent = count;
    }

    searchInput.addEventListener('input', applyFilters);
    statusFilter.addEventListener('change', applyFilters);
    labFilter.addEventListener('change', applyFilters);
</script>