<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@700;800&display=swap');

    .hist-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .hist-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .hist-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .hist-header::after {
        content: '';
        position: absolute;
        bottom: -50px;
        left: 15%;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(91, 14, 20, 0.15);
        pointer-events: none;
    }

    .hist-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .hist-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .hist-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .hist-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    .hist-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        background: #F0EDE8;
        flex-wrap: wrap;
    }

    .hist-stat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .hist-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .hist-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .hist-stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .hist-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 32px;
        background: #F0EDE8;
        border-bottom: 1px solid #E2DDD8;
    }

    .hist-filter-select {
        padding: 8px 14px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
    }

    .hist-filter-select:focus {
        border-color: #273F4F;
    }

    .hist-search-wrap {
        position: relative;
    }

    .hist-search-wrap svg {
        position: absolute;
        left: 11px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        pointer-events: none;
        width: 14px;
        height: 14px;
    }

    .hist-search-wrap input {
        padding: 8px 14px 8px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 200px;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .hist-search-wrap input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    .hist-table-wrap {
        padding: 0 32px 32px;
        background: #F0EDE8;
    }

    .hist-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
        border: 1px solid #E8E3DD;
    }

    table.hist-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .hist-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .hist-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .hist-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .hist-table tbody tr:last-child {
        border-bottom: none;
    }

    .hist-table tbody tr:hover {
        background: #FAF9F7;
    }

    .hist-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .badge-purpose {
        display: inline-flex;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .badge-lab {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #1C2B35;
        color: #F1E194;
        white-space: nowrap;
    }

    .badge-pc {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .pill-active {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #ECFDF5;
        color: #065F46;
        border: 1px solid #A7F3D0;
        white-space: nowrap;
    }

    .pill-done {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #F3F4F6;
        color: #6B7280;
        border: 1px solid #E5E7EB;
        white-space: nowrap;
    }

    @keyframes livePulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8)
        }
    }

    .hist-empty {
        padding: 72px 24px;
        text-align: center;
    }

    .hist-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }
</style>

<div class="hist-page">

    <!-- Header -->
    <div class="hist-header">
        <div class="hist-header-inner">
            <div>
                <p class="hist-eyebrow">Admin Panel</p>
                <h1>Student Sit-in History</h1>
                <p>Complete record of all laboratory sessions</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= sessions ? sessions.length : 0 %> total records
            </span>
        </div>
    </div>

    <% var safeSessions=(typeof sessions !=='undefined' && sessions) ? sessions : []; var
        doneSessions=safeSessions.filter(s=> s.status === 'done').length;
        var activeSessions = safeSessions.filter(s => s.status === 'active').length;
        %>

        <!-- Stats -->
        <div class="hist-stats">
            <div class="hist-stat">
                <div class="hist-stat-icon" style="background:#E8EFF4;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#273F4F" width="18" height="18">
                        <path fill-rule="evenodd"
                            d="M3 6a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm4.5 7.5a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0v-2.25a.75.75 0 0 1 .75-.75Zm3.75-1.5a.75.75 0 0 0-1.5 0v4.5a.75.75 0 0 0 1.5 0V12Zm2.25-3a.75.75 0 0 1 .75.75v6.75a.75.75 0 0 1-1.5 0V9.75A.75.75 0 0 1 13.5 9Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <div class="hist-stat-val" style="color:#273F4F;">
                        <%= safeSessions.length %>
                    </div>
                    <div class="hist-stat-label">Total</div>
                </div>
            </div>
            <div class="hist-stat">
                <div class="hist-stat-icon" style="background:#ECFDF5;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#059669" width="18" height="18">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <div class="hist-stat-val" style="color:#059669;">
                        <%= doneSessions %>
                    </div>
                    <div class="hist-stat-label">Completed</div>
                </div>
            </div>
            <div class="hist-stat">
                <div class="hist-stat-icon" style="background:#ECFDF5;">
                    <div
                        style="width:10px;height:10px;border-radius:50%;background:#10B981;animation:livePulse 1.5s ease-in-out infinite;margin:auto;">
                    </div>
                </div>
                <div>
                    <div class="hist-stat-val" style="color:#10B981;">
                        <%= activeSessions %>
                    </div>
                    <div class="hist-stat-label">Active</div>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="hist-toolbar">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                <select id="statusFilter" class="hist-filter-select">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="done">Completed</option>
                </select>
                <select id="labFilter" class="hist-filter-select">
                    <option value="">All Labs</option>
                    <option value="524">Lab 524</option>
                    <option value="526">Lab 526</option>
                    <option value="528">Lab 528</option>
                    <option value="530">Lab 530</option>
                    <option value="542">Lab 542</option>
                    <option value="544">Lab 544</option>
                </select>
            </div>
            <div class="hist-search-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                <input type="text" id="searchInput" placeholder="Search sessions...">
            </div>
        </div>

        <!-- Table -->
        <div class="hist-table-wrap">
            <div class="hist-table-card">
                <div style="overflow-x:auto;">
                    <table class="hist-table">
                        <thead>
                            <tr>
                                <th>ID Number</th>
                                <th>Student Name</th>
                                <th>Course</th>
                                <th>Purpose</th>
                                <th>Lab</th>
                                <th>PC</th>
                                <th>Time In</th>
                                <th>Time Out</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="histBody">
                            <% if (safeSessions.length> 0) { %>
                                <% safeSessions.forEach(function(s) { %>
                                    <tr class="hist-row" data-status="<%= s.status %>"
                                        data-lab="<%= s.lab_room || '' %>">

                                        <!-- ★ Fixed: use s.id_number, s.last_name, s.first_name (from JOIN) not user.xxx ★ -->
                                        <td
                                            style="font-family:monospace;font-size:12px;color:#4B5563;white-space:nowrap;">
                                            <%= s.id_number || '—' %>
                                        </td>
                                        <td style="font-size:12px;font-weight:600;color:#1C2B35;white-space:nowrap;">
                                            <%= s.last_name %>, <%= s.first_name %>
                                        </td>
                                        <td>
                                            <span
                                                style="display:inline-flex;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;">
                                                <%= s.course %>
                                            </span>
                                        </td>
                                        <td><span class="badge-purpose">
                                                <%= s.purpose || '—' %>
                                            </span></td>
                                        <td><span class="badge-lab">
                                                <%= s.lab_room || '—' %>
                                            </span></td>
                                        <td>
                                            <% if (s.computer_number) { %>
                                                <span class="badge-pc">PC-<%= String(s.computer_number).padStart(2,'0')
                                                        %></span>
                                                <% } else { %>
                                                    <span style="font-size:11px;color:#D1D5DB;">—</span>
                                                    <% } %>
                                        </td>
                                        <td
                                            style="font-size:12px;color:#4B5563;white-space:nowrap;font-variant-numeric:tabular-nums;">
                                            <%= s.time_in ? new
                                                Date(s.time_in).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
                                                : '—' %>
                                        </td>
                                        <td
                                            style="font-size:12px;white-space:nowrap;font-variant-numeric:tabular-nums;">
                                            <% if (s.time_out) { %>
                                                <span style="color:#4B5563;">
                                                    <%= new
                                                        Date(s.time_out).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
                                                        %>
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        style="display:inline-flex;align-items:center;gap:4px;color:#059669;font-weight:600;font-size:11px;">
                                                        <span
                                                            style="width:6px;height:6px;border-radius:50%;background:#10B981;animation:livePulse 1.5s ease-in-out infinite;flex-shrink:0;"></span>
                                                        Still In
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td style="font-size:12px;color:#4B5563;white-space:nowrap;">
                                            <%= s.time_in ? new
                                                Date(s.time_in).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'})
                                                : '—' %>
                                        </td>
                                        <td>
                                            <% if (s.status==='active' ) { %>
                                                <span class="pill-active">
                                                    <span
                                                        style="width:5px;height:5px;border-radius:50%;background:#10B981;animation:livePulse 1.5s ease-in-out infinite;"></span>
                                                    Active
                                                </span>
                                                <% } else { %>
                                                    <span class="pill-done">
                                                        <span
                                                            style="width:5px;height:5px;border-radius:50%;background:#9CA3AF;"></span>
                                                        Done
                                                    </span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="10">
                                                    <div class="hist-empty">
                                                        <div
                                                            style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#F3F0EC,#E8E3DD);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                                fill="#C4BDB6" width="28" height="28">
                                                                <path fill-rule="evenodd"
                                                                    d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z"
                                                                    clip-rule="evenodd" />
                                                            </svg>
                                                        </div>
                                                        <p
                                                            style="font-size:15px;font-weight:700;color:#4B5563;margin:0 0 6px;">
                                                            No sit-in history yet</p>
                                                        <p style="font-size:12px;color:#9CA3AF;margin:0;">Session
                                                            records will appear here once students sit in.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="hist-table-footer">
                    <span>Showing <strong id="visibleCount" style="color:#1C2B35;">
                            <%= safeSessions.length %>
                        </strong>
                        of <strong style="color:#1C2B35;">
                            <%= safeSessions.length %>
                        </strong> records</span>
                    <span>CCS Laboratory Sit-in Monitoring System</span>
                </div>
            </div>
        </div>

</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const labFilter = document.getElementById('labFilter');
    const countEl = document.getElementById('visibleCount');

    function applyFilters() {
        const q = searchInput.value.toLowerCase();
        const status = statusFilter.value;
        const lab = labFilter.value;
        let count = 0;
        document.querySelectorAll('.hist-row').forEach(row => {
            const matchQ = !q || row.textContent.toLowerCase().includes(q);
            const matchStatus = !status || row.dataset.status === status;
            const matchLab = !lab || row.dataset.lab === lab;
            const show = matchQ && matchStatus && matchLab;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        countEl.textContent = count;
    }

    searchInput.addEventListener('input', applyFilters);
    statusFilter.addEventListener('change', applyFilters);
    labFilter.addEventListener('change', applyFilters);
</script>