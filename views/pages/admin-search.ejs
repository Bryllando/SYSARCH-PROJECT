<div class="p-6">

    <!-- Search Card — matches Image 1 layout -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 max-w-lg mb-8">

        <!-- Card Title row -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <h2 class="font-bold text-[#273F4F] text-base">Search Student</h2>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                class="size-5 text-gray-300">
                <path fill-rule="evenodd"
                    d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                    clip-rule="evenodd" />
            </svg>
        </div>

        <!-- Search input centered -->
        <form method="GET" action="/admin/search" class="px-5 pt-5 pb-4 flex flex-col gap-4">
            <input type="text" name="q" value="<%= query %>" placeholder="Search..."
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#273F4F] focus:outline-none transition-all">

            <!-- Search button bottom-right -->
            <div class="flex justify-end">
                <button type="submit"
                    class="px-5 py-2 rounded-lg text-sm font-bold text-white cursor-pointer transition-all hover:-translate-y-0.5"
                    style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
                    Search
                </button>
            </div>
        </form>
    </div>

    <!-- Results Table — only shows after searching -->
    <% if (query) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between flex-wrap gap-3">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                    <span class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Search Results</span>
                </div>
                <span class="text-xs text-gray-400">
                    <strong class="text-gray-600">
                        <%= students.length %>
                    </strong>
                    result<%= students.length !==1 ? 's' : '' %> for
                        "<strong class="text-[#273F4F]">
                            <%= query %>
                        </strong>"
                </span>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100">
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">ID
                                Number</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Name</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Course</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Year</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Email</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Sessions Left</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% if (students && students.length> 0) { %>
                            <% students.forEach(function(s) { %>
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-4 py-3 font-mono text-xs text-gray-600">
                                        <%= s.id_number %>
                                    </td>
                                    <td class="px-4 py-3 font-semibold text-gray-700">
                                        <%= s.last_name %>, <%= s.first_name %>
                                                <%= s.middle_initial ? s.middle_initial + '.' : '' %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                                            <%= s.course %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-gray-600 text-center">
                                        <%= s.year_level %>
                                    </td>
                                    <td class="px-4 py-3 text-gray-500 text-xs">
                                        <%= s.email %>
                                    </td>
                                    <td class="px-4 py-3 text-center font-bold text-[#5B0E14]">
                                        <%= s.remaining_sessions ?? 30 %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2">
                                            <a href="/admin/students/<%= s.id %>"
                                                class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold text-white transition-all hover:-translate-y-0.5"
                                                style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                    fill="currentColor" class="size-3">
                                                    <path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" />
                                                    <path fill-rule="evenodd"
                                                        d="M1.38 8.28a.87.87 0 0 1 0-.566 7.003 7.003 0 0 1 13.239.005.87.87 0 0 1 0 .566A7.003 7.003 0 0 1 1.379 8.28ZM11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                                                        clip-rule="evenodd" />
                                                </svg>
                                                View
                                            </a>
                                            <button
                                                onclick="openSitinModal('<%= s.id %>', '<%= s.id_number %>', '<%= s.last_name %>, <%= s.first_name %><%= s.middle_initial ? " " + s.middle_initial + "
                                                ." : "" %>', '<%= s.remaining_sessions ?? 30 %>')"
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs
                                                    font-bold text-white transition-all hover:-translate-y-0.5
                                                    cursor-pointer"
                                                    style="background: linear-gradient(135deg, #5B0E14, #3A0910);">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                        fill="currentColor" class="size-3">
                                                        <path
                                                            d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                                    </svg>
                                                    Sit-in
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="px-4 py-16 text-center">
                                                <div class="flex flex-col items-center gap-3">
                                                    <div
                                                        class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                            fill="currentColor" class="size-7 text-gray-300">
                                                            <path fill-rule="evenodd"
                                                                d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z"
                                                                clip-rule="evenodd" />
                                                        </svg>
                                                    </div>
                                                    <p class="text-sm text-gray-400 font-medium">No students found for "
                                                        <%= query %>"
                                                    </p>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

</div>

<!-- ===== SIT-IN FORM MODAL — matches Image 2 layout (label left, value right) ===== -->
<div id="sitinModal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeSitinModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 overflow-hidden">

        <!-- Modal Header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-base">Sit In Form</h3>
            <button onclick="closeSitinModal()"
                class="w-7 h-7 flex items-center justify-center rounded border border-gray-300 text-gray-500 hover:text-gray-700 hover:border-gray-400 transition-colors cursor-pointer text-xs">
                ✕
            </button>
        </div>

        <!-- Form Body — label left, value/input right (Image 2 style) -->
        <form action="/admin/sitin/start" method="POST" class="px-5 py-4 space-y-3">
            <input type="hidden" name="user_id" id="sitinUserId">

            <!-- ID Number -->
            <div class="flex items-center gap-3">
                <label class="w-36 text-sm text-gray-600 text-right shrink-0">ID Number:</label>
                <p id="sitinIdNumber"
                    class="flex-1 px-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 font-medium min-h-8.5">
                </p>
            </div>

            <!-- Student Name -->
            <div class="flex items-center gap-3">
                <label class="w-36 text-sm text-gray-600 text-right shrink-0">Student Name:</label>
                <p id="sitinName"
                    class="flex-1 px-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 font-medium min-h-8.5">
                </p>
            </div>

            <!-- Purpose -->
            <div class="flex items-center gap-3">
                <label class="w-36 text-sm text-gray-600 text-right shrink-0">Purpose:</label>
                <div class="flex-1 relative">
                    <select name="purpose" required
                        class="w-full px-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 appearance-none focus:ring-2 focus:ring-[#273F4F] outline-none">
                        <option value="" disabled selected>Select...</option>
                        <option>C Programming</option>
                        <option>Java Programming</option>
                        <option>C# Programming</option>
                        <option>ASP.Net</option>
                        <option>PHP Programming</option>
                        <option>Database</option>
                        <option>Research</option>
                        <option>Other</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                            stroke="currentColor" class="size-3.5 text-gray-400">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Lab -->
            <div class="flex items-center gap-3">
                <label class="w-36 text-sm text-gray-600 text-right shrink-0">Lab:</label>
                <div class="flex-1 relative">
                    <select name="lab_room" required
                        class="w-full px-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 appearance-none focus:ring-2 focus:ring-[#273F4F] outline-none">
                        <option value="" disabled selected>Select...</option>
                        <option value="524">Lab 524</option>
                        <option value="526">Lab 526</option>
                        <option value="528">Lab 528</option>
                        <option value="530">Lab 530</option>
                        <option value="Mac Lab">Mac Lab</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                            stroke="currentColor" class="size-3.5 text-gray-400">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Remaining Sessions -->
            <div class="flex items-center gap-3">
                <label class="w-36 text-sm text-gray-600 text-right shrink-0">Remaining Session:</label>
                <p id="sitinSessions"
                    class="flex-1 px-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 font-medium min-h-8.5">
                </p>
            </div>

            <!-- Buttons — Close left, Sit In right (Image 2 style) -->
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="closeSitinModal()"
                    class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors cursor-pointer">
                    Close
                </button>
                <button type="submit"
                    class="px-4 py-2 rounded-lg text-sm font-semibold text-white transition-all hover:-translate-y-0.5 cursor-pointer"
                    style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
                    Sit In
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openSitinModal(id, idNumber, name, sessions) {
        document.getElementById('sitinUserId').value = id;
        document.getElementById('sitinIdNumber').textContent = idNumber;
        document.getElementById('sitinName').textContent = name;
        document.getElementById('sitinSessions').textContent = sessions + ' sessions left';
        document.getElementById('sitinModal').classList.remove('hidden');
        document.getElementById('sitinModal').classList.add('flex');
    }
    function closeSitinModal() {
        document.getElementById('sitinModal').classList.add('hidden');
        document.getElementById('sitinModal').classList.remove('flex');
    }
</script>