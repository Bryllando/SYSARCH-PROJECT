<div class="p-6 flex flex-col items-center">

    <!-- Search Card — small, centered, matches screenshot exactly -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 w-full max-w-sm mb-8">

        <!-- Title row -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <h2 class="font-bold text-gray-800 text-base">Search Student</h2>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                class="size-5 text-gray-300">
                <path fill-rule="evenodd"
                    d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                    clip-rule="evenodd" />
            </svg>
        </div>

        <!-- Search form body -->
        <form method="GET" action="/admin/search" class="px-5 pt-5 pb-4 flex flex-col gap-4">
            <input type="text" name="q" value="<%= query %>" placeholder="Search..." class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm
                       focus:ring-2 focus:ring-[#273F4F] focus:outline-none transition-all">
            <!-- Search button bottom-right -->
            <div class="flex justify-end">
                <button type="submit"
                    class="px-5 py-2 rounded-lg text-sm font-bold text-white cursor-pointer transition-all hover:-translate-y-0.5"
                    style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
                    Search
                </button>
            </div>
        </form>
    </div>

    <!-- Results Table — full width, only shown after searching -->
    <% if (query) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden w-full">

            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between flex-wrap gap-3">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                    <span class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Search Results</span>
                </div>
                <span class="text-xs text-gray-400">
                    <strong class="text-gray-600">
                        <%= students.length %>
                    </strong>
                    result<%= students.length !==1 ? 's' : '' %> for
                        "<strong class="text-[#273F4F]">
                            <%= query %>
                        </strong>"
                </span>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100">
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">ID
                                Number</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Name</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Course</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Year</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Email</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Sessions Left</th>
                            <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                                Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% if (students && students.length> 0) { %>
                            <% students.forEach(function(s) { %>
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-4 py-3 font-mono text-xs text-gray-600">
                                        <%= s.id_number %>
                                    </td>
                                    <td class="px-4 py-3 font-semibold text-gray-700">
                                        <%= s.last_name %>, <%= s.first_name %>
                                                <%= s.middle_initial ? s.middle_initial + '.' : '' %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                                            <%= s.course %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-gray-600 text-center">
                                        <%= s.year_level %>
                                    </td>
                                    <td class="px-4 py-3 text-gray-500 text-xs">
                                        <%= s.email %>
                                    </td>
                                    <td class="px-4 py-3 text-center font-bold text-[#5B0E14]">
                                        <%= s.remaining_sessions ?? 30 %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2">
                                            <a href="/admin/students/<%= s.id %>"
                                                class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold text-white transition-all hover:-translate-y-0.5"
                                                style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                    fill="currentColor" class="size-3">
                                                    <path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" />
                                                    <path fill-rule="evenodd"
                                                        d="M1.38 8.28a.87.87 0 0 1 0-.566 7.003 7.003 0 0 1 13.239.005.87.87 0 0 1 0 .566A7.003 7.003 0 0 1 1.379 8.28ZM11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                                                        clip-rule="evenodd" />
                                                </svg>
                                                View
                                            </a>
                                            <button
                                                onclick="openSitinModal('<%= s.id %>', '<%= s.id_number %>', '<%= s.last_name %>, <%= s.first_name %><%= s.middle_initial ? " " + s.middle_initial + "
                                                ." : "" %>', '<%= s.remaining_sessions ?? 30 %>')"
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs
                                                    font-bold text-white transition-all hover:-translate-y-0.5
                                                    cursor-pointer"
                                                    style="background: linear-gradient(135deg, #5B0E14, #3A0910);">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                        fill="currentColor" class="size-3">
                                                        <path
                                                            d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                                    </svg>
                                                    Sit-in
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="px-4 py-16 text-center">
                                                <div class="flex flex-col items-center gap-3">
                                                    <div
                                                        class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                            fill="currentColor" class="size-7 text-gray-300">
                                                            <path fill-rule="evenodd"
                                                                d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z"
                                                                clip-rule="evenodd" />
                                                        </svg>
                                                    </div>
                                                    <p class="text-sm text-gray-400 font-medium">No students found for "
                                                        <%= query %>"
                                                    </p>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

</div>

<!-- ===== SIT-IN FORM MODAL — small centered card matching screenshot ===== -->
<div id="sitinModal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeSitinModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 overflow-hidden">

        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-base">Sit In Form</h3>
            <button onclick="closeSitinModal()"
                class="w-7 h-7 flex items-center justify-center rounded border border-gray-300 text-gray-500 hover:text-gray-700 hover:border-gray-400 transition-colors cursor-pointer text-xs font-bold">
                ✕
            </button>
        </div>

        <!-- Form — label left, value right (matches screenshot) -->
        <form id="sitinForm" action="/admin/sitin/start" method="POST">
            <input type="hidden" name="return_to" value="/admin">
            <input type="hidden" name="user_id" id="sitinUserId">
            <input type="hidden" name="computer_number" id="sitinComputerNumber" value="">

            <!-- Student info strip -->
            <div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid #F3F0EC;">
                <div style="padding:14px 20px;border-right:1px solid #F3F0EC;">
                    <div
                        style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;">
                        ID Number</div>
                    <div id="sitinIdNumber" style="font-size:14px;font-weight:700;color:#1C2B35;font-family:monospace;">
                    </div>
                </div>
                <div style="padding:14px 20px;background:#FFF9F0;">
                    <div
                        style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;">
                        Sessions Left</div>
                    <div id="sitinSessions" style="font-size:14px;font-weight:800;color:#5B0E14;"></div>
                </div>
                <div style="padding:14px 20px;grid-column:span 2;border-top:1px solid #F3F0EC;">
                    <div
                        style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;">
                        Student Name</div>
                    <div id="sitinName" style="font-size:14px;font-weight:700;color:#1C2B35;"></div>
                </div>
            </div>


            <!-- Purpose + Lab -->
            <div style="padding:16px 20px 0;display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                <div>
                    <label
                        style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6B7280;margin-bottom:6px;">Purpose
                        *</label>
                    <div style="position:relative;">
                        <select name="purpose" required id="sitinPurpose"
                            style="width:100%;padding:10px 32px 10px 12px;border:1.5px solid #D6D0CA;border-radius:9px;background:#F9F8F6;font-size:13px;appearance:none;outline:none;cursor:pointer;">
                            <option value="" disabled selected>Select...</option>
                            <option>C Programming</option>
                            <option>Java Programming</option>
                            <option>C# Programming</option>
                            <option>ASP.Net</option>
                            <option>PHP Programming</option>
                            <option>Database</option>
                            <option>Research</option>
                            <option>Other</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label
                        style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6B7280;margin-bottom:6px;">Laboratory
                        *</label>
                    <div style="position:relative;">
                        <select name="lab_room" required id="sitinLabRoom"
                            style="width:100%;padding:10px 32px 10px 12px;border:1.5px solid #D6D0CA;border-radius:9px;background:#F9F8F6;font-size:13px;appearance:none;outline:none;cursor:pointer;"
                            onchange="loadSitinPcGrid(this.value)">
                            <option value="" disabled selected>Select...</option>
                            <option value="524">Lab 524</option>
                            <option value="526">Lab 526</option>
                            <option value="528">Lab 528</option>
                            <option value="530">Lab 530 - Multimedia Lab</option>
                            <option value="542">Lab 542 - It Laboratory</option>
                            <option value="544">Lab 544 - Mac Laboratory</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- PC Grid (shown after lab is selected) -->
            <div id="sitinPcSection" style="display:none;padding:0 20px 12px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                    <label
                        style="font-size:10px;font-weight:700;text-transform:uppercase;color:#6B7280;letter-spacing:0.08em;">
                        Select PC <span
                            style="color:#9CA3AF;text-transform:none;font-weight:400;font-size:10px;">(optional)</span>
                    </label>
                    <span style="font-size:11px;color:#9CA3AF;" id="sitinSelectedPcLabel">None selected</span>
                </div>
                <div id="sitinPcGrid"
                    style="background:#F9F8F6;border:1.5px solid #E2DDD8;border-radius:12px;padding:12px;max-height:200px;overflow-y:auto;">
                    <div style="text-align:center;color:#9CA3AF;font-size:12px;padding:16px;">Select a lab to load PCs
                    </div>
                </div>
                <!-- Legend -->
                <div style="display:flex;gap:12px;margin-top:8px;flex-wrap:wrap;">
                    <span style="display:flex;align-items:center;gap:5px;font-size:10px;font-weight:600;color:#4B5563;">
                        <span
                            style="width:8px;height:8px;border-radius:50%;background:#10B981;border:1.5px solid #A7F3D0;"></span>Available
                    </span>
                    <span style="display:flex;align-items:center;gap:5px;font-size:10px;font-weight:600;color:#4B5563;">
                        <span
                            style="width:8px;height:8px;border-radius:50%;background:#F59E0B;border:1.5px solid #FDE68A;"></span>In
                        Use
                    </span>
                    <span style="display:flex;align-items:center;gap:5px;font-size:10px;font-weight:600;color:#4B5563;">
                        <span
                            style="width:8px;height:8px;border-radius:50%;background:#DC2626;border:1.5px solid #FECACA;"></span>Defective
                    </span>
                </div>
            </div>

            <div style="display:flex;gap:10px;padding:0 20px 18px;">
                <button type="button" onclick="closeSitinModal()"
                    style="flex:1;padding:10px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Cancel</button>
                <button type="submit"
                    style="flex:2;padding:10px;background:linear-gradient(135deg,#5B0E14,#7a131b);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">
                    Confirm Sit-in
                </button>
            </div>
        </form>

    </div>
</div>

<script>
    function openSitinModal(id, idNumber, name, sessions) {
        document.getElementById('sitinUserId').value = id;
        document.getElementById('sitinIdNumber').textContent = idNumber;
        document.getElementById('sitinName').textContent = name;
        document.getElementById('sitinSessions').textContent = sessions + ' sessions left';
        document.getElementById('sitinModal').classList.remove('hidden');
        document.getElementById('sitinModal').classList.add('flex');
    }
    function closeSitinModal() {
        document.getElementById('sitinModal').classList.add('hidden');
        document.getElementById('sitinModal').classList.remove('flex');
    }
</script>