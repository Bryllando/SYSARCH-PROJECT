<div class="p-6">

    <div class="mb-6">
        <h1 class="text-2xl font-extrabold text-[#273F4F]">Search Students</h1>
        <p class="text-gray-500 text-sm mt-1">Find a student by ID number, first name, or last name.</p>
    </div>

    <!-- Search Bar -->
    <form method="GET" action="/admin/search" class="mb-6 flex gap-3">
        <div class="relative flex-1 max-w-md">
            <input type="text" name="q" value="<%= query %>" placeholder="Search by ID, first name, or last name..."
                class="w-full pl-10 pr-4 py-2.5 bg-white border border-gray-300 rounded-xl text-sm
                       focus:ring-2 focus:ring-[#273F4F] focus:outline-none transition-all shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                class="size-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none">
                <path fill-rule="evenodd"
                    d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                    clip-rule="evenodd" />
            </svg>
        </div>
        <button type="submit" class="px-5 py-2.5 rounded-xl text-sm font-bold text-white shadow-sm transition-all
                   hover:-translate-y-0.5 cursor-pointer"
            style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
            Search
        </button>
    </form>

    <!-- Results Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between flex-wrap gap-3">
            <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                <span class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Search Results</span>
            </div>
            <% if (query) { %>
                <span class="text-xs text-gray-400">
                    <strong class="text-gray-600">
                        <%= students.length %>
                    </strong>
                    result<%= students.length !==1 ? 's' : '' %> for
                        "<strong class="text-[#273F4F]">
                            <%= query %>
                        </strong>"
                </span>
                <% } %>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-100">
                        <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">ID
                            Number</th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">Name
                        </th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">Course
                        </th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">Year
                        </th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">Email
                        </th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                            Sessions Left</th>
                        <th class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider">
                            Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">

                    <% if (students && students.length> 0) { %>
                        <% students.forEach(function(s) { %>
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-4 py-3 font-mono text-xs text-gray-600">
                                    <%= s.id_number %>
                                </td>
                                <td class="px-4 py-3 font-semibold text-gray-700">
                                    <%= s.last_name %>, <%= s.first_name %>
                                            <%= s.middle_initial ? s.middle_initial + '.' : '' %>
                                </td>
                                <td class="px-4 py-3">
                                    <span
                                        class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-blue-50 text-blue-700">
                                        <%= s.course %>
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-gray-600 text-center">
                                    <%= s.year_level %>
                                </td>
                                <td class="px-4 py-3 text-gray-500 text-xs">
                                    <%= s.email %>
                                </td>
                                <td class="px-4 py-3 text-center font-bold text-[#5B0E14]">
                                    <%= s.remaining_sessions ?? 30 %>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center gap-2">
                                        <a href="/admin/students/<%= s.id %>" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold
                                               text-white transition-all hover:-translate-y-0.5"
                                            style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                fill="currentColor" class="size-3">
                                                <path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" />
                                                <path fill-rule="evenodd"
                                                    d="M1.38 8.28a.87.87 0 0 1 0-.566 7.003 7.003 0 0 1 13.239.005.87.87 0 0 1 0 .566A7.003 7.003 0 0 1 1.379 8.28ZM11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                                                    clip-rule="evenodd" />
                                            </svg>
                                            View
                                        </a>
                                        <button
                                            onclick="openSitinModal(
                                            '<%= s.id %>',
                                            '<%= s.id_number %>',
                                            '<%= s.last_name %>, <%= s.first_name %><%= s.middle_initial ? " " + s.middle_initial + "
                                            ." : "" %>',
                                            '<%= s.remaining_sessions ?? 30 %>'
                                                )"
                                                class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs
                                                font-bold
                                                text-white transition-all hover:-translate-y-0.5 cursor-pointer"
                                                style="background: linear-gradient(135deg, #5B0E14, #3A0910);">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                    fill="currentColor" class="size-3">
                                                    <path
                                                        d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                                </svg>
                                                Sit-in
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="px-4 py-16 text-center">
                                            <div class="flex flex-col items-center gap-3">
                                                <div
                                                    class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                        fill="currentColor" class="size-7 text-gray-300">
                                                        <path fill-rule="evenodd"
                                                            d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z"
                                                            clip-rule="evenodd" />
                                                    </svg>
                                                </div>
                                                <p class="text-sm text-gray-400 font-medium">
                                                    <% if (query) { %>No students found for "<%= query %>"<% } else { %>
                                                                Enter a search term above<% } %>
                                                </p>
                                            </div>
                                        </td>
                                    </tr>
                                    <% } %>

                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ===== SIT-IN FORM MODAL ===== -->
<div id="sitinModal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeSitinModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between"
            style="background: linear-gradient(135deg, #5B0E14, #3A0910);">
            <h3 class="font-bold text-white flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
                    <path fill-rule="evenodd"
                        d="M4.5 2A1.5 1.5 0 0 0 3 3.5v13A1.5 1.5 0 0 0 4.5 18h11a1.5 1.5 0 0 0 1.5-1.5V7.621a1.5 1.5 0 0 0-.44-1.06l-4.12-4.122A1.5 1.5 0 0 0 11.378 2H4.5Zm2.25 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Zm0 3a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z"
                        clip-rule="evenodd" />
                </svg>
                Sit In Form
            </h3>
            <button onclick="closeSitinModal()" class="text-white/60 hover:text-white transition-colors cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
                    <path
                        d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
                </svg>
            </button>
        </div>
        <form action="/admin/sitin/start" method="POST" class="p-6 space-y-4">
            <input type="hidden" name="user_id" id="sitinUserId">

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider">ID Number</label>
                    <p id="sitinIdNumber"
                        class="text-sm font-semibold text-gray-700 p-2.5 bg-gray-50 rounded-xl border border-gray-200">
                    </p>
                </div>
                <div class="space-y-1">
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider">Sessions Left</label>
                    <p id="sitinSessions"
                        class="text-sm font-bold text-[#5B0E14] p-2.5 bg-red-50 rounded-xl border border-red-100"></p>
                </div>
            </div>

            <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider">Student Name</label>
                <p id="sitinName"
                    class="text-sm font-semibold text-gray-700 p-2.5 bg-gray-50 rounded-xl border border-gray-200"></p>
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700 ml-1">Purpose</label>
                <div class="relative">
                    <select name="purpose" required class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2
                               focus:ring-[#273F4F] outline-none appearance-none text-sm">
                        <option value="" disabled selected>Select Purpose</option>
                        <option>C Programming</option>
                        <option>Java Programming</option>
                        <option>C# Programming</option>
                        <option>ASP.Net</option>
                        <option>PHP Programming</option>
                        <option>Database</option>
                        <option>Research</option>
                        <option>Other</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                            stroke="currentColor" class="size-4 text-gray-400">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700 ml-1">Laboratory</label>
                <div class="relative">
                    <select name="lab_room" required class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2
                               focus:ring-[#273F4F] outline-none appearance-none text-sm">
                        <option value="" disabled selected>Select Lab Room</option>
                        <option value="524">Lab 524</option>
                        <option value="526">Lab 526</option>
                        <option value="528">Lab 528</option>
                        <option value="530">Lab 530</option>
                        <option value="Mac Lab">Mac Lab</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                            stroke="currentColor" class="size-4 text-gray-400">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="flex gap-3 pt-1">
                <button type="submit" class="btn-maroon flex-1 py-3 text-base cursor-pointer">Sit In</button>
                <button type="button" onclick="closeSitinModal()"
                    class="btn-dark flex-1 py-3 text-base cursor-pointer">Close</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openSitinModal(id, idNumber, name, sessions) {
        document.getElementById('sitinUserId').value = id;
        document.getElementById('sitinIdNumber').textContent = idNumber;
        document.getElementById('sitinName').textContent = name;
        document.getElementById('sitinSessions').textContent = sessions + ' sessions left';
        document.getElementById('sitinModal').classList.remove('hidden');
        document.getElementById('sitinModal').classList.add('flex');
    }
    function closeSitinModal() {
        document.getElementById('sitinModal').classList.add('hidden');
        document.getElementById('sitinModal').classList.remove('flex');
    }
</script>