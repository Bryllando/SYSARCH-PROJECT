            <div>
                <div class="labres-stat-val" style="color:#059669;" id="stat-avail">—</div>
                <div class="labres-stat-label">Available PCs</div>
            </div>
        </div>
        <div class="labres-stat">
            <div class="labres-stat-icon" style="background:#FFF7ED;">
                <div style="width:12px;height:12px;border-radius:50%;background:#F59E0B;"></div>
            </div>
            <div>
                <div class="labres-stat-val" style="color:#D97706;" id="stat-inuse">—</div>
                <div class="labres-stat-label">In Use</div>
            </div>
        </div>
        <div class="labres-stat">
            <div class="labres-stat-icon" style="background:#EFF6FF;">
                <div style="width:12px;height:12px;border-radius:50%;background:#3B82F6;"></div>
            </div>
            <div>
                <div class="labres-stat-val" style="color:#1D4ED8;" id="stat-reserved">—</div>
                <div class="labres-stat-label">Reserved</div>
            </div>
