<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .labres-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    /* ── Header ── */
    .labres-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .labres-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .labres-header::after {
        content: '';
        position: absolute;
        bottom: -50px;
        left: 15%;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(91, 14, 20, 0.15);
        pointer-events: none;
    }

    .labres-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .labres-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .labres-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .labres-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    /* ── Stats ── */
    .labres-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        flex-wrap: wrap;
        background: #F0EDE8;
    }

    .labres-stat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .labres-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .labres-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .labres-stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* ── Lab Grid ── */
    .labres-grid-section {
        padding: 0 32px 32px;
    }

    .labres-grid-title {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 16px 0 12px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
    }

    .labres-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 16px;
    }

    .lab-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #E8E3DD;
        padding: 20px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
        position: relative;
        overflow: hidden;
    }

    .lab-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        border-radius: 16px 0 0 16px;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
    }

    .lab-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(39, 63, 79, 0.13);
        border-color: #5B0E14;
    }

    .lab-card:active {
        transform: translateY(-1px);
    }

    .lab-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
    }

    .lab-card-name {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 2px;
    }

    .lab-card-desc {
        font-size: 11px;
        color: #9CA3AF;
        margin: 0 0 14px;
    }

    .lab-card-pills {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .lab-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 9px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 700;
        border: 1px solid;
    }

    .lab-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .pill-avail {
        background: #ECFDF5;
        color: #065F46;
        border-color: #A7F3D0;
    }

    .pill-avail .lab-pill-dot {
        background: #10B981;
    }

    .pill-inuse {
        background: #FFF7ED;
        color: #92400E;
        border-color: #FDE68A;
    }

    .pill-inuse .lab-pill-dot {
        background: #F59E0B;
        animation: pulse 1.5s infinite;
    }

    .pill-defect {
        background: #FEF2F2;
        color: #991B1B;
        border-color: #FECACA;
    }

    .pill-defect .lab-pill-dot {
        background: #DC2626;
    }

    .lab-card-arrow {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 28px;
        height: 28px;
        background: #F3F0EC;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s;
    }

    .lab-card:hover .lab-card-arrow {
        background: #5B0E14;
    }

    .lab-card:hover .lab-card-arrow svg {
        color: #F1E194;
    }

    @keyframes pulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8);
        }
    }

    /* ── PC Grid Modal ── */
    .pcmodal-overlay {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .pcmodal-overlay.open {
        display: flex;
    }

    .pcmodal-overlay.open .pcmodal-card {
        animation: pcModalIn 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes pcModalIn {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(20px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .pcmodal-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 860px;
        max-height: 90vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        font-family: 'DM Sans', sans-serif;
    }

    .pcmodal-header {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

    .pcmodal-header-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .pcmodal-header-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: rgba(241, 225, 148, 0.15);
        border: 1px solid rgba(241, 225, 148, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pcmodal-header-title {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 2px;
    }

    .pcmodal-header-sub {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .pcmodal-close {
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 9px;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.15s;
    }

    .pcmodal-close:hover {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
    }

    /* Legend */
    .pcmodal-legend {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 24px;
        background: #F7F5F2;
        border-bottom: 1px solid #E8E3DD;
        flex-wrap: wrap;
    }

    .pcmodal-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #4B5563;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid;
    }

    /* PC Layout */
    .pcmodal-body {
        padding: 20px 24px;
        overflow-y: auto;
        flex: 1;
    }

    .pc-teacher-area {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        border-radius: 10px;
        padding: 10px 16px;
        text-align: center;
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .pc-row-label {
        font-size: 10px;
        font-weight: 700;
        color: #C4BDB6;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 14px 0 8px;
    }

    .pc-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
        margin-bottom: 4px;
    }

    .pc-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        cursor: pointer;
        padding: 10px 6px;
        border-radius: 12px;
        border: 2px solid transparent;
        transition: all 0.18s;
        position: relative;
    }

    .pc-unit:hover:not(.pc-inuse):not(.pc-defect) {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
        transform: translateY(-2px);
    }

    .pc-unit.selected {
        border-color: #5B0E14 !important;
        background: rgba(91, 14, 20, 0.1) !important;
    }

    .pc-unit.pc-inuse {
        cursor: not-allowed;
        opacity: 0.75;
    }

    .pc-unit.pc-defect {
        cursor: not-allowed;
        opacity: 0.55;
    }

    .pc-unit.pc-reserved {
        cursor: not-allowed;
    }

    .pc-icon-wrap {
        width: 52px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border: 2px solid;
    }

    .pc-avail .pc-icon-wrap {
        background: #ECFDF5;
        border-color: #A7F3D0;
    }

    .pc-inuse .pc-icon-wrap {
        background: #FFF7ED;
        border-color: #FDE68A;
    }

    .pc-defect .pc-icon-wrap {
        background: #FEF2F2;
        border-color: #FECACA;
    }

    .pc-reserved .pc-icon-wrap {
        background: #EFF6FF;
        border-color: #BFDBFE;
    }

    .pc-status-dot {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    .pc-avail .pc-status-dot {
        background: #10B981;
    }

    .pc-inuse .pc-status-dot {
        background: #F59E0B;
        animation: pulse 1.5s infinite;
    }

    .pc-defect .pc-status-dot {
        background: #DC2626;
    }

    .pc-reserved .pc-status-dot {
        background: #3B82F6;
    }

    .pc-number {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .pc-avail .pc-number {
        color: #065F46;
    }

    .pc-inuse .pc-number {
        color: #92400E;
    }

    .pc-defect .pc-number {
        color: #991B1B;
    }

    .pc-reserved .pc-number {
        color: #1D4ED8;
    }

    .pc-label {
        font-size: 9px;
        font-weight: 600;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    /* Admin status badge on PC */
    .pc-admin-tag {
        position: absolute;
        top: -6px;
        left: 50%;
        transform: translateX(-50%);
        background: #5B0E14;
        color: #F1E194;
        font-size: 8px;
        font-weight: 800;
        padding: 1px 5px;
        border-radius: 999px;
        white-space: nowrap;
        letter-spacing: 0.05em;
        z-index: 2;
    }

    /* Footer */
    .pcmodal-footer {
        padding: 14px 24px;
        border-top: 1px solid #E8E3DD;
        background: #FAFAF9;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        flex-shrink: 0;
    }

    .pcmodal-footer-info {
        font-size: 12px;
        color: #9CA3AF;
    }

    .pcmodal-footer-info strong {
        color: #1C2B35;
    }

    .btn-reserve {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s, transform 0.1s;
    }

    .btn-reserve:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .btn-reserve:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
    }

    /* ── Reserve Form Modal ── */
    .resform-overlay {
        position: fixed;
        inset: 0;
        z-index: 300;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .resform-overlay.open {
        display: flex;
    }

    .resform-overlay.open .resform-card {
        animation: pcModalIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .resform-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.3);
        width: 100%;
        max-width: 480px;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
    }

    .resform-header {
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        padding: 18px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .resform-title {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: #fff;
    }

    .resform-close {
        width: 30px;
        height: 30px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 8px;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        transition: all 0.15s;
    }

    .resform-close:hover {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
    }

    .resform-pc-badge {
        margin: 0;
        padding: 14px 24px;
        background: linear-gradient(135deg, #F9F8F6, #F0EDE8);
        border-bottom: 1px solid #E8E3DD;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .resform-pc-icon {
        width: 42px;
        height: 36px;
        border-radius: 9px;
        background: #ECFDF5;
        border: 2px solid #A7F3D0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .resform-pc-info {
        font-size: 13px;
    }

    .resform-pc-num {
        font-weight: 800;
        color: #1C2B35;
    }

    .resform-pc-lab {
        font-size: 11px;
        color: #6B7280;
    }

    .resform-body {
        padding: 20px 24px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .resform-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .resform-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6B7280;
    }

    .resform-input {
        width: 100%;
        padding: 10px 13px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #F9F8F6;
        font-size: 13px;
        color: #1C2B35;
        outline: none;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
    }

    .resform-input:focus {
        border-color: #5B0E14;
        box-shadow: 0 0 0 3px rgba(91, 14, 20, 0.08);
        background: #fff;
    }

    .resform-select {
        appearance: none;
        cursor: pointer;
    }

    .select-wrap {
        position: relative;
    }

    .select-wrap svg {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: #9CA3AF;
    }

    .resform-time-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 8px;
        align-items: center;
    }

    .resform-time-sep {
        font-size: 12px;
        color: #9CA3AF;
        font-weight: 600;
        text-align: center;
    }

    .resform-note {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 10px 12px;
        background: #FFF7ED;
        border: 1px solid #FDE68A;
        border-radius: 9px;
        font-size: 11px;
        color: #92400E;
    }

    .resform-footer {
        display: flex;
        gap: 10px;
        padding: 0 24px 22px;
    }

    .btn-rescancel {
        flex: 1;
        padding: 11px;
        background: #F3F0EC;
        color: #374151;
        border: 1.5px solid #E8E3DD;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background 0.15s;
    }

    .btn-rescancel:hover {
        background: #E8E3DD;
    }

    .btn-ressubmit {
        flex: 2;
        padding: 11px;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s, transform 0.1s;
    }

    .btn-ressubmit:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    /* ── Admin: PC Context Menu ── */
    .pc-ctx-menu {
        position: fixed;
        z-index: 400;
        background: #fff;
        border: 1px solid #E8E3DD;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
        padding: 6px;
        min-width: 180px;
        display: none;
        animation: ctxIn 0.15s ease;
        font-family: 'DM Sans', sans-serif;
    }

    .pc-ctx-menu.open {
        display: block;
    }

    @keyframes ctxIn {
        from {
            opacity: 0;
            transform: scale(0.92) translateY(-4px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .ctx-item {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 9px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        color: #374151;
        transition: background 0.12s;
    }

    .ctx-item:hover {
        background: #F7F5F2;
    }

    .ctx-item.danger {
        color: #DC2626;
    }

    .ctx-item.danger:hover {
        background: #FEF2F2;
    }

    .ctx-item.success {
        color: #059669;
    }

    .ctx-item.success:hover {
        background: #ECFDF5;
    }

    .ctx-sep {
        height: 1px;
        background: #F3F0EC;
        margin: 4px 0;
    }

    /* ── Reservations list (bottom) ── */
    .labres-reservations-section {
        padding: 0 32px 40px;
    }
</style>

<div class="labres-page">

    <!-- Header -->
    <div class="labres-header">
        <div class="labres-header-inner">
            <div>
                <p class="labres-eyebrow">
                    <% if (typeof user !=='undefined' && user.role==='admin' ) { %>Admin Panel<% } else { %>Student
                            Portal<% } %>
                </p>
                <h1>Computer Laboratory Reservation</h1>
                <p>Select a lab and choose an available computer to reserve your seat</p>
            </div>
            <span
