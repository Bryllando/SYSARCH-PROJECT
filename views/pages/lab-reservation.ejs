                                    <td style="padding:13px 16px;">
                                        <div style="font-weight:600;color:#1C2B35;font-size:13px;">
                                            <%= r.last_name %>, <%= r.first_name %>
                                        </div>
                                        <div style="font-size:11px;color:#9CA3AF;font-family:monospace;">
