        <div class="labres-stat">
            <div class="labres-stat-icon" style="background:#FEF2F2;">
                <div style="width:12px;height:12px;border-radius:50%;background:#DC2626;"></div>
            </div>
            <div>
                <div class="labres-stat-val" style="color:#DC2626;" id="stat-defect">—</div>
                <div class="labres-stat-label">Defective</div>
            </div>
        </div>
