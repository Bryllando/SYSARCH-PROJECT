            style="background:#fff;border-radius:16px;overflow:hidden;border:1px solid #E8E3DD;box-shadow:0 2px 8px rgba(0,0,0,0.04);">
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:13px;">
                    <thead>
                        <tr style="background:#F7F5F2;border-bottom:2px solid #E8E3DD;">
