        </div>
        <div class="ctx-item" onclick="adminSetPcStatus('in_use')" style="color:#92400E;">
            <div style="width:10px;height:10px;border-radius:50%;background:#F59E0B;"></div>
            Mark as In Use
        </div>
        <div class="ctx-sep"></div>
        <div class="ctx-item danger" onclick="adminSetPcStatus('defective')">
            <div style="width:10px;height:10px;border-radius:50%;background:#DC2626;"></div>
            Mark as Defective
        </div>
        <div class="ctx-sep"></div>
        <div class="ctx-item" onclick="adminViewPcReservations()" style="color:#273F4F;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor" width="12" height="12">
                <path fill-rule="evenodd"
                    d="M5 2A1.5 1.5 0 0 0 3.5 3.5v9A1.5 1.5 0 0 0 5 14h7a1.5 1.5 0 0 0 1.5-1.5V5.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.44A1.5 1.5 0 0 0 8.878 2H5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1H6Zm0 2.5a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1H6Z"
                    clip-rule="evenodd" />
            </svg>
            View Reservations
        </div>
    </div>
    <% } %>

        <script>
            const IS_ADMIN = '<%= typeof user !== "undefined" && user.role === "admin" ? "true" : "false" %>' === 'true';

            // ── Lab Data ──────────────────────────────────────────────────────
            const LABS = [
                { id: 'lab524', room: '524', name: 'Lab 524', desc: 'General Purpose Laboratory', rows: 4, cols: 5, totalPcs: 20 },
                { id: 'lab526', room: '526', name: 'Lab 526', desc: 'General Purpose Laboratory', rows: 4, cols: 5, totalPcs: 20 },
                { id: 'lab528', room: '528', name: 'Lab 528', desc: 'General Purpose Laboratory', rows: 4, cols: 5, totalPcs: 20 },
                { id: 'lab530', room: '530', name: 'Lab 530', desc: 'Multimedia Laboratory', rows: 3, cols: 5, totalPcs: 15 },
                { id: 'lab542', room: '542', name: 'Lab 542', desc: 'IT Laboratory', rows: 4, cols: 5, totalPcs: 20 },
                { id: 'lab544', room: '544', name: 'Lab 544', desc: 'Mac Laboratory', rows: 3, cols: 4, totalPcs: 12 },
            ];

            // ── PC Status Store (in real app, fetched from server) ──────────
            const PC_STATUS_STORE = {};
            function initLabPcs(labId, total) {
                if (!PC_STATUS_STORE[labId]) {
                    const pcs = {};
                    for (let i = 1; i <= total; i++) {
                        const r = Math.random();
                        let status = 'available';
                        if (r < 0.15) status = 'defective';
                        else if (r < 0.35) status = 'in_use';
                        else if (r < 0.48) status = 'reserved';
                        pcs[i] = { status, reservedBy: status === 'reserved' ? 'Sample Student' : null };
                    }
                    PC_STATUS_STORE[labId] = pcs;
                }
                return PC_STATUS_STORE[labId];
            }

            function getLabStats(labId, total) {
                const pcs = initLabPcs(labId, total);
                const counts = { available: 0, in_use: 0, reserved: 0, defective: 0 };
                Object.values(pcs).forEach(p => counts[p.status]++);
                return counts;
            }

            // ── Render Lab Grid Cards ─────────────────────────────────────────
            function renderLabGrid() {
                const grid = document.getElementById('labGrid');
                let totalAvail = 0, totalInuse = 0, totalReserved = 0, totalDefect = 0;

                grid.innerHTML = LABS.map(lab => {
                    const stats = getLabStats(lab.id, lab.totalPcs);
                    totalAvail += stats.available;
                    totalInuse += stats.in_use;
                    totalReserved += stats.reserved;
                    totalDefect += stats.defective;

                    const pillsHtml = [
                        stats.available > 0 ? `<span class="lab-pill pill-avail"><span class="lab-pill-dot"></span>${stats.available} Available</span>` : '',
                        stats.in_use > 0 ? `<span class="lab-pill pill-inuse"><span class="lab-pill-dot"></span>${stats.in_use} In Use</span>` : '',
                        stats.defective > 0 ? `<span class="lab-pill pill-defect"><span class="lab-pill-dot"></span>${stats.defective} Defective</span>` : '',
                    ].filter(Boolean).join('');

                    return `
        <div class="lab-card" onclick="openPcModal('${lab.id}')">
            <div class="lab-card-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor" width="12" height="12" style="color:#6B7280;">
                    <path fill-rule="evenodd" d="M3.036 7.018a.75.75 0 0 1 .75-.75h7.19L8.53 3.822a.75.75 0 0 1 1.06-1.06l3.75 3.75a.75.75 0 0 1 0 1.06l-3.75 3.75a.75.75 0 0 1-1.06-1.06l2.447-2.447H3.786a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="lab-card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#F1E194" width="24" height="24">
                    <path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/>
                </svg>
            </div>
            <p class="lab-card-name">${lab.name}</p>
            <p class="lab-card-desc">${lab.desc} · ${lab.totalPcs} PCs</p>
            <div class="lab-card-pills">${pillsHtml}</div>
        </div>`;
                }).join('');

                document.getElementById('stat-avail').textContent = totalAvail;
                document.getElementById('stat-inuse').textContent = totalInuse;
                document.getElementById('stat-reserved').textContent = totalReserved;
                document.getElementById('stat-defect').textContent = totalDefect;
            }

            // ── PC Modal ──────────────────────────────────────────────────────
            let currentLabId = null;
            let selectedPcNum = null;
            let ctxTargetPcNum = null;

            function pcSvg(color) {
                return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="${color}" width="24" height="24">
        <path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/>
    </svg>`;
            }

            function renderPcGrid(labId) {
                const lab = LABS.find(l => l.id === labId);
                const pcs = initLabPcs(labId, lab.totalPcs);
                const body = document.getElementById('pcModalBody');

                document.getElementById('pcModalLabName').textContent = lab.name;
                document.getElementById('pcModalLabDesc').textContent = `${lab.desc} · ${lab.totalPcs} computers`;

                let html = `<div class="pc-teacher-area">🖥 Teacher / Instructor Station</div>`;

                let pcNum = 1;
                for (let row = 0; row < lab.rows; row++) {
                    const rowLetter = String.fromCharCode(65 + row);
                    html += `<div class="pc-row-label">Row ${rowLetter}</div><div class="pc-grid">`;
                    for (let col = 0; col < lab.cols && pcNum <= lab.totalPcs; col++) {
                        const pc = pcs[pcNum];
                        const statusClass = pc.status === 'available' ? 'pc-avail'
                            : pc.status === 'in_use' ? 'pc-inuse'
                                : pc.status === 'reserved' ? 'pc-reserved'
                                    : 'pc-defect';
                        const iconColor = pc.status === 'available' ? '#059669'
                            : pc.status === 'in_use' ? '#D97706'
                                : pc.status === 'reserved' ? '#2563EB'
                                    : '#DC2626';
                        const labelText = pc.status === 'available' ? 'Free'
                            : pc.status === 'in_use' ? 'In Use'
                                : pc.status === 'reserved' ? 'Reserved'
                                    : 'Defective';

                        const clickHandler = IS_ADMIN
                            ? `oncontextmenu="adminCtxMenu(event, ${pcNum}); return false;" onclick="adminCtxMenu(event, ${pcNum})"`
                            : (pc.status === 'available' ? `onclick="selectPc(${pcNum})"` : '');

                        const adminBadge = IS_ADMIN && pc.status !== 'available' ? `<div class="pc-admin-tag">${labelText}</div>` : '';

                        html += `
            <div class="pc-unit ${statusClass}" id="pc-unit-${pcNum}" data-pc="${pcNum}" ${clickHandler} title="PC-${String(pcNum).padStart(2, '0')} — ${labelText}">
                ${adminBadge}
                <div class="pc-icon-wrap">
                    ${pcSvg(iconColor)}
                    <span class="pc-status-dot"></span>
                </div>
                <span class="pc-number">PC-${String(pcNum).padStart(2, '0')}</span>
                <span class="pc-label">${labelText}</span>
            </div>`;
                        pcNum++;
                    }
                    html += `</div>`;
                }
                body.innerHTML = html;
            }

            function openPcModal(labId) {
                currentLabId = labId;
                selectedPcNum = null;
                document.getElementById('selectedPcLabel').textContent = 'None';
                const btn = document.getElementById('btnReserve');
                if (btn) btn.disabled = true;
                renderPcGrid(labId);
                document.getElementById('pcModal').classList.add('open');
            }

            function closePcModal() {
                document.getElementById('pcModal').classList.remove('open');
                closeCtxMenu();
                currentLabId = null;
                selectedPcNum = null;
            }

            function selectPc(pcNum) {
                if (!currentLabId) return;
                const lab = LABS.find(l => l.id === currentLabId);
                const pcs = PC_STATUS_STORE[currentLabId];
                if (!pcs || pcs[pcNum].status !== 'available') return;

                document.querySelectorAll('.pc-unit').forEach(el => el.classList.remove('selected'));
                document.getElementById(`pc-unit-${pcNum}`).classList.add('selected');

                selectedPcNum = pcNum;
                const label = `PC-${String(pcNum).padStart(2, '0')} — ${lab.name}`;
                document.getElementById('selectedPcLabel').textContent = label;
                const btn = document.getElementById('btnReserve');
                if (btn) btn.disabled = false;
            }

            // ── Reserve Form ──────────────────────────────────────────────────
            function openReserveForm() {
                if (!selectedPcNum || !currentLabId) return;
                const lab = LABS.find(l => l.id === currentLabId);
                document.getElementById('formPcLabel').textContent = `PC-${String(selectedPcNum).padStart(2, '0')}`;
                document.getElementById('formLabLabel').textContent = lab.name;
                document.getElementById('formLabRoom').value = lab.room;
                document.getElementById('formPcNumber').value = selectedPcNum;
                const today = new Date().toISOString().split('T')[0];
                document.getElementById('formDate').min = today;
                document.getElementById('resFormModal').classList.add('open');
            }

            function closeReserveForm() {
                document.getElementById('resFormModal').classList.remove('open');
            }

            function validateTimeRange() {
                const start = document.getElementById('formTimeStart').value;
                const end = document.getElementById('formTimeEnd').value;
                const warn = document.getElementById('timeWarning');
                const preview = document.getElementById('timePreview');
                const slot = document.getElementById('formTimeSlot');

                if (!start || !end) { warn.style.display = 'none'; preview.style.display = 'none'; return; }

                const [sh, sm] = start.split(':').map(Number);
                const [eh, em] = end.split(':').map(Number);
                const diffMin = (eh * 60 + em) - (sh * 60 + sm);

                if (diffMin <= 0) {
                    warn.textContent = '⚠ End time must be after start time.';
                    warn.style.display = 'block'; preview.style.display = 'none'; slot.value = ''; return;
                }
                if (diffMin > 180) {
                    warn.textContent = '⚠ Maximum sit-in time is 3 hours.';
                    warn.style.display = 'block'; preview.style.display = 'none'; slot.value = ''; return;
                }
                warn.style.display = 'none';

                const to12 = t => {
                    const [h, m] = t.split(':').map(Number);
                    const ap = h >= 12 ? 'PM' : 'AM'; const hr = h % 12 || 12;
                    return `${String(hr).padStart(2, '0')}:${String(m).padStart(2, '0')} ${ap}`;
                };
                const slotStr = `${to12(start)} – ${to12(end)}`;
                slot.value = slotStr;
                preview.textContent = `✓ ${slotStr} (${Math.floor(diffMin / 60)}h ${diffMin % 60}m)`;
                preview.style.display = 'block';
            }

            function submitReservation() {
                const form = document.getElementById('labResForm');
                const slot = document.getElementById('formTimeSlot');
                if (!slot.value) { alert('Please set a valid time slot (max 3 hours).'); return; }
                form.submit();
            }

            // ── Admin PC Context Menu ─────────────────────────────────────────
            function adminCtxMenu(event, pcNum) {
                if (!IS_ADMIN) return;
                event.preventDefault();
                ctxTargetPcNum = pcNum;
                const menu = document.getElementById('pcCtxMenu');
                if (!menu) return;
                menu.style.left = Math.min(event.clientX, window.innerWidth - 200) + 'px';
                menu.style.top = Math.min(event.clientY, window.innerHeight - 180) + 'px';
                menu.classList.add('open');
            }

            function closeCtxMenu() {
                const menu = document.getElementById('pcCtxMenu');
                if (menu) menu.classList.remove('open');
                ctxTargetPcNum = null;
            }

            function adminSetPcStatus(status) {
                if (!currentLabId || !ctxTargetPcNum) return;
                PC_STATUS_STORE[currentLabId][ctxTargetPcNum].status = status;

                // In real app: POST to /admin/lab-computers/:id/status
                fetch(`/admin/lab-computers/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lab_room: LABS.find(l => l.id === currentLabId).room, computer_number: ctxTargetPcNum, status })
                }).catch(() => { });

                closeCtxMenu();
                renderPcGrid(currentLabId);
                renderLabGrid();
            }

            function adminViewPcReservations() {
                if (!ctxTargetPcNum || !currentLabId) return;
                const lab = LABS.find(l => l.id === currentLabId);
                closeCtxMenu();
                closePcModal();
                window.location.href = `/admin/lab-reservations?lab=${lab.room}&pc=${ctxTargetPcNum}`;
            }

            document.addEventListener('click', (e) => {
                if (!document.getElementById('pcCtxMenu')?.contains(e.target)) closeCtxMenu();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') { closePcModal(); closeReserveForm(); closeCtxMenu(); }
            });

            renderLabGrid();
        </script>