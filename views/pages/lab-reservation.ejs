                                                <% } else { %>
                                                    <div
                                                        style="text-align:center;font-size:11px;color:#C4BDB6;font-style:italic;">
                                                        Processed</div>
                                                    <% } %>
                                        </td>
                                        <% } %>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="<%= typeof user !== 'undefined' && user.role === 'admin' ? 8 : 7 %>"
                                                style="padding:56px 24px;text-align:center;">
                                                <div
                                                    style="width:52px;height:52px;border-radius:50%;background:#F3F0EC;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                        fill="#C4BDB6" width="26" height="26">
                                                        <path fill-rule="evenodd"
                                                            d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z"
                                                            clip-rule="evenodd" />
                                                    </svg>
                                                </div>
                                                <p style="font-size:14px;font-weight:700;color:#4B5563;margin:0 0 4px;">
                                                    No reservations yet</p>
                                                <p style="font-size:12px;color:#9CA3AF;margin:0;">Choose a lab above to
                                                    make a reservation.</p>
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

