<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .lc-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .lc-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .lc-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .lc-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .lc-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .lc-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .lc-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    /* ── Stats ── */
    .lc-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        flex-wrap: wrap;
    }

    .lc-stat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .lc-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .lc-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .lc-stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* ── Lab tabs ── */
    .lc-tabs {
        display: flex;
        gap: 6px;
        padding: 16px 32px 0;
        flex-wrap: wrap;
    }

    .lc-tab {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        border: 1.5px solid #E2DDD8;
        background: #fff;
        color: #374151;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .lc-tab:hover {
        border-color: #273F4F;
        color: #273F4F;
    }

    .lc-tab.active {
        background: #273F4F;
        border-color: #273F4F;
        color: #F1E194;
    }

    /* ── PC Grid card ── */
    .lc-grid-card {
        margin: 16px 32px 32px;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        border: 1px solid #E8E3DD;
    }

    .lc-grid-card-head {
        padding: 14px 20px;
        background: #F7F5F2;
        border-bottom: 1px solid #E8E3DD;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .lc-legend {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }

    .lc-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #4B5563;
    }

    .lc-legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid;
    }

    .lc-grid-body {
        padding: 20px 24px;
    }

    /* ── Teacher station ── */
    .lc-teacher {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        border-radius: 10px;
        padding: 10px 16px;
        text-align: center;
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .lc-row-label {
        font-size: 10px;
        font-weight: 700;
        color: #C4BDB6;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 14px 0 8px;
    }

    /* ── 10-column PC grid ── */
    .lc-pc-grid {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 8px;
        margin-bottom: 4px;
    }

    .lc-pc-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        padding: 8px 4px;
        border-radius: 10px;
        border: 2px solid transparent;
        transition: all 0.18s;
        position: relative;
        user-select: none;
    }

    .lc-pc-unit:hover {
        transform: translateY(-2px);
    }

    .lc-pc-unit.pc-avail:hover {
        border-color: #059669;
        background: rgba(5, 150, 105, 0.07);
    }

    .lc-pc-unit.pc-inuse:hover {
        border-color: #D97706;
        background: rgba(217, 119, 6, 0.07);
    }

    .lc-pc-unit.pc-defect:hover {
        border-color: #DC2626;
        background: rgba(220, 38, 38, 0.07);
    }

    .lc-pc-unit.pc-reserved:hover {
        border-color: #2563EB;
        background: rgba(37, 99, 235, 0.07);
    }

    .lc-pc-unit.pc-selecting {
        border-color: #5B0E14 !important;
        background: rgba(91, 14, 20, 0.1) !important;
        transform: scale(1.05);
    }

    .lc-pc-icon-wrap {
        width: 42px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border: 2px solid;
    }

    .pc-avail .lc-pc-icon-wrap {
        background: #ECFDF5;
        border-color: #A7F3D0;
    }

    .pc-inuse .lc-pc-icon-wrap {
        background: #FFF7ED;
        border-color: #FDE68A;
    }

    .pc-defect .lc-pc-icon-wrap {
        background: #FEF2F2;
        border-color: #FECACA;
    }

    .pc-reserved .lc-pc-icon-wrap {
        background: #EFF6FF;
        border-color: #BFDBFE;
    }

    .lc-pc-dot {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    .pc-avail .lc-pc-dot {
        background: #10B981;
    }

    .pc-inuse .lc-pc-dot {
        background: #F59E0B;
        animation: lcPulse 1.5s infinite;
    }

    .pc-defect .lc-pc-dot {
        background: #DC2626;
    }

    .pc-reserved .lc-pc-dot {
        background: #3B82F6;
    }

    @keyframes lcPulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8)
        }
    }

    .lc-pc-number {
        font-size: 9px;
        font-weight: 700;
    }

    .pc-avail .lc-pc-number {
        color: #065F46;
    }

    .pc-inuse .lc-pc-number {
        color: #92400E;
    }

    .pc-defect .lc-pc-number {
        color: #991B1B;
    }

    .pc-reserved .lc-pc-number {
        color: #1D4ED8;
    }

    .lc-pc-label {
        font-size: 7.5px;
        font-weight: 600;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    /* ── Status Change Modal ── */
    .sc-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .sc-overlay.open {
        display: flex;
    }

    .sc-overlay.open .sc-card {
        animation: scIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes scIn {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(16px)
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0)
        }
    }

    .sc-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 400px;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
    }

    .sc-header {
        padding: 18px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg, #273F4F, #1a2d38);
    }

    .sc-header-title {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: #fff;
    }

    .sc-close {
        width: 30px;
        height: 30px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 8px;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        transition: all 0.15s;
    }

    .sc-close:hover {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
    }

    .sc-pc-badge {
        padding: 14px 24px;
        background: linear-gradient(135deg, #F9F8F6, #F0EDE8);
        border-bottom: 1px solid #E8E3DD;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sc-pc-num {
        font-weight: 800;
        color: #1C2B35;
        font-size: 14px;
    }

    .sc-pc-lab {
        font-size: 11px;
        color: #6B7280;
    }

    .sc-body {
        padding: 20px 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .sc-status-btn {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: 12px;
        border: 2px solid;
        cursor: pointer;
        transition: all 0.15s;
        font-size: 13px;
        font-weight: 700;
        background: #fff;
        font-family: 'DM Sans', sans-serif;
        text-align: left;
        width: 100%;
    }

    .sc-status-btn:hover {
        transform: translateX(4px);
    }

    .sc-status-btn.btn-avail {
        border-color: #A7F3D0;
        color: #065F46;
    }

    .sc-status-btn.btn-avail:hover {
        background: #ECFDF5;
    }

    .sc-status-btn.btn-inuse {
        border-color: #FDE68A;
        color: #92400E;
    }

    .sc-status-btn.btn-inuse:hover {
        background: #FFF7ED;
    }

    .sc-status-btn.btn-defect {
        border-color: #FECACA;
        color: #991B1B;
    }

    .sc-status-btn.btn-defect:hover {
        background: #FEF2F2;
    }

    .sc-status-btn.btn-reserved {
        border-color: #BFDBFE;
        color: #1D4ED8;
    }

    .sc-status-btn.btn-reserved:hover {
        background: #EFF6FF;
    }

    .sc-status-btn .sc-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .sc-status-btn.btn-avail .sc-dot {
        background: #10B981;
    }

    .sc-status-btn.btn-inuse .sc-dot {
        background: #F59E0B;
    }

    .sc-status-btn.btn-defect .sc-dot {
        background: #DC2626;
    }

    .sc-status-btn.btn-reserved .sc-dot {
        background: #3B82F6;
    }

    .sc-status-btn .sc-current-badge {
        margin-left: auto;
        font-size: 10px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.06);
        color: #6B7280;
    }

    .sc-footer {
        padding: 0 24px 20px;
    }

    .sc-cancel {
        width: 100%;
        padding: 11px;
        background: #F3F0EC;
        color: #374151;
        border: 1.5px solid #E8E3DD;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background 0.15s;
    }

    .sc-cancel:hover {
        background: #E8E3DD;
    }
</style>

