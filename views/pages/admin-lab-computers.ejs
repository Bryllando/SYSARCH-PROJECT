<script>
    const LABS = [
        { room: '524', name: 'Lab 524', desc: 'General Purpose' },
        { room: '526', name: 'Lab 526', desc: 'General Purpose' },
        { room: '528', name: 'Lab 528', desc: 'General Purpose' },
        { room: '530', name: 'Lab 530', desc: 'Multimedia Lab' },
        { room: '542', name: 'Lab 542', desc: 'IT Laboratory' },
        { room: '544', name: 'Lab 544', desc: 'Mac Laboratory' },
    ];

    let currentLabRoom = null;
    let currentPcData = {};   // pcNum → {status, ...}
    let modalPcNum = null;
    let modalCurrentStatus = null;

    // ── Init ──────────────────────────────────────────────────────────────────
    (async function init() {
        renderTabs();
        await loadLab(LABS[0].room);
        await updateGlobalStats();
    })();

    function renderTabs() {
        const wrap = document.getElementById('lcTabs');
        wrap.innerHTML = LABS.map((lab, i) => `
            <button class="lc-tab ${i === 0 ? 'active' : ''}" id="tab-${lab.room}"
                onclick="switchTab('${lab.room}')">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path clip-rule="evenodd" d="M1 3.25A2.25 2.25 0 0 1 3.25 1h9.5A2.25 2.25 0 0 1 15 3.25v5.5A2.25 2.25 0 0 1 12.75 11H9.28a3.5 3.5 0 0 1 .67 1.344.5.5 0 0 1-.482.656H6.53a.5.5 0 0 1-.482-.656A3.5 3.5 0 0 1 6.72 11H3.25A2.25 2.25 0 0 1 1 8.75v-5.5Z" fill-rule="evenodd"/>
                </svg>
                ${lab.name}
            </button>`).join('');
    }

    async function switchTab(labRoom) {
        LABS.forEach(l => {
            const t = document.getElementById('tab-' + l.room);
            if (t) t.classList.toggle('active', l.room === labRoom);
        });
        await loadLab(labRoom);
    }

    async function loadLab(labRoom) {
        currentLabRoom = labRoom;
        const lab = LABS.find(l => l.room === labRoom);
        document.getElementById('lcCurrentLabTitle').textContent = lab.name + ' — ' + lab.desc + ' · 50 PCs';
        document.getElementById('lcGridBody').innerHTML = '<div style="text-align:center;padding:40px;color:#9CA3AF;font-size:13px;">Loading PC layout…</div>';
        try {
            const res = await fetch('/lab-computers/' + labRoom);
            const data = await res.json();
            currentPcData = {};
            data.forEach(pc => { currentPcData[pc.computer_number] = pc; });
            renderPcGrid();
        } catch (e) {
            document.getElementById('lcGridBody').innerHTML = '<div style="text-align:center;padding:40px;color:#DC2626;font-size:13px;">Failed to load PCs. Please refresh.</div>';
        }
    }

    function pcSvg(color) {
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="${color}" width="20" height="20"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg>`;
    }

    function renderPcGrid() {
        const rows = 5, cols = 10, total = 50;
        let html = `<div class="lc-teacher">🖥 Teacher / Instructor Station</div>`;
        let pcNum = 1;

        for (let r = 0; r < rows; r++) {
            html += `<div class="lc-row-label">Row ${String.fromCharCode(65 + r)}</div><div class="lc-pc-grid">`;
            for (let c = 0; c < cols && pcNum <= total; c++) {
                const pc = currentPcData[pcNum] || { status: 'available' };
                const st = pc.status || 'available';
                const cls = st === 'available' ? 'pc-avail' : st === 'in_use' ? 'pc-inuse' : st === 'reserved' ? 'pc-reserved' : 'pc-defect';
                const ic = st === 'available' ? '#059669' : st === 'in_use' ? '#D97706' : st === 'reserved' ? '#2563EB' : '#DC2626';
                const lbl = st === 'available' ? 'Free' : st === 'in_use' ? 'In Use' : st === 'reserved' ? 'Reserved' : 'Defective';
                const emoji = st === 'defective' ? '🔧' : '';
                html += `<div class="lc-pc-unit ${cls}" id="lcpc-${pcNum}" onclick="openStatusModal(${pcNum})" title="PC-${String(pcNum).padStart(2, '0')} — ${lbl}">
                    <div class="lc-pc-icon-wrap">${pcSvg(ic)}<span class="lc-pc-dot"></span></div>
                    <span class="lc-pc-number">${String(pcNum).padStart(2, '0')}</span>
                    <span class="lc-pc-label">${emoji}${lbl}</span>
                </div>`;
                pcNum++;
            }
            html += `</div>`;
        }

        document.getElementById('lcGridBody').innerHTML = html;
        updateLabStats();
    }

    function updateLabStats() {
        // Update global stat display from all labs combined — but just show for current lab context
    }

    async function updateGlobalStats() {
        let avail = 0, inuse = 0, defect = 0, reserved = 0;
        await Promise.all(LABS.map(async lab => {
            try {
                const res = await fetch('/lab-computers/' + lab.room);
                const data = await res.json();
                data.forEach(pc => {
                    const s = pc.status || 'available';
                    if (s === 'available') avail++;
                    else if (s === 'in_use') inuse++;
                    else if (s === 'defective') defect++;
                    else if (s === 'reserved') reserved++;
                });
            } catch (e) { }
        }));
        document.getElementById('lcStatAvail').textContent = avail;
        document.getElementById('lcStatInuse').textContent = inuse;
        document.getElementById('lcStatDefect').textContent = defect;
        document.getElementById('lcStatReserved').textContent = reserved;
    }

    // ── Status Change Modal ───────────────────────────────────────────────────
    function openStatusModal(pcNum) {
        modalPcNum = pcNum;
        const pc = currentPcData[pcNum] || { status: 'available' };
        modalCurrentStatus = pc.status || 'available';

        const lab = LABS.find(l => l.room === currentLabRoom);
        document.getElementById('scPcNum').textContent = `PC-${String(pcNum).padStart(2, '0')}`;
        document.getElementById('scPcLab').textContent = lab.name + ' — ' + lab.desc;

        // Show "Current" badge on the right button
        ['Avail', 'Inuse', 'Defect', 'Reserved'].forEach(n => {
            document.getElementById('scBadge' + n).style.display = 'none';
        });
        const map = { available: 'Avail', in_use: 'Inuse', defective: 'Defect', reserved: 'Reserved' };
        const badge = document.getElementById('scBadge' + (map[modalCurrentStatus] || 'Avail'));
        if (badge) badge.style.display = 'inline-block';

        // Flash the PC unit
        const el = document.getElementById('lcpc-' + pcNum);
        if (el) el.classList.add('pc-selecting');

        document.getElementById('scOverlay').classList.add('open');
    }

    function closeStatusModal() {
        document.getElementById('scOverlay').classList.remove('open');
        if (modalPcNum) {
            const el = document.getElementById('lcpc-' + modalPcNum);
            if (el) el.classList.remove('pc-selecting');
        }
        modalPcNum = null;
    }

    async function applyStatus(newStatus) {
        if (!modalPcNum || !currentLabRoom) return;
        const pcNum = modalPcNum;
        closeStatusModal();

        try {
            const res = await fetch('/admin/lab-computers/status', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lab_room: currentLabRoom, computer_number: pcNum, status: newStatus })
            });
            const data = await res.json();
            if (data.success) {
                // Update local cache
                if (!currentPcData[pcNum]) currentPcData[pcNum] = {};
                currentPcData[pcNum].status = newStatus;
                renderPcGrid();
                updateGlobalStats();
                showToast(newStatus, pcNum);
            }
        } catch (e) {
            console.error('Failed to update PC status', e);
        }
    }

    function showToast(status, pcNum) {
        const labels = { available: 'Available ✅', in_use: 'In Use 🟡', defective: 'Defective 🔧', reserved: 'Reserved 🔵' };
        const toastEl = document.createElement('div');
        toastEl.style.cssText = `position:fixed;top:20px;right:20px;z-index:99999;padding:12px 18px;background:#1C2B35;color:#fff;border-radius:12px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:10px;animation:scIn 0.25s ease both;`;
        toastEl.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#F1E194" width="16" height="16"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg> PC-${String(pcNum).padStart(2, '0')} → <span style="color:#F1E194;">${labels[status] || status}</span>`;
        document.body.appendChild(toastEl);
        setTimeout(() => toastEl.remove(), 2500);
    }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeStatusModal(); });
</script>