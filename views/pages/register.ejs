<div class="flex justify-center items-center min-h-[90vh] py-8 px-4">
    <div class="bg-white p-6 md:p-10 rounded-2xl shadow-2xl w-full max-w-2xl border border-gray-100">

        <h2 class="text-2xl md:text-3xl font-extrabold text-center text-[#273F4F] mb-6">
            Register for CCS Sit-in
        </h2>
        <hr><br>

        <% if (typeof messages !=='undefined' ) { %>
            <% messages.forEach(function(msg) { %>
                <div class="mb-4 p-3 rounded-xl flex items-center gap-3
                    <%= msg.type === 'error'
                        ? 'bg-red-50 text-red-700 border border-red-200'
                        : 'bg-green-50 text-green-700 border border-green-200' %>">
                    <span class="font-medium text-sm">
                        <%= msg.text %>
                    </span>
                </div>
                <% }) %>
                    <% } %>

                        <form action="/register" method="POST" class="space-y-4">
                            <div class="space-y-1">
                                <label class="block text-sm font-bold text-gray-700 ml-1">ID Number</label>
                                <input type="text" name="id_number" placeholder="eg. 2023-12345" required
                                    class="w-48 p-2 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none transition-all text-sm">
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700 ml-1">Last Name</label>
                                    <input type="text" name="last_name" placeholder="Last Name" required
                                        class="w-full p-2.5 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none text-sm">
                                </div>
                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700 ml-1">First Name</label>
                                    <input type="text" name="first_name" placeholder="First Name" required
                                        class="w-full p-2.5 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none text-sm">
                                </div>
                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700 ml-1">M.I.</label>
                                    <input type="text" name="middle_initial" maxlength="2" placeholder="M.I."
                                        class="w-full p-2.5 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none text-center text-sm">
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700 ml-1">Course</label>
                                    <div class="relative">
                                        <select name="course" required
                                            class="w-full p-2.5 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm">
                                            <option value="" disabled selected>Select Course</option>
                                            <option value="BSCS">BS Computer Science</option>
                                            <option value="BSIT">BS Information Technology</option>
                                            <option value="BSIS">BS Information Systems</option>
                                            <option value="ACT">ACT</option>
                                        </select>
                                        <div
                                            class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                            </svg>
                                        </div>
                                    </div>
                                </div>
                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700 ml-1">Year Level</label>
                                    <div class="relative">
                                        <select name="section" required
                                            class="w-full p-2.5 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm">
                                            <option value="" disabled selected>Select Year Level</option>
                                            <option value="1">1st Year</option>
                                            <option value="2">2nd Year</option>
                                            <option value="3">3rd Year</option>
                                            <option value="4">4th Year</option>
                                        </select>
                                        <div
                                            class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="2" stroke="currentColor" class="size-4 text-gray-400">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                            </svg>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-1">
                                <label class="block text-sm font-bold text-gray-700 ml-1">Email Address</label>
                                <input type="email" name="email" placeholder="student@university.edu" required
                                    class="w-full p-2.5 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none text-sm">
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700 ml-1">Password</label>
                                    <div class="relative">
                                        <input type="password" name="password" id="passwordInput" placeholder="••••••••"
                                            required
                                            class="w-full p-2.5 pr-10 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none text-sm">
                                        <button type="button" id="togglePassword"
                                            class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-[#273F4F]">
                                            <svg id="eyeOpen1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                fill="currentColor" class="size-4">
                                                <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                                                <path fill-rule="evenodd"
                                                    d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z"
                                                    clip-rule="evenodd" />
                                            </svg>
                                            <svg id="eyeClosed1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                fill="currentColor" class="size-4 hidden">
                                                <path
                                                    d="M3.53 2.47a.75.75 0 0 0-1.06 1.06l18 18a.75.75 0 1 0 1.06-1.06l-18-18ZM22.676 12.553a11.249 11.249 0 0 1-2.631 4.31l-3.099-3.099a5.25 5.25 0 0 0-6.71-6.71L7.759 4.577a11.217 11.217 0 0 1 4.242-.827c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113Z" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>

                                <div class="space-y-1">
                                    <label class="block text-sm font-bold text-gray-700 ml-1">Confirm Password</label>
                                    <div class="relative">
                                        <input type="password" name="confirm_password" id="confirmPasswordInput"
                                            placeholder="••••••••" required
                                            class="w-full p-2.5 pr-10 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none text-sm">
                                        <button type="button" id="toggleConfirmPassword"
                                            class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-[#273F4F]">
                                            <svg id="eyeOpen2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                fill="currentColor" class="size-4">
                                                <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                                                <path fill-rule="evenodd"
                                                    d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z"
                                                    clip-rule="evenodd" />
                                            </svg>
                                            <svg id="eyeClosed2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                fill="currentColor" class="size-4 hidden">
                                                <path
                                                    d="M3.53 2.47a.75.75 0 0 0-1.06 1.06l18 18a.75.75 0 1 0 1.06-1.06l-18-18ZM22.676 12.553a11.249 11.249 0 0 1-2.631 4.31l-3.099-3.099a5.25 5.25 0 0 0-6.71-6.71L7.759 4.577a11.217 11.217 0 0 1 4.242-.827c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113Z" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-blue-50 border border-blue-100 p-3 rounded-xl">
                                <h3 class="text-blue-500 text-xs font-bold mb-2 flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                        class="size-4">
                                        <path fill-rule="evenodd"
                                            d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                    Password Requirements
                                </h3>
                                <ul class="text-xs text-blue-400 grid grid-cols-2 gap-1 list-disc ml-4">
                                    <li id="req-length">8+ characters</li>
                                    <li id="req-upper">Uppercase letter</li>
                                    <li id="req-lower">Lowercase letter</li>
                                    <li id="req-number">One number</li>
                                    <li id="req-match" class="col-span-2">Passwords must match</li>
                                </ul>
                            </div>

                            <button type="submit" class="btn-maroon">
                                Create Account
                            </button>
                        </form>

                        <p class="mt-6 text-center text-sm text-gray-600">
                            Already registered? <a href="/login" class="text-[#273F4F] font-bold hover:underline">Login
                                here</a>
                        </p>
    </div>
</div>

<script src="/js/register.js"></script>