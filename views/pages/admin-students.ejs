<script>
    /* ── Edit Modal ── */
    function openEditModal(id, idNumber, firstName, lastName, mi, course, yearLevel, email, address, sessions) {
        document.getElementById('editStudentForm').action = '/admin/students/' + id + '/edit';
        document.getElementById('editIdNumber').value = idNumber;
        document.getElementById('editFirstName').value = firstName;
        document.getElementById('editLastName').value = lastName;
        document.getElementById('editMiddleInitial').value = mi;
        document.getElementById('editEmail').value = email;
        document.getElementById('editAddress').value = address;
        document.getElementById('editSessions').value = sessions;
        // Set course
        var courseSelect = document.getElementById('editCourse');
        for (var i = 0; i < courseSelect.options.length; i++) {
            if (courseSelect.options[i].value === course) { courseSelect.selectedIndex = i; break; }
        }
        // Set year level
        var yearSelect = document.getElementById('editYearLevel');
        for (var j = 0; j < yearSelect.options.length; j++) {
            if (yearSelect.options[j].value == yearLevel) { yearSelect.selectedIndex = j; break; }
        }
        document.getElementById('editStudentModal').classList.add('open');
    }
    function closeEditModal() {
        document.getElementById('editStudentModal').classList.remove('open');
    }

    /* ── Add Student Modal ── */
    function openAddStudentModal() {
        document.getElementById('addStudentModal').classList.add('open');
    }
    function closeAddStudentModal() {
        document.getElementById('addStudentModal').classList.remove('open');
    }

    // ── Real-time password validation for Add Student modal ──
    (function () {
        const passInput    = document.getElementById('addPassword');
        const confirmInput = document.getElementById('addConfirmPassword');
        const submitBtn    = document.getElementById('addStudentSubmitBtn');
        const reqsBox      = document.getElementById('addPasswordReqs');

        const reqLen   = document.getElementById('req-add-len');
        const reqUp    = document.getElementById('req-add-up');
        const reqLow   = document.getElementById('req-add-low');
        const reqNum   = document.getElementById('req-add-num');
        const reqMatch = document.getElementById('req-add-match');

        function mark(el, met) {
            el.classList.toggle('met', met);
        }

        function runValidation() {
            const val     = passInput.value;
            const confirm = confirmInput.value;

            const hasLen   = val.length >= 8;
            const hasUp    = /[A-Z]/.test(val);
            const hasLow   = /[a-z]/.test(val);
            const hasNum   = /[0-9]/.test(val);
            const matches  = val.length > 0 && val === confirm;

            mark(reqLen,   hasLen);
            mark(reqUp,    hasUp);
            mark(reqLow,   hasLow);
            mark(reqNum,   hasNum);
            mark(reqMatch, matches);

            const allGood = hasLen && hasUp && hasLow && hasNum && matches;
            submitBtn.disabled    = !allGood;
            submitBtn.style.opacity = allGood ? '1' : '0.5';
        }

        passInput.addEventListener('focus', function () {
            reqsBox.style.display = 'block';
        });

        passInput.addEventListener('input', runValidation);
        confirmInput.addEventListener('input', runValidation);

        // Initialize disabled state
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.5';
    })();

    /* ── Sit-in Modal ── */
    function openSitinModal(id, idNumber, name, sessions) {
        document.getElementById('mUserId').value = id;
        document.getElementById('mIdNumber').textContent = idNumber;
        document.getElementById('mName').textContent = name;
        document.getElementById('mSessions').textContent = sessions + ' sessions';
        var m = document.getElementById('sitinModal');
        m.style.display = 'flex';
    }
    function closeSitinModal() {
        document.getElementById('sitinModal').style.display = 'none';
    }
    document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') return;
        closeEditModal();
        closeAddStudentModal();
        closeSitinModal();
    });

    /* ── Search ── */
    document.getElementById('studentSearch').addEventListener('input', function () {
        var q = this.value.toLowerCase();
        document.querySelectorAll('.stud-row').forEach(function (row) {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
        var visible = document.querySelectorAll('.stud-row:not([style*="none"])').length;
        document.getElementById('showingCount').innerHTML = 'Showing <strong>' + visible + '</strong> entries';
    });
</script>

