<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .stud-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .stud-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .stud-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
    }

    .stud-header::after {
        content: '';
        position: absolute;
        bottom: -60px;
        left: 20%;
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: rgba(91, 14, 20, 0.15);
    }

    .stud-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .stud-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .stud-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .stud-total-badge {
        background: rgba(241, 225, 148, 0.15);
        border: 1px solid rgba(241, 225, 148, 0.3);
        color: #F1E194;
        font-size: 12px;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 999px;
        letter-spacing: 0.04em;
    }

    .stud-toolbar {
        padding: 20px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        background: #F0EDE8;
        border-bottom: 1px solid #E2DDD8;
    }

    .stud-search-wrap {
        position: relative;
    }

    .stud-search-wrap svg {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        pointer-events: none;
        width: 15px;
        height: 15px;
    }

    .stud-search-wrap input {
        padding: 9px 14px 9px 36px;
        border: 1.5px solid #D6D0CA;
        border-radius: 10px;
        background: #fff;
        font-size: 13px;
        color: #1C2B35;
        outline: none;
        width: 220px;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .stud-search-wrap input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.1);
    }

    .btn-add-student {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 16px;
        background: linear-gradient(135deg, #059669, #047857);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s, transform 0.1s;
    }

    .btn-add-student:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .btn-reset-sessions {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 16px;
        background: #5B0E14;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background 0.15s, transform 0.1s;
        text-decoration: none;
    }

    .btn-reset-sessions:hover {
        background: #7a131b;
        transform: translateY(-1px);
    }

    .stud-table-wrap {
        padding: 0 32px 32px;
        background: #F0EDE8;
    }

    .stud-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
        border: 1px solid #E8E3DD;
    }

    table.stud-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .stud-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .stud-table th {
        padding: 14px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .stud-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .stud-table tbody tr:last-child {
        border-bottom: none;
    }

    .stud-table tbody tr:hover {
        background: #FAF9F7;
    }

    .stud-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .cell-avatar {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cell-avatar-img {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .cell-avatar-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .cell-name {
        font-weight: 600;
        color: #1C2B35;
        font-size: 13px;
        white-space: nowrap;
    }

    .cell-id {
        font-family: monospace;
        font-size: 11px;
        color: #9CA3AF;
        margin-top: 1px;
    }

    .cell-course {
        display: inline-flex;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
    }

    .cell-year {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        background: #F3F0EC;
        color: #4B5563;
    }

    .session-bar-wrap {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 80px;
    }

    .session-bar-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 6px;
    }

    .session-count {
        font-weight: 700;
        font-size: 13px;
        color: #1C2B35;
        min-width: 22px;
    }

    .session-bar {
        flex: 1;
        height: 5px;
        background: #E8E3DD;
        border-radius: 999px;
        overflow: hidden;
    }

    .session-bar-fill {
        height: 100%;
        border-radius: 999px;
        transition: width 0.3s ease;
    }

    .session-bar-fill.high {
        background: linear-gradient(90deg, #059669, #34D399);
    }

    .session-bar-fill.mid {
        background: linear-gradient(90deg, #D97706, #FBBF24);
    }

    .session-bar-fill.low {
        background: linear-gradient(90deg, #DC2626, #F87171);
    }

    .cell-actions {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-edit-row {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: linear-gradient(135deg, #273F4F, #1a2d38);
        color: #fff;
        text-decoration: none;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }

    .btn-edit-row:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .btn-sitin {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap;
    }

    .btn-sitin:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .stud-empty {
        padding: 64px 24px;
        text-align: center;
    }

    .stud-table-footer {
        padding: 14px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
    }

    /* ── Shared modal overlay ── */
    .stud-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }

    .stud-modal-overlay.open {
        display: flex;
    }

    .stud-modal-overlay.open .stud-modal-card {
        animation: studModalIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes studModalIn {
        from {
            opacity: 0;
            transform: scale(0.93) translateY(10px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .stud-modal-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.22), 0 0 0 1px rgba(0, 0, 0, 0.05);
        width: 100%;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
        max-height: 90vh;
        overflow-y: auto;
    }

    .stud-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
    }

    .stud-modal-close {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        transition: all 0.15s;
    }

    .stud-modal-close:hover {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
    }

    .modal-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .modal-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6B7280;
    }

    .modal-input {
        width: 100%;
        padding: 10px 13px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #F9F8F6;
        font-size: 13px;
        color: #1C2B35;
        outline: none;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
    }

    .modal-input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
        background: #fff;
    }

    .modal-input:disabled {
        background: #F3F4F6;
        color: #9CA3AF;
        cursor: not-allowed;
    }

    .modal-select {
        width: 100%;
        padding: 10px 32px 10px 13px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #F9F8F6;
        font-size: 13px;
        color: #1C2B35;
        appearance: none;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
        box-sizing: border-box;
    }

    .modal-select:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    .select-wrap {
        position: relative;
    }

    .select-wrap svg {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: #9CA3AF;
    }
</style>

<div class="stud-page">

    <!-- Header -->
    <div class="stud-header">
        <div class="stud-header-inner">
            <div>
                <h1>Students</h1>
                <p>All registered students in the CCS laboratory system</p>
            </div>
            <span class="stud-total-badge">
                <%= students ? students.length : 0 %> registered
            </span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="stud-toolbar">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">

            <!-- Add Student Account Button -->
            <button type="button" class="btn-add-student" onclick="openAddStudentModal()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                    <path
                        d="M8.75 3.75a.75.75 0 0 0-1.5 0v3.5h-3.5a.75.75 0 0 0 0 1.5h3.5v3.5a.75.75 0 0 0 1.5 0v-3.5h3.5a.75.75 0 0 0 0-1.5h-3.5v-3.5Z" />
                </svg>
                Add Student Account
            </button>

            <!-- Reset Sessions -->
            <form action="/admin/students/reset-sessions" method="POST" style="margin:0;display:inline-flex;" id="resetSessionsForm">
                <button type="button" class="btn-reset-sessions" onclick="showConfirmModal({title:'Reset All Sessions',message:'Reset ALL student sessions to 30? This will affect every student account.',type:'warning',confirmText:'Reset All',onConfirm:()=>{document.getElementById('resetSessionsForm').submit();}})">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12"
                        height="12">
                        <path fill-rule="evenodd"
                            d="M13.836 2.477a.75.75 0 0 1 .75.75v3.182a.75.75 0 0 1-.75.75h-3.182a.75.75 0 0 1 0-1.5h1.37l-.84-.841a4.5 4.5 0 0 0-7.08.932.75.75 0 0 1-1.3-.75 6 6 0 0 1 9.44-1.242l.842.84V3.227a.75.75 0 0 1 .75-.75Zm-.911 7.5A.75.75 0 0 1 13.199 11a6 6 0 0 1-9.44 1.241l-.84-.84v1.371a.75.75 0 0 1-1.5 0V9.591a.75.75 0 0 1 .75-.75H5.35a.75.75 0 0 1 0 1.5H3.98l.841.841a4.5 4.5 0 0 0 7.08-.932.75.75 0 0 1 1.025-.273Z"
                            clip-rule="evenodd" />
                    </svg>
                    Reset All Sessions
                </button>
            </form>
        </div>

        <div class="stud-search-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd"
                    d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                    clip-rule="evenodd" />
            </svg>
            <input type="text" id="studentSearch" placeholder="Search students...">
        </div>
    </div>

    <!-- Table -->
    <div class="stud-table-wrap">
        <div class="stud-table-card">
            <div style="overflow-x:auto;">
                <table class="stud-table">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>ID Number</th>
                            <th>Course</th>
                            <th>Year</th>
                            <th>Sessions Left</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="studentBody">
                        <% if (students && students.length> 0) { %>
                            <% students.forEach(function(s) { var sessions=s.remaining_sessions ?? 30; var
                                pct=Math.round((sessions / 30) * 100); var barClass=pct> 60 ? 'high' : pct > 30 ? 'mid'
                                : 'low';
                                var initials = (s.first_name ? s.first_name[0] : '') + (s.last_name ? s.last_name[0] :
                                '');
                                var mi = s.middle_initial ? ' ' + s.middle_initial + '.' : '';
                                var fullName = s.last_name + ', ' + s.first_name + mi;
                                %>
                                <tr class="stud-row">
                                    <td>
                                        <div class="cell-avatar">
                                            <div class="cell-avatar-img">
                                                <% if (s.profile_picture && s.profile_picture !=='' ) { %>
                                                    <img src="<%= s.profile_picture %>" alt="">
                                                    <% } else { %>
                                                        <%= initials.toUpperCase() %>
                                                            <% } %>
                                            </div>
                                            <div>
                                                <div class="cell-name">
                                                    <%= s.last_name %>, <%= s.first_name %>
                                                            <%= mi %>
                                                </div>
                                                <div class="cell-id">
                                                    <%= s.email %>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span
                                            style="font-family:monospace;font-size:12px;color:#4B5563;background:#F3F0EC;padding:3px 8px;border-radius:5px;">
                                            <%= s.id_number %>
                                        </span>
                                    </td>
                                    <td><span class="cell-course">
                                            <%= s.course %>
                                        </span></td>
                                    <td><span class="cell-year">
                                            <%= s.year_level %>
                                        </span></td>
                                    <td>
                                        <div class="session-bar-wrap">
                                            <div class="session-bar-row">
                                                <span class="session-count">
                                                    <%= sessions %>
                                                </span>
                                                <div class="session-bar">
                                                    <div class="session-bar-fill <%= barClass %>"
                                                        style="width:<%= Math.min(pct,100) %>%"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="cell-actions">
                                            <!-- Edit Button -->
                                            <button class="btn-edit-row" onclick="openEditModal(
                                                '<%= s.id %>',
                                                '<%= s.id_number %>',
                                                '<%= s.first_name %>',
                                                '<%= s.last_name %>',
                                                '<%= s.middle_initial || '' %>',
                                                '<%= s.course %>',
                                                '<%= s.year_level %>',
                                                '<%= s.email %>',
                                                '<%= (s.address || '').replace(/'/g, '') %>',
                                                '<%= sessions %>'
                                            )">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"
                                                    fill="currentColor" width="11" height="11">
                                                    <path
                                                        d="M2.04 9.367 8.9 2.504a2.121 2.121 0 0 1 3 3L4.96 12.367a2 2 0 0 1-.885.52l-3.164.853a.5.5 0 0 1-.61-.61l.853-3.164a2 2 0 0 1 .52-.885Z" />
                                                </svg>
                                                Edit
                                            </button>
                                            <!-- Sit-in Button -->
                                            <button class="btn-sitin"
                                                onclick="openSitinModal(this.dataset.id, this.dataset.idnumber, this.dataset.name, this.dataset.sessions)"
                                                data-id="<%= s.id %>" data-idnumber="<%= s.id_number %>"
                                                data-name='<%= fullName %>' data-sessions="<%= sessions %>">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"
                                                    fill="currentColor" width="11" height="11">
                                                    <path
                                                        d="M7 7a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM10.735 13c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                                </svg>
                                                Sit-in
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6">
                                                <div class="stud-empty">
                                                    <p style="font-size:14px;font-weight:600;color:#9CA3AF;margin:0;">No
                                                        students registered yet</p>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
            <div class="stud-table-footer">
                <span id="showingCount">Showing <strong>
                        <%= students ? students.length : 0 %>
                    </strong> entries</span>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════
     EDIT STUDENT MODAL
═══════════════════════════════════ -->
<div id="editStudentModal" class="stud-modal-overlay" onclick="if(event.target===this) closeEditModal()">
    <div class="stud-modal-card" style="max-width:520px;">

        <div class="stud-modal-header" style="background:linear-gradient(135deg,#273F4F,#1a2d38);">
            <div
                style="display:flex;align-items:center;gap:10px;font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:#fff;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="17" height="17">
                    <path
                        d="M2.695 14.763l-1.262 3.154a.5.5 0 0 0 .65.65l3.155-1.262a4 4 0 0 0 1.343-.885L17.5 5.5a2.121 2.121 0 0 0-3-3L3.58 13.42a4 4 0 0 0-.885 1.343Z" />
                </svg>
                Edit Student
            </div>
            <button class="stud-modal-close" onclick="closeEditModal()">✕</button>
        </div>

        <form id="editStudentForm" method="POST" style="padding:24px;display:flex;flex-direction:column;gap:14px;">
            <input type="hidden" name="_method" value="POST">

            <!-- ID Number (read-only) -->
            <div class="modal-field">
                <label class="modal-label">ID Number <span
                        style="color:#9CA3AF;font-weight:400;text-transform:none;">(read-only)</span></label>
                <input type="text" id="editIdNumber" class="modal-input" disabled>
            </div>

            <!-- Name row -->
            <div style="display:grid;grid-template-columns:1fr 1fr 80px;gap:10px;">
                <div class="modal-field">
                    <label class="modal-label">First Name <span style="color:#DC2626;">*</span></label>
                    <input type="text" name="first_name" id="editFirstName" class="modal-input" required>
                </div>
                <div class="modal-field">
                    <label class="modal-label">Last Name <span style="color:#DC2626;">*</span></label>
                    <input type="text" name="last_name" id="editLastName" class="modal-input" required>
                </div>
                <div class="modal-field">
                    <label class="modal-label">M.I.</label>
