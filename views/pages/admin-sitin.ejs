<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .sitin-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .sitin-header {
        padding: 28px 32px 20px;
        background: #F0EDE8;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        border-bottom: 1px solid #E2DDD8;
    }

    .sitin-header-left h1 {
        font-family: 'Syne', sans-serif;
        font-size: 26px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 4px;
        letter-spacing: -0.5px;
    }

    .sitin-header-left p {
        font-size: 13px;
        color: #9CA3AF;
        margin: 0;
    }

    .live-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 14px;
        background: #fff;
        border: 1.5px solid #DCFCE7;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        color: #059669;
        box-shadow: 0 2px 8px rgba(5, 150, 105, 0.1);
    }

    .live-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #10B981;
        animation: livePulse 1.5s ease-in-out infinite;
    }

    @keyframes livePulse {

        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.8);
        }
    }

    .sitin-card {
        margin: 16px 32px 32px;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
        border: 1px solid #E8E3DD;
    }

    .sitin-card-toolbar {
        padding: 14px 20px;
        border-bottom: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        background: #FAFAF9;
    }

    .sitin-search-wrap {
        position: relative;
    }

    .sitin-search-wrap svg {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        width: 13px;
        height: 13px;
        pointer-events: none;
    }

    .sitin-search-wrap input {
        padding: 8px 12px 8px 30px;
        border: 1.5px solid #E2DDD8;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 180px;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
    }

    .sitin-search-wrap input:focus {
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    table.sitin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .sitin-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #EDE9E4;
    }

    .sitin-table th {
        padding: 12px 14px;
        text-align: left;
        font-size: 9.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .sitin-table tbody tr {
        border-bottom: 1px solid #F7F5F2;
        transition: background 0.1s;
    }

    .sitin-table tbody tr:last-child {
        border-bottom: none;
    }

    .sitin-table tbody tr:hover {
        background: #FAFAF8;
    }

    .sitin-table td {
        padding: 13px 14px;
        vertical-align: middle;
    }

    .sit-id {
        font-family: monospace;
        font-size: 11px;
        color: #9CA3AF;
        background: #F3F0EC;
        padding: 3px 7px;
        border-radius: 5px;
    }

    .name-cell {
        display: flex;
        align-items: center;
        gap: 9px;
    }

    .name-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .name-text {
        font-size: 13px;
        font-weight: 600;
        color: #1C2B35;
        white-space: nowrap;
    }

    .purpose-tag {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .lab-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #1C2B35;
        color: #F1E194;
        white-space: nowrap;
    }

    .pc-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
        white-space: nowrap;
    }

    .pc-tag.no-pc {
        background: #F3F4F6;
        color: #9CA3AF;
    }

    .time-cell {
        font-size: 12px;
        color: #4B5563;
        font-weight: 500;
        font-variant-numeric: tabular-nums;
    }

    .status-active {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 7px;
        font-size: 10px;
        font-weight: 700;
        background: #ECFDF5;
        color: #059669;
        border: 1px solid #A7F3D0;
        white-space: nowrap;
    }

    .btn-logout {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        background: #FFF1F2;
        color: #BE123C;
        border: 1.5px solid #FECDD3;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background 0.15s, border-color 0.15s, transform 0.1s;
        white-space: nowrap;
    }

    .btn-logout:hover {
        background: #DC2626;
        border-color: #DC2626;
        color: #fff;
        transform: translateY(-1px);
    }

    .btn-edit-pc {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        background: #F0F9FF;
        color: #0369A1;
        border: 1.5px solid #BAE6FD;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .btn-edit-pc:hover {
        background: #0369A1;
        border-color: #0369A1;
        color: #fff;
        transform: translateY(-1px);
    }

    .btn-extend {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        background: #EEF2FF;
        color: #3730A3;
        border: 1.5px solid #C7D2FE;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .btn-extend:hover {
        background: #4F46E5;
        border-color: #4F46E5;
        color: #fff;
        transform: translateY(-1px);
    }

    .sitin-empty {
        padding: 72px 24px;
        text-align: center;
    }

    .sitin-card-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
    }

    /* ── Edit PC Modal ── */
    .edit-pc-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .edit-pc-overlay.open {
        display: flex;
    }

    .edit-pc-overlay.open .edit-pc-card {
        animation: epIn 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes epIn {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(20px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .edit-pc-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 860px;
        max-height: 90vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        font-family: 'DM Sans', sans-serif;
    }

    .edit-pc-header {
        background: linear-gradient(135deg, #0369A1, #0284C7);
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

    .edit-pc-close {
        width: 32px;
        height: 32px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 9px;
        color: rgba(255, 255, 255, 0.8);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.15s;
    }

    .edit-pc-close:hover {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
    }

    .edit-pc-legend {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 24px;
        background: #F7F5F2;
        border-bottom: 1px solid #E8E3DD;
        flex-wrap: wrap;
        font-size: 11px;
        font-weight: 600;
        color: #4B5563;
        flex-shrink: 0;
    }

    .edit-pc-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid;
    }

    .edit-pc-body {
        padding: 20px 24px;
        overflow-y: auto;
        flex: 1;
    }

    .pc-teacher-area {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        border-radius: 10px;
        padding: 10px 16px;
        text-align: center;
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .pc-row-label {
        font-size: 10px;
        font-weight: 700;
        color: #C4BDB6;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 14px 0 8px;
    }

    .pc-grid-10 {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 8px;
        margin-bottom: 4px;
    }

    .pc-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        padding: 8px 4px;
        border-radius: 10px;
        border: 2px solid transparent;
        transition: all 0.18s;
        position: relative;
    }

    .pc-unit:hover:not(.pc-defect) {
        border-color: #0369A1;
        background: rgba(3, 105, 161, 0.07);
        transform: translateY(-2px);
    }

    .pc-unit.selected {
        border-color: #0369A1 !important;
        background: rgba(3, 105, 161, 0.12) !important;
    }

    .pc-unit.pc-current {
        border-color: #059669 !important;
        background: rgba(5, 150, 105, 0.1) !important;
    }

    .pc-unit.pc-defect {
        cursor: not-allowed;
        opacity: 0.55;
    }

    .pc-unit.pc-occupied-other {
        cursor: not-allowed;
        opacity: 0.7;
    }

    .pc-icon-wrap {
        width: 38px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border: 2px solid;
    }

    .pc-avail .pc-icon-wrap {
        background: #ECFDF5;
        border-color: #A7F3D0;
    }

    .pc-in-use .pc-icon-wrap {
        background: #FFF7ED;
        border-color: #FDE68A;
    }

    .pc-defect .pc-icon-wrap {
        background: #FEF2F2;
        border-color: #FECACA;
    }

    .pc-reserved .pc-icon-wrap {
        background: #EFF6FF;
        border-color: #BFDBFE;
    }

    .pc-current .pc-icon-wrap {
        background: #ECFDF5;
        border-color: #6EE7B7;
    }

    .pc-status-dot {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    .pc-avail .pc-status-dot {
        background: #10B981;
    }

    .pc-in-use .pc-status-dot {
        background: #F59E0B;
        animation: livePulse 1.5s infinite;
    }

    .pc-defect .pc-status-dot {
        background: #DC2626;
    }

    .pc-reserved .pc-status-dot {
        background: #3B82F6;
    }

    .pc-current .pc-status-dot {
        background: #059669;
    }

    .pc-number {
        font-size: 9px;
        font-weight: 700;
    }

    .pc-avail .pc-number {
        color: #065F46;
    }

    .pc-in-use .pc-number {
        color: #92400E;
    }

    .pc-defect .pc-number {
        color: #991B1B;
    }

    .pc-reserved .pc-number {
        color: #1D4ED8;
    }

    .pc-current .pc-number {
        color: #065F46;
    }

    .pc-label {
        font-size: 7.5px;
        font-weight: 600;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .edit-pc-footer {
        padding: 14px 24px;
        border-top: 1px solid #E8E3DD;
        background: #FAFAF9;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        flex-shrink: 0;
    }

    .btn-save-pc {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        background: linear-gradient(135deg, #0369A1, #0284C7);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
    }

    .btn-save-pc:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .btn-clear-pc {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 16px;
        background: #F3F4F6;
        color: #6B7280;
        border: 1.5px solid #E5E7EB;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-clear-pc:hover {
        background: #E5E7EB;
    }

    /* ── Behavior Rating ── */
    .btn-rate {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        background: #FFF8F0;
        color: #92400E;
        border: 1.5px solid #FDE68A;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .btn-rate:hover {
        background: #F59E0B;
        border-color: #F59E0B;
        color: #fff;
        transform: translateY(-1px);
    }

    .rating-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 9px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
        cursor: pointer;
        border: none;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s;
    }

    .rating-badge:hover { opacity: 0.8; }

    .r5 { background:#ECFDF5; color:#065F46; }
    .r4 { background:#F0FDF4; color:#166534; }
    .r3 { background:#F3F4F6; color:#374151; }
    .r2 { background:#FFF7ED; color:#92400E; }
    .r1 { background:#FEF2F2; color:#991B1B; }

    /* Rating popover */
    .rate-popover {
        position: fixed;
        z-index: 99999;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.08);
        border: 1px solid #E8E3DD;
        padding: 16px;
        width: 260px;
        display: none;
        animation: ratePopIn 0.18s cubic-bezier(.34,1.56,.64,1) both;
    }

    .rate-popover.open { display: block; }

    @keyframes ratePopIn {
        from { opacity: 0; transform: scale(.92) translateY(6px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .rate-popover-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9CA3AF;
        margin: 0 0 12px;
    }

    .rate-option {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1.5px solid transparent;
        cursor: pointer;
        transition: all 0.12s;
        margin-bottom: 5px;
        background: #FAFAF9;
    }

    .rate-option:last-child { margin-bottom: 0; }

    .rate-option:hover { background: #F3F0EC; border-color: #E2DDD8; }
    .rate-option.active { border-color: currentColor; }

    .rate-option-emoji { font-size: 16px; }

    .rate-option-text {
        flex: 1;
    }

    .rate-option-label {
        font-size: 12px;
        font-weight: 700;
        color: #1C2B35;
    }

    .rate-option-sub {
        font-size: 10px;
        color: #9CA3AF;
        margin-top: 1px;
    }

    .rate-option-score {
        font-size: 18px;
        font-weight: 800;
        line-height: 1;
    }

    .extend-overlay {
        position: fixed;
        inset: 0;
        z-index: 100000;
        background: rgba(15, 23, 42, 0.62);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 14px;
    }

    .extend-overlay.open {
        display: flex;
    }

    .extend-card {
        width: 100%;
        max-width: 620px;
        background: #fff;
        border: 1px solid #E8E3DD;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
        overflow: hidden;
        animation: ratePopIn 0.18s ease-out both;
    }

    .extend-time-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 10px;
        align-items: center;
    }

    .extend-input {
        width: 100%;
        padding: 10px 12px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        font-size: 13px;
    }

    .extend-input:focus {
        outline: none;
        border-color: #273F4F;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    .extend-error {
        display: none;
        margin-top: 8px;
        font-size: 12px;
        color: #B91C1C;
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 8px;
        padding: 8px 10px;
    }

    .extend-meta {
        margin-top: 8px;
        font-size: 12px;
        color: #4B5563;
    }
</style>

<div class="sitin-page">

    <!-- Header -->
    <div class="sitin-header">
        <div class="sitin-header-left">
            <h1>Current Sit-in</h1>
            <p>Live view of students active in the laboratory</p>
        </div>
        <div class="live-pill">
            <span class="live-dot"></span>
            Live Session
        </div>
    </div>

    <!-- Table card -->
    <div class="sitin-card">

        <div class="sitin-card-toolbar">
            <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:6px;height:6px;border-radius:50%;background:#059669;"></div>
                    <span
                        style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6B7280;">Active
                        Sessions</span>
                </div>
                <form method="GET" action="/admin/sitin" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                    <input type="date" name="filter_date" value="<%= sitinFilters ? sitinFilters.filter_date : '' %>"
                        style="padding:7px 9px;border:1px solid #E2DDD8;border-radius:8px;font-size:11px;">
                    <button type="submit" class="btn-edit-pc">Filter</button>
                    <a href="/admin/sitin" class="btn-logout" style="text-decoration:none;">Clear</a>
                </form>
            </div>
            <div class="sitin-search-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                <input type="text" id="searchInput" placeholder="Search sessions...">
            </div>
        </div>

        <div style="overflow-x:auto;">
            <table class="sitin-table">
                <thead>
                    <tr>
                        <th>Sit ID</th>
                        <th>Student</th>
                        <th>ID Number</th>
                        <th>Course</th>
                        <th>Purpose</th>
                        <th>Lab</th>
                        <th>PC</th>
                        <th>Session</th>
                        <th>Time In</th>
                        <th>End Time</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="sitinBody">
                    <% if (typeof sessions !=='undefined' && sessions && sessions.length> 0) { %>
                        <% sessions.forEach(function(s) { %>
                            <% var initials=(s.first_name ? s.first_name[0] : '' ) + (s.last_name ? s.last_name[0] : ''
                                ); %>
                                <tr class="sitin-row">
                                    <td><span class="sit-id">#<%= s.id %></span></td>
                                    <td>
                                        <div class="name-cell">
                                            <div class="name-avatar">
                                                <%= initials.toUpperCase() %>
                                            </div>
                                            <div class="name-text">
                                                <%= s.last_name %>, <%= s.first_name %>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="font-family:monospace;font-size:12px;color:#4B5563;">
                                        <%= s.id_number %>
                                    </td>
                                    <td>
                                        <span
                                            style="display:inline-flex;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;">
                                            <%= s.course %>
                                        </span>
                                    </td>
                                    <td><span class="purpose-tag">
                                            <%= s.purpose || '—' %>
                                        </span></td>
                                    <td>
                                        <span class="lab-tag">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"
                                                fill="currentColor" width="10" height="10">
                                                <path fill-rule="evenodd"
                                                    d="M5 2a1 1 0 0 0-1 1v7.5a.5.5 0 0 0 .5.5h6a.5.5 0 0 0 .5-.5V5.621a1 1 0 0 0-.293-.707l-2.328-2.328A1 1 0 0 0 7.672 2H5Z"
                                                    clip-rule="evenodd" />
                                            </svg>
                                            <%= s.lab_room %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if (s.computer_number) { %>
                                            <span class="pc-tag">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"
                                                    fill="currentColor" width="10" height="10">
                                                    <path clip-rule="evenodd"
                                                        d="M1 3.25A2.25 2.25 0 0 1 3.25 1h7.5A2.25 2.25 0 0 1 13 3.25v5.5A2.25 2.25 0 0 1 10.75 11H8.59a2.5 2.5 0 0 1 .66 1.07.5.5 0 0 1-.482.68H5.23a.5.5 0 0 1-.482-.68A2.5 2.5 0 0 1 5.41 11H3.25A2.25 2.25 0 0 1 1 8.75v-5.5Z"
                                                        fill-rule="evenodd" />
                                                </svg>
                                                PC-<%= String(s.computer_number).padStart(2,'0') %>
                                            </span>
                                            <% } else { %>
                                                <span class="pc-tag no-pc">No PC</span>
                                                <% } %>
                                    </td>
                                    <td>
                                        <span
                                            style="font-size:13px;font-weight:700;color:<%= (s.remaining_sessions ?? 30) > 10 ? '#059669' : '#DC2626' %>;">
                                            <%= s.remaining_sessions ?? 30 %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="time-cell">
                                            <%= s.time_in ? new Date(s.time_in).toLocaleTimeString('en-US',
                                                {hour:'2-digit', minute:'2-digit'}) : '—' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="time-cell">
                                            <%= s.time_end ? new Date(s.time_end).toLocaleTimeString('en-US',
                                                {hour:'2-digit', minute:'2-digit'}) : '—' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-active">
                                            <span
                                                style="width:5px;height:5px;background:#10B981;border-radius:50%;animation:livePulse 1.5s ease-in-out infinite;"></span>
                                            Active
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;min-width:140px;">
                                            <!-- Edit PC button -->
                                            <button class="btn-edit-pc"
                                                onclick="openEditPcModal(<%= s.id %>, '<%= s.lab_room %>', <%= s.computer_number || 'null' %>)">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"
                                                    fill="currentColor" width="11" height="11">
                                                    <path clip-rule="evenodd"
                                                        d="M1 3.25A2.25 2.25 0 0 1 3.25 1h7.5A2.25 2.25 0 0 1 13 3.25v5.5A2.25 2.25 0 0 1 10.75 11H8.59a2.5 2.5 0 0 1 .66 1.07.5.5 0 0 1-.482.68H5.23a.5.5 0 0 1-.482-.68A2.5 2.5 0 0 1 5.41 11H3.25A2.25 2.25 0 0 1 1 8.75v-5.5Z"
                                                        fill-rule="evenodd" />
                                                </svg>
                                                Edit PC
                                            </button>
                                            <button type="button" class="btn-extend"
                                                onclick='openExtendModal(
                                                    <%= s.id %>,
                                                    <%- JSON.stringify(`${s.last_name}, ${s.first_name}`) %>,
                                                    <%- JSON.stringify(s.lab_room || '') %>,
                                                    <%- JSON.stringify(String(s.computer_number || '')) %>,
                                                    <%- JSON.stringify(s.time_in || '') %>,
                                                    <%- JSON.stringify(s.time_end || '') %>
                                                )'>
                                                Extend
                                            </button>
                                            <!-- Rate Behavior -->
                                            <% var br = s.behavior_rating; %>
                                            <% var rMeta = {5:{lbl:'Excellent',emoji:'⭐',cls:'r5'},4:{lbl:'Good',emoji:'👍',cls:'r4'},3:{lbl:'Neutral',emoji:'😐',cls:'r3'},2:{lbl:'Poor',emoji:'⚠️',cls:'r2'},1:{lbl:'Disruptive',emoji:'🚫',cls:'r1'}}; %>
                                            <button
                                                id="rate-btn-<%= s.id %>"
                                                class="<%= br ? 'rating-badge ' + rMeta[br].cls : 'btn-rate' %>"
                                                onclick="openRatePopover(event, <%= s.id %>, <%= br || 'null' %>)"
                                                title="Rate student behavior">
                                                <%= br ? (rMeta[br].emoji + ' ' + rMeta[br].lbl) : '⭐ Rate' %>
                                            </button>
                                            <!-- Logout -->
                                            <form action="/admin/sitin/<%= s.id %>/end" method="POST"
                                                onsubmit="return confirm('Log out this student from the lab?')">
                                                <button type="submit" class="btn-logout">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"
                                                        fill="currentColor" width="11" height="11">
                                                        <path fill-rule="evenodd"
                                                            d="M2 3.75A1.75 1.75 0 0 1 3.75 2h4a1.75 1.75 0 0 1 1.75 1.75v.5a.75.75 0 0 1-1.5 0v-.5a.25.25 0 0 0-.25-.25h-4a.25.25 0 0 0-.25.25v6.5c0 .138.112.25.25.25h4a.25.25 0 0 0 .25-.25v-.5a.75.75 0 0 1 1.5 0v.5A1.75 1.75 0 0 1 7.75 12h-4A1.75 1.75 0 0 1 2 10.25v-6.5Zm9.22.97a.75.75 0 0 1 1.06 0l1.75 1.75a.75.75 0 0 1 0 1.06l-1.75 1.75a.75.75 0 1 1-1.06-1.06l.47-.47H5.75a.75.75 0 0 1 0-1.5h5.69l-.47-.47a.75.75 0 0 1 0-1.06Z"
                                                            clip-rule="evenodd" />
                                                    </svg>
                                                    Log Out
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="12">
                                                <div class="sitin-empty">
                                                    <div
                                                        style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#F3F0EC,#E8E3DD);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                            fill="#C4BDB6" width="28" height="28">
                                                            <path fill-rule="evenodd"
                                                                d="M8.25 6.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM15.75 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM2.25 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM6.31 15.117A6.745 6.745 0 0 1 12 12a6.745 6.745 0 0 1 6.709 7.498.75.75 0 0 1-.372.568A12.696 12.696 0 0 1 12 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 0 1-.372-.568 6.787 6.787 0 0 1 1.019-4.38Z"
                                                                clip-rule="evenodd" />
                                                        </svg>
                                                    </div>
                                                    <p
                                                        style="font-size:15px;font-weight:700;color:#4B5563;margin:0 0 4px;">
                                                        No active sessions</p>
                                                    <p style="font-size:12px;color:#9CA3AF;margin:0;">Students will
                                                        appear here once they sit in</p>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                </tbody>
            </table>
        </div>

        <div class="sitin-card-footer">
            <span>Showing <strong id="countDisplay">
                    <%= sessions ? sessions.length : 0 %>
                </strong> active entries</span>
            <span style="font-size:11px;color:#C4BDB6;">Auto-refreshes when you navigate back</span>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     EDIT PC MODAL
══════════════════════════════════════ -->
<div id="editPcModal" class="edit-pc-overlay" onclick="if(event.target===this) closeEditPcModal()">
    <div class="edit-pc-card">
        <div class="edit-pc-header">
            <div style="display:flex;align-items:center;gap:14px;">
                <div
                    style="width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="white" width="22" height="22">
                        <path clip-rule="evenodd"
                            d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z"
                            fill-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p style="font-family:'Syne',sans-serif;font-size:17px;font-weight:800;color:#fff;margin:0 0 2px;"
                        id="editPcTitle">Edit PC Assignment</p>
                    <p style="font-size:11px;color:rgba(255,255,255,0.55);margin:0;" id="editPcSub">Select a new PC or
                        clear the assignment</p>
                </div>
            </div>
            <button class="edit-pc-close" onclick="closeEditPcModal()">✕</button>
        </div>

        <div class="edit-pc-legend">
            <div class="edit-pc-legend-item">
                <div class="legend-dot" style="background:#10B981;border-color:#A7F3D0;"></div>Available
            </div>
            <div class="edit-pc-legend-item">
                <div class="legend-dot" style="background:#059669;border-color:#6EE7B7;"></div>Current PC
            </div>
            <div class="edit-pc-legend-item">
                <div class="legend-dot" style="background:#F59E0B;border-color:#FDE68A;"></div>In Use (other)
            </div>
            <div class="edit-pc-legend-item">
                <div class="legend-dot" style="background:#3B82F6;border-color:#BFDBFE;"></div>Reserved
            </div>
            <div class="edit-pc-legend-item">
                <div class="legend-dot" style="background:#DC2626;border-color:#FECACA;"></div>Defective
            </div>
            <span style="margin-left:auto;font-size:11px;color:#9CA3AF;font-style:italic;">Click any available PC
                (including current) to select</span>
        </div>

        <div class="edit-pc-body" id="editPcBody">
            <div style="text-align:center;padding:40px;color:#9CA3AF;">Loading PC layout…</div>
        </div>

        <div class="edit-pc-footer">
            <div>
                <div style="font-size:12px;color:#9CA3AF;margin-bottom:2px;">Selected:</div>
                <div style="font-size:13px;font-weight:700;color:#1C2B35;" id="editPcSelectedLabel">None</div>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
                <button class="btn-clear-pc" onclick="clearPcSelection()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12"
                        height="12">
                        <path
                            d="M5.28 4.22a.75.75 0 0 0-1.06 1.06L6.94 8l-2.72 2.72a.75.75 0 1 0 1.06 1.06L8 9.06l2.72 2.72a.75.75 0 1 0 1.06-1.06L9.06 8l2.72-2.72a.75.75 0 0 0-1.06-1.06L8 6.94 5.28 4.22Z" />
                    </svg>
                    Clear (No PC)
                </button>
                <form id="editPcForm" method="POST" style="margin:0;">
                    <input type="hidden" name="computer_number" id="editPcInput">
                    <button type="submit" class="btn-save-pc">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13"
                            height="13">
                            <path fill-rule="evenodd"
                                d="M12.416 3.376a.75.75 0 0 1 .208 1.04l-5 7.5a.75.75 0 0 1-1.154.114l-3-3a.75.75 0 0 1 1.06-1.06l2.353 2.353 4.493-6.74a.75.75 0 0 1 1.04-.207Z"
                                clip-rule="evenodd" />
                        </svg>
                        Save PC Assignment
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Extend Session Modal -->
<div id="extendOverlay" class="extend-overlay" onclick="if(event.target===this) closeExtendModal()">
    <div class="extend-card">
        <div style="padding:16px 18px;border-bottom:1px solid #F3F0EC;background:#FAFAF9;display:flex;align-items:center;justify-content:space-between;">
            <div>
                <div style="font-size:16px;font-weight:800;color:#1C2B35;">Extend Session</div>
                <div style="font-size:12px;color:#9CA3AF;">Select your extend time slot</div>
            </div>
            <button type="button" onclick="closeExtendModal()" class="edit-pc-close" style="background:#fff;border-color:#E2E8F0;color:#94A3B8;">✕</button>
        </div>
        <div style="padding:14px 18px;border-bottom:1px solid #F3F0EC;background:#FFF9F0;">
            <div id="extendInfo" style="font-size:12px;color:#374151;line-height:1.6;">—</div>
        </div>
        <form id="extendForm" method="POST" style="padding:18px;">
            <div class="extend-time-grid">
                <input type="datetime-local" id="extendStartInput" name="start_time" class="extend-input" oninput="updateExtendDuration()">
                <div style="color:#9CA3AF;font-size:14px;font-weight:700;">→</div>
                <input type="datetime-local" id="extendEndInput" name="end_time" class="extend-input" oninput="updateExtendDuration()">
            </div>
            <div id="extendError" class="extend-error">Maximum extension is 3 hours only</div>
            <div id="extendDuration" class="extend-meta">Duration: —</div>
            <div style="margin-top:14px;display:flex;gap:8px;justify-content:flex-end;">
                <button type="button" class="btn-clear-pc" onclick="closeExtendModal()">Cancel</button>
                <button type="submit" id="extendSubmitBtn" class="btn-save-pc" disabled>Extend</button>
            </div>
        </form>
    </div>
</div>

<script>
    // ── Search ──────────────────────────────────────────────────────────────────
    document.getElementById('searchInput').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        let count = 0;
        document.querySelectorAll('.sitin-row').forEach(row => {
            const show = row.textContent.toLowerCase().includes(q);
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        document.getElementById('countDisplay').textContent = count;
    });

    let extendState = {
        sessionId: null,
        currentEnd: null
    };

    function toInputDateTime(sqlDateTime) {
        if (!sqlDateTime) return '';
        const d = new Date(sqlDateTime);
        if (Number.isNaN(d.getTime())) return '';
        const pad = (n) => String(n).padStart(2, '0');
        return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    function openExtendModal(sessionId, studentName, labRoom, pcNum, timeIn, timeEnd) {
        extendState.sessionId = sessionId;
        const baseStart = timeEnd ? new Date(timeEnd) : new Date(new Date(timeIn).getTime() + (2 * 60 * 60 * 1000));
        const defaultEnd = new Date(baseStart.getTime() + (30 * 60 * 1000));
        extendState.currentEnd = baseStart;

        document.getElementById('extendInfo').textContent =
            `${studentName} • Lab ${labRoom} • PC-${String(pcNum || '').padStart(2, '0')} • Current End: ${baseStart.toLocaleString()}`;
        document.getElementById('extendStartInput').value = toInputDateTime(baseStart);
        document.getElementById('extendEndInput').value = toInputDateTime(defaultEnd);

        const form = document.getElementById('extendForm');
        form.action = `/admin/sitin/${sessionId}/extend`;
        document.getElementById('extendOverlay').classList.add('open');
        updateExtendDuration();
    }

    function closeExtendModal() {
        document.getElementById('extendOverlay').classList.remove('open');
        extendState = { sessionId: null, currentEnd: null };
        const btn = document.getElementById('extendSubmitBtn');
        btn.disabled = true;
        btn.textContent = 'Extend';
        btn.style.opacity = '';
    }

    function updateExtendDuration() {
        const startVal = document.getElementById('extendStartInput').value;
        const endVal = document.getElementById('extendEndInput').value;
        const errorEl = document.getElementById('extendError');
        const durationEl = document.getElementById('extendDuration');
        const submitBtn = document.getElementById('extendSubmitBtn');

        errorEl.style.display = 'none';
        submitBtn.disabled = true;
        if (!startVal || !endVal) {
            durationEl.textContent = 'Duration: —';
            return;
        }
        const start = new Date(startVal);
        const end = new Date(endVal);
        const diffMinutes = Math.floor((end - start) / 60000);

        if (extendState.currentEnd && start < extendState.currentEnd) {
            errorEl.textContent = 'Start time must be at or after the current end time';
            errorEl.style.display = 'block';
            durationEl.textContent = 'Duration: —';
            return;
        }
        if (diffMinutes <= 0) {
            errorEl.textContent = 'End time must be after start time';
            errorEl.style.display = 'block';
            durationEl.textContent = 'Duration: —';
            return;
        }
        if (diffMinutes > 180) {
            errorEl.textContent = 'Maximum extension is 3 hours only';
            errorEl.style.display = 'block';
            durationEl.textContent = 'Duration: —';
            return;
        }

        const hours = Math.floor(diffMinutes / 60);
        const mins = diffMinutes % 60;
        durationEl.textContent = `Duration: ${hours ? `${hours} hour${hours > 1 ? 's' : ''}` : ''}${hours && mins ? ' ' : ''}${mins ? `${mins} minute${mins > 1 ? 's' : ''}` : ''}`;
        submitBtn.disabled = false;
    }

    document.getElementById('extendForm').addEventListener('submit', function (e) {
        const submitBtn = document.getElementById('extendSubmitBtn');
        if (submitBtn.disabled) {
            e.preventDefault();
            return;
        }
        submitBtn.disabled = true;
        submitBtn.textContent = 'Extending...';
        submitBtn.style.opacity = '0.7';
    });

    // ── Edit PC Modal state ─────────────────────────────────────────────────────
    let editSessionId = null;
    let editLabRoom = null;
    let editCurrentPc = null;
    let editSelectedPc = null; // null = clear, number = selected

    async function openEditPcModal(sessionId, labRoom, currentPc) {
        editSessionId = sessionId;
        editLabRoom = labRoom;
        editCurrentPc = currentPc;
        editSelectedPc = currentPc; // default to current

        document.getElementById('editPcTitle').textContent = `Edit PC — Session #${sessionId}`;
        document.getElementById('editPcSub').textContent = `Lab ${labRoom}${currentPc ? ` · Currently on PC-${String(currentPc).padStart(2, '0')}` : ' · No PC assigned'}`;
        document.getElementById('editPcModal').classList.add('open');
        document.getElementById('editPcBody').innerHTML = '<div style="text-align:center;padding:40px;color:#9CA3AF;">Loading PC layout…</div>';

        updateEditPcForm();
        await loadEditPcGrid(labRoom, currentPc);
    }

    function closeEditPcModal() {
        document.getElementById('editPcModal').classList.remove('open');
        editSessionId = null;
        editLabRoom = null;
        editCurrentPc = null;
        editSelectedPc = null;
    }

    function clearPcSelection() {
        editSelectedPc = null;
        updateEditPcForm();
        // Re-highlight grid
        document.querySelectorAll('.pc-unit').forEach(el => el.classList.remove('selected'));
        document.getElementById('editPcSelectedLabel').textContent = 'None (will clear PC assignment)';
    }

    function updateEditPcForm() {
        const form = document.getElementById('editPcForm');
        form.action = `/admin/sitin/${editSessionId}/edit-pc`;
        document.getElementById('editPcInput').value = editSelectedPc || '';
        document.getElementById('editPcSelectedLabel').textContent = editSelectedPc
            ? `PC-${String(editSelectedPc).padStart(2, '0')}`
            : 'None (clear assignment)';
    }

    async function loadEditPcGrid(labRoom, currentPc) {
        try {
            const res = await fetch(`/lab-computers/${labRoom}`);
            const data = await res.json();
            const pcMap = {};
            data.forEach(pc => { pcMap[pc.computer_number] = pc; });
            renderEditPcGrid(labRoom, pcMap, currentPc);
        } catch (e) {
            document.getElementById('editPcBody').innerHTML =
                '<div style="text-align:center;padding:40px;color:#DC2626;">Failed to load PC data.</div>';
        }
    }

    function pcSvgColor(color) {
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="${color}" width="20" height="20"><path clip-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 1 1.1 1.677A.75.75 0 0 1 13 17.5H7a.75.75 0 0 1-.745-.823A3.501 3.501 0 0 1 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Z" fill-rule="evenodd"/></svg>`;
    }

    function renderEditPcGrid(labRoom, pcMap, currentPc) {
        const totalPcs = 50;
        const rows = 5, cols = 10;
        let html = `<div class="pc-teacher-area">🖥 Teacher / Instructor Station</div>`;
        let pcNum = 1;

        for (let row = 0; row < rows; row++) {
            const rowLetter = String.fromCharCode(65 + row);
            html += `<div class="pc-row-label">Row ${rowLetter}</div><div class="pc-grid-10">`;

            for (let col = 0; col < cols && pcNum <= totalPcs; col++) {
                const pc = pcMap[pcNum] || { status: 'available' };
                const isCurrent = pcNum === currentPc;
                const status = pc.status || 'available';

                let unitClass, iconColor, labelText, canClick;

                if (isCurrent) {
                    unitClass = 'pc-unit pc-current';
                    iconColor = '#059669';
                    labelText = 'Current';
                    canClick = true;
                } else if (status === 'available') {
                    unitClass = 'pc-unit pc-avail';
                    iconColor = '#059669';
                    labelText = 'Free';
                    canClick = true;
                } else if (status === 'in_use') {
                    unitClass = 'pc-unit pc-in-use pc-occupied-other';
                    iconColor = '#D97706';
                    labelText = 'In Use';
                    canClick = false;
                } else if (status === 'reserved') {
                    unitClass = 'pc-unit pc-reserved';
                    iconColor = '#2563EB';
                    labelText = 'Reserved';
                    canClick = true; // admin can override
                } else {
                    unitClass = 'pc-unit pc-defect';
                    iconColor = '#DC2626';
                    labelText = 'Defective';
                    canClick = false;
                }

                const clickAttr = canClick ? `onclick="selectEditPc(${pcNum})"` : '';
                const selectedClass = (editSelectedPc === pcNum) ? ' selected' : '';

                html += `
                <div class="${unitClass}${selectedClass}" id="epc-${pcNum}" data-pc="${pcNum}" ${clickAttr}
                     title="PC-${String(pcNum).padStart(2, '0')} — ${labelText}">
                    <div class="pc-icon-wrap">
                        ${pcSvgColor(iconColor)}
                        <span class="pc-status-dot"></span>
                    </div>
                    <span class="pc-number">PC-${String(pcNum).padStart(2, '0')}</span>
                    <span class="pc-label">${labelText}</span>
                </div>`;
                pcNum++;
            }
            html += `</div>`;
        }

        document.getElementById('editPcBody').innerHTML = html;
        // Restore selection highlight
        if (editSelectedPc) {
            const el = document.getElementById(`epc-${editSelectedPc}`);
            if (el) el.classList.add('selected');
        }
    }

    function selectEditPc(pcNum) {
        document.querySelectorAll('.pc-unit').forEach(el => el.classList.remove('selected'));
        editSelectedPc = pcNum;
        const el = document.getElementById(`epc-${pcNum}`);
        if (el) el.classList.add('selected');
        updateEditPcForm();
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeEditPcModal(); closeRatePopover(); closeExtendModal(); }
    });

    // ── Behavior Rating Popover ──
    const RATINGS = [
        { score: 5, emoji: '⭐', label: 'Excellent',   sub: 'Fully focused, working on task',    cls: 'r5', color: '#065F46' },
        { score: 4, emoji: '👍', label: 'Good',        sub: 'Mostly productive, minor distraction', cls: 'r4', color: '#166534' },
        { score: 3, emoji: '😐', label: 'Neutral',     sub: 'Mixed activity, unclear intent',   cls: 'r3', color: '#374151' },
        { score: 2, emoji: '⚠️', label: 'Poor',        sub: 'Mostly gaming or off-task browsing', cls: 'r2', color: '#92400E' },
        { score: 1, emoji: '🚫', label: 'Disruptive',  sub: 'Violating lab rules or misleading', cls: 'r1', color: '#991B1B' },
    ];

    let ratePopSessionId = null;
    const ratePopover = document.createElement('div');
    ratePopover.className = 'rate-popover';
    ratePopover.innerHTML = `
        <p class="rate-popover-title">Rate Behavior</p>
        ${RATINGS.map(r => `
            <div class="rate-option" data-score="${r.score}" onclick="submitRating(${r.score})" style="color:${r.color};">
                <span class="rate-option-emoji">${r.emoji}</span>
                <div class="rate-option-text">
                    <div class="rate-option-label">${r.label}</div>
                    <div class="rate-option-sub">${r.sub}</div>
                </div>
                <span class="rate-option-score">${r.score}</span>
            </div>
        `).join('')}
    `;
    document.body.appendChild(ratePopover);

    function openRatePopover(event, sessionId, currentRating) {
        event.stopPropagation();
        closeEditPcModal();

        ratePopSessionId = sessionId;

        ratePopover.querySelectorAll('.rate-option').forEach(opt => {
            const s = parseInt(opt.dataset.score);
            opt.classList.toggle('active', s === currentRating);
        });

        const btn = event.currentTarget;
        const rect = btn.getBoundingClientRect();
        
        // Show temporarily (invisible) to get true dimensions
        ratePopover.style.visibility = 'hidden';
        ratePopover.classList.add('open');
        const pw = ratePopover.offsetWidth || 260;
        const ph = ratePopover.offsetHeight || 330;
        ratePopover.style.visibility = 'visible';

        let top = rect.bottom + 6;
        let left = rect.left;
        
        if (left + pw > window.innerWidth - 12) left = window.innerWidth - pw - 12;
        if (left < 12) left = 12;

        // Flip up if it exceeds bottom of viewport
        if (top + ph > window.innerHeight - 12) {
            top = rect.top - ph - 6;
            if (top < 12) top = 12;
        }

        ratePopover.style.top  = top + 'px';
        ratePopover.style.left = left + 'px';
    }

    function closeRatePopover() {
        ratePopover.classList.remove('open');
        ratePopSessionId = null;
    }

    document.addEventListener('click', e => {
        if (!ratePopover.contains(e.target)) closeRatePopover();
    });

    async function submitRating(score) {
        if (!ratePopSessionId) return;
        const sid = ratePopSessionId;
        closeRatePopover();

        try {
            const res = await fetch(`/admin/sitin/${sid}/rate`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ rating: score })
            });
            const data = await res.json();
            if (!data.success) throw new Error(data.error);

            // Update the button badge in place
            const r = RATINGS.find(x => x.score === score);
            const btn = document.getElementById(`rate-btn-${sid}`);
            if (btn && r) {
                btn.className = `rating-badge ${r.cls}`;
                btn.textContent = `${r.emoji} ${r.label}`;
                // Update onclick to pass current rating
                btn.setAttribute('onclick', `openRatePopover(event, ${sid}, ${score})`);
            }
        } catch (err) {
            if (window.showAppToast) window.showAppToast('error', 'Failed to save rating. Please try again.');
        }
    }
</script>