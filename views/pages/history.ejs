<div class="p-6">

    <div class="mb-6">
        <h1 class="text-2xl font-extrabold text-[#273F4F]">Sit-in History</h1>
        <p class="text-gray-500 text-sm mt-1">Your complete laboratory sit-in records.</p>
    </div>

    <!-- ── Flash toast for vulgar word / feedback errors shown by session toast partial ── -->

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

        <!-- Table toolbar -->
        <div class="px-6 py-4 border-b border-gray-100 flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#5B0E14]"></div>
                <span class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">History Information</span>
            </div>
            <div class="flex flex-wrap items-center justify-end gap-4 sm:gap-8 mt-4 sm:mt-0">
                <div class="flex items-center gap-3">
                    <label class="text-xs text-gray-500 whitespace-nowrap">Show entries</label>
                    <select id="entriesPerPage"
                        class="border border-gray-300 rounded-lg px-3 py-2 text-xs text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#273F4F] bg-white cursor-pointer">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="flex items-center gap-3">
                    <input type="text" id="searchInput" placeholder="Search..."
                        class="border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#273F4F] bg-white w-full sm:w-52">
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-100">
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            ID Number</th>
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            Name</th>
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            Purpose</th>
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            Laboratory</th>
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            Login</th>
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            Logout</th>
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            Date</th>
                        <th
                            class="px-4 py-3 text-left text-xs font-bold text-[#273F4F] uppercase tracking-wider whitespace-nowrap">
                            Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">

                    <% var safeSessions=(typeof sessions !=='undefined' && sessions) ? sessions : []; %>

                        <% if (safeSessions.length> 0) { %>
                            <% safeSessions.forEach(function(s) { %>
                                <tr class="hover:bg-gray-50 transition-colors history-row">
                                    <td class="px-4 py-3 font-mono text-xs text-gray-600 whitespace-nowrap">
                                        <%= user.id_number %>
                                    </td>
                                    <td class="px-4 py-3 text-gray-700 text-xs whitespace-nowrap">
                                        <%= user.last_name %>, <%= user.first_name %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span
                                            class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 whitespace-nowrap">
                                            <%= s.purpose || '—' %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-xs whitespace-nowrap">
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-lg text-xs font-bold bg-[#273F4F]/10 text-[#273F4F]">
                                            <%= s.lab_room || '—' %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
                                        <%= s.time_in ? new Date(s.time_in).toLocaleTimeString('en-US', {hour:'2-digit',
                                            minute:'2-digit'}) : '—' %>
                                    </td>
                                    <td class="px-4 py-3 text-xs whitespace-nowrap">
                                        <% if (s.time_out) { %>
                                            <span class="text-gray-600">
                                                <%= new Date(s.time_out).toLocaleTimeString('en-US', {hour:'2-digit',
                                                    minute:'2-digit'}) %>
                                            </span>
                                            <% } else { %>
                                                <span
                                                    class="inline-flex items-center gap-1 text-green-600 font-medium text-xs">
                                                    <span
                                                        class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>Active
                                                </span>
                                                <% } %>
                                    </td>
                                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">
                                        <%= s.time_in ? new Date(s.time_in).toLocaleDateString('en-US', {year:'numeric',
                                            month:'short', day:'numeric'}) : '—' %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <% if (s.status==='done' ) { %>
                                            <% if (s.has_feedback) { %>
                                            <button disabled
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold text-white whitespace-nowrap opacity-60 cursor-not-allowed"
                                                style="background: linear-gradient(135deg, #059669, #047857);">
                                                ✓ Submitted
                                            </button>
                                            <% } else { %>
                                            <button onclick="openFeedbackModal('<%= s.id %>')"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold text-white transition-all hover:-translate-y-0.5 whitespace-nowrap"
                                                style="background: linear-gradient(135deg, #059669, #047857);">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                    fill="currentColor" class="size-3">
                                                    <path fill-rule="evenodd"
                                                        d="M1 8.74c0 .983.713 1.825 1.69 1.943L3 10.72v2.03a.75.75 0 0 0 1.28.53l1.5-1.5.31-.03H9a2.26 2.26 0 0 0 2.25-2.25v-5.5A2.25 2.25 0 0 0 9 1.75H4A2.25 2.25 0 0 0 1.75 4v4.74H1Z"
                                                        clip-rule="evenodd" />
                                                </svg>
                                                Submit
                                            </button>
                                            <% } %>
                                            <% } else { %>
                                                <span class="text-xs text-gray-400">—</span>
                                                <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="8" class="px-4 py-16 text-center">
                                                <div class="flex flex-col items-center gap-3">
                                                    <div
                                                        class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                            fill="currentColor" class="size-7 text-gray-300">
                                                            <path fill-rule="evenodd"
                                                                d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z"
                                                                clip-rule="evenodd" />
                                                        </svg>
                                                    </div>
                                                    <p class="text-sm text-gray-400 font-medium">No sit-in history
                                                        found.</p>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-gray-100 text-xs text-gray-500">
            Showing <span class="font-semibold text-gray-700">
                <%= safeSessions.length %>
            </span> entries
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════
     FEEDBACK MODAL — Fixed star rating UX
════════════════════════════════════════════ -->
<div id="feedbackModal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeFeedbackModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">

        <!-- Header -->
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between"
            style="background: linear-gradient(135deg, #5B0E14, #3A0910);">
            <div style="display:flex;align-items:center;gap:10px;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#F1E194" width="18" height="18">
                    <path fill-rule="evenodd"
                        d="M10 2c-2.236 0-4.43.18-6.57.524C1.993 2.755 1 4.014 1 5.426v5.148c0 1.413.993 2.671 2.43 2.902.848.137 1.705.248 2.57.331v3.443a.75.75 0 0 0 1.28.53l3.58-3.579a.78.78 0 0 1 .527-.224 41.202 41.202 0 0 0 5.183-.5c1.437-.232 2.43-1.49 2.43-2.903V5.426c0-1.413-.993-2.67-2.43-2.902A41.289 41.289 0 0 0 10 2Z"
                        clip-rule="evenodd" />
                </svg>
                <h3 class="font-bold text-white text-base">Submit Feedback</h3>
            </div>
            <button onclick="closeFeedbackModal()"
                class="text-white/60 hover:text-white transition-colors cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
                    <path
                        d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
                </svg>
            </button>
        </div>

        <form action="/feedback" method="POST" class="p-6 space-y-5" id="feedbackForm">
            <input type="hidden" name="session_id" id="feedbackSessionId">

            <!-- ── Star Rating ── -->
            <div class="space-y-2">
                <label class="block text-sm font-bold text-gray-700">
                    Rating <span style="color:#9CA3AF;font-weight:400;">(click a star)</span>
                </label>

                <!-- Star row -->
                <div id="starRating" style="display:flex;gap:6px;align-items:center;">
                    <% for (var i=1; i <=5; i++) { %>
                        <button type="button" data-star="<%= i %>" class="star-btn"
                            style="font-size:32px;color:#D1D5DB;cursor:pointer;background:none;border:none;padding:2px;line-height:1;transition:color 0.15s,transform 0.1s;"
                            title="<%= i %> star<%= i > 1 ? 's' : '' %>">★</button>
                        <% } %>
                            <span id="ratingLabel"
                                style="font-size:12px;font-weight:600;color:#9CA3AF;margin-left:8px;min-width:80px;">
                                No rating
                            </span>
                </div>

                <!-- Hidden rating value -->
                <input type="hidden" name="rating" id="ratingInput" value="0">

                <!-- Clear rating button -->
                <button type="button" onclick="clearRating()"
                    style="font-size:11px;color:#9CA3AF;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;display:none;"
                    id="clearRatingBtn">
                    Clear rating
                </button>
            </div>

            <!-- ── Feedback Message ── -->
            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700">
                    Message <span style="color:#DC2626;">*</span>
                </label>
                <textarea name="message" rows="4" required
                    placeholder="Share your experience about the laboratory sit-in session..." id="feedbackMessage"
                    class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm resize-none transition-all"
                    oninput="updateCharCount(this)"></textarea>
                <div style="display:flex;justify-content:space-between;align-items:center;">
                    <span style="font-size:11px;color:#9CA3AF;" id="charCount">0 / 500 characters</span>
                    <!-- Profanity warning hint -->
                    <span style="font-size:10px;color:#9CA3AF;">⚠ Keep language respectful</span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex gap-3">
                <button type="submit" id="feedbackSubmitBtn"
                    style="flex:2;padding:12px;background:linear-gradient(135deg,#5B0E14,#7a131b);color:#fff;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;transition:opacity 0.15s;">
                    Submit Feedback
                </button>
                <button type="button" onclick="closeFeedbackModal()"
                    style="flex:1;padding:12px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .star-btn:hover {
        transform: scale(1.15);
    }
</style>

<script>
    /* ── Feedback Modal ── */
    function openFeedbackModal(sessionId) {
        document.getElementById('feedbackSessionId').value = sessionId;
        document.getElementById('feedbackModal').classList.remove('hidden');
        document.getElementById('feedbackModal').classList.add('flex');
        // Reset form state
        clearRating();
        document.getElementById('feedbackMessage').value = '';
        document.getElementById('charCount').textContent = '0 / 500 characters';
    }

    function closeFeedbackModal() {
        document.getElementById('feedbackModal').classList.add('hidden');
        document.getElementById('feedbackModal').classList.remove('flex');
    }

    /* ── Star Rating Logic ── */
    var RATING_LABELS = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
    var RATING_COLORS = ['', '#DC2626', '#F59E0B', '#3B82F6', '#059669', '#F59E0B'];
    var currentRating = 0;

    function setRating(val) {
        currentRating = val;
        document.getElementById('ratingInput').value = val;

        // Update star colors
        document.querySelectorAll('.star-btn').forEach(function (btn) {
            var s = parseInt(btn.dataset.star);
            btn.style.color = s <= val ? '#F59E0B' : '#D1D5DB';
            btn.style.textShadow = s <= val ? '0 0 8px rgba(245,158,11,0.4)' : 'none';
        });

        // Update label
        var label = document.getElementById('ratingLabel');
        label.textContent = RATING_LABELS[val] || 'No rating';
        label.style.color = RATING_COLORS[val] || '#9CA3AF';
        label.style.fontWeight = val > 0 ? '700' : '600';

        // Show/hide clear button
        document.getElementById('clearRatingBtn').style.display = val > 0 ? 'inline' : 'none';
    }

    function clearRating() {
        setRating(0);
    }

    /* ── Attach star click + hover events ── */
    document.querySelectorAll('.star-btn').forEach(function (star) {
        star.addEventListener('click', function () {
            setRating(parseInt(this.dataset.star));
        });

        star.addEventListener('mouseenter', function () {
            var hoverVal = parseInt(this.dataset.star);
            document.querySelectorAll('.star-btn').forEach(function (s) {
                s.style.color = parseInt(s.dataset.star) <= hoverVal ? '#FBBF24' : '#D1D5DB';
            });
        });

        star.addEventListener('mouseleave', function () {
            // Restore to currently selected rating
            document.querySelectorAll('.star-btn').forEach(function (s) {
                s.style.color = parseInt(s.dataset.star) <= currentRating ? '#F59E0B' : '#D1D5DB';
                s.style.textShadow = parseInt(s.dataset.star) <= currentRating ? '0 0 8px rgba(245,158,11,0.4)' : 'none';
            });
        });
    });

    /* ── Char counter ── */
    function updateCharCount(el) {
        var len = el.value.length;
        var counter = document.getElementById('charCount');
        counter.textContent = len + ' / 500 characters';
        counter.style.color = len > 450 ? '#DC2626' : '#9CA3AF';
        if (len > 500) {
            el.value = el.value.substring(0, 500);
            counter.textContent = '500 / 500 characters';
        }
    }

    /* ── Table search ── */
    document.getElementById('searchInput').addEventListener('input', function () {
        var q = this.value.toLowerCase();
        document.querySelectorAll('.history-row').forEach(function (row) {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    /* ── ESC closes modal ── */
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeFeedbackModal();
    });

    /* ── Submit loading/disabled state ── */
    document.getElementById('feedbackForm').addEventListener('submit', function () {
        var submitBtn = document.getElementById('feedbackSubmitBtn');
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
        submitBtn.textContent = 'Submitting...';
    });
</script>