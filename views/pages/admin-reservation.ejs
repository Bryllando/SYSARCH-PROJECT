<div class="min-h-screen bg-gray-50">

    <% var pending=reservations.filter(r=> r.status === 'pending').length;
        var approved = reservations.filter(r => r.status === 'approved').length;
        var rejected = reservations.filter(r => r.status === 'rejected').length;
        %>

        <!-- ── Header ── -->
        <div class="relative overflow-hidden px-8 py-7" style="background: linear-gradient(135deg, #1C2B35, #273F4F);">
            <div class="absolute -right-10 -top-10 w-44 h-44 rounded-full opacity-10 bg-white"></div>
            <div class="absolute -left-6 -bottom-8 w-32 h-32 rounded-full opacity-5 bg-white"></div>
            <div class="relative z-10 flex flex-wrap items-end justify-between gap-4">
                <div>
                    <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: rgba(241,225,148,0.7);">
                        Admin Panel</p>
                    <h1 class="text-3xl font-extrabold text-white tracking-tight">Reservations</h1>
                    <p class="text-sm mt-1" style="color: rgba(255,255,255,0.5);">Manage and approve student laboratory
                        reservation requests</p>
                </div>
            </div>
        </div>

        <!-- ── Stats ── -->
        <div class="flex flex-wrap gap-3 px-8 py-4 bg-gray-50 border-b border-gray-200">
            <div
                class="flex flex-1 min-w-28 items-center gap-3 bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 bg-amber-50">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#D97706" class="size-5">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.25V5Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-extrabold" style="color:#D97706;">
                        <%= pending %>
                    </p>
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Pending</p>
                </div>
            </div>
            <div
                class="flex flex-1 min-w-28 items-center gap-3 bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 bg-green-50">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#059669" class="size-5">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-green-600">
                        <%= approved %>
                    </p>
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Approved</p>
                </div>
            </div>
            <div
                class="flex flex-1 min-w-28 items-center gap-3 bg-white rounded-xl border border-gray-100 shadow-sm p-4">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 bg-red-50">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#DC2626" class="size-5">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-extrabold text-red-600">
                        <%= rejected %>
                    </p>
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Rejected</p>
                </div>
            </div>
            <div class="flex flex-1 min-w-28 items-center gap-3 bg-white rounded-xl border-l-4 border border-gray-100 shadow-sm p-4"
                style="border-left-color: #273F4F;">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style="background:#E8EFF4;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#273F4F" class="size-5">
                        <path fill-rule="evenodd"
                            d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-extrabold" style="color:#273F4F;">
                        <%= reservations.length %>
                    </p>
                    <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Total</p>
                </div>
            </div>
        </div>

        <!-- ── Toolbar ── -->
        <div class="flex flex-wrap items-center justify-between gap-3 px-8 py-4 bg-gray-50 border-b border-gray-200">
            <div class="flex items-center gap-2 flex-wrap">
                <select id="statusFilter"
                    class="cursor-pointer rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 outline-none">
                    <option value="">All Status</option>
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                </select>
                <select id="labFilter"
                    class="cursor-pointer rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 outline-none">
                    <option value="">All Labs</option>
                    <option value="524">Lab 524</option>
                    <option value="526">Lab 526</option>
                    <option value="528">Lab 528</option>
                    <option value="530">Lab 530</option>
                    <option value="Mac Lab">Mac Lab</option>
                </select>
            </div>
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-3.5 text-gray-400"
                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                <input type="text" id="searchInput" placeholder="Search reservations..."
                    class="rounded-xl border border-gray-300 bg-white py-2 pl-9 pr-4 text-xs text-gray-700 outline-none w-56 focus:border-gray-500">
            </div>
        </div>

        <!-- ── Table ── -->
        <div class="px-8 pb-8 pt-4">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm border-collapse">
                        <thead>
                            <tr class="bg-gray-50 border-b-2 border-gray-100">
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Student</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    ID Number</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Course</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Lab</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Purpose</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Date</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Time Slot</th>
                                <th
                                    class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Status</th>
                                <th
                                    class="px-4 py-3 text-center text-xs font-bold uppercase tracking-widest text-gray-500">
                                    Actions</th>
                            </tr>
                        </thead>
                        <tbody id="resBody" class="divide-y divide-gray-50">
                            <% if (reservations && reservations.length> 0) { %>
                                <% reservations.forEach(function(r) { var initials=(r.first_name ? r.first_name[0] : ''
                                    ) + (r.last_name ? r.last_name[0] : '' ); %>
                                    <tr class="res-row hover:bg-gray-50 transition-colors" data-status="<%= r.status %>"
                                        data-lab="<%= r.lab_room %>">

                                        <!-- Student -->
                                        <td class="px-4 py-4">
                                            <div class="flex items-center gap-2.5">
                                                <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-xs font-bold"
                                                    style="background: linear-gradient(135deg,#273F4F,#5B0E14); color:#F1E194;">
                                                    <%= initials.toUpperCase() %>
                                                </div>
                                                <span class="whitespace-nowrap text-xs font-semibold text-gray-800">
                                                    <%= r.last_name %>, <%= r.first_name %>
                                                </span>
                                            </div>
                                        </td>

                                        <!-- ID -->
                                        <td class="px-4 py-4">
                                            <span
                                                class="rounded-md bg-gray-100 px-2 py-1 font-mono text-xs text-gray-600">
                                                <%= r.id_number %>
                                            </span>
                                        </td>

                                        <!-- Course -->
                                        <td class="px-4 py-4">
                                            <span
                                                class="rounded-md bg-blue-50 px-2 py-1 text-xs font-bold text-blue-700">
                                                <%= r.course %>
                                            </span>
                                        </td>

                                        <!-- Lab -->
                                        <td class="px-4 py-4">
                                            <span class="rounded-md px-2 py-1 text-xs font-bold"
                                                style="background:#1C2B35; color:#F1E194;">
                                                <%= r.lab_room %>
                                            </span>
                                        </td>

                                        <!-- Purpose -->
                                        <td class="px-4 py-4 text-xs text-gray-600">
                                            <%= r.purpose || '—' %>
                                        </td>

                                        <!-- Date -->
                                        <td class="px-4 py-4 text-xs text-gray-600 whitespace-nowrap">
                                            <%= r.date %>
                                        </td>

                                        <!-- Time Slot -->
                                        <td class="px-4 py-4 text-xs text-gray-400 whitespace-nowrap">
                                            <%= r.time_slot %>
                                        </td>

                                        <!-- Status badge -->
                                        <td class="px-4 py-4">
                                            <% if (r.status==='approved' ) { %>
                                                <span
                                                    class="inline-flex items-center gap-1.5 rounded-md border border-green-200 bg-green-50 px-2.5 py-1 text-xs font-bold text-green-600">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Approved
                                                </span>
                                                <% } else if (r.status==='rejected' ) { %>
                                                    <span
                                                        class="inline-flex items-center gap-1.5 rounded-md border border-red-200 bg-red-50 px-2.5 py-1 text-xs font-bold text-red-600">
                                                        <span
                                                            class="w-1.5 h-1.5 rounded-full bg-red-500"></span>Rejected
                                                    </span>
                                                    <% } else { %>
                                                        <span
                                                            class="inline-flex items-center gap-1.5 rounded-md border border-amber-200 bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-600">
                                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"
                                                                style="animation: pulse 1.5s infinite;"></span>Pending
                                                        </span>
                                                        <% } %>
                                        </td>

                                        <!-- Actions -->
                                        <td class="px-4 py-4">
                                            <% if (r.status==='pending' ) { %>
                                                <div class="flex items-center justify-center gap-2">
                                                    <form action="/admin/reservations/<%= r.id %>/approve" method="POST"
                                                        onsubmit="return confirm('Approve this reservation?')">
                                                        <button type="submit"
                                                            class="flex items-center gap-1 rounded-lg px-3 py-1.5 text-xs font-bold text-white transition-all hover:-translate-y-0.5 cursor-pointer"
                                                            style="background: linear-gradient(135deg,#059669,#047857);">
                                                            Approve
                                                        </button>
                                                    </form>
                                                    <form action="/admin/reservations/<%= r.id %>/reject" method="POST"
                                                        onsubmit="return confirm('Reject this reservation?')">
                                                        <button type="submit"
                                                            class="rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-bold text-red-700 transition-all hover:bg-red-600 hover:text-white cursor-pointer">
                                                            Reject
                                                        </button>
                                                    </form>
                                                </div>
                                                <% } else { %>
                                                    <div class="text-center text-xs italic text-gray-300">Processed
                                                    </div>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="9" class="px-4 py-20 text-center">
                                                    <div class="flex flex-col items-center gap-3">
                                                        <div
                                                            class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                                fill="currentColor" class="size-7 text-gray-300">
                                                                <path fill-rule="evenodd"
                                                                    d="M6.75 2.25A.75.75 0 0 1 7.5 3v1.5h9V3A.75.75 0 0 1 18 3v1.5h.75a3 3 0 0 1 3 3v11.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V7.5a3 3 0 0 1 3-3H6V3a.75.75 0 0 1 .75-.75Zm13.5 9a1.5 1.5 0 0 0-1.5-1.5H5.25a1.5 1.5 0 0 0-1.5 1.5v7.5a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-7.5Z"
                                                                    clip-rule="evenodd" />
                                                            </svg>
                                                        </div>
                                                        <p class="text-sm font-semibold text-gray-400">No reservations
                                                            yet</p>
                                                        <p class="text-xs text-gray-300">Student reservation requests
                                                            will appear here.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Footer -->
                <div
                    class="flex items-center justify-between bg-gray-50 border-t border-gray-100 px-5 py-3 text-xs text-gray-400">
                    <span>
                        Showing <strong id="visibleCount" class="text-gray-600">
                            <%= reservations.length %>
                        </strong>
                        of <strong>
                            <%= reservations.length %>
                        </strong> reservations
                    </span>
                    <span>Students receive notifications on status change</span>
                </div>
            </div>
        </div>

</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const labFilter = document.getElementById('labFilter');
    const countEl = document.getElementById('visibleCount');

    function applyFilters() {
        const q = searchInput.value.toLowerCase();
        const status = statusFilter.value;
        const lab = labFilter.value;
        let count = 0;

        document.querySelectorAll('.res-row').forEach(row => {
            const matchQ = row.textContent.toLowerCase().includes(q);
            const matchStatus = !status || row.dataset.status === status;
            const matchLab = !lab || row.dataset.lab === lab;
            const show = matchQ && matchStatus && matchLab;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });

        countEl.textContent = count;
    }

    searchInput.addEventListener('input', applyFilters);
    statusFilter.addEventListener('change', applyFilters);
    labFilter.addEventListener('change', applyFilters);
</script>