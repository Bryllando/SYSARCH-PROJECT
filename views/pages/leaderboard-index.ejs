<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800;900&display=swap');

    .lb-wrap {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    /* ── Header ── */
    .lb-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 32px 24px 28px;
        position: relative;
        overflow: hidden;
        text-align: center;
    }

    .lb-header::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.06);
        pointer-events: none;
    }

    .lb-header::after {
        content: '';
        position: absolute;
        bottom: -40px;
        left: -20px;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        background: rgba(91, 14, 20, 0.12);
        pointer-events: none;
    }

    .lb-header-inner {
        position: relative;
        z-index: 1;
        max-width: 700px;
        margin: 0 auto;
    }

    .lb-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 36px;
        font-weight: 900;
        color: #fff;
        letter-spacing: -1px;
        margin: 0 0 6px;
    }

    .lb-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0 0 16px;
    }

    .lb-max-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(241, 225, 148, 0.15);
        border: 1px solid rgba(241, 225, 148, 0.3);
        color: #F1E194;
        font-size: 12px;
        font-weight: 700;
        padding: 6px 16px;
        border-radius: 999px;
        letter-spacing: 0.04em;
    }

    /* ── Body container ── */
    .lb-body {
        padding: 28px 24px 48px;
        max-width: 900px;
        margin: 0 auto;
    }

    /* ── Formula strip ── */
    .lb-formula {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 28px;
    }

    .lb-formula-card {
        background: #fff;
        border-radius: 16px;
        padding: 18px 20px;
        border: 1px solid #E8E3DD;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
        display: flex;
        align-items: center;
        gap: 14px;
        transition: transform 0.15s, box-shadow 0.15s;
    }

    .lb-formula-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(39, 63, 79, 0.1);
    }

    .lb-formula-icon {
        width: 48px;
        height: 48px;
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .lb-formula-pct {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 900;
        line-height: 1;
    }

    .lb-formula-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-top: 3px;
    }

    /* ── Podium ── */
    .lb-podium-section {
        background: #fff;
        border-radius: 20px;
        padding: 28px 24px 0;
        border: 1px solid #E8E3DD;
        margin-bottom: 20px;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        overflow: hidden;
    }

    .lb-podium-title {
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 800;
        color: #9CA3AF;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-bottom: 24px;
    }

    .lb-podium {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: 12px;
    }

    .podium-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .podium-crown {
        font-size: 20px;
        line-height: 1;
    }

    .podium-avatar {
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        overflow: hidden;
        border: 3px solid;
        flex-shrink: 0;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        color: #F1E194;
        font-size: 16px;
    }

    .podium-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .podium-name {
        font-size: 12px;
        font-weight: 700;
        color: #1C2B35;
        text-align: center;
        max-width: 90px;
    }

    .podium-course {
        font-size: 10px;
        color: #9CA3AF;
        text-align: center;
    }

    .podium-pts {
        font-family: 'Syne', sans-serif;
        font-size: 16px;
        font-weight: 900;
    }

    .podium-block {
        border-radius: 12px 12px 0 0;
        width: 100px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-top: 10px;
        gap: 4px;
    }

    /* 1st */
    .podium-item.rank-1 .podium-avatar {
        width: 76px;
        height: 76px;
        border-color: #F59E0B;
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.2);
    }

    .podium-item.rank-1 .podium-pts {
        color: #D97706;
    }

    .podium-item.rank-1 .podium-block {
        height: 100px;
        background: linear-gradient(135deg, #F59E0B, #D97706);
        width: 110px;
    }

    /* 2nd */
    .podium-item.rank-2 .podium-avatar {
        width: 64px;
        height: 64px;
        border-color: #9CA3AF;
    }

    .podium-item.rank-2 .podium-pts {
        color: #6B7280;
    }

    .podium-item.rank-2 .podium-block {
        height: 70px;
        background: linear-gradient(135deg, #9CA3AF, #6B7280);
    }

    /* 3rd */
    .podium-item.rank-3 .podium-avatar {
        width: 56px;
        height: 56px;
        border-color: #CD7F32;
    }

    .podium-item.rank-3 .podium-pts {
        color: #92400E;
    }

    .podium-item.rank-3 .podium-block {
        height: 56px;
        background: linear-gradient(135deg, #CD7F32, #A0522D);
    }

    /* ── Full table ── */
    .lb-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #E8E3DD;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
    }

    .lb-card-head {
        padding: 16px 24px;
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .lb-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: #1C2B35;
    }

    .lb-search {
        padding: 7px 12px 7px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 180px;
        position: relative;
    }

    .lb-search:focus {
        border-color: #273F4F;
    }

    .lb-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .lb-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .lb-table th {
        padding: 12px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .lb-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .lb-table tbody tr:hover {
        background: #FAF9F7;
    }

    .lb-table tbody tr:last-child {
        border-bottom: none;
    }

    .lb-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    /* Rank badges */
    .rank-badge {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 800;
        flex-shrink: 0;
    }

    .rank-1 {
        background: linear-gradient(135deg, #F59E0B, #D97706);
        color: #fff;
    }

    .rank-2 {
        background: linear-gradient(135deg, #9CA3AF, #6B7280);
        color: #fff;
    }

    .rank-3 {
        background: linear-gradient(135deg, #CD7F32, #A0522D);
        color: #fff;
    }

    .rank-other {
        background: #F3F0EC;
        color: #6B7280;
    }

    /* Score bar */
    .score-bar-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 120px;
    }

    .score-bar {
        flex: 1;
        height: 7px;
        background: #F3F0EC;
        border-radius: 999px;
        overflow: hidden;
    }

    .score-bar-fill {
        height: 100%;
        border-radius: 999px;
        transition: width 0.6s ease;
    }

    /* Footer note */
    .lb-footer {
        padding: 14px 24px;
        border-top: 1px solid #F3F0EC;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }
</style>

<div class="lb-wrap">
    <!-- Header -->
    <div class="lb-header">
        <div class="lb-header-inner">
            <p
                style="font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(241,225,148,0.7);margin:0 0 8px;">
                CCS Laboratory</p>
            <h1>🏆 Student Leaderboard</h1>
            <p>Score = (Tidy LB Pts x 0.5) + (Total Hours x 0.3) + (Task Completion Rate x 0.2)</p>
            <span class="lb-max-badge">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd"
                        d="M11.5 2.25a.75.75 0 0 1 .75.75v10.5a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75Zm-4 3a.75.75 0 0 1 .75.75v7.5a.75.75 0 0 1-1.5 0V6a.75.75 0 0 1 .75-.75Zm-4 3a.75.75 0 0 1 .75.75v4.5a.75.75 0 0 1-1.5 0V9a.75.75 0 0 1 .75-.75Z"
                        clip-rule="evenodd" />
                </svg>
                Max 100 pts
            </span>
        </div>
    </div>

    <div class="lb-body">

        <!-- Formula Cards -->
        <div class="lb-formula">
            <div class="lb-formula-card">
                <div class="lb-formula-icon" style="background:#FFF7ED;">🎯</div>
                <div>
                    <div class="lb-formula-pct" style="color:#D97706;">50%</div>
                    <div class="lb-formula-label">Tidy LB Points (Raw / 3)</div>
                </div>
            </div>
            <div class="lb-formula-card">
                <div class="lb-formula-icon" style="background:#EFF6FF;">💻</div>
                <div>
                    <div class="lb-formula-pct" style="color:#1D4ED8;">30%</div>
                    <div class="lb-formula-label">Total Hours</div>
                </div>
            </div>
            <div class="lb-formula-card">
                <div class="lb-formula-icon" style="background:#ECFDF5;">✅</div>
                <div>
                    <div class="lb-formula-pct" style="color:#059669;">20%</div>
                    <div class="lb-formula-label">Task Completion Rate</div>
                </div>
            </div>
        </div>

        <!-- Podium (top 3) -->
        <% if (students && students.length>= 3) {
            const s1 = students[0], s2 = students[1], s3 = students[2];
            const init = s => ((s.first_name||'')[0]||'') + ((s.last_name||'')[0]||'');
            %>
            <div class="lb-podium-section">
                <p class="lb-podium-title">✨ Top Performers</p>
                <div class="lb-podium">
                    <!-- 2nd -->
                    <div class="podium-item rank-2">
                        <div class="podium-crown">🥈</div>
                        <div class="podium-avatar" style="width:64px;height:64px;border-color:#9CA3AF;">
                            <% if (s2.profile_picture && s2.profile_picture !=='' ) { %><img
                                    src="<%= s2.profile_picture %>">
                                <% } else { %>
                                    <%= init(s2).toUpperCase() %>
                                        <% } %>
                        </div>
                        <div class="podium-name">
                            <%= s2.last_name %>, <%= s2.first_name %>
                        </div>
                        <div class="podium-course">
                            <%= s2.course %>
                        </div>
                        <div class="podium-pts">
                            <%= s2.points %> pts
                        </div>
                        <div class="podium-block"
                            style="height:70px;background:linear-gradient(135deg,#9CA3AF,#6B7280);">
                            <span
                                style="font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:rgba(255,255,255,0.9);">2</span>
                        </div>
                    </div>
                    <!-- 1st -->
                    <div class="podium-item rank-1">
                        <div class="podium-crown">👑</div>
                        <div class="podium-avatar"
                            style="width:80px;height:80px;border-color:#F59E0B;box-shadow:0 0 0 4px rgba(245,158,11,0.2);">
                            <% if (s1.profile_picture && s1.profile_picture !=='' ) { %><img
                                    src="<%= s1.profile_picture %>">
                                <% } else { %>
                                    <%= init(s1).toUpperCase() %>
                                        <% } %>
                        </div>
                        <div class="podium-name">
                            <%= s1.last_name %>, <%= s1.first_name %>
                        </div>
                        <div class="podium-course">
                            <%= s1.course %>
                        </div>
                        <div class="podium-pts">
                            <%= s1.points %> pts
                        </div>
                        <div class="podium-block"
                            style="height:100px;background:linear-gradient(135deg,#F59E0B,#D97706);width:110px;">
                            <span
                                style="font-family:'Syne',sans-serif;font-size:24px;font-weight:900;color:rgba(255,255,255,0.95);">1</span>
                        </div>
                    </div>
                    <!-- 3rd -->
                    <div class="podium-item rank-3">
                        <div class="podium-crown">🥉</div>
                        <div class="podium-avatar" style="width:56px;height:56px;border-color:#CD7F32;">
                            <% if (s3.profile_picture && s3.profile_picture !=='' ) { %><img
                                    src="<%= s3.profile_picture %>">
                                <% } else { %>
                                    <%= init(s3).toUpperCase() %>
                                        <% } %>
                        </div>
                        <div class="podium-name">
                            <%= s3.last_name %>, <%= s3.first_name %>
                        </div>
                        <div class="podium-course">
                            <%= s3.course %>
                        </div>
                        <div class="podium-pts">
                            <%= s3.points %> pts
                        </div>
                        <div class="podium-block"
                            style="height:56px;background:linear-gradient(135deg,#CD7F32,#A0522D);">
                            <span
                                style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:rgba(255,255,255,0.9);">3</span>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>

                <!-- Full Rankings Table -->
                <div class="lb-card">
                    <div class="lb-card-head">
                        <span class="lb-card-title">Full Rankings</span>
                        <div style="position:relative;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9CA3AF;width:14px;height:14px;pointer-events:none;">
                                <path fill-rule="evenodd"
                                    d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                                    clip-rule="evenodd" />
                            </svg>
                            <input type="text" class="lb-search" id="lbSearch" placeholder="Search student..."
                                oninput="filterLb()" style="padding-left:32px;">
                        </div>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="lb-table">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Student</th>
                                    <th>Course</th>
                                    <th>Tidy Pts (Raw)</th>
                                    <th>LB Pts x50%</th>
                                    <th>Total Time</th>
                                    <th>Hrs x30%</th>
                                    <th>Final Score</th>
                                </tr>
                            </thead>
                            <tbody id="lbBody">
                                <% if (students && students.length> 0) { %>
                                    <% students.forEach(function(s, i) { const
                                        rankClass=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other'; const
                                        rankEmoji=i===0?'🥇':i===1?'🥈':i===2?'🥉':('#' + (i+1)); const
                                        initials=((s.first_name||'')[0]||'') + ((s.last_name||'')[0]||''); const
                                        pct=Math.min(s.points, 100); const barColor=pct>=70?'#F59E0B':pct>=40?'#3B82F6':'#10B981';
                                        const isMe = typeof user !== 'undefined' && user && user.id === s.id;
                                        %>
                                        <tr class="lb-row"
                                            style="<%= isMe ? 'background:rgba(241,225,148,0.12);' : '' %>">
                                            <td>
                                                <span class="rank-badge <%= rankClass %>">
                                                    <%= rankEmoji %>
                                                </span>
                                            </td>
                                            <td>
                                                <div style="display:flex;align-items:center;gap:10px;">
                                                    <div
                                                        style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#273F4F,#5B0E14);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#F1E194;flex-shrink:0;overflow:hidden;<%= isMe ? 'box-shadow:0 0 0 3px #F59E0B;' : '' %>">
                                                        <% if (s.profile_picture && s.profile_picture !=='' ) { %><img
                                                                src="<%= s.profile_picture %>"
                                                                style="width:100%;height:100%;object-fit:cover;">
                                                            <% } else { %>
                                                                <%= initials.toUpperCase() %>
                                                                    <% } %>
                                                    </div>
                                                    <div>
                                                        <div style="font-size:13px;font-weight:600;color:#1C2B35;">
                                                            <%= s.last_name %>, <%= s.first_name %>
                                                                    <% if (isMe) { %><span
                                                                            style="font-size:10px;font-weight:700;background:#F59E0B;color:#fff;padding:1px 6px;border-radius:999px;margin-left:4px;">You</span>
                                                                        <% } %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><span
                                                    style="background:#EFF6FF;color:#1D4ED8;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;">
                                                    <%= s.course %>
                                                </span></td>
                                            <td><span style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#273F4F;"><%= s.tidy_points_raw %></span></td>
                                            <td><span style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#D97706;"><%= (s.tidy_lb_points * 0.5).toFixed(2) %></span></td>
                                            <td style="font-size:12px;color:#4B5563;"><%= s.total_hours.toFixed(2) %> hrs</td>
                                            <td><span style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#1D4ED8;"><%= (s.total_hours * 0.3).toFixed(2) %></span></td>
                                            <td>
                                                <div class="score-bar-wrap">
                                                    <div class="score-bar">
                                                        <div class="score-bar-fill"
                                                            style="width:<%= pct %>%;background:<%= barColor %>;"></div>
                                                    </div>
                                                    <span
                                                        style="font-family:'Syne',sans-serif;font-size:17px;font-weight:800;color:<%= barColor %>;min-width:56px;text-align:right;">
                                                        <%= Number(s.points).toFixed(2) %>
                                                    </span>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8"
                                                        style="padding:56px;text-align:center;color:#9CA3AF;">No
                                                        rankings yet. Start your first sit-in!</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <div class="lb-footer">
                        <span>Showing <strong id="lbCount" style="color:#1C2B35;">
                                <%= students ? students.length : 0 %>
                            </strong> students</span>
                        <span>Final Score = (Tidy LB Points x 0.5) + (Total Hours x 0.3) + (Task Completion Rate x 0.2). Tidy LB Points = Raw / 3.</span>
                    </div>
                </div>

                <div class="lb-card" style="margin-top:18px;">
                    <div class="lb-card-head">
                        <span class="lb-card-title">Most Visited Laboratory</span>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="lb-table">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Laboratory</th>
                                    <th>Sit-ins x25%</th>
                                    <th>Hours x25%</th>
                                    <th>Rating x25%</th>
                                    <th>Unique Users x25%</th>
                                    <th>Lab Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (labs && labs.length > 0) { %>
                                    <% labs.forEach(function(lab, idx) { %>
                                        <tr>
                                            <td><span class="rank-badge <%= idx===0?'rank-1':idx===1?'rank-2':idx===2?'rank-3':'rank-other' %>"><%= idx < 3 ? (idx===0?'🥇':idx===1?'🥈':'🥉') : ('#'+(idx+1)) %></span></td>
                                            <td>Lab <%= lab.lab_room %></td>
                                            <td><%= (lab.sitins * 0.25).toFixed(2) %></td>
                                            <td><%= (lab.hours * 0.25).toFixed(2) %></td>
                                            <td><%= (lab.rating * 0.25).toFixed(2) %></td>
                                            <td><%= (lab.unique_users * 0.25).toFixed(2) %></td>
                                            <td style="font-weight:800;color:#1a2035;"><%= lab.score.toFixed(2) %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="7" style="padding:26px;text-align:center;color:#9CA3AF;">No laboratory analytics yet.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <div class="lb-footer">
                        <span>Lab Score = (Sit-ins x 0.25) + (Hours x 0.25) + (Rating x 0.25) + (Unique Users x 0.25).</span>
                    </div>
                </div>
    </div>
</div>

<script>
    function filterLb() {
        const q = document.getElementById('lbSearch').value.toLowerCase();
        let count = 0;
        document.querySelectorAll('.lb-row').forEach(row => {
            const show = !q || row.textContent.toLowerCase().includes(q);
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        document.getElementById('lbCount').textContent = count;
    }
</script>