<style>
    .lb-rank-medal {
        font-size: 16px;
        width: 26px;
        text-align: center;
        flex-shrink: 0;
    }

    .lb-entry {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        transition: background 0.12s;
    }

    .lb-entry:hover {
        background: rgba(255, 255, 255, 0.05);
    }

    .lb-entry:last-child {
        border-bottom: none;
    }

    .lb-mini-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .lb-mini-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .lb-mini-name {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.9);
    }

    .lb-mini-sub {
        font-size: 10px;
        color: rgba(255, 255, 255, 0.4);
    }

    .lb-mini-pts {
        font-family: 'Syne', sans-serif;
        font-size: 16px;
        font-weight: 800;
        color: #F1E194;
        margin-left: auto;
    }

    .lb-mini-bar {
        height: 3px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 999px;
        overflow: hidden;
        margin-top: 3px;
    }

    .lb-mini-bar-fill {
        height: 100%;
        border-radius: 999px;
    }
</style>

<script>
    (async function loadLeaderboard() {
        try {
            const res = await fetch('/api/leaderboard');
            const data = await res.json();
            const container = document.getElementById('lbWidget');

            if (!data || data.length === 0) {
                container.innerHTML = '<div style="text-align:center;padding:40px;color:rgba(255,255,255,0.35);font-size:12px;">No rankings yet. Be the first!</div>';
                return;
            }

            const medals = ['🥇', '🥈', '🥉'];
            const barColors = ['#F59E0B', '#9CA3AF', '#CD7F32'];

            container.innerHTML = data.slice(0, 5).map((s, i) => {
                const initials = ((s.first_name || '')[0] || '') + ((s.last_name || '')[0] || '');
                const pct = Math.min(s.points, 100);
                const barColor = i < 3 ? barColors[i] : '#3B82F6';
                const medal = i < 3 ? medals[i] : `<span style="font-size:11px;font-weight:800;color:rgba(255,255,255,0.5);">#${i + 1}</span>`;
                const avatarHtml = s.profile_picture
                    ? `<img src="${s.profile_picture}">`
                    : initials.toUpperCase();

                return `<div class="lb-entry">
                    <div class="lb-rank-medal">${medal}</div>
                    <div class="lb-mini-avatar">${avatarHtml}</div>
                    <div style="flex:1;min-width:0;">
                        <div class="lb-mini-name">${s.last_name || ''}, ${s.first_name || ''}</div>
                        <div class="lb-mini-sub">${s.course || ''} · ${s.total_sitins} sit-ins</div>
                        <div class="lb-mini-bar">
                            <div class="lb-mini-bar-fill" style="width:${pct}%;background:${barColor};"></div>
                        </div>
                    </div>
                    <div class="lb-mini-pts">${s.points}<span style="font-size:9px;color:rgba(255,255,255,0.35);font-weight:500;">pts</span></div>
                </div>`;
            }).join('');
        } catch (e) {
            document.getElementById('lbWidget').innerHTML = '<div style="text-align:center;padding:40px;color:rgba(255,255,255,0.35);font-size:12px;">Unable to load rankings.</div>';
        }
    })();
</script>