  }
  .tag-announce { background:rgba(241,225,148,.18); color:#F1E194; border:1px solid rgba(241,225,148,.3); }
  .tag-help     { background:rgba(59,130,246,.18);  color:#93c5fd;  border:1px solid rgba(59,130,246,.3); }
  .tag-event    { background:rgba(34,197,94,.18);   color:#86efac;  border:1px solid rgba(34,197,94,.3); }
  .tag-general  { background:rgba(168,85,247,.18);  color:#d8b4fe;  border:1px solid rgba(168,85,247,.3); }

  .forum-thread-title { font-size: .9rem; font-weight: 600; color: #fff; margin-bottom: .2rem; }
  .forum-thread-sub   { font-size: .78rem; color: rgba(255,255,255,.85); margin-top:.2rem; }
  .forum-thread-meta  { font-size: .7rem; color: rgba(255,255,255,.70); }

  .event-card {
    display: flex; gap: 1.2rem; align-items: flex-start;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(241,225,148,0.1);
    border-radius: 1rem;
    padding: 1.2rem;
    margin-bottom: 1rem;
    transition: border-color .2s, background .2s;
  }
  .event-card:hover { border-color: rgba(241,225,148,.35); background: rgba(241,225,148,.06); }
  .event-date-box {
    min-width: 52px;
    background: rgba(241,225,148,0.14);
    border: 1px solid rgba(241,225,148,0.28);
    border-radius: .8rem;
    text-align: center;
    padding: .5rem .4rem;
    flex-shrink: 0;
  }
  .event-title { font-size: .9rem; font-weight: 600; color: #fff; }
  .event-sub   { font-size: .78rem; color: rgba(255,255,255,.85); margin-top:.3rem; line-height:1.5; }

  .group-card {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(241,225,148,0.1);
    border-radius: 1.1rem;
    padding: 1.4rem;
    display: flex; flex-direction: column; gap: .6rem;
    transition: border-color .2s, transform .2s;
  }
  .group-card:hover { border-color: rgba(241,225,148,.35); transform: translateY(-2px); }
  .group-card-title { font-size: .88rem; font-weight: 700; color: #fff; }
  .group-card-sub   { font-size: .75rem; color: rgba(255,255,255,.85); line-height:1.5; }
  .group-card-count { font-size: .72rem; color: rgba(255,255,255,.70); }
  .group-icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: linear-gradient(135deg,#5B0E14,#9b1e28);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    border: 1px solid rgba(241,225,148,0.25);
  }
  .join-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: .4rem;
    background: rgba(241,225,148,0.12);
    border: 1px solid rgba(241,225,148,0.30);
    color: #F1E194;
    font-size: .78rem; font-weight: 700;
    padding: .45rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background .2s, border-color .2s;
    margin-top: auto;
    width: max-content;
    text-decoration: none;
  }
  .join-btn:hover { background: rgba(241,225,148,0.22); border-color: rgba(241,225,148,0.55); }

  /* Notice banner */
  .notice-bar {
    background: rgba(241,225,148,0.10);
    border: 1px solid rgba(241,225,148,0.25);
    border-radius: .9rem;
    padding: .85rem 1.2rem;
    display: flex; align-items: center; gap: .75rem;
    margin-bottom: 2rem;
    font-size: .85rem;
    color: rgba(255,255,255,0.88);
  }
</style>

