<div class="p-6 space-y-6">

    <!-- Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #EFF6FF, #DBEAFE);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                    class="size-6 text-blue-600">
                    <path
                        d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM1.49 15.326a.78.78 0 0 1-.358-.442 3 3 0 0 1 4.308-3.516 6.484 6.484 0 0 0-1.905 3.959c-.023.222-.014.442.025.654a4.97 4.97 0 0 1-2.07-.655ZM16.44 15.98a4.97 4.97 0 0 0 2.07-.654.78.78 0 0 0 .357-.442 3 3 0 0 0-4.308-3.517 6.484 6.484 0 0 1 1.907 3.96 2.32 2.32 0 0 1-.026.654ZM18 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM5.304 16.19a.844.844 0 0 1-.277-.71 5 5 0 0 1 9.947 0 .843.843 0 0 1-.277.71A6.975 6.975 0 0 1 10 18a6.974 6.974 0 0 1-4.696-1.81Z" />
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-widest">Students Registered</p>
                <p class="text-3xl font-extrabold text-[#273F4F]">
                    <%= totalStudents %>
                </p>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #F0FDF4, #DCFCE7);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                    class="size-6 text-green-600">
                    <path fill-rule="evenodd"
                        d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                        clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-widest">Currently Sit-in</p>
                <p class="text-3xl font-extrabold text-green-600">
                    <%= activeSitins %>
                </p>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #FFF7ED, #FFEDD5);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                    class="size-6 text-orange-500">
                    <path fill-rule="evenodd"
                        d="M3 6a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm4.5 7.5a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0v-2.25a.75.75 0 0 1 .75-.75Zm3.75-1.5a.75.75 0 0 0-1.5 0v4.5a.75.75 0 0 0 1.5 0V12Zm2.25-3a.75.75 0 0 1 .75.75v6.75a.75.75 0 0 1-1.5 0V9.75A.75.75 0 0 1 13.5 9Z"
                        clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-widest">Total Sit-in</p>
                <p class="text-3xl font-extrabold text-orange-500">
                    <%= totalSitins || 0 %>
                </p>
            </div>
        </div>
    </div>

    <!-- Main content: Chart + Announcement -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Chart -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#5B0E14]"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Sit-in Statistics</h2>
            </div>
            <div class="p-5">
                <canvas id="sitin-chart" height="220"></canvas>
            </div>
        </div>

        <!-- Announcements / Post -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Post Announcement</h2>
            </div>
            <div class="p-5 flex flex-col gap-3">
                <form action="/admin/announcement" method="POST" class="space-y-3">
                    <textarea name="message" rows="4" placeholder="Write an announcement..."
                        class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm resize-none transition-all"></textarea>
                    <button type="submit" class="btn-maroon py-2.5 text-sm">Post Announcement</button>
                </form>
                <div class="border-t border-gray-100 pt-3 space-y-3 max-h-48 overflow-y-auto">
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Posted Announcements</p>
                    <% if (typeof announcements !=='undefined' && announcements && announcements.length> 0) { %>
                        <% announcements.forEach(function(ann) { %>
                            <div class="border-l-4 border-[#5B0E14] pl-3">
                                <p class="text-xs text-gray-400">CCS Admin | <%= new
                                        Date(ann.created_at).toLocaleDateString() %>
                                </p>
                                <p class="text-sm text-gray-700 mt-0.5">
                                    <%= ann.message %>
                                </p>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p class="text-xs text-gray-400">No announcements yet.</p>
                                    <% } %>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }

    .modal-overlay.open {
        display: flex;
    }

    /* Subtle entrance animation */
    .modal-overlay.open .modal-card {
        animation: modalIn 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes modalIn {
        from {
            opacity: 0;
            transform: scale(0.94) translateY(8px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    /* ---- Search modal card ---- */
    #searchModal .modal-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 20px 60px -10px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(0, 0, 0, 0.06);
        width: 100%;
        max-width: 380px;
        overflow: hidden;
    }

    #searchModal .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
    }

    #searchModal .modal-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
    }

    #searchModal .modal-title svg {
        color: #273F4F;
    }

    #searchModal .modal-close {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: transparent;
        color: #94a3b8;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.15s;
        line-height: 1;
    }

    #searchModal .modal-close:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #475569;
    }

    #searchModal .modal-body {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    #searchModal .search-input-wrap {
        position: relative;
    }

    #searchModal .search-input-wrap svg {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    #searchModal .search-input {
        width: 100%;
        padding: 10px 12px 10px 38px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 13.5px;
        color: #1e293b;
        background: #f8fafc;
        outline: none;
        transition: all 0.15s;
        box-sizing: border-box;
    }

    #searchModal .search-input:focus {
        border-color: #273F4F;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, 0.08);
    }

    #searchModal .search-input::placeholder {
        color: #94a3b8;
    }

    #searchModal .search-error {
        display: none;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        color: #dc2626;
    }

    #searchModal .search-error.visible {
        display: flex;
    }

    #searchModal .modal-footer {
        display: flex;
        justify-content: flex-end;
        padding: 0 20px 20px;
    }

    #searchModal .btn-search {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 20px;
        background: #273F4F;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        letter-spacing: 0.01em;
    }

    #searchModal .btn-search:hover {
        background: #1a2d38;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(39, 63, 79, 0.25);
    }

    #searchModal .btn-search:active {
        transform: translateY(0);
    }

    /* ---- Sit-in modal card ---- */
    #sitinModal .modal-card {
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 24px 64px -12px rgba(0, 0, 0, 0.28), 0 0 0 1px rgba(0, 0, 0, 0.06);
        width: 100%;
        max-width: 480px;
        overflow: hidden;
    }

    #sitinModal .modal-header {
        padding: 18px 24px;
        background: linear-gradient(135deg, #5B0E14 0%, #3A0910 100%);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    #sitinModal .modal-title {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 15px;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.01em;
    }

    #sitinModal .modal-title svg {
        opacity: 0.9;
    }

    #sitinModal .modal-close {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        transition: all 0.15s;
    }

    #sitinModal .modal-close:hover {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.35);
    }

    #sitinModal .modal-body {
        padding: 22px 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    /* Student info pill strip */
    .student-info-strip {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .info-pill {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 13px;
    }

    .info-pill.full {
        grid-column: span 2;
    }

    .info-pill .pill-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-pill .pill-value {
        font-size: 13.5px;
        font-weight: 600;
        color: #1e293b;
    }

    .info-pill.sessions-pill {
        background: #fff1f2;
        border-color: #fecdd3;
    }

    .info-pill.sessions-pill .pill-value {
        color: #5B0E14;
        font-weight: 700;
    }

    /* Form fields inside sit-in modal */
    .sitin-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .sitin-label {
        font-size: 12px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .sitin-select {
        width: 100%;
        padding: 10px 36px 10px 13px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 13.5px;
        color: #1e293b;
        background: #f8fafc;
        appearance: none;
        outline: none;
        transition: all 0.15s;
        cursor: pointer;
    }

    .sitin-select:focus {
        border-color: #5B0E14;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(91, 14, 20, 0.08);
    }

    .select-wrap {
        position: relative;
    }

    .select-wrap svg {
        position: absolute;
        right: 11px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    /* Sit-in modal footer */
    #sitinModal .modal-footer {
        display: flex;
        gap: 10px;
        padding: 0 24px 22px;
    }

    .btn-sitin-submit {
        flex: 1;
        padding: 11px;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        letter-spacing: 0.01em;
    }

    .btn-sitin-submit:hover {
        background: linear-gradient(135deg, #6d1019, #8a1620);
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(91, 14, 20, 0.3);
    }

    .btn-sitin-submit:active {
        transform: translateY(0);
    }

    .btn-sitin-cancel {
        flex: 1;
        padding: 11px;
        background: #f1f5f9;
        color: #475569;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-sitin-cancel:hover {
        background: #e2e8f0;
        color: #1e293b;
        border-color: #cbd5e1;
    }

    /* Divider */
    .modal-divider {
        height: 1px;
        background: #f1f5f9;
        margin: 0 24px;
    }
</style>

<!-- ===== SEARCH STUDENT MODAL ===== -->
<div id="searchModal" class="modal-overlay" onclick="if(event.target===this) closeSearchModal()">
    <div class="modal-card">

        <div class="modal-header">
            <div class="modal-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                Search Student
            </div>
            <button class="modal-close" onclick="closeSearchModal()">✕</button>
        </div>

        <div class="modal-body">
            <div class="search-input-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="15" height="15">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                <input type="text" id="searchStudentInput" class="search-input" placeholder="Enter student ID number..."
                    onkeydown="if(event.key==='Enter') searchStudent()" autocomplete="off" />
            </div>

            <div id="searchError" class="search-error">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                    <path fill-rule="evenodd"
                        d="M6.701 2.25c.577-1 2.02-1 2.598 0l5.196 9a1.5 1.5 0 0 1-1.299 2.25H2.804a1.5 1.5 0 0 1-1.3-2.25l5.197-9ZM8 4a.75.75 0 0 1 .75.75v3a.75.75 0 1 1-1.5 0v-3A.75.75 0 0 1 8 4Zm0 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"
                        clip-rule="evenodd" />
                </svg>
                <span id="searchErrorText">Student not found.</span>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn-search" onclick="searchStudent()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
                    <path fill-rule="evenodd"
                        d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
                        clip-rule="evenodd" />
                </svg>
                Search
            </button>
        </div>

    </div>
</div>

<!-- ===== SIT-IN FORM MODAL ===== -->
<div id="sitinModal" class="modal-overlay" onclick="if(event.target===this) closeSitinModal()">
    <div class="modal-card">

        <div class="modal-header">
            <div class="modal-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="17" height="17">
                    <path fill-rule="evenodd"
                        d="M4.5 2A1.5 1.5 0 0 0 3 3.5v13A1.5 1.5 0 0 0 4.5 18h11a1.5 1.5 0 0 0 1.5-1.5V7.621a1.5 1.5 0 0 0-.44-1.06l-4.12-4.122A1.5 1.5 0 0 0 11.378 2H4.5Zm2.25 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Zm0 3a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z"
                        clip-rule="evenodd" />
                </svg>
                Sit In Form
            </div>
            <button class="modal-close" onclick="closeSitinModal()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14" height="14">
                    <path
                        d="M5.28 4.22a.75.75 0 0 0-1.06 1.06L6.94 8l-2.72 2.72a.75.75 0 1 0 1.06 1.06L8 9.06l2.72 2.72a.75.75 0 1 0 1.06-1.06L9.06 8l2.72-2.72a.75.75 0 0 0-1.06-1.06L8 6.94 5.28 4.22Z" />
                </svg>
            </button>
        </div>

        <form id="sitinForm" action="/admin/sitin/start" method="POST">
            <input type="hidden" name="return_to" value="/admin">
            <input type="hidden" name="user_id" id="sitinUserId">

            <div class="modal-body">

                <!-- Student info pills -->
                <div class="student-info-strip">
                    <div class="info-pill">
                        <div class="pill-label">ID Number</div>
                        <div class="pill-value" id="sitinIdNumber">—</div>
                    </div>
                    <div class="info-pill sessions-pill">
                        <div class="pill-label">Sessions Left</div>
                        <div class="pill-value" id="sitinSessions">—</div>
                    </div>
                    <div class="info-pill full">
                        <div class="pill-label">Student Name</div>
                        <div class="pill-value" id="sitinName">—</div>
                    </div>
                </div>

                <!-- Purpose -->
                <div class="sitin-field">
                    <label class="sitin-label">Purpose</label>
                    <div class="select-wrap">
                        <select name="purpose" required class="sitin-select">
                            <option value="" disabled selected>Select purpose...</option>
                            <option value="C Programming">C Programming</option>
                            <option value="Java Programming">Java Programming</option>
                            <option value="C# Programming">C# Programming</option>
                            <option value="ASP.Net">ASP.Net</option>
                            <option value="PHP Programming">PHP Programming</option>
                            <option value="Database">Database</option>
                            <option value="Research">Research</option>
                            <option value="Other">Other</option>
                        </select>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14"
                            height="14">
                            <path fill-rule="evenodd"
                                d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z"
                                clip-rule="evenodd" />
                        </svg>
                    </div>
                </div>

                <!-- Laboratory -->
                <div class="sitin-field">
                    <label class="sitin-label">Laboratory</label>
                    <div class="select-wrap">
                        <select name="lab_room" required class="sitin-select">
                            <option value="" disabled selected>Select lab room...</option>
                            <option value="524">Lab 524</option>
                            <option value="526">Lab 526</option>
                            <option value="528">Lab 528</option>
                            <option value="530">Lab 530</option>
                            <option value="Mac Lab">Mac Lab</option>
                        </select>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14"
                            height="14">
                            <path fill-rule="evenodd"
                                d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z"
                                clip-rule="evenodd" />
                        </svg>
                    </div>
                </div>

            </div>

            <div class="modal-divider"></div>

            <div class="modal-footer">
                <button type="button" class="btn-sitin-cancel" onclick="closeSitinModal()">Cancel</button>
                <button type="submit" class="btn-sitin-submit">
                    Confirm Sit In
                </button>
            </div>
        </form>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Chart
    const ctx = document.getElementById('sitin-chart');
    if (ctx) {
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['C Programming', 'Java', 'C#', 'ASP.Net', 'PHP', 'Other'],
                datasets: [{
                    data: [30, 25, 20, 10, 10, 5],
                    backgroundColor: ['#5B0E14', '#273F4F', '#F1E194', '#059669', '#3B82F6', '#F97316'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12 } } }
            }
        });
    }

    // ── Search Modal ──────────────────────────────────────────
    function openSearchModal() {
        document.getElementById('searchModal').classList.add('open');
        setTimeout(() => document.getElementById('searchStudentInput').focus(), 120);
    }
    function closeSearchModal() {
        document.getElementById('searchModal').classList.remove('open');
        document.getElementById('searchStudentInput').value = '';
        document.getElementById('searchError').classList.remove('visible');
    }

    // ── Sit-in Modal ──────────────────────────────────────────
    function openSitinModal(id, idNumber, name, sessions) {
        document.getElementById('sitinUserId').value = id;
        document.getElementById('sitinIdNumber').textContent = idNumber;
        document.getElementById('sitinName').textContent = name;
        document.getElementById('sitinSessions').textContent = sessions;
        document.getElementById('sitinModal').classList.add('open');
    }
    function closeSitinModal() {
        document.getElementById('sitinModal').classList.remove('open');
    }

    // ── Search & transition to Sit-in ────────────────────────
    async function searchStudent() {
        const q = document.getElementById('searchStudentInput').value.trim();
        if (!q) return;

        const errEl = document.getElementById('searchError');
        const errText = document.getElementById('searchErrorText');
        errEl.classList.remove('visible');

        try {
            const res = await fetch('/admin/search-student?q=' + encodeURIComponent(q));
            const data = await res.json();

            if (!data || data.error) {
                errText.textContent = 'No student found with that ID. Please try again.';
                errEl.classList.add('visible');
                return;
            }

            const name = data.last_name + ', ' + data.first_name +
                (data.middle_initial ? ' ' + data.middle_initial + '.' : '');
            const sessions = (data.remaining_sessions ?? 30) + ' sessions';

            closeSearchModal();
            // Small delay so close animation finishes before open
            setTimeout(() => openSitinModal(data.id, data.id_number, name, sessions), 150);

        } catch (e) {
            errText.textContent = 'Connection error. Please try again.';
            errEl.classList.add('visible');
        }
    }

    // // ── Sidebar Search link → open modal ────────────────────
    // document.addEventListener('DOMContentLoaded', () => {
    //     document.querySelectorAll('a[href="/admin/search"]').forEach(link => {
    //         link.addEventListener('click', e => {
    //             e.preventDefault();
    //             openSearchModal();
    //         });
    //     });
    // });

    // ── ESC key closes open modal ────────────────────────────
    document.addEventListener('keydown', e => {
        if (e.key !== 'Escape') return;
        if (document.getElementById('searchModal').classList.contains('open')) closeSearchModal();
        if (document.getElementById('sitinModal').classList.contains('open')) closeSitinModal();
    });
</script>