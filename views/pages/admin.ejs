<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .adm-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    /* ── Stats ── */
    .adm-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        padding: 20px 24px 0;
    }

    .adm-stat {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #E8E3DD;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
    }

    .adm-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .adm-stat-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9CA3AF;
        margin-bottom: 3px;
    }

    .adm-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 30px;
        font-weight: 800;
        line-height: 1;
    }

    /* ── Main grid ── */
    .adm-main {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 14px;
        padding: 14px 24px;
    }

    /* ── Panel base ── */
    .adm-panel {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #E8E3DD;
        overflow: hidden;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
    }

    .adm-panel-head {
        padding: 14px 18px;
        border-bottom: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        gap: 8px;
        background: #FAFAF9;
    }

    .adm-panel-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .adm-panel-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #374151;
    }

    /* ── Tabs ── */
    .adm-tabs {
        display: flex;
        gap: 4px;
        padding: 10px 18px;
        border-bottom: 1px solid #F3F0EC;
        background: #F7F5F2;
    }

    .adm-tab {
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        background: transparent;
        color: #9CA3AF;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .adm-tab.active {
        background: #273F4F;
        color: #fff;
    }

    /* ── Leaderboard ── */
    .adm-lb-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        border-bottom: 1px solid #F7F5F2;
        transition: background 0.12s;
    }

    .adm-lb-item:last-child {
        border-bottom: none;
    }

    .adm-lb-item:hover {
        background: #FAFAF9;
    }

    .adm-lb-rank {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        flex-shrink: 0;
    }

    .adm-lb-rank.gold {
        background: linear-gradient(135deg, #F59E0B, #D97706);
        color: #fff;
    }

    .adm-lb-rank.silver {
        background: linear-gradient(135deg, #9CA3AF, #6B7280);
        color: #fff;
    }

    .adm-lb-rank.bronze {
        background: linear-gradient(135deg, #CD7F32, #A0522D);
        color: #fff;
    }

    .adm-lb-rank.other {
        background: #F3F0EC;
        color: #6B7280;
    }

    .adm-lb-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .adm-lb-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .adm-lb-name {
        font-size: 13px;
        font-weight: 600;
        color: #1C2B35;
    }

    .adm-lb-sub {
        font-size: 11px;
        color: #9CA3AF;
    }

    .adm-lb-bar-wrap {
        flex: 1;
    }

    .adm-lb-bar {
        height: 5px;
        background: #E8E3DD;
        border-radius: 999px;
        overflow: hidden;
    }

    .adm-lb-bar-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #273F4F, #4A6B80);
    }

    .adm-lb-count {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: #273F4F;
        min-width: 32px;
        text-align: right;
    }

    .adm-lb-share {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 7px;
        font-size: 10px;
        font-weight: 700;
        background: rgba(91, 14, 20, 0.08);
        color: #5B0E14;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .adm-lb-share:hover {
        background: #5B0E14;
        color: #fff;
    }

    /* ── Announcement Composer ── */
    .ann-textarea {
        width: 100%;
        min-height: 110px;
        padding: 12px 14px;
        border: 1.5px solid #E2DDD8;
        border-radius: 12px;
        font-size: 13px;
        color: #1C2B35;
        background: #F9F8F6;
        resize: none;
        outline: none;
        font-family: 'DM Sans', sans-serif;
        line-height: 1.6;
        transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
    }

    .ann-textarea:focus {
        border-color: #5B0E14;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(91, 14, 20, 0.07);
    }

    .ann-textarea::placeholder {
        color: #B8B0A8;
    }

    .ann-emoji-trigger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid #E2DDD8;
        background: #F7F5F2;
        cursor: pointer;
        font-size: 16px;
        transition: all 0.15s;
    }

    .ann-emoji-trigger:hover {
        border-color: #273F4F;
        background: #E8EFF4;
    }

    .ann-emoji-panel {
        position: absolute;
        bottom: 42px;
        left: 0;
        background: #fff;
        border: 1.5px solid #E8E3DD;
        border-radius: 14px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
        padding: 10px;
        display: none;
        z-index: 20;
        width: 260px;
    }

    .ann-emoji-panel.open {
        display: block;
        animation: emojiIn 0.15s ease;
    }

    @keyframes emojiIn {
        from {
            opacity: 0;
            transform: translateY(6px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .ann-emoji-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 2px;
    }

    .ann-emoji-btn {
        font-size: 18px;
        padding: 4px;
        border-radius: 6px;
        cursor: pointer;
        border: none;
        background: transparent;
        transition: background 0.1s;
        line-height: 1;
        text-align: center;
    }

    .ann-emoji-btn:hover {
        background: #F0EDE8;
    }

    .ann-media-preview {
        position: relative;
        margin-top: 10px;
        border-radius: 10px;
        overflow: hidden;
        border: 1.5px solid #E8E3DD;
        display: none;
    }

    .ann-media-preview.has-file {
        display: block;
    }

    .ann-media-preview img,
    .ann-media-preview video {
        width: 100%;
        max-height: 160px;
        object-fit: cover;
        display: block;
    }

    .ann-media-remove {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
    }

    .ann-toolbar {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 16px;
        border-top: 1px solid #F3F0EC;
        background: #FAFAF9;
        flex-wrap: wrap;
    }

    .ann-toolbar-left {
        display: flex;
        align-items: center;
        gap: 6px;
        flex: 1;
    }

    .ann-char-count {
        font-size: 10px;
        color: #C4BDB6;
        font-weight: 600;
    }

    .ann-post-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 18px;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
    }

    .ann-post-btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .ann-media-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
        border: 1.5px solid #E2DDD8;
        background: #F7F5F2;
        color: #6B7280;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .ann-media-btn:hover {
        border-color: #273F4F;
        color: #273F4F;
        background: #E8EFF4;
    }

    /* ── Announcements Feed (FIXED) ── */
    .adm-feed {
        padding: 0 24px 32px;
    }

    .adm-feed-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 0 12px;
    }

    .adm-feed-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9CA3AF;
    }

    .ann-card {
        background: #fff;
        border: 1px solid #E8E3DD;
        border-radius: 16px;
        margin-bottom: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(39, 63, 79, 0.06);
        transition: box-shadow 0.15s;
    }

    .ann-card:hover {
        box-shadow: 0 4px 18px rgba(39, 63, 79, 0.10);
    }

    .ann-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 16px 10px;
        border-bottom: 1px solid #F7F5F2;
    }

    .ann-card-meta {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ann-card-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .ann-card-author {
        font-size: 13px;
        font-weight: 700;
        color: #1C2B35;
    }

    .ann-card-time {
        font-size: 11px;
        color: #9CA3AF;
        margin-top: 1px;
    }

    .ann-card-body {
        padding: 12px 16px 10px;
    }

    .ann-card-msg {
        font-size: 14px;
        color: #374151;
        line-height: 1.7;
        white-space: pre-wrap;
        margin: 0;
        word-break: break-word;
    }

    .ann-card-media {
        margin: 0 16px 12px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #F0EDE8;
    }

    .ann-card-media img {
        width: 100%;
        max-height: 320px;
        object-fit: cover;
        display: block;
    }

    .ann-card-media video {
        width: 100%;
        max-height: 320px;
        display: block;
    }

    .ann-del-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 11px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 700;
        color: #DC2626;
        background: #FEF2F2;
        border: 1.5px solid #FECACA;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .ann-del-btn:hover {
        background: #DC2626;
        color: #fff;
        border-color: #DC2626;
    }

    /* Reactions */
    .ann-card-reactions {
        padding: 6px 16px 8px;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .react-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 13px;
        border: 1.5px solid #E8E3DD;
        background: #F7F5F2;
        cursor: pointer;
        transition: all 0.15s;
        color: #6B7280;
        font-family: inherit;
    }

    .react-pill:hover {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
    }

    .react-pill .rcount {
        font-size: 11px;
        font-weight: 700;
    }

    /* Comments section in admin feed */
    .ann-card-comments {
        border-top: 1px solid #F3F0EC;
    }

    .ann-comments-toggle-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 9px 16px;
        font-size: 12px;
        font-weight: 600;
        color: #9CA3AF;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
        font-family: inherit;
        transition: color 0.15s;
    }

    .ann-comments-toggle-btn:hover {
        color: #5B0E14;
    }

    .ann-comments-list {
        padding: 4px 16px 12px;
        display: none;
        max-height: 220px;
        overflow-y: auto;
    }

    .ann-comments-list.open {
        display: block;
    }

    .adm-comment-item {
        display: flex;
        gap: 8px;
        margin-bottom: 8px;
    }

    .adm-comment-avatar {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .adm-comment-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .adm-comment-bubble {
        background: #F7F5F2;
        border-radius: 0 10px 10px 10px;
        padding: 7px 11px;
        flex: 1;
    }

    .adm-comment-name {
        font-size: 11px;
        font-weight: 700;
        color: #1C2B35;
        margin-bottom: 2px;
    }

    .adm-comment-msg {
        font-size: 12px;
        color: #4B5563;
        line-height: 1.5;
    }

    .adm-comment-time {
        font-size: 10px;
        color: #C4BDB6;
        margin-top: 2px;
    }

    .adm-empty {
        padding: 32px 24px;
        text-align: center;
        color: #C4BDB6;
        font-size: 13px;
    }
</style>

<div class="adm-page">

    <!-- Stats Row -->
    <div class="adm-stats">
        <div class="adm-stat">
            <div class="adm-stat-icon" style="background:linear-gradient(135deg,#EFF6FF,#DBEAFE);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#3B82F6" width="20" height="20">
                    <path
                        d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM1.49 15.326a.78.78 0 0 1-.358-.442 3 3 0 0 1 4.308-3.516 6.484 6.484 0 0 0-1.905 3.959c-.023.222-.014.442.025.654a4.97 4.97 0 0 1-2.07-.655ZM16.44 15.98a4.97 4.97 0 0 0 2.07-.654.78.78 0 0 0 .357-.442 3 3 0 0 0-4.308-3.517 6.484 6.484 0 0 1 1.907 3.96 2.32 2.32 0 0 1-.026.654ZM18 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM5.304 16.19a.844.844 0 0 1-.277-.71 5 5 0 0 1 9.947 0 .843.843 0 0 1-.277.71A6.975 6.975 0 0 1 10 18a6.974 6.974 0 0 1-4.696-1.81Z" />
                </svg>
            </div>
            <div>
                <div class="adm-stat-label">Students Registered</div>
                <div class="adm-stat-val" style="color:#273F4F;">
                    <%= totalStudents %>
                </div>
            </div>
        </div>
        <div class="adm-stat">
            <div class="adm-stat-icon" style="background:linear-gradient(135deg,#F0FDF4,#DCFCE7);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#059669" width="20" height="20">
                    <path fill-rule="evenodd"
                        d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                        clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <div class="adm-stat-label">Currently Sit-in</div>
                <div class="adm-stat-val" style="color:#059669;">
                    <%= activeSitins %>
                </div>
            </div>
        </div>
        <div class="adm-stat">
            <div class="adm-stat-icon" style="background:linear-gradient(135deg,#FFF7ED,#FFEDD5);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EA580C" width="20" height="20">
                    <path fill-rule="evenodd"
                        d="M3 6a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm4.5 7.5a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0v-2.25a.75.75 0 0 1 .75-.75Zm3.75-1.5a.75.75 0 0 0-1.5 0v4.5a.75.75 0 0 0 1.5 0V12Zm2.25-3a.75.75 0 0 1 .75.75v6.75a.75.75 0 0 1-1.5 0V9.75A.75.75 0 0 1 13.5 9Z"
                        clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <div class="adm-stat-label">Total Sit-in</div>
                <div class="adm-stat-val" style="color:#EA580C;">
                    <%= totalSitins %>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="adm-main">

        <!-- Left: Leaderboard -->
        <div class="adm-panel">
            <div class="adm-panel-head">
                <span class="adm-panel-dot" style="background:#F59E0B;"></span>
                <span class="adm-panel-title">Top Students Analytics</span>
                <span style="margin-left:auto;font-size:10px;color:#9CA3AF;">Click Share to post to announcements</span>
            </div>
            <div class="adm-tabs" id="lbTabs">
                <button class="adm-tab active" data-tab="students" onclick="switchTab('students')">🎓 By Sit-in</button>
                <button class="adm-tab" data-tab="labs" onclick="switchTab('labs')">🖥 By Lab</button>
                <button class="adm-tab" data-tab="purposes" onclick="switchTab('purposes')">📌 By Purpose</button>
            </div>

            <!-- By Students -->
            <div id="tab-students">
                <% var maxSitins=topStudents.length> 0 ? topStudents[0].sitin_count : 1; %>
                    <% if (topStudents.length> 0) { %>
                        <% topStudents.forEach(function(s, i) { var
                            rankClass=i===0?'gold':i===1?'silver':i===2?'bronze':'other'; var
                            initials=(s.first_name?s.first_name[0]:'')+(s.last_name?s.last_name[0]:''); var
                            pct=Math.round((s.sitin_count/maxSitins)*100); %>
                            <div class="adm-lb-item">
                                <span class="adm-lb-rank <%= rankClass %>">
                                    <%= i+1 %>
                                </span>
                                <div class="adm-lb-avatar">
                                    <% if(s.profile_picture && s.profile_picture!=='' ) { %><img
                                            src="<%= s.profile_picture %>">
                                        <% } else { %>
                                            <%= initials.toUpperCase() %>
                                                <% } %>
                                </div>
                                <div style="flex:1;min-width:0;">
                                    <div class="adm-lb-name">
                                        <%= s.last_name %>, <%= s.first_name %>
                                    </div>
                                    <div class="adm-lb-sub">
                                        <%= s.course %> · <%= s.id_number %>
                                    </div>
                                    <div class="adm-lb-bar-wrap" style="margin-top:4px;">
                                        <div class="adm-lb-bar">
                                            <div class="adm-lb-bar-fill" style="width:<%= pct %>%;"></div>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span class="adm-lb-count">
                                        <%= s.sitin_count %>
                                    </span>
                                    <button class="adm-lb-share"
                                        onclick="shareToAnnouncement('🏆 Top Student: <%= s.first_name %> <%= s.last_name %> (<%= s.id_number %>) with <%= s.sitin_count %> sit-in sessions! #CCSLabRecognition')">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor"
                                            width="10" height="10">
                                            <path
                                                d="M7.724 1.282a.75.75 0 0 0-1.448 0l-.424 1.74a3.25 3.25 0 0 1-2.374 2.374l-1.74.425a.75.75 0 0 0 0 1.448l1.74.424a3.25 3.25 0 0 1 2.374 2.375l.424 1.74a.75.75 0 0 0 1.448 0l.425-1.74a3.25 3.25 0 0 1 2.374-2.375l1.74-.424a.75.75 0 0 0 0-1.448l-1.74-.425A3.25 3.25 0 0 1 8.15 3.022l-.424-1.74Z" />
                                        </svg>
                                        Share
                                    </button>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="adm-empty">No sit-in data yet.</div>
                                    <% } %>
            </div>

            <!-- By Labs -->
            <div id="tab-labs" style="display:none;">
                <% var maxLab=topLabs.length> 0 ? topLabs[0].count : 1; %>
                    <% if (topLabs.length> 0) { %>
                        <% topLabs.forEach(function(lab, i) { var
                            rankClass=i===0?'gold':i===1?'silver':i===2?'bronze':'other'; var
                            pct=Math.round((lab.count/maxLab)*100); %>
                            <div class="adm-lb-item">
                                <span class="adm-lb-rank <%= rankClass %>">
                                    <%= i+1 %>
                                </span>
                                <div class="adm-lb-avatar"
                                    style="background:linear-gradient(135deg,#1C2B35,#273F4F);font-size:14px;">🖥</div>
                                <div style="flex:1;min-width:0;">
                                    <div class="adm-lb-name">Lab <%= lab.lab_room %>
                                    </div>
                                    <div class="adm-lb-sub">Laboratory Room</div>
                                    <div class="adm-lb-bar-wrap" style="margin-top:4px;">
                                        <div class="adm-lb-bar">
                                            <div class="adm-lb-bar-fill"
                                                style="width:<%= pct %>%;background:linear-gradient(90deg,#5B0E14,#9b1a24);">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span class="adm-lb-count" style="color:#5B0E14;">
                                        <%= lab.count %>
                                    </span>
                                    <button class="adm-lb-share"
                                        onclick="shareToAnnouncement('🖥 Lab <%= lab.lab_room %> is the most used laboratory this period with <%= lab.count %> sessions! #CCSLaboratory')">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor"
                                            width="10" height="10">
                                            <path
                                                d="M7.724 1.282a.75.75 0 0 0-1.448 0l-.424 1.74a3.25 3.25 0 0 1-2.374 2.374l-1.74.425a.75.75 0 0 0 0 1.448l1.74.424a3.25 3.25 0 0 1 2.374 2.375l.424 1.74a.75.75 0 0 0 1.448 0l.425-1.74a3.25 3.25 0 0 1 2.374-2.375l1.74-.424a.75.75 0 0 0 0-1.448l-1.74-.425A3.25 3.25 0 0 1 8.15 3.022l-.424-1.74Z" />
                                        </svg>
                                        Share
                                    </button>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="adm-empty">No lab data yet.</div>
                                    <% } %>
            </div>

            <!-- By Purpose -->
            <div id="tab-purposes" style="display:none;">
                <% var maxPurp=topPurposes.length> 0 ? topPurposes[0].count : 1; %>
                    <% if (topPurposes.length> 0) { %>
                        <% topPurposes.forEach(function(p, i) { var
                            rankClass=i===0?'gold':i===1?'silver':i===2?'bronze':'other'; var
                            pct=Math.round((p.count/maxPurp)*100); %>
                            <div class="adm-lb-item">
                                <span class="adm-lb-rank <%= rankClass %>">
                                    <%= i+1 %>
                                </span>
                                <div class="adm-lb-avatar"
                                    style="background:linear-gradient(135deg,#059669,#047857);font-size:14px;">📌</div>
                                <div style="flex:1;min-width:0;">
                                    <div class="adm-lb-name">
                                        <%= p.purpose %>
                                    </div>
                                    <div class="adm-lb-sub">Most common purpose</div>
                                    <div class="adm-lb-bar-wrap" style="margin-top:4px;">
                                        <div class="adm-lb-bar">
                                            <div class="adm-lb-bar-fill"
                                                style="width:<%= pct %>%;background:linear-gradient(90deg,#059669,#34D399);">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span class="adm-lb-count" style="color:#059669;">
                                        <%= p.count %>
                                    </span>
                                    <button class="adm-lb-share"
                                        onclick="shareToAnnouncement('📌 Most popular activity: &quot;<%= p.purpose %>&quot; with <%= p.count %> sessions! #CCSLab')">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor"
                                            width="10" height="10">
                                            <path
                                                d="M7.724 1.282a.75.75 0 0 0-1.448 0l-.424 1.74a3.25 3.25 0 0 1-2.374 2.374l-1.74.425a.75.75 0 0 0 0 1.448l1.74.424a3.25 3.25 0 0 1 2.374 2.375l.424 1.74a.75.75 0 0 0 1.448 0l.425-1.74a3.25 3.25 0 0 1 2.374-2.375l1.74-.424a.75.75 0 0 0 0-1.448l-1.74-.425A3.25 3.25 0 0 1 8.15 3.022l-.424-1.74Z" />
                                        </svg>
                                        Share
                                    </button>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="adm-empty">No purpose data yet.</div>
                                    <% } %>
            </div>
        </div>

        <!-- Right: Post Announcement Composer -->
        <div class="adm-panel">
            <div class="adm-panel-head">
                <span class="adm-panel-dot" style="background:#5B0E14;"></span>
                <span class="adm-panel-title">Post Announcement</span>
            </div>
            <form action="/admin/announcement" method="POST" enctype="multipart/form-data" id="annForm">
                <div style="padding:14px 16px;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                        <div
                            style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#5B0E14,#3A0910);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#F1E194;flex-shrink:0;">
                            A</div>
                        <div>
                            <div style="font-size:12px;font-weight:700;color:#1C2B35;">CCS Admin</div>
                            <div style="font-size:10px;color:#9CA3AF;">Post to all students</div>
                        </div>
                    </div>
                    <textarea name="message" id="annMessage" class="ann-textarea"
                        placeholder="Share an announcement, recognition, reminder, or update..." maxlength="1000"
                        oninput="updateCharCount(this)"></textarea>
                    <div id="annMediaPreview" class="ann-media-preview">
                        <img id="annMediaImg" src="" alt="" style="display:none;">
                        <video id="annMediaVid" controls style="display:none;"></video>
                        <button type="button" class="ann-media-remove" onclick="removeMedia()">✕</button>
                    </div>
                    <input type="file" name="media" id="annMediaFile" accept="image/*,video/mp4,video/webm,.gif"
                        style="display:none;" onchange="previewMedia(this)">
                </div>
                <div class="ann-toolbar">
                    <div class="ann-toolbar-left" style="position:relative;">
                        <button type="button" class="ann-emoji-trigger" onclick="toggleEmojiPanel(event)"
                            title="Add emoji">😊</button>
                        <div class="ann-emoji-panel" id="emojiPanel">
                            <div
                                style="font-size:10px;font-weight:700;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;">
                                Emojis</div>
                            <div class="ann-emoji-grid">
                                <% ['😊','😄','🎉','👏','🔥','✅','⚠️','📢','🏆','🎓','💻','📌','📅','💡','👍','❤️','🙏','😂','🤔','🚀','⭐','🎯','📊','🔔','👀','💪','🌟','🎁','📝','🔑','🏫','🖥'].forEach(function(e){
                                    %>
                                    <button type="button" class="ann-emoji-btn" onclick="insertEmoji('<%= e %>')"
                                        title="<%= e %>">
                                        <%= e %>
                                    </button>
                                    <% }); %>
                            </div>
                        </div>
                        <label class="ann-media-btn" for="annMediaFile" style="cursor:pointer;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12"
                                height="12">
                                <path fill-rule="evenodd"
                                    d="M2 4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4Zm10.5 5.707a.5.5 0 0 0-.146-.353l-1.5-1.5a.5.5 0 0 0-.708 0L9.354 9.646 8.707 9a.5.5 0 0 0-.707 0l-2 2a.5.5 0 0 0 .707.707L8 10.207l.646.647a.5.5 0 0 0 .708 0l.896-.897 1.146 1.147a.5.5 0 0 0 .708-.708l-1.5-1.5A.5.5 0 0 0 10 8.5a.5.5 0 0 0 .354.146l1.5-1.5a.5.5 0 0 0 .146-.354V9.707ZM6.5 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"
                                    clip-rule="evenodd" />
                            </svg>
                            Photo / GIF
                        </label>
                        <span class="ann-char-count"><span id="charCount">0</span>/1000</span>
                    </div>
                    <button type="submit" class="ann-post-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor" width="12"
                            height="12">
                            <path
                                d="M1.429 1.5a.75.75 0 0 0-.827 1.094l1.95 3.9L9 7l-6.448.506-1.95 3.9A.75.75 0 0 0 1.43 12.5l11-5.25a.75.75 0 0 0 0-1.5l-11-5.25Z" />
                        </svg>
                        Post
                    </button>
                </div>
            </form>
            <div style="padding:10px 16px;background:#F7F5F2;border-top:1px solid #F3F0EC;">
                <p style="font-size:10px;color:#B8B0A8;margin:0;">💡 Use the <strong
                        style="color:#9CA3AF;">Share</strong> buttons in the leaderboard to auto-fill an announcement.
                </p>
            </div>
        </div>
    </div>

    <!-- ══ Announcements Feed (FIXED LAYOUT) ══ -->
    <div class="adm-feed">
        <div class="adm-feed-head">
            <span class="adm-feed-title">📣 Posted Announcements (<%= announcements.length %>)</span>
        </div>

        <% if (announcements.length> 0) { %>
            <% announcements.forEach(function(ann) { %>
                <div class="ann-card">
                    <!-- Head -->
                    <div class="ann-card-head">
                        <div class="ann-card-meta">
                            <div class="ann-card-avatar">A</div>
                            <div>
                                <div class="ann-card-author">CCS Admin<% if(ann.first_name) { %> · <%= ann.first_name %>
                                            <% } %>
                                </div>
                                <div class="ann-card-time">
                                    <%= new
                                        Date(ann.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'})
                                        %>
                                </div>
                            </div>
                        </div>
                        <form action="/admin/announcement/<%= ann.id %>/delete" method="POST" style="margin:0;"
                            onsubmit="return confirm('Delete this announcement?')">
                            <button type="submit" class="ann-del-btn">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor"
                                    width="10" height="10">
                                    <path fill-rule="evenodd"
                                        d="M6 2a.75.75 0 0 0-.712.513L4.843 4H2.75a.75.75 0 0 0 0 1.5h.428l.612 5.5A1.5 1.5 0 0 0 5.282 12.5h3.436a1.5 1.5 0 0 0 1.492-1.5l.612-5.5h.428a.75.75 0 0 0 0-1.5h-2.093L8.712 2.513A.75.75 0 0 0 8 2H6ZM5.5 5.5l.312 3H8.188l.312-3H5.5Z"
                                        clip-rule="evenodd" />
                                </svg>
                                Delete
                            </button>
                        </form>
                    </div>

                    <!-- Media -->
                    <% if (ann.media_url && ann.media_url !=='' ) { %>
                        <div class="ann-card-media">
                            <% if (ann.media_type==='video' ) { %>
                                <video controls>
                                    <source src="<%= ann.media_url %>">
                                </video>
                                <% } else { %>
                                    <img src="<%= ann.media_url %>" alt="Announcement media" loading="lazy">
                                    <% } %>
                        </div>
                        <% } %>

                            <!-- Body -->
                            <div class="ann-card-body">
                                <p class="ann-card-msg">
                                    <%= ann.message %>
                                </p>
                            </div>

                            <!-- Reactions (read-only view for admin) -->
                            <div class="ann-card-reactions" id="adm-reactions-<%= ann.id %>">
                                <% var reactionEmojis=['👍','❤️','😂','😮','😢','👏']; %>
                                    <% reactionEmojis.forEach(function(emoji) { var count=(ann.reactions &&
                                        ann.reactions[emoji]) ? ann.reactions[emoji] : 0; if (count> 0) { %>
                                        <span class="react-pill">
                                            <%= emoji %> <span class="rcount">
                                                    <%= count %>
                                                </span>
                                        </span>
                                        <% } }); %>
                            </div>

                            <!-- Comments section -->
                            <div class="ann-card-comments">
                                <button class="ann-comments-toggle-btn" onclick="admToggleComments(<%= ann.id %>)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"
                                        width="12" height="12">
                                        <path fill-rule="evenodd"
                                            d="M1 8.74c0 .983.713 1.825 1.69 1.943L3 10.72v2.03a.75.75 0 0 0 1.28.53l1.5-1.5.31-.03H9a2.26 2.26 0 0 0 2.25-2.25v-5.5A2.25 2.25 0 0 0 9 1.75H4A2.25 2.25 0 0 0 1.75 4v4.74H1Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                    <span id="adm-ctoggle-<%= ann.id %>">View comments</span>
                                </button>
                                <div class="ann-comments-list" id="adm-comments-body-<%= ann.id %>">
                                    <div id="adm-comments-list-<%= ann.id %>">
                                        <div style="text-align:center;color:#C4BDB6;font-size:12px;padding:8px;">
                                            Loading...</div>
                                    </div>
                                </div>
                            </div>
                </div>
                <% }); %>
                    <% } else { %>
                        <div
                            style="background:#fff;border:1px solid #E8E3DD;border-radius:16px;padding:48px 24px;text-align:center;color:#C4BDB6;">
                            <div style="font-size:32px;margin-bottom:10px;">📣</div>
                            <p style="font-size:14px;font-weight:600;color:#4B5563;margin:0;">No announcements yet</p>
                            <p style="font-size:12px;margin:4px 0 0;">Post your first announcement above.</p>
                        </div>
                        <% } %>
    </div>
</div>

<!-- Search + Sit-in modals (kept from original) -->
<div id="searchModal" class="modal-overlay" onclick="if(event.target===this) closeSearchModal()">
    <div class="modal-card">
        <div class="modal-header">
            <div class="modal-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                Search Student
            </div>
            <button class="modal-close" onclick="closeSearchModal()">✕</button>
        </div>
        <div class="modal-body">
            <div class="search-input-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="15" height="15">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                <input type="text" id="searchStudentInput" class="search-input" placeholder="Enter student ID number..."
                    onkeydown="if(event.key==='Enter') searchStudent()" autocomplete="off" />
            </div>
            <div id="searchError" class="search-error"><span id="searchErrorText">No student found.</span></div>
        </div>
        <div class="modal-footer"><button class="btn-search" onclick="searchStudent()">Search</button></div>
    </div>
</div>

<div id="sitinModal" class="modal-overlay" onclick="if(event.target===this) closeSitinModal()">
    <div class="modal-card">
        <div class="modal-header" style="background:linear-gradient(135deg,#5B0E14,#3A0910);">
            <div class="modal-title" style="color:#fff;">Sit In Form</div>
            <button class="modal-close" onclick="closeSitinModal()"
                style="border-color:rgba(255,255,255,0.2);background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);">✕</button>
        </div>
        <form id="sitinForm" action="/admin/sitin/start" method="POST">
            <input type="hidden" name="return_to" value="/admin">
            <input type="hidden" name="user_id" id="sitinUserId">
            <input type="hidden" name="computer_number" id="sitinComputerNumber" value="">
            <div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid #F3F0EC;">
                <div style="padding:14px 20px;border-right:1px solid #F3F0EC;">
                    <div
                        style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;">
                        ID Number</div>
                    <div id="sitinIdNumber" style="font-size:14px;font-weight:700;color:#1C2B35;font-family:monospace;">
                    </div>
                </div>
                <div style="padding:14px 20px;background:#FFF9F0;">
                    <div
                        style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;">
                        Sessions Left</div>
                    <div id="sitinSessions" style="font-size:14px;font-weight:800;color:#5B0E14;"></div>
                </div>
                <div style="padding:14px 20px;grid-column:span 2;border-top:1px solid #F3F0EC;">
                    <div
                        style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;">
                        Student Name</div>
                    <div id="sitinName" style="font-size:14px;font-weight:700;color:#1C2B35;"></div>
                </div>
            </div>
            <div style="padding:16px 20px 0;display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                <div>
                    <label
                        style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6B7280;margin-bottom:6px;">Purpose
                        *</label>
                    <select name="purpose" required id="sitinPurpose"
                        style="width:100%;padding:10px 12px;border:1.5px solid #D6D0CA;border-radius:9px;background:#F9F8F6;font-size:13px;appearance:none;outline:none;cursor:pointer;">
                        <option value="" disabled selected>Select...</option>
                        <option>C Programming</option>
                        <option>Java Programming</option>
                        <option>C# Programming</option>
                        <option>ASP.Net</option>
                        <option>PHP Programming</option>
                        <option>Database</option>
                        <option>Research</option>
                        <option>Other</option>
                    </select>
                </div>
                <div>
                    <label
                        style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6B7280;margin-bottom:6px;">Laboratory
                        *</label>
                    <select name="lab_room" required id="sitinLabRoom"
                        style="width:100%;padding:10px 12px;border:1.5px solid #D6D0CA;border-radius:9px;background:#F9F8F6;font-size:13px;appearance:none;outline:none;cursor:pointer;"
                        onchange="loadSitinPcGrid(this.value)">
                        <option value="" disabled selected>Select...</option>
                        <option value="524">Lab 524</option>
                        <option value="526">Lab 526</option>
                        <option value="528">Lab 528</option>
                        <option value="530">Lab 530</option>
                        <option value="542">Lab 542</option>
                        <option value="544">Lab 544</option>
                    </select>
                </div>
            </div>
            <div id="sitinPcSection" style="display:none;padding:0 20px 12px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                    <label style="font-size:10px;font-weight:700;text-transform:uppercase;color:#6B7280;">Select PC
                        <span
                            style="color:#9CA3AF;text-transform:none;font-weight:400;font-size:10px;">(optional)</span></label>
                    <span style="font-size:11px;color:#9CA3AF;" id="sitinSelectedPcLabel">None selected</span>
                </div>
                <div id="sitinPcGrid"
                    style="background:#F9F8F6;border:1.5px solid #E2DDD8;border-radius:12px;padding:12px;max-height:200px;overflow-y:auto;">
                    <div style="text-align:center;color:#9CA3AF;font-size:12px;padding:16px;">Select a lab to load PCs
                    </div>
                </div>
            </div>
            <div style="display:flex;gap:10px;padding:0 20px 18px;">
                <button type="button" onclick="closeSitinModal()"
                    style="flex:1;padding:10px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Cancel</button>
                <button type="submit"
                    style="flex:2;padding:10px;background:linear-gradient(135deg,#5B0E14,#7a131b);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Confirm
                    Sit-in</button>
            </div>
        </form>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
    }

    .modal-overlay.open {
        display: flex;
    }

    .modal-overlay.open .modal-card {
        animation: modalIn .2s cubic-bezier(.34, 1.56, .64, 1) both;
    }

    @keyframes modalIn {
        from {
            opacity: 0;
            transform: scale(.94) translateY(8px)
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0)
        }
    }

    .modal-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 20px 60px -10px rgba(0, 0, 0, .25);
        width: 100%;
        max-width: 460px;
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
    }

    .modal-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
    }

    .modal-close {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: transparent;
        color: #94a3b8;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        transition: all .15s;
    }

    .modal-body {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .search-input-wrap {
        position: relative;
    }

    .search-input-wrap svg {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 10px 12px 10px 38px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 13px;
        color: #1e293b;
        background: #f8fafc;
        outline: none;
        transition: all .15s;
        box-sizing: border-box;
    }

    .search-input:focus {
        border-color: #273F4F;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, .08);
    }

    .search-error {
        display: none;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 12px;
        color: #dc2626;
    }

    .search-error.visible {
        display: flex;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        padding: 0 20px 20px;
    }

    .btn-search {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 20px;
        background: #273F4F;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all .15s;
    }
</style>

<script>
    // ── Tab switching ──
    function switchTab(tab) {
        ['students', 'labs', 'purposes'].forEach(t => {
            document.getElementById('tab-' + t).style.display = t === tab ? 'block' : 'none';
        });
        document.querySelectorAll('.adm-tab').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.tab === tab);
        });
    }

    // ── Emoji picker ──
    function toggleEmojiPanel(e) {
        e.stopPropagation();
        document.getElementById('emojiPanel').classList.toggle('open');
    }
    function insertEmoji(emoji) {
        const ta = document.getElementById('annMessage');
        const pos = ta.selectionStart;
        ta.value = ta.value.slice(0, pos) + emoji + ta.value.slice(pos);
        ta.selectionStart = ta.selectionEnd = pos + emoji.length;
        ta.focus();
        updateCharCount(ta);
    }
    document.addEventListener('click', () => document.getElementById('emojiPanel').classList.remove('open'));

    function updateCharCount(ta) {
        document.getElementById('charCount').textContent = ta.value.length;
    }

    function previewMedia(input) {
        if (!input.files || !input.files[0]) return;
        const file = input.files[0];
        const preview = document.getElementById('annMediaPreview');
        const img = document.getElementById('annMediaImg');
        const vid = document.getElementById('annMediaVid');
        const url = URL.createObjectURL(file);
        preview.classList.add('has-file');
        if (file.type.startsWith('video')) {
            img.style.display = 'none'; vid.style.display = 'block'; vid.src = url;
        } else {
            vid.style.display = 'none'; img.style.display = 'block'; img.src = url;
        }
    }
    function removeMedia() {
        document.getElementById('annMediaFile').value = '';
        document.getElementById('annMediaPreview').classList.remove('has-file');
        document.getElementById('annMediaImg').src = '';
        document.getElementById('annMediaVid').src = '';
    }

    function shareToAnnouncement(text) {
        const ta = document.getElementById('annMessage');
        ta.value = text;
        ta.focus();
        updateCharCount(ta);
        ta.scrollIntoView({ behavior: 'smooth', block: 'center' });
        ta.style.boxShadow = '0 0 0 3px rgba(91,14,20,0.2)';
        setTimeout(() => ta.style.boxShadow = '', 1500);
    }

    // ── Admin: View comments on announcements ──
    const admCommentsLoaded = {};

    async function admToggleComments(annId) {
        const body = document.getElementById('adm-comments-body-' + annId);
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open');
        const toggleLabel = document.getElementById('adm-ctoggle-' + annId);

        if (!isOpen && !admCommentsLoaded[annId]) {
            admCommentsLoaded[annId] = true;
            try {
                const res = await fetch('/announcements/' + annId + '/comments');
                const comments = await res.json();
                const list = document.getElementById('adm-comments-list-' + annId);
                if (comments.length === 0) {
                    list.innerHTML = '<div style="text-align:center;color:#C4BDB6;font-size:12px;padding:12px;">No comments yet.</div>';
                } else {
                    list.innerHTML = comments.map(c => {
                        const initials = ((c.first_name || '')[0] || '') + ((c.last_name || '')[0] || '');
                        const avatarHtml = c.profile_picture
                            ? `<img src="${c.profile_picture}">`
                            : initials.toUpperCase();
                        return `<div class="adm-comment-item">
                            <div class="adm-comment-avatar">${avatarHtml}</div>
                            <div class="adm-comment-bubble">
                                <div class="adm-comment-name">${c.first_name} ${c.last_name}</div>
                                <div class="adm-comment-msg">${c.message.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
                                <div class="adm-comment-time">${new Date(c.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</div>
                            </div>
                        </div>`;
                    }).join('');
                }
                if (toggleLabel) toggleLabel.textContent = comments.length + ' comment' + (comments.length !== 1 ? 's' : '');
            } catch (e) {
                document.getElementById('adm-comments-list-' + annId).innerHTML = '<div style="color:#DC2626;font-size:12px;padding:8px;">Failed to load comments.</div>';
            }
        }

        if (toggleLabel) {
            toggleLabel.textContent = body.classList.contains('open')
                ? (toggleLabel.textContent.includes('comment') ? toggleLabel.textContent : 'View comments')
                : 'View comments';
        }
    }

    // ── Search + Sit-in modals ──
    function openSearchModal() {
        document.getElementById('searchModal').classList.add('open');
        setTimeout(() => document.getElementById('searchStudentInput').focus(), 120);
    }
    function closeSearchModal() {
        document.getElementById('searchModal').classList.remove('open');
        document.getElementById('searchStudentInput').value = '';
        document.getElementById('searchError').classList.remove('visible');
    }
    function openSitinModal(id, idNumber, name, sessions) {
        document.getElementById('sitinUserId').value = id;
        document.getElementById('sitinIdNumber').textContent = idNumber;
        document.getElementById('sitinName').textContent = name;
        document.getElementById('sitinSessions').textContent = sessions;
        document.getElementById('sitinModal').classList.add('open');
    }
    function closeSitinModal() { document.getElementById('sitinModal').classList.remove('open'); }
    async function searchStudent() {
        const q = document.getElementById('searchStudentInput').value.trim();
        if (!q) return;
        const errEl = document.getElementById('searchError');
        errEl.classList.remove('visible');
        try {
            const res = await fetch('/admin/search-student?q=' + encodeURIComponent(q));
            const data = await res.json();
            if (!data || data.error) { errEl.classList.add('visible'); return; }
            const name = data.last_name + ', ' + data.first_name + (data.middle_initial ? ' ' + data.middle_initial + '.' : '');
            closeSearchModal();
            setTimeout(() => openSitinModal(data.id, data.id_number, name, (data.remaining_sessions ?? 30) + ' sessions'), 150);
        } catch (e) { errEl.classList.add('visible'); }
    }
    document.addEventListener('keydown', e => {
        if (e.key !== 'Escape') return;
        closeSearchModal(); closeSitinModal();
    });
</script>