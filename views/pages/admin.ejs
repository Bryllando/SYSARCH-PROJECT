<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
    }

    .modal-overlay.open {
        display: flex;
    }

    .modal-overlay.open .modal-card {
        animation: modalIn .2s cubic-bezier(.34, 1.56, .64, 1) both;
    }

    @keyframes modalIn {
        from {
            opacity: 0;
            transform: scale(.94) translateY(8px)
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0)
        }
    }

    .modal-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 20px 60px -10px rgba(0, 0, 0, .25);
        width: 100%;
        max-width: 460px;
        overflow: hidden;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
    }

    .modal-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
    }

    .modal-close {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: transparent;
        color: #94a3b8;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        transition: all .15s;
    }

    .modal-body {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .search-input-wrap {
        position: relative;
    }

    .search-input-wrap svg {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 10px 12px 10px 38px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 13px;
        color: #1e293b;
        background: #f8fafc;
        outline: none;
        transition: all .15s;
        box-sizing: border-box;
    }

    .search-input:focus {
        border-color: #273F4F;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(39, 63, 79, .08);
    }

    .search-error {
        display: none;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 12px;
        color: #dc2626;
    }

    .search-error.visible {
        display: flex;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        padding: 0 20px 20px;
    }

    .btn-search {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 20px;
        background: #273F4F;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all .15s;
    }
</style>

<script>
    // ── Tab switching ──
    function switchTab(tab) {
        ['students', 'labs', 'purposes'].forEach(t => {
            document.getElementById('tab-' + t).style.display = t === tab ? 'block' : 'none';
        });
        document.querySelectorAll('.adm-tab').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.tab === tab);
        });
    }

    // ── Emoji picker ──
    function toggleEmojiPanel(e) {
        e.stopPropagation();
        document.getElementById('emojiPanel').classList.toggle('open');
    }
    function insertEmoji(emoji) {
        const ta = document.getElementById('annMessage');
        const pos = ta.selectionStart;
        ta.value = ta.value.slice(0, pos) + emoji + ta.value.slice(pos);
        ta.selectionStart = ta.selectionEnd = pos + emoji.length;
        ta.focus();
        updateCharCount(ta);
    }
    document.addEventListener('click', () => document.getElementById('emojiPanel').classList.remove('open'));

    function updateCharCount(ta) {
        const len     = ta.value.length;
        const countEl = document.getElementById('charCount');
        countEl.textContent = len;
        // Visual threshold feedback
        ta.classList.remove('near-limit', 'at-limit');
        countEl.classList.remove('near-limit', 'at-limit');
        if (len >= 1000) {
            ta.classList.add('at-limit');
            countEl.classList.add('at-limit');
        } else if (len >= 800) {
            ta.classList.add('near-limit');
            countEl.classList.add('near-limit');
        }
    }

    function previewMedia(input) {
        const errorEl  = document.getElementById('annMediaError');
        const errorTxt = document.getElementById('annMediaErrorText');
        const postBtn  = document.querySelector('.ann-post-btn');
        const badge    = document.getElementById('annMediaBadge');

        errorEl.classList.remove('visible');

        if (!input.files || !input.files[0]) return;
        const file = input.files[0];

        // Allowed types
        const ALLOWED = ['image/jpeg','image/png','image/gif','image/webp','video/mp4','video/webm'];
        if (!ALLOWED.includes(file.type)) {
            errorTxt.textContent = 'Unsupported file type. Use JPG, PNG, GIF, WEBP, MP4, or WEBM.';
            errorEl.classList.add('visible');
            input.value = '';
            return;
        }

        // Size limit: 10 MB
        const MAX = 10 * 1024 * 1024;
        if (file.size > MAX) {
            errorTxt.textContent = 'File too large. Maximum allowed size is 10 MB.';
            errorEl.classList.add('visible');
            input.value = '';
            return;
        }

        const preview = document.getElementById('annMediaPreview');
        const img     = document.getElementById('annMediaImg');
        const vid     = document.getElementById('annMediaVid');
        const url     = URL.createObjectURL(file);

        preview.classList.add('has-file');

        if (file.type.startsWith('video')) {
            img.style.display = 'none';
            vid.style.display = 'block';
            vid.src = url;
            badge.textContent = 'VIDEO';
        } else if (file.type === 'image/gif') {
            vid.style.display = 'none';
            img.style.display = 'block';
            img.src = url;
            badge.textContent = 'GIF';
        } else {
            vid.style.display = 'none';
            img.style.display = 'block';
            img.src = url;
            badge.textContent = 'IMAGE';
        }
    }
    function removeMedia() {
        document.getElementById('annMediaFile').value = '';
        document.getElementById('annMediaPreview').classList.remove('has-file');
        document.getElementById('annMediaImg').src = '';
        document.getElementById('annMediaVid').src = '';
        document.getElementById('annMediaBadge').textContent = '';
        document.getElementById('annMediaError').classList.remove('visible');
    }

    function shareToAnnouncement(text) {
        const ta = document.getElementById('annMessage');
        ta.value = text;
        ta.focus();
        updateCharCount(ta);
        ta.scrollIntoView({ behavior: 'smooth', block: 'center' });
        ta.style.boxShadow = '0 0 0 3px rgba(91,14,20,0.2)';
        setTimeout(() => ta.style.boxShadow = '', 1500);
    }


    // ── Edit Announcement Modal ──
    function openEditModal(id, currentMessage) {
        const modal = document.getElementById('editAnnModal');
        const form = document.getElementById('editAnnForm');
        const textarea = document.getElementById('editAnnMessage');
        const counter = document.getElementById('editCharCount');
        form.action = '/admin/announcement/' + id + '/edit';
        textarea.value = currentMessage || '';
        counter.textContent = (currentMessage || '').length;
        modal.classList.add('open');
        setTimeout(() => textarea.focus(), 150);
        textarea.oninput = function() { counter.textContent = this.value.length; };
    }
    function closeEditModal() {
        document.getElementById('editAnnModal').classList.remove('open');
    }

    // ── Announcement actions (Pin/Edit/Delete) ──
    // Some browsers/DOM states can cause nested forms or inline handlers to misbehave.
    // Use a single delegated handler so buttons always work.
    (function bindAnnouncementActions() {
        const esc = (v) => String(v ?? '').replace(/\s+/g, ' ').trim();

        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('[data-ann-action]');
            if (!btn) return;

            const action = btn.getAttribute('data-ann-action');

            if (action === 'edit-open') {
                const id = btn.getAttribute('data-ann-id');
                if (!id) return;
                const card = btn.closest('.ann-card');
                const msgEl = card ? card.querySelector('.ann-card-msg') : null;
                openEditModal(id, msgEl ? msgEl.textContent : '');
                return;
            }

            const url = btn.getAttribute('data-ann-url');
            if (!url) return;

            if (action === 'delete') {
                const ok = confirm('Delete this announcement permanently?');
                if (!ok) return;
            }

            btn.disabled = true;
            try {
                const res = await fetch(url, { method: 'POST', credentials: 'same-origin' });
                if (!res.ok) throw new Error('Request failed');
                window.location.reload();
            } catch (_) {
                btn.disabled = false;
                if (window.showAppToast) window.showAppToast('error', 'Action failed. Please try again.');
                else alert('Action failed. Please try again.');
            }
        });

        const editForm = document.getElementById('editAnnForm');
        if (editForm) {
            editForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const fd = new FormData(editForm);
                const body = new URLSearchParams();
                for (const [k, v] of fd.entries()) body.append(k, String(v));

                const submitBtn = editForm.querySelector('button[type="submit"]');
                if (submitBtn) submitBtn.disabled = true;
                try {
                    const res = await fetch(editForm.action, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body
                    });
                    if (!res.ok) throw new Error('Request failed');
                    window.location.reload();
                } catch (_) {
                    if (submitBtn) submitBtn.disabled = false;
                    if (window.showAppToast) window.showAppToast('error', 'Failed to save changes.');
                    else alert('Failed to save changes.');
                }
            });
        }
    })();

    // -- Search + Sit-in modals --
    function openSearchModal() {
        document.getElementById('searchModal').classList.add('open');
        setTimeout(() => document.getElementById('searchStudentInput').focus(), 120);
    }
    function closeSearchModal() {
        document.getElementById('searchModal').classList.remove('open');
        document.getElementById('searchStudentInput').value = '';
        document.getElementById('searchError').classList.remove('visible');
    }
    function openSitinModal(id, idNumber, name, sessions) {
        document.getElementById('sitinUserId').value = id;
        document.getElementById('sitinIdNumber').textContent = idNumber;
        document.getElementById('sitinName').textContent = name;
        document.getElementById('sitinSessions').textContent = sessions;
        document.getElementById('sitinModal').classList.add('open');
    }
    function closeSitinModal() { document.getElementById('sitinModal').classList.remove('open'); }
    async function searchStudent() {
        const q = document.getElementById('searchStudentInput').value.trim();
        if (!q) return;
        const errEl = document.getElementById('searchError');
        errEl.classList.remove('visible');
        try {
            const res = await fetch('/admin/search-student?q=' + encodeURIComponent(q));
            const data = await res.json();
            if (!data || data.error) { errEl.classList.add('visible'); return; }
            const name = data.last_name + ', ' + data.first_name + (data.middle_initial ? ' ' + data.middle_initial + '.' : '');
            closeSearchModal();
            setTimeout(() => openSitinModal(data.id, data.id_number, name, (data.remaining_sessions ?? 30) + ' sessions'), 150);
        } catch (e) { errEl.classList.add('visible'); }
    }

    document.addEventListener('keydown', e => {
        if (e.key !== 'Escape') return;
        closeSearchModal(); closeSitinModal(); closeEditModal();
    });

    async function loadAdminAiInsights(force = false) {
        const el = document.getElementById('admin-ai-content');
        const updatedEl = document.getElementById('admin-ai-updated');
        if (!el) return;
        const esc = (v) => String(v || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        try {
            const res = await fetch(`/api/ai/admin-insights`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ refresh: force })
            });
            const data = await res.json();
            if (!data.success || !data.insights) {
                el.innerHTML = '<div class="adm-ai-empty">No AI insights available yet.</div>';
                return;
            }
            const i = data.insights;
            if (updatedEl) {
                updatedEl.textContent = data.meta && Number.isFinite(data.meta.minutes_ago)
                    ? `Last updated: ${data.meta.minutes_ago} min ago`
                    : 'Live Summary';
            }
            el.innerHTML = `
                <div class="adm-ai-grid">
                    <div class="adm-ai-tile">
                        <p class="adm-ai-kicker">🧭 Lab Recommendation</p>
                        <p class="adm-ai-value">${esc(i.lab_insight || '-')}</p>
                    </div>
                    <div class="adm-ai-tile">
                        <p class="adm-ai-kicker">💬 Feedback Summary</p>
                        <p class="adm-ai-value">${esc(i.feedback_summary || '-')}</p>
                    </div>
                    <div class="adm-ai-tile">
                        <p class="adm-ai-kicker">🚩 Underperforming Labs</p>
                        <p class="adm-ai-value">${esc(i.underperforming_labs || '-')}</p>
                    </div>
                    <div class="adm-ai-tile">
                        <p class="adm-ai-kicker">⏰ Peak Hours Insight</p>
                        <p class="adm-ai-value">${esc(i.peak_hours_insight || '-')}</p>
                    </div>
                </div>
                <div class="adm-ai-action">
                    <p class="adm-ai-kicker">📊 Student Engagement</p>
                    <p class="adm-ai-value">${esc(i.student_engagement || '-')}</p>
                </div>
                <div class="adm-ai-action">
                    <p class="adm-ai-kicker">✅ Recommended Action</p>
                    <p class="adm-ai-value">${esc(i.recommended_action || '-')}</p>
                </div>
            `;
        } catch (_) {
            el.innerHTML = '<div class="adm-ai-empty" style="color:#b91c1c;">AI insights are temporarily unavailable.</div>';
        }
    }

    loadAdminAiInsights();
    const adminAiRefresh = document.getElementById('admin-ai-refresh');
    if (adminAiRefresh) adminAiRefresh.addEventListener('click', () => loadAdminAiInsights(true));

    const studyTipBtn = document.getElementById('studyTipBtn');
    const studyTipPanel = document.getElementById('studyTipPanel');
    const studyTipClose = document.getElementById('studyTipClose');

    async function loadStudyTip() {
        try {
            const res = await fetch('/admin/ai-study-tip');
            const data = await res.json();
            if (!data.success || !data.tip) throw new Error('no data');
            const tip = data.tip;
            document.getElementById('stBadge').textContent = tip.badge || 'Best Week: No data';
            document.getElementById('stHeroTitle').textContent = tip.hero_title || 'Best week to sit-in — No data';
            document.getElementById('stHeroDesc').textContent = tip.hero_description || 'No data yet.';
            document.getElementById('stHeroStat').textContent = tip.hero_stat || '📌 No key stats yet.';
            document.getElementById('stBestDay').textContent = tip.best_day || 'No data yet.';
            document.getElementById('stBusyDay').textContent = tip.busiest_day || 'No data yet.';
            document.getElementById('stBestLab').textContent = tip.most_available_lab || 'No data yet.';
            document.getElementById('stBestTime').textContent = tip.best_time || 'No data yet.';
            document.getElementById('stFooter').textContent = tip.footer || 'Based on system-wide lab data';
        } catch (_) {
            document.getElementById('stBadge').textContent = 'Best Week: No data';
            document.getElementById('stHeroTitle').textContent = 'Best week to sit-in — No data yet';
            document.getElementById('stHeroDesc').textContent = 'Unable to fetch analytics right now.';
            document.getElementById('stHeroStat').textContent = '📌 Try refreshing after new sit-in records are saved.';
            document.getElementById('stBestDay').textContent = 'No data yet.';
            document.getElementById('stBusyDay').textContent = 'No data yet.';
            document.getElementById('stBestLab').textContent = 'No data yet.';
            document.getElementById('stBestTime').textContent = 'No data yet.';
        }
    }

    if (studyTipBtn && studyTipPanel) {
        studyTipBtn.addEventListener('click', async () => {
            studyTipPanel.classList.add('open');
            await loadStudyTip();
        });
    }
    if (studyTipClose && studyTipPanel) {
        studyTipClose.addEventListener('click', () => studyTipPanel.classList.remove('open'));
    }

</script>