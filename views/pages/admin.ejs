<div class="p-6 space-y-6">

    <!-- Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #EFF6FF, #DBEAFE);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                    class="size-6 text-blue-600">
                    <path
                        d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM1.49 15.326a.78.78 0 0 1-.358-.442 3 3 0 0 1 4.308-3.516 6.484 6.484 0 0 0-1.905 3.959c-.023.222-.014.442.025.654a4.97 4.97 0 0 1-2.07-.655ZM16.44 15.98a4.97 4.97 0 0 0 2.07-.654.78.78 0 0 0 .357-.442 3 3 0 0 0-4.308-3.517 6.484 6.484 0 0 1 1.907 3.96 2.32 2.32 0 0 1-.026.654ZM18 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM5.304 16.19a.844.844 0 0 1-.277-.71 5 5 0 0 1 9.947 0 .843.843 0 0 1-.277.71A6.975 6.975 0 0 1 10 18a6.974 6.974 0 0 1-4.696-1.81Z" />
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-widest">Students Registered</p>
                <p class="text-3xl font-extrabold text-[#273F4F]">
                    <%= totalStudents %>
                </p>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #F0FDF4, #DCFCE7);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                    class="size-6 text-green-600">
                    <path fill-rule="evenodd"
                        d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                        clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-widest">Currently Sit-in</p>
                <p class="text-3xl font-extrabold text-green-600">
                    <%= activeSitins %>
                </p>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #FFF7ED, #FFEDD5);">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                    class="size-6 text-orange-500">
                    <path fill-rule="evenodd"
                        d="M3 6a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm4.5 7.5a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0v-2.25a.75.75 0 0 1 .75-.75Zm3.75-1.5a.75.75 0 0 0-1.5 0v4.5a.75.75 0 0 0 1.5 0V12Zm2.25-3a.75.75 0 0 1 .75.75v6.75a.75.75 0 0 1-1.5 0V9.75A.75.75 0 0 1 13.5 9Z"
                        clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-widest">Total Sit-in</p>
                <p class="text-3xl font-extrabold text-orange-500">
                    <%= totalSitins || 0 %>
                </p>
            </div>
        </div>
    </div>

    <!-- Main content: Chart + Announcement -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Chart placeholder -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#5B0E14]"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Sit-in Statistics</h2>
            </div>
            <div class="p-5">
                <canvas id="sitin-chart" height="220"></canvas>
            </div>
        </div>

        <!-- Announcements / Post -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Post Announcement</h2>
            </div>
            <div class="p-5 flex flex-col gap-3">
                <form action="/admin/announcement" method="POST" class="space-y-3">
                    <textarea name="message" rows="4" placeholder="Write an announcement..."
                        class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm resize-none transition-all"></textarea>
                    <button type="submit" class="btn-maroon py-2.5 text-sm">Post Announcement</button>
                </form>
                <div class="border-t border-gray-100 pt-3 space-y-3 max-h-48 overflow-y-auto">
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Posted Announcements</p>
                    <% if (typeof announcements !=='undefined' && announcements &&announcements.length> 0) { %>
                        <% announcements.forEach(function(ann) { %>
                            <div class="border-l-4 border-[#5B0E14] pl-3">
                                <p class="text-xs text-gray-400">CCS Admin | <%= new
                                        Date(ann.created_at).toLocaleDateString() %>
                                </p>
                                <p class="text-sm text-gray-700 mt-0.5">
                                    <%= ann.message %>
                                </p>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p class="text-xs text-gray-400">No announcements yet.</p>
                                    <% } %>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- ===== SEARCH STUDENT MODAL ===== -->
<div id="searchModal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeSearchModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between"
            style="background: linear-gradient(135deg, #273F4F, #1a2d38);">
            <h3 class="font-bold text-white flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                Search Student
            </h3>
            <button onclick="closeSearchModal()"
                class="text-white/60 hover:text-white transition-colors cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
                    <path
                        d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
                </svg>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <div class="relative">
                <input type="text" id="searchStudentInput" placeholder="Enter ID Number..."
                    class="w-full pl-10 p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none text-sm transition-all"
                    onkeydown="if(event.key==='Enter') searchStudent()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                    class="size-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
            </div>
            <div id="searchError"
                class="hidden text-xs text-red-600 font-medium bg-red-50 border border-red-200 rounded-xl px-3 py-2">
            </div>
            <button onclick="searchStudent()"
                class="btn-dark w-full py-3 text-sm flex items-center justify-center gap-2 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                Search
            </button>
        </div>
    </div>
</div>

<!-- ===== SIT-IN FORM MODAL ===== -->
<div id="sitinModal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeSitinModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between"
            style="background: linear-gradient(135deg, #5B0E14, #3A0910);">
            <h3 class="font-bold text-white flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
                    <path fill-rule="evenodd"
                        d="M4.5 2A1.5 1.5 0 0 0 3 3.5v13A1.5 1.5 0 0 0 4.5 18h11a1.5 1.5 0 0 0 1.5-1.5V7.621a1.5 1.5 0 0 0-.44-1.06l-4.12-4.122A1.5 1.5 0 0 0 11.378 2H4.5Zm2.25 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Zm0 3a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z"
                        clip-rule="evenodd" />
                </svg>
                Sit In Form
            </h3>
            <button onclick="closeSitinModal()" class="text-white/60 hover:text-white transition-colors cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5">
                    <path
                        d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
                </svg>
            </button>
        </div>
        <form id="sitinForm" action="/admin/sitin/start" method="POST" class="p-6 space-y-4">
            <input type="hidden" name="user_id" id="sitinUserId">

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider">ID Number</label>
                    <p id="sitinIdNumber"
                        class="text-sm font-semibold text-gray-700 p-2.5 bg-gray-50 rounded-xl border border-gray-200">
                    </p>
                </div>
                <div class="space-y-1">
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider">Remaining
                        Sessions</label>
                    <p id="sitinSessions"
                        class="text-sm font-bold text-[#5B0E14] p-2.5 bg-red-50 rounded-xl border border-red-100"></p>
                </div>
            </div>

            <div class="space-y-1">
                <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider">Student Name</label>
                <p id="sitinName"
                    class="text-sm font-semibold text-gray-700 p-2.5 bg-gray-50 rounded-xl border border-gray-200"></p>
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700 ml-1">Purpose</label>
                <div class="relative">
                    <select name="purpose" required
                        class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm">
                        <option value="" disabled selected>Select Purpose</option>
                        <option value="C Programming">C Programming</option>
                        <option value="Java Programming">Java Programming</option>
                        <option value="C# Programming">C# Programming</option>
                        <option value="ASP.Net">ASP.Net</option>
                        <option value="PHP Programming">PHP Programming</option>
                        <option value="Database">Database</option>
                        <option value="Research">Research</option>
                        <option value="Other">Other</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                            stroke="currentColor" class="size-4 text-gray-400">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700 ml-1">Laboratory</label>
                <div class="relative">
                    <select name="lab_room" required
                        class="w-full p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] outline-none appearance-none text-sm">
                        <option value="" disabled selected>Select Lab Room</option>
                        <option value="524">Lab 524</option>
                        <option value="526">Lab 526</option>
                        <option value="528">Lab 528</option>
                        <option value="530">Lab 530</option>
                        <option value="Mac Lab">Mac Lab</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                            stroke="currentColor" class="size-4 text-gray-400">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="flex gap-3 pt-1">
                <button type="submit" class="btn-maroon flex-1 py-3 text-base cursor-pointer">
                    Sit In
                </button>
                <button type="button" onclick="closeSitinModal()" class="btn-dark flex-1 py-3 text-base cursor-pointer">
                    Close
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Chart
    const ctx = document.getElementById('sitin-chart');
    if (ctx) {
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['C Programming', 'Java', 'C#', 'ASP.Net', 'PHP', 'Other'],
                datasets: [{
                    data: [30, 25, 20, 10, 10, 5],
                    backgroundColor: ['#5B0E14', '#273F4F', '#F1E194', '#059669', '#3B82F6', '#F97316'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12 } } }
            }
        });
    }

    // Search Modal
    function openSearchModal() {
        document.getElementById('searchModal').classList.remove('hidden');
        document.getElementById('searchModal').classList.add('flex');
        setTimeout(() => document.getElementById('searchStudentInput').focus(), 100);
    }
    function closeSearchModal() {
        document.getElementById('searchModal').classList.add('hidden');
        document.getElementById('searchModal').classList.remove('flex');
        document.getElementById('searchStudentInput').value = '';
        document.getElementById('searchError').classList.add('hidden');
    }

    // Sit-in Modal
    function closeSitinModal() {
        document.getElementById('sitinModal').classList.add('hidden');
        document.getElementById('sitinModal').classList.remove('flex');
    }

    async function searchStudent() {
        const q = document.getElementById('searchStudentInput').value.trim();
        if (!q) return;
        const errEl = document.getElementById('searchError');
        errEl.classList.add('hidden');

        try {
            const res = await fetch('/admin/search-student?q=' + encodeURIComponent(q));
            const data = await res.json();
            if (!data || data.error) {
                errEl.textContent = 'Student not found. Check the ID number and try again.';
                errEl.classList.remove('hidden');
                return;
            }
            // Populate sit-in form
            document.getElementById('sitinUserId').value = data.id;
            document.getElementById('sitinIdNumber').textContent = data.id_number;
            document.getElementById('sitinName').textContent = data.last_name + ', ' + data.first_name + (data.middle_initial ? ' ' + data.middle_initial + '.' : '');
            document.getElementById('sitinSessions').textContent = (data.remaining_sessions ?? 30) + ' sessions left';

            closeSearchModal();
            document.getElementById('sitinModal').classList.remove('hidden');
            document.getElementById('sitinModal').classList.add('flex');
        } catch (e) {
            errEl.textContent = 'Error searching student. Please try again.';
            errEl.classList.remove('hidden');
        }
    }

    // Hook sidebar Search link to open modal
    document.addEventListener('DOMContentLoaded', () => {
        const searchLinks = document.querySelectorAll('a[href="/admin/search"]');
        searchLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                openSearchModal();
            });
        });
    });
</script>