<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .adm-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    /* ── Stats ── */
    .adm-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        padding: 20px 24px 0;
    }

    .adm-stat {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #E8E3DD;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
    }

    .adm-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .adm-stat-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9CA3AF;
        margin-bottom: 3px;
    }

    .adm-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 30px;
        font-weight: 800;
        line-height: 1;
    }

    /* ── Main grid ── */
    .adm-main {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 14px;
        padding: 14px 24px;
    }

    /* ── Panel base ── */
    .adm-panel {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #E8E3DD;
        overflow: hidden;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
    }

    .adm-panel-head {
        padding: 14px 18px;
        border-bottom: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        gap: 8px;
        background: #FAFAF9;
    }

    .adm-panel-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .adm-panel-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #374151;
    }

    /* ── Tabs ── */
    .adm-tabs {
        display: flex;
        gap: 4px;
        padding: 10px 18px;
        border-bottom: 1px solid #F3F0EC;
        background: #F7F5F2;
    }

    .adm-tab {
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        background: transparent;
        color: #9CA3AF;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .adm-tab.active {
        background: #273F4F;
        color: #fff;
    }

    /* ── Leaderboard ── */
    .adm-lb-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        border-bottom: 1px solid #F7F5F2;
        transition: background 0.12s;
    }

    .adm-lb-item:last-child {
        border-bottom: none;
    }

    .adm-lb-item:hover {
        background: #FAFAF9;
    }

    .adm-lb-rank {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        flex-shrink: 0;
    }

    .adm-lb-rank.gold {
        background: linear-gradient(135deg, #F59E0B, #D97706);
        color: #fff;
    }

    .adm-lb-rank.silver {
        background: linear-gradient(135deg, #9CA3AF, #6B7280);
        color: #fff;
    }

    .adm-lb-rank.bronze {
        background: linear-gradient(135deg, #CD7F32, #A0522D);
        color: #fff;
    }

    .adm-lb-rank.other {
        background: #F3F0EC;
        color: #6B7280;
    }

    .adm-lb-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .adm-lb-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .adm-lb-name {
        font-size: 13px;
        font-weight: 600;
        color: #1C2B35;
    }

    .adm-lb-sub {
        font-size: 11px;
        color: #9CA3AF;
    }

    .adm-lb-bar-wrap {
        flex: 1;
    }

    .adm-lb-bar {
        height: 5px;
        background: #E8E3DD;
        border-radius: 999px;
        overflow: hidden;
    }

    .adm-lb-bar-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #273F4F, #4A6B80);
    }

    .adm-lb-count {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: #273F4F;
        min-width: 32px;
        text-align: right;
    }

    .adm-lb-share {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 7px;
        font-size: 10px;
        font-weight: 700;
        background: rgba(91, 14, 20, 0.08);
        color: #5B0E14;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .adm-lb-share:hover {
        background: #5B0E14;
        color: #fff;
    }

    /* ── Announcement Composer ── */
    .ann-textarea {
        width: 100%;
        min-height: 110px;
        padding: 12px 14px;
        border: 1.5px solid #E2DDD8;
        border-radius: 12px;
        font-size: 13px;
        color: #1C2B35;
        background: #F9F8F6;
        resize: none;
        outline: none;
        font-family: 'DM Sans', sans-serif;
        line-height: 1.6;
        transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
    }

    .ann-textarea:focus {
        border-color: #5B0E14;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(91, 14, 20, 0.07);
    }

    .ann-textarea::placeholder {
        color: #B8B0A8;
    }

    .ann-emoji-trigger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid #E2DDD8;
        background: #F7F5F2;
        cursor: pointer;
        font-size: 16px;
        transition: all 0.15s;
    }

    .ann-emoji-trigger:hover {
        border-color: #273F4F;
        background: #E8EFF4;
    }

    .ann-emoji-panel {
        position: absolute;
        bottom: 42px;
        left: 0;
        background: #fff;
        border: 1.5px solid #E8E3DD;
        border-radius: 14px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
        padding: 10px;
        display: none;
        z-index: 20;
        width: 260px;
    }

    .ann-emoji-panel.open {
        display: block;
        animation: emojiIn 0.15s ease;
    }

    @keyframes emojiIn {
        from {
            opacity: 0;
            transform: translateY(6px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .ann-emoji-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 2px;
    }

    .ann-emoji-btn {
        font-size: 18px;
        padding: 4px;
        border-radius: 6px;
        cursor: pointer;
        border: none;
        background: transparent;
        transition: background 0.1s;
        line-height: 1;
        text-align: center;
    }

    .ann-emoji-btn:hover {
        background: #F0EDE8;
    }

    .ann-media-preview {
        position: relative;
        margin-top: 10px;
        border-radius: 10px;
        overflow: hidden;
        border: 1.5px solid #E8E3DD;
        display: none;
    }

    .ann-media-preview.has-file {
        display: block;
    }

    .ann-media-preview img,
    .ann-media-preview video {
        width: 100%;
        max-height: 160px;
        object-fit: cover;
        display: block;
    }

    .ann-media-remove {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
    }

    .ann-media-badge {
        position: absolute;
        bottom: 8px;
        left: 8px;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background: rgba(0, 0, 0, 0.55);
        color: #fff;
        backdrop-filter: blur(4px);
    }

    .ann-media-error {
        display: none;
        align-items: center;
        gap: 5px;
        margin-top: 6px;
        padding: 6px 10px;
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 600;
        color: #DC2626;
        animation: emojiIn 0.15s ease;
    }

    .ann-media-error.visible {
        display: flex;
    }

    .ann-textarea.near-limit {
        border-color: #F59E0B;
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.08);
    }

    .ann-textarea.at-limit {
        border-color: #DC2626;
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.08);
    }

    .ann-char-count.near-limit { color: #F59E0B; }
    .ann-char-count.at-limit   { color: #DC2626; font-weight: 700; }

    .ann-toolbar {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 16px;
        border-top: 1px solid #F3F0EC;
        background: #FAFAF9;
        flex-wrap: wrap;
    }

    .ann-toolbar-left {
        display: flex;
        align-items: center;
        gap: 6px;
        flex: 1;
    }

    .ann-char-count {
        font-size: 10px;
        color: #C4BDB6;
        font-weight: 600;
    }

    .ann-post-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 18px;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
    }

    .ann-post-btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .ann-media-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
        border: 1.5px solid #E2DDD8;
        background: #F7F5F2;
        color: #6B7280;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .ann-media-btn:hover {
        border-color: #273F4F;
        color: #273F4F;
        background: #E8EFF4;
    }

    /* ── Announcements Feed (FIXED) ── */
    .adm-feed {
        padding: 0 24px 32px;
    }

    .adm-feed-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 0 12px;
    }

    .adm-feed-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9CA3AF;
    }

    .ann-card {
        background: #fff;
        border: 1px solid #E8E3DD;
        border-radius: 16px;
        margin-bottom: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(39, 63, 79, 0.06);
        transition: box-shadow 0.15s;
    }

    .ann-card:hover {
        box-shadow: 0 4px 18px rgba(39, 63, 79, 0.10);
    }

    .ann-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 16px 10px;
        border-bottom: 1px solid #F7F5F2;
    }

    .ann-card-meta {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ann-card-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .ann-card-author {
        font-size: 13px;
        font-weight: 700;
        color: #1C2B35;
    }

    .ann-card-time {
        font-size: 11px;
        color: #9CA3AF;
        margin-top: 1px;
    }

    .ann-card-body {
        padding: 12px 16px 10px;
        max-height: 200px;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .ann-card-body::-webkit-scrollbar {
        display: none;
    }

    .ann-card-msg {
        font-size: 14px;
        color: #374151;
        line-height: 1.7;
        margin: 0;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .ann-card-media {
        margin: 0 16px 12px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #F0EDE8;
    }

    .ann-card-media img {
        width: 100%;
        max-height: 320px;
        object-fit: cover;
        display: block;
    }

    .ann-card-media video {
        width: 100%;
        max-height: 320px;
        display: block;
    }

    .ann-del-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 11px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 700;
        color: #DC2626;
        background: #FEF2F2;
        border: 1.5px solid #FECACA;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .ann-del-btn:hover {
        background: #DC2626;
        color: #fff;
        border-color: #DC2626;
    }

    .adm-ai-wrap {
        padding: 12px 24px 0;
    }

    .adm-ai-card {
        background: #fff;
        border: 1px solid #E8E3DD;
        border-radius: 16px;
        padding: 0;
        box-shadow: 0 6px 18px rgba(28, 43, 53, 0.08);
        overflow: hidden;
    }

    .adm-ai-head {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        color: #fff;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #E8E3DD;
    }

    .adm-ai-head .adm-panel-title {
        color: #F1E194;
        font-size: 11px;
        letter-spacing: .08em;
    }

    .adm-ai-refresh {
        border: none;
        border-radius: 999px;
        background: #F1E194;
        color: #1C2B35;
        font-size: 11px;
        font-weight: 700;
        padding: 5px 10px;
        cursor: pointer;
    }

    .adm-ai-body {
        padding: 14px 16px;
        background: #fff;
    }

    .adm-ai-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .adm-ai-tile {
        background: #F7F5F2;
        border: 1px solid #E8E3DD;
        border-radius: 12px;
        padding: 10px 11px;
    }

    .adm-ai-kicker {
        margin: 0 0 5px;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #5B0E14;
    }

    .adm-ai-value {
        margin: 0;
        font-size: 12px;
        line-height: 1.45;
        color: #1C2B35;
        font-weight: 600;
    }

    .adm-ai-action {
        margin-top: 10px;
        padding: 10px 11px;
        border-radius: 12px;
        border: 1px solid rgba(241,225,148,.35);
        background: rgba(241,225,148,.12);
    }

    .adm-ai-action .adm-ai-kicker {
        color: #1C2B35;
    }

    .adm-ai-empty {
        color: #6B7280;
        font-size: 12px;
        padding: 8px 0;
    }

    @media (max-width: 900px) {
        .adm-ai-grid { grid-template-columns: 1fr; }
    }

    .study-tip-trigger-wrap {
        padding: 10px 24px 0;
        display: flex;
        justify-content: flex-end;
    }

    .study-tip-trigger {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        color: #F1E194;
        font-size: 12px;
        font-weight: 700;
        padding: 9px 14px;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(28, 43, 53, 0.25);
    }

    .study-tip-panel {
        position: fixed;
        top: 82px;
        right: 24px;
        width: 410px;
        max-width: calc(100vw - 24px);
        max-height: calc(100vh - 110px);
        overflow-y: auto;
        background: #FFFFFF;
        border: 1px solid #E8E3DD;
        box-shadow: 0 8px 32px rgba(28,43,53,0.15);
        border-radius: 16px;
        z-index: 120;
        display: none;
        animation: studyTipIn .22s ease-out both;
        font-family: 'DM Sans', sans-serif;
    }

    .study-tip-panel.open { display: block; }

    @keyframes studyTipIn {
        from { opacity: 0; transform: translateY(-10px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .study-tip-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 12px 14px;
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        border-radius: 16px 16px 0 0;
        color: #fff;
    }

    .study-tip-title {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: .04em;
    }

    .study-tip-title .ico { color: #F1E194; }

    .study-tip-pill {
        background: #5B0E14;
        color: #F1E194;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

    .study-tip-close {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.1);
        color: #fff;
        cursor: pointer;
        font-size: 20px;
        line-height: 1;
    }

    .study-tip-body { padding: 14px; }

    .study-tip-hero {
        background: #F7F5F2;
        border: 1px solid #E8E3DD;
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 12px;
    }

    .study-tip-hero h3 {
        margin: 0 0 4px;
        color: #1C2B35;
        font-family: 'Syne', sans-serif;
        font-size: 20px;
        font-weight: 800;
    }

    .study-tip-hero p {
        margin: 0 0 10px;
        color: #4B5563;
        font-size: 13px;
        line-height: 1.5;
    }

    .study-tip-stat {
        background: rgba(241,225,148,0.12);
        border: 1px solid rgba(241,225,148,0.3);
        border-radius: 10px;
        padding: 9px 10px;
        color: #5B0E14;
        font-size: 12px;
        font-weight: 700;
    }

    .study-tip-row {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 10px 0;
        border-bottom: 1px dashed #E8E3DD;
    }

    .study-tip-row:last-child { border-bottom: none; }

    .study-tip-ico {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: #F0EDE8;
        border: 1px solid #E8E3DD;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .study-tip-label {
        margin: 0 0 3px;
        color: #5B0E14;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .study-tip-value {
        margin: 0;
        color: #1C2B35;
        font-size: 20px;
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        line-height: 1.35;
    }

    .study-tip-foot {
        margin-top: 12px;
        padding-top: 8px;
        border-top: 1px solid #F0ECE6;
        color: #9CA3AF;
        font-size: 11px;
        font-style: italic;
        display: flex;
        align-items: center;
        gap: 6px;
    }


</style>

<div class="adm-page">

    <div class="study-tip-trigger-wrap">
        <button class="study-tip-trigger" id="studyTipBtn">💡 AI Study Tip</button>
    </div>

    

    <div class="adm-ai-wrap">
        <div class="adm-ai-card">
            <div class="adm-ai-head">
                <div class="adm-panel-title">AI Insights</div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <span id="admin-ai-updated" style="font-size:10px;color:rgba(255,255,255,.7);font-weight:700;">Live Summary</span>
                    <button id="admin-ai-refresh" class="adm-ai-refresh">Refresh Insights</button>
                </div>
            </div>
            <div id="admin-ai-content" class="adm-ai-body">
                <div class="adm-ai-empty">Loading insights...</div>
            </div>
        </div>
    </div>

    <aside class="study-tip-panel" id="studyTipPanel">
        <div class="study-tip-head">
            <div class="study-tip-title"><span class="ico">🛡</span> AI STUDY TIP</div>
            <span class="study-tip-pill" id="stBadge">Best Week: Loading...</span>
            <button class="study-tip-close" id="studyTipClose" aria-label="Close">×</button>
        </div>
        <div class="study-tip-body">
            <section class="study-tip-hero">
                <h3 id="stHeroTitle">Best week to sit-in — Loading</h3>
                <p id="stHeroDesc">Fetching system-wide session trends...</p>
                <div class="study-tip-stat" id="stHeroStat">📌 Loading statistics...</div>
            </section>

            <div class="study-tip-row">
                <div class="study-tip-ico">📅</div>
                <div>
                    <p class="study-tip-label">Best Day To Sit-In</p>
                    <p class="study-tip-value" id="stBestDay">Loading...</p>
                </div>
            </div>
            <div class="study-tip-row">
                <div class="study-tip-ico">⚠️</div>
                <div>
                    <p class="study-tip-label">Busiest Day</p>
                    <p class="study-tip-value" id="stBusyDay">Loading...</p>
                </div>
            </div>
            <div class="study-tip-row">
                <div class="study-tip-ico">🖥</div>
                <div>
                    <p class="study-tip-label">Most Available Lab</p>
                    <p class="study-tip-value" id="stBestLab">Loading...</p>
                </div>
            </div>
            <div class="study-tip-row">
                <div class="study-tip-ico">🕐</div>
                <div>
                    <p class="study-tip-label">Best Time To Visit</p>
                    <p class="study-tip-value" id="stBestTime">Loading...</p>
                </div>
            </div>

            <div class="study-tip-foot"><span>📊</span><span id="stFooter">Based on system-wide lab data</span></div>
        </div>
    </aside>

    <!-- Main Grid -->
    <div class="adm-main">

        <!-- Left: Leaderboard -->
        <div class="adm-panel">
            <div class="adm-panel-head">
                <span class="adm-panel-dot" style="background:#F59E0B;"></span>
                <span class="adm-panel-title">Top Students Analytics</span>
                <span style="margin-left:auto;font-size:10px;color:#9CA3AF;">Click Share to post to announcements</span>
            </div>
            <div class="adm-tabs" id="lbTabs">
                <button class="adm-tab active" data-tab="students" onclick="switchTab('students')">🎓 By Sit-in</button>
                <button class="adm-tab" data-tab="labs" onclick="switchTab('labs')">🖥 By Lab</button>
                <button class="adm-tab" data-tab="purposes" onclick="switchTab('purposes')">📌 By Purpose</button>
            </div>

            <!-- By Students -->
            <div id="tab-students">
                <% var maxSitins=topStudents.length> 0 ? topStudents[0].sitin_count : 1; %>
                    <% if (topStudents.length> 0) { %>
                        <% topStudents.forEach(function(s, i) { var
                            rankClass=i===0?'gold':i===1?'silver':i===2?'bronze':'other'; var
                            initials=(s.first_name?s.first_name[0]:'')+(s.last_name?s.last_name[0]:''); var
                            pct=Math.round((s.sitin_count/maxSitins)*100); %>
                            <div class="adm-lb-item">
                                <span class="adm-lb-rank <%= rankClass %>">
                                    <%= i+1 %>
                                </span>
                                <div class="adm-lb-avatar">
                                    <% if(s.profile_picture && s.profile_picture!=='' ) { %><img
                                            src="<%= s.profile_picture %>">
                                        <% } else { %>
                                            <%= initials.toUpperCase() %>
                                                <% } %>
                                </div>
                                <div style="flex:1;min-width:0;">
                                    <div class="adm-lb-name">
                                        <%= s.last_name %>, <%= s.first_name %>
                                    </div>
                                    <div class="adm-lb-sub">
                                        <%= s.course %> · <%= s.id_number %>
                                    </div>
                                    <div class="adm-lb-bar-wrap" style="margin-top:4px;">
                                        <div class="adm-lb-bar">
                                            <div class="adm-lb-bar-fill" style="width:<%= pct %>%;"></div>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span class="adm-lb-count">
                                        <%= s.sitin_count %>
                                    </span>
                                    <button class="adm-lb-share"
                                        onclick="shareToAnnouncement('🏆 Top Student: <%= s.first_name %> <%= s.last_name %> (<%= s.id_number %>) with <%= s.sitin_count %> sit-in sessions! #CCSLabRecognition')">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor"
                                            width="10" height="10">
                                            <path
                                                d="M7.724 1.282a.75.75 0 0 0-1.448 0l-.424 1.74a3.25 3.25 0 0 1-2.374 2.374l-1.74.425a.75.75 0 0 0 0 1.448l1.74.424a3.25 3.25 0 0 1 2.374 2.375l.424 1.74a.75.75 0 0 0 1.448 0l.425-1.74a3.25 3.25 0 0 1 2.374-2.375l1.74-.424a.75.75 0 0 0 0-1.448l-1.74-.425A3.25 3.25 0 0 1 8.15 3.022l-.424-1.74Z" />
                                        </svg>
                                        Share
                                    </button>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="adm-empty">No sit-in data yet.</div>
                                    <% } %>
            </div>

            <!-- By Labs -->
            <div id="tab-labs" style="display:none;">
                <% var maxLab=topLabs.length> 0 ? topLabs[0].count : 1; %>
                    <% if (topLabs.length> 0) { %>
                        <% topLabs.forEach(function(lab, i) { var
                            rankClass=i===0?'gold':i===1?'silver':i===2?'bronze':'other'; var
                            pct=Math.round((lab.count/maxLab)*100); %>
                            <div class="adm-lb-item">
                                <span class="adm-lb-rank <%= rankClass %>">
                                    <%= i+1 %>
                                </span>
                                <div class="adm-lb-avatar"
                                    style="background:linear-gradient(135deg,#1C2B35,#273F4F);font-size:14px;">🖥</div>
                                <div style="flex:1;min-width:0;">
                                    <div class="adm-lb-name">Lab <%= lab.lab_room %>
                                    </div>
                                    <div class="adm-lb-sub">Laboratory Room</div>
                                    <div class="adm-lb-bar-wrap" style="margin-top:4px;">
                                        <div class="adm-lb-bar">
                                            <div class="adm-lb-bar-fill"
                                                style="width:<%= pct %>%;background:linear-gradient(90deg,#5B0E14,#9b1a24);">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span class="adm-lb-count" style="color:#5B0E14;">
                                        <%= lab.count %>
                                    </span>
                                    <button class="adm-lb-share"
                                        onclick="shareToAnnouncement('🖥 Lab <%= lab.lab_room %> is the most used laboratory this period with <%= lab.count %> sessions! #CCSLaboratory')">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor"
                                            width="10" height="10">
                                            <path
                                                d="M7.724 1.282a.75.75 0 0 0-1.448 0l-.424 1.74a3.25 3.25 0 0 1-2.374 2.374l-1.74.425a.75.75 0 0 0 0 1.448l1.74.424a3.25 3.25 0 0 1 2.374 2.375l.424 1.74a.75.75 0 0 0 1.448 0l.425-1.74a3.25 3.25 0 0 1 2.374-2.375l1.74-.424a.75.75 0 0 0 0-1.448l-1.74-.425A3.25 3.25 0 0 1 8.15 3.022l-.424-1.74Z" />
                                        </svg>
                                        Share
                                    </button>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="adm-empty">No lab data yet.</div>
                                    <% } %>
            </div>

            <!-- By Purpose -->
            <div id="tab-purposes" style="display:none;">
                <% var maxPurp=topPurposes.length> 0 ? topPurposes[0].count : 1; %>
                    <% if (topPurposes.length> 0) { %>
                        <% topPurposes.forEach(function(p, i) { var
                            rankClass=i===0?'gold':i===1?'silver':i===2?'bronze':'other'; var
                            pct=Math.round((p.count/maxPurp)*100); %>
                            <div class="adm-lb-item">
                                <span class="adm-lb-rank <%= rankClass %>">
                                    <%= i+1 %>
                                </span>
                                <div class="adm-lb-avatar"
                                    style="background:linear-gradient(135deg,#059669,#047857);font-size:14px;">📌</div>
                                <div style="flex:1;min-width:0;">
                                    <div class="adm-lb-name">
                                        <%= p.purpose %>
                                    </div>
                                    <div class="adm-lb-sub">Most common purpose</div>
                                    <div class="adm-lb-bar-wrap" style="margin-top:4px;">
                                        <div class="adm-lb-bar">
                                            <div class="adm-lb-bar-fill"
                                                style="width:<%= pct %>%;background:linear-gradient(90deg,#059669,#34D399);">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span class="adm-lb-count" style="color:#059669;">
                                        <%= p.count %>
                                    </span>
                                    <button class="adm-lb-share"
                                        onclick="shareToAnnouncement('📌 Most popular activity: &quot;<%= p.purpose %>&quot; with <%= p.count %> sessions! #CCSLab')">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor"
                                            width="10" height="10">
                                            <path
                                                d="M7.724 1.282a.75.75 0 0 0-1.448 0l-.424 1.74a3.25 3.25 0 0 1-2.374 2.374l-1.74.425a.75.75 0 0 0 0 1.448l1.74.424a3.25 3.25 0 0 1 2.374 2.375l.424 1.74a.75.75 0 0 0 1.448 0l.425-1.74a3.25 3.25 0 0 1 2.374-2.375l1.74-.424a.75.75 0 0 0 0-1.448l-1.74-.425A3.25 3.25 0 0 1 8.15 3.022l-.424-1.74Z" />
                                        </svg>
                                        Share
                                    </button>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="adm-empty">No purpose data yet.</div>
                                    <% } %>
            </div>
        </div>

        <!-- Right: Post Announcement Composer -->
        <div class="adm-panel">
            <div class="adm-panel-head">
                <span class="adm-panel-dot" style="background:#5B0E14;"></span>
                <span class="adm-panel-title">Post Announcement</span>
            </div>
            <form action="/admin/announcement" method="POST" enctype="multipart/form-data" id="annForm">
                <div style="padding:14px 16px;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                        <div
                            style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#5B0E14,#3A0910);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#F1E194;flex-shrink:0;">
                            A</div>
                        <div>
                            <div style="font-size:12px;font-weight:700;color:#1C2B35;">CCS Admin</div>
                            <div style="font-size:10px;color:#9CA3AF;">Post to all students</div>
                        </div>
                    </div>
                    <textarea name="message" id="annMessage" class="ann-textarea"
                        placeholder="Share an announcement, recognition, reminder, or update..." maxlength="1000"
                        oninput="updateCharCount(this)"></textarea>
                    <div id="annMediaPreview" class="ann-media-preview">
                        <img id="annMediaImg" src="" alt="" style="display:none;">
                        <video id="annMediaVid" controls style="display:none;"></video>
                        <button type="button" class="ann-media-remove" onclick="removeMedia()">✕</button>
                        <span id="annMediaBadge" class="ann-media-badge"></span>
                    </div>
                    <div id="annMediaError" class="ann-media-error">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M7 14A7 7 0 1 0 7 0a7 7 0 0 0 0 14Zm-.75-9.25a.75.75 0 0 1 1.5 0v3.5a.75.75 0 0 1-1.5 0v-3.5ZM7 11.25a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/>
                        </svg>
                        <span id="annMediaErrorText"></span>
                    </div>
                    <input type="file" name="media" id="annMediaFile" accept="image/*,video/mp4,video/webm,.gif"
                        style="display:none;" onchange="previewMedia(this)">
                </div>
                <div class="ann-toolbar">
                    <div class="ann-toolbar-left" style="position:relative;">
                        <button type="button" class="ann-emoji-trigger" onclick="toggleEmojiPanel(event)"
                            title="Add emoji">😊</button>
                        <div class="ann-emoji-panel" id="emojiPanel">
                            <div
                                style="font-size:10px;font-weight:700;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;">
                                Emojis</div>
                            <div class="ann-emoji-grid">
                                <% ['😊','😄','🎉','👏','🔥','✅','⚠️','📢','🏆','🎓','💻','📌','📅','💡','👍','❤️','🙏','😂','🤔','🚀','⭐','🎯','📊','🔔','👀','💪','🌟','🎁','📝','🔑','🏫','🖥'].forEach(function(e){
                                    %>
                                    <button type="button" class="ann-emoji-btn" onclick="insertEmoji('<%= e %>')"
                                        title="<%= e %>">
                                        <%= e %>
                                    </button>
                                    <% }); %>
                            </div>
                        </div>
                        <label class="ann-media-btn" for="annMediaFile" style="cursor:pointer;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12"
                                height="12">
                                <path fill-rule="evenodd"
                                    d="M2 4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4Zm10.5 5.707a.5.5 0 0 0-.146-.353l-1.5-1.5a.5.5 0 0 0-.708 0L9.354 9.646 8.707 9a.5.5 0 0 0-.707 0l-2 2a.5.5 0 0 0 .707.707L8 10.207l.646.647a.5.5 0 0 0 .708 0l.896-.897 1.146 1.147a.5.5 0 0 0 .708-.708l-1.5-1.5A.5.5 0 0 0 10 8.5a.5.5 0 0 0 .354.146l1.5-1.5a.5.5 0 0 0 .146-.354V9.707ZM6.5 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"
                                    clip-rule="evenodd" />
                            </svg>
                            Photo / GIF
                        </label>
                        <span class="ann-char-count"><span id="charCount">0</span>/1000</span>
                    </div>
                    <button type="submit" class="ann-post-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="currentColor" width="12"
                            height="12">
                            <path
                                d="M1.429 1.5a.75.75 0 0 0-.827 1.094l1.95 3.9L9 7l-6.448.506-1.95 3.9A.75.75 0 0 0 1.43 12.5l11-5.25a.75.75 0 0 0 0-1.5l-11-5.25Z" />
                        </svg>
                        Post
                    </button>
                </div>
            </form>
            <div style="padding:10px 16px;background:#F7F5F2;border-top:1px solid #F3F0EC;">
                <p style="font-size:10px;color:#B8B0A8;margin:0;">💡 Use the <strong
                        style="color:#9CA3AF;">Share</strong> buttons in the leaderboard to auto-fill an announcement.
                </p>
            </div>
        </div>
    </div>

    <!-- ══ Announcements Feed (FIXED LAYOUT) ══ -->
    <div class="adm-feed">
        <div class="adm-feed-head">
            <span class="adm-feed-title">📣 Posted Announcements (<%= announcements.length %>)</span>
        </div>

        <% if (announcements.length > 0) { %>
            <% announcements.forEach(function(ann) { %>
                <div class="ann-card" id="ann-card-<%= ann.id %>">
                    <!-- Head: Avatar + Admin Name + Pin Badge + Time -->
                    <div class="ann-card-head">
                        <div class="ann-card-meta">
                            <div class="ann-card-avatar"><%= ann.first_name ? ann.first_name[0].toUpperCase() : 'A' %></div>
                            <div>
                                <div class="ann-card-author">
                                    <%= ann.first_name ? (ann.first_name + ' ' + (ann.last_name || '')) : 'CCS Admin' %>
                                    <% if (ann.is_pinned) { %>
                                        <span style="font-size:10px;font-weight:700;background:#FEF3C7;color:#92400E;padding:2px 6px;border-radius:999px;margin-left:6px;vertical-align:middle;">📌 Pinned</span>
                                    <% } %>
                                </div>
                                <div class="ann-card-time">
                                    <%= new Date(ann.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                                </div>
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;flex-shrink:0;">
                            <button
                                type="button"
                                data-ann-action="pin"
                                data-ann-url="/admin/announcement/<%= ann.id %>/pin"
                                style="display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:8px;font-size:10px;font-weight:700;border:1.5px solid #FDE68A;background:#FFF7ED;color:#92400E;cursor:pointer;font-family:inherit;transition:all 0.15s;"
                                title="<%= ann.is_pinned ? 'Unpin this announcement' : 'Pin this announcement to top' %>"
                            >
                                📌 <%= ann.is_pinned ? 'Unpin' : 'Pin' %>
                            </button>
                            <button
                                type="button"
                                data-ann-action="edit-open"
                                data-ann-id="<%= ann.id %>"
                                style="display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:8px;font-size:10px;font-weight:700;border:1.5px solid #BFDBFE;background:#EFF6FF;color:#1D4ED8;cursor:pointer;font-family:inherit;transition:all 0.15s;"
                                title="Edit this announcement"
                            >
                                ✏️ Edit
                            </button>
                            <button
                                type="button"
                                class="ann-del-btn"
                                data-ann-action="delete"
                                data-ann-url="/admin/announcement/<%= ann.id %>/delete"
                                title="Delete this announcement"
                            >
                                🗑️ Delete
                            </button>
                        </div>
                    </div>

                    <!-- Body (text content — always before media) -->
                    <div class="ann-card-body">
                        <p class="ann-card-msg"><%= ann.message %></p>
                    </div>

                    <!-- Media (image/video — after body text) -->
                    <% if (ann.media_url && ann.media_url !== '') { %>
                        <div class="ann-card-media">
                            <% if (ann.media_type === 'video') { %>
                                <video controls><source src="<%= ann.media_url %>"></video>
                            <% } else { %>
                                <img src="<%= ann.media_url %>" alt="Announcement media" loading="lazy">
                            <% } %>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        <% } else { %>
            <div style="background:#fff;border:1px solid #E8E3DD;border-radius:16px;padding:48px 24px;text-align:center;color:#C4BDB6;">
                <div style="font-size:32px;margin-bottom:10px;">📣</div>
                <p style="font-size:14px;font-weight:600;color:#4B5563;margin:0;">No announcements yet</p>
                <p style="font-size:12px;margin:4px 0 0;">Post your first announcement above.</p>
            </div>
        <% } %>
    </div>
</div>

<!-- ══ Edit Announcement Modal ══ -->
<div id="editAnnModal" class="modal-overlay" onclick="if(event.target===this) closeEditModal()">
    <div class="modal-card" style="max-width:520px;">
        <div class="modal-header" style="background:linear-gradient(135deg,#273F4F,#1a2d38);">
            <div class="modal-title" style="color:#fff;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#F1E194" width="15" height="15">
                    <path d="M13.488 2.513a1.75 1.75 0 0 0-2.475 0L3.22 10.303a1 1 0 0 0-.258.42l-.97 3.397a.75.75 0 0 0 .93.93l3.397-.97a1 1 0 0 0 .42-.258l7.79-7.79a1.75 1.75 0 0 0 0-2.475l-.04-.04Z"/>
                </svg>
                Edit Announcement
            </div>
            <button class="modal-close" onclick="closeEditModal()" style="border-color:rgba(255,255,255,0.2);background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);">✕</button>
        </div>
        <form id="editAnnForm" method="POST" action="">
            <div style="padding:18px 20px;">
                <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6B7280;margin-bottom:8px;letter-spacing:0.08em;">Announcement Message</label>
                <textarea id="editAnnMessage" name="message" class="ann-textarea" style="min-height:140px;" placeholder="Enter announcement message..." maxlength="1000" required></textarea>
                <div style="text-align:right;margin-top:4px;">
                    <span style="font-size:10px;color:#C4BDB6;font-weight:600;"><span id="editCharCount">0</span>/1000</span>
                </div>
            </div>
            <div style="display:flex;gap:10px;padding:0 20px 18px;">
                <button type="button" onclick="closeEditModal()" style="flex:1;padding:10px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;">Cancel</button>
                <button type="submit" style="flex:2;padding:10px;background:linear-gradient(135deg,#5B0E14,#7a131b);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Search + Sit-in modals (kept from original) -->
<div id="searchModal" class="modal-overlay" onclick="if(event.target===this) closeSearchModal()">
    <div class="modal-card">
        <div class="modal-header">
            <div class="modal-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                Search Student
            </div>
            <button class="modal-close" onclick="closeSearchModal()">✕</button>
        </div>
        <div class="modal-body">
            <div class="search-input-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="15" height="15">
                    <path fill-rule="evenodd"
                        d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                        clip-rule="evenodd" />
                </svg>
                <input type="text" id="searchStudentInput" class="search-input" placeholder="Enter student ID number..."
                    onkeydown="if(event.key==='Enter') searchStudent()" autocomplete="off" />
