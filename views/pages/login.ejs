<div class="flex justify-center items-center min-h-[80vh] px-4">
    <div class="bg-white p-6 md:p-10 rounded-2xl shadow-2xl w-full max-w-lg border border-gray-100">

        <h2 class="text-2xl md:text-3xl font-extrabold text-center text-[#273F4F] mb-10">
            Login to CCS Sit-in
        </h2>

        <% if (typeof messages !=='undefined' ) { %>
            <% messages.forEach(function(msg) { %>
                <div class="mb-4 p-3 rounded-xl flex items-center gap-3
                    <%= msg.type === 'error'
                        ? 'bg-red-50 text-red-700 border border-red-200'
                        : 'bg-green-50 text-green-700 border border-green-200' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                        stroke="currentColor" class="size-5 shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                    </svg>
                    <span class="font-medium text-sm">
                        <%= msg.text %>
                    </span>
                </div>
                <% }) %>
                    <% } %>

                        <form action="/login" method="POST" class="space-y-5">
                            <div class="space-y-1">
                                <label class="block text-sm font-semibold text-gray-700 ml-1">ID Number</label>
                                <div class="relative">
                                    <div
                                        class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                            class="size-5">
                                            <path
                                                d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                                            <path
                                                d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
                                        </svg>
                                    </div>
                                    <input type="text" name="id_number" placeholder="Enter your ID Number"
                                        class="w-full pl-10 p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none transition-all text-sm">
                                </div>
                            </div>

                            <div class="space-y-1">
                                <label class="block text-sm font-semibold text-gray-700 ml-1">Password</label>
                                <div class="relative">
                                    <div
                                        class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                            class="size-5">
                                            <path fill-rule="evenodd"
                                                d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                    </div>
                                    <input type="password" name="password" id="passwordInput"
                                        placeholder="Enter your Password"
                                        class="w-full pl-10 pr-10 p-3 bg-gray-50 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#273F4F] focus:bg-white outline-none transition-all text-sm">
                                    <button type="button" id="togglePassword"
                                        class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-[#273F4F]">
                                        <svg id="eyeOpen" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="currentColor" class="size-5">
                                            <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                                            <path fill-rule="evenodd"
                                                d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        <svg id="eyeClosed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="currentColor" class="size-5 hidden">
                                            <path
                                                d="M3.53 2.47a.75.75 0 0 0-1.06 1.06l18 18a.75.75 0 1 0 1.06-1.06l-18-18ZM22.676 12.553a11.249 11.249 0 0 1-2.631 4.31l-3.099-3.099a5.25 5.25 0 0 0-6.71-6.71L7.759 4.577a11.217 11.217 0 0 1 4.242-.827c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113Z" />
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <button type="submit" class="btn-maroon">
                                Sign In
                            </button>
                        </form>

                        <p class="mt-6 text-center text-sm text-gray-600">
                            Don't have an account? <a href="/register"
                                class="text-[#273F4F] font-bold hover:underline">Register here</a>
                        </p>
    </div>
</div>

<script src="/js/login.js"></script>