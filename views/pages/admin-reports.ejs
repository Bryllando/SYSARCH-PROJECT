<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .rep-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .rep-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .rep-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .rep-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .rep-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .rep-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .rep-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    /* Controls bar */
    .rep-controls {
        padding: 16px 32px;
        background: #fff;
        border-bottom: 1px solid #E2DDD8;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: space-between;
    }

    .rep-controls-left {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .rep-controls-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .rep-date-input {
        padding: 7px 12px;
        border: 1.5px solid #D6D0CA;
        border-radius: 8px;
        background: #F9F8F6;
        font-size: 12px;
        color: #374151;
        outline: none;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
    }

    .rep-date-input:focus {
        border-color: #273F4F;
        background: #fff;
    }

    .rep-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        border: none;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
    }

    .rep-btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .rep-btn.search {
        background: #273F4F;
        color: #fff;
    }

    .rep-btn.reset {
        background: #DC2626;
        color: #fff;
    }

    .rep-btn.csv {
        background: #059669;
        color: #fff;
    }

    .rep-btn.excel {
        background: #1D6F42;
        color: #fff;
    }

    .rep-btn.pdf {
        background: #DC2626;
        color: #fff;
    }

    .rep-btn.print {
        background: #374151;
        color: #fff;
    }

    .rep-filter-input {
        padding: 7px 12px;
        border: 1.5px solid #D6D0CA;
        border-radius: 8px;
        background: #F9F8F6;
        font-size: 12px;
        color: #374151;
        outline: none;
        width: 180px;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s;
    }

    .rep-filter-input:focus {
        border-color: #273F4F;
        background: #fff;
    }

    /* Table */
    .rep-table-wrap {
        padding: 16px 32px 32px;
        background: #F0EDE8;
    }

    .rep-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        border: 1px solid #E8E3DD;
    }

    table.rep-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .rep-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .rep-table th {
        padding: 12px 14px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
        cursor: pointer;
        user-select: none;
    }

    .rep-table th:hover {
        color: #273F4F;
    }

    .rep-table th .sort-icon {
        margin-left: 4px;
        opacity: 0.4;
        font-size: 9px;
    }

    .rep-table th.sorted .sort-icon {
        opacity: 1;
        color: #273F4F;
    }

    .rep-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.1s;
    }

    .rep-table tbody tr:last-child {
        border-bottom: none;
    }

    .rep-table tbody tr:hover {
        background: #FAF9F7;
    }

    .rep-table td {
        padding: 12px 14px;
        vertical-align: middle;
        font-size: 12px;
    }

    .badge-purpose {
        display: inline-flex;
        padding: 3px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        background: #EFF6FF;
        color: #1D4ED8;
    }

    .badge-lab {
        display: inline-flex;
        padding: 4px 9px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        background: #1C2B35;
        color: #F1E194;
    }

    .rep-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }

    /* Download overlay */
    .dl-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
    }

    .dl-overlay.open {
        display: flex;
    }

    .dl-overlay.open .dl-card {
        animation: dlIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes dlIn {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(12px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .dl-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
        padding: 36px 48px;
        text-align: center;
        min-width: 280px;
        font-family: 'DM Sans', sans-serif;
    }

    .dl-spinner {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        border: 4px solid #E8E3DD;
        border-top-color: #273F4F;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 16px;
    }

    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .dl-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg, #059669, #34D399);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .dl-title {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 6px;
    }

    .dl-sub {
        font-size: 13px;
        color: #9CA3AF;
        margin: 0;
    }

    /* Print styles */
    @media print {

        .rep-controls,
        .rep-header,
        .stud-toolbar,
        header,
        aside,
        footer {
            display: none !important;
        }

        .rep-table-wrap {
            padding: 0 !important;
        }

        .rep-table-card {
            border: none !important;
            box-shadow: none !important;
        }

        .rep-page {
            background: white !important;
        }

        body {
            background: white !important;
        }
    }
</style>

<!-- External libraries -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>

<div class="rep-page">

    <!-- Header -->
    <div class="rep-header">
        <div class="rep-header-inner">
            <div>
                <p class="rep-eyebrow">Admin Panel</p>
                <h1>Generate Reports</h1>
                <p>Sit-in session records and export tools</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= sessions ? sessions.length : 0 %> total records
            </span>
        </div>
    </div>

    <!-- Controls -->
    <div class="rep-controls">
        <!-- Left: Date filter + Search/Reset -->
        <div class="rep-controls-left">
            <input type="date" id="dateFrom" class="rep-date-input" title="From date">
            <span style="font-size:12px;color:#9CA3AF;">to</span>
            <input type="date" id="dateTo" class="rep-date-input" title="To date">
            <button class="rep-btn search" onclick="applyDateFilter()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd"
                        d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
                        clip-rule="evenodd" />
                </svg>
                Search
            </button>
            <button class="rep-btn reset" onclick="resetFilters()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd"
                        d="M13.836 2.477a.75.75 0 0 1 .75.75v3.182a.75.75 0 0 1-.75.75h-3.182a.75.75 0 0 1 0-1.5h1.37l-.84-.841a4.5 4.5 0 0 0-7.08.932.75.75 0 0 1-1.3-.75 6 6 0 0 1 9.44-1.242l.842.84V3.227a.75.75 0 0 1 .75-.75Zm-.911 7.5A.75.75 0 0 1 13.199 11a6 6 0 0 1-9.44 1.241l-.84-.84v1.371a.75.75 0 0 1-1.5 0V9.591a.75.75 0 0 1 .75-.75H5.35a.75.75 0 0 1 0 1.5H3.98l.841.841a4.5 4.5 0 0 0 7.08-.932.75.75 0 0 1 1.025-.273Z"
                        clip-rule="evenodd" />
                </svg>
                Reset
            </button>
        </div>

        <!-- Right: Export buttons + text filter -->
        <div class="rep-controls-right">
            <button class="rep-btn csv" onclick="exportCSV()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd"
                        d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm1 5.75a.75.75 0 0 0 0 1.5h6a.75.75 0 0 0 0-1.5H5Zm0 3a.75.75 0 0 0 0 1.5h6a.75.75 0 0 0 0-1.5H5Z"
                        clip-rule="evenodd" />
                </svg>
                CSV
            </button>
            <button class="rep-btn excel" onclick="exportExcel()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd"
                        d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm4.75 6.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5a.75.75 0 0 1 .75-.75Z"
                        clip-rule="evenodd" />
                </svg>
                Excel
            </button>
            <button class="rep-btn pdf" onclick="exportPDF()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd"
                        d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm.75 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z"
                        clip-rule="evenodd" />
                </svg>
                PDF
            </button>
            <button class="rep-btn print" onclick="printReport()">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd"
                        d="M4.25 1.5A.75.75 0 0 1 5 .75h6a.75.75 0 0 1 .75.75V3h.5A2.25 2.25 0 0 1 14.5 5.25v4.5A2.25 2.25 0 0 1 12.25 12H12v1.25A1.75 1.75 0 0 1 10.25 15h-4.5A1.75 1.75 0 0 1 4 13.25V12h-.25A2.25 2.25 0 0 1 1.5 9.75v-4.5A2.25 2.25 0 0 1 3.75 3h.5V1.5ZM5.5 3h5V2.25h-5V3Zm-.75 7.5v2.75c0 .138.112.25.25.25h5.5a.25.25 0 0 0 .25-.25V10.5h-6Zm7-5.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"
                        clip-rule="evenodd" />
                </svg>
                Print
            </button>
            <input type="text" class="rep-filter-input" id="filterInput" placeholder="Filter..."
                oninput="applyTextFilter()">
        </div>
    </div>

    <!-- Table -->
    <div class="rep-table-wrap">
        <div class="rep-table-card">
            <div style="overflow-x:auto;" id="printArea">
                <div style="padding:16px 20px 0;display:none;" id="printTitle">
                    <h2
                        style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#1C2B35;margin:0 0 4px;">
                        CCS Sit-in Reports</h2>
                    <p style="font-size:12px;color:#9CA3AF;margin:0 0 12px;">Generated: <span id="printDate"></span></p>
                </div>
                <table class="rep-table" id="reportTable">
                    <thead>
                        <tr>
                            <th onclick="sortTable(0)" data-col="0">ID Number <span class="sort-icon">↕</span></th>
                            <th onclick="sortTable(1)" data-col="1">Name <span class="sort-icon">↕</span></th>
                            <th onclick="sortTable(2)" data-col="2">Purpose <span class="sort-icon">↕</span></th>
                            <th onclick="sortTable(3)" data-col="3">Laboratory <span class="sort-icon">↕</span></th>
                            <th onclick="sortTable(4)" data-col="4">Login <span class="sort-icon">↕</span></th>
                            <th onclick="sortTable(5)" data-col="5">Logout <span class="sort-icon">↕</span></th>
                            <th onclick="sortTable(6)" data-col="6">Date <span class="sort-icon">↕</span></th>
                        </tr>
                    </thead>
                    <tbody id="reportBody">
                        <% var safeSessions=(typeof sessions !=='undefined' && sessions) ? sessions : []; %>
                            <% if (safeSessions.length> 0) { %>
                                <% safeSessions.forEach(function(s) { %>
                                    <tr class="rep-row"
                                        data-date="<%= s.time_in ? new Date(s.time_in).toISOString().split('T')[0] : '' %>"
                                        data-search="<%= (s.id_number || '') + ' ' + (s.last_name || '') + ' ' + (s.first_name || '') + ' ' + (s.purpose || '') + ' ' + (s.lab_room || '') %>">
                                        <td style="font-family:monospace;color:#4B5563;">
                                            <%= s.id_number %>
                                        </td>
                                        <td style="font-weight:600;color:#1C2B35;white-space:nowrap;">
                                            <%= s.last_name %>, <%= s.first_name %>
                                        </td>
                                        <td><span class="badge-purpose">
                                                <%= s.purpose || '—' %>
                                            </span></td>
                                        <td><span class="badge-lab">
                                                <%= s.lab_room || '—' %>
                                            </span></td>
                                        <td style="color:#4B5563;font-variant-numeric:tabular-nums;white-space:nowrap;">
                                            <%= s.time_in ? new
                                                Date(s.time_in).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'})
                                                : '—' %>
                                        </td>
                                        <td style="font-variant-numeric:tabular-nums;white-space:nowrap;">
                                            <% if (s.time_out) { %>
                                                <span style="color:#4B5563;">
                                                    <%= new
                                                        Date(s.time_out).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'})
                                                        %>
                                                </span>
                                                <% } else { %>
                                                    <span style="color:#059669;font-weight:600;font-size:11px;">Still
                                                        In</span>
                                                    <% } %>
                                        </td>
                                        <td style="color:#4B5563;white-space:nowrap;">
                                            <%= s.time_in ? new Date(s.time_in).toLocaleDateString('en-CA') : '—' %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="7"
                                                    style="padding:64px 24px;text-align:center;color:#9CA3AF;font-size:13px;">
                                                    No records found.</td>
                                            </tr>
                                            <% } %>
                    </tbody>
                </table>
            </div>
            <div class="rep-table-footer">
                <span>Showing <strong id="visibleCount" style="color:#1C2B35;">
                        <%= safeSessions.length %>
                    </strong>
                    of <strong style="color:#1C2B35;">
                        <%= safeSessions.length %>
                    </strong> records</span>
                <span>CCS Laboratory Sit-in Monitoring System</span>
            </div>
        </div>
    </div>
</div>

<!-- Download Overlay -->
<div id="dlOverlay" class="dl-overlay">
    <div class="dl-card">
        <div id="dlSpinner" class="dl-spinner"></div>
        <div id="dlIcon" class="dl-icon" style="display:none;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="white" width="22" height="22">
                <path fill-rule="evenodd"
                    d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                    clip-rule="evenodd" />
            </svg>
        </div>
        <p class="dl-title" id="dlTitle">Preparing Export...</p>
        <p class="dl-sub" id="dlSub">Please wait a moment</p>
    </div>
</div>

<script>
    // ── All session data embedded for client-side operations ──────────────────────
    var allRows = [];
    (function () {
        var rows = document.querySelectorAll('.rep-row');
        rows.forEach(function (r) {
            allRows.push({
                el: r,
                date: r.dataset.date,
                search: r.dataset.search.toLowerCase(),
                cells: Array.from(r.querySelectorAll('td')).map(function (td) { return td.textContent.trim(); })
            });
        });
    })();

    var activeFrom = '', activeTo = '', activeText = '';

    // ── Date Filter ───────────────────────────────────────────────────────────────
    function applyDateFilter() {
        activeFrom = document.getElementById('dateFrom').value;
        activeTo = document.getElementById('dateTo').value;
        applyFilters();
    }

    function resetFilters() {
        document.getElementById('dateFrom').value = '';
        document.getElementById('dateTo').value = '';
        document.getElementById('filterInput').value = '';
        activeFrom = ''; activeTo = ''; activeText = '';
        applyFilters();
    }

    function applyTextFilter() {
        activeText = document.getElementById('filterInput').value.toLowerCase();
        applyFilters();
    }

    function applyFilters() {
        var count = 0;
        allRows.forEach(function (r) {
            var show = true;
            if (activeFrom && r.date && r.date < activeFrom) show = false;
            if (activeTo && r.date && r.date > activeTo) show = false;
            if (activeText && !r.search.includes(activeText)) show = false;
            r.el.style.display = show ? '' : 'none';
            if (show) count++;
        });
        document.getElementById('visibleCount').textContent = count;
    }

    // ── Sort ──────────────────────────────────────────────────────────────────────
    var sortDir = {};
    function sortTable(col) {
        sortDir[col] = !sortDir[col];
        var asc = sortDir[col];
        var tbody = document.getElementById('reportBody');
        var rows = Array.from(tbody.querySelectorAll('.rep-row'));
        rows.sort(function (a, b) {
            var at = a.querySelectorAll('td')[col].textContent.trim();
            var bt = b.querySelectorAll('td')[col].textContent.trim();
            return asc ? at.localeCompare(bt) : bt.localeCompare(at);
        });
        rows.forEach(function (r) { tbody.appendChild(r); });
        document.querySelectorAll('.rep-table th').forEach(function (th, i) {
            th.classList.toggle('sorted', i === col);
            var icon = th.querySelector('.sort-icon');
            if (icon) icon.textContent = i === col ? (asc ? '↑' : '↓') : '↕';
        });
        // Rebuild allRows after sort
        allRows = [];
        tbody.querySelectorAll('.rep-row').forEach(function (r) {
            allRows.push({
                el: r, date: r.dataset.date,
                search: r.dataset.search.toLowerCase(),
                cells: Array.from(r.querySelectorAll('td')).map(function (td) { return td.textContent.trim(); })
            });
        });
    }

    // ── Download Overlay ──────────────────────────────────────────────────────────
    function showDownload(format, doExport) {
        var overlay = document.getElementById('dlOverlay');
        var spinner = document.getElementById('dlSpinner');
        var icon = document.getElementById('dlIcon');
        var title = document.getElementById('dlTitle');
        var sub = document.getElementById('dlSub');

        spinner.style.display = 'block';
        icon.style.display = 'none';
        title.textContent = 'Preparing ' + format + ' Export...';
        sub.textContent = 'Collecting visible records';
        overlay.classList.add('open');

        setTimeout(function () {
            title.textContent = 'Downloading ' + format + '...';
            sub.textContent = 'Starting download';
            doExport();

            setTimeout(function () {
                spinner.style.display = 'none';
                icon.style.display = 'flex';
                title.textContent = 'Download Complete!';
                sub.textContent = format + ' file saved successfully';

                setTimeout(function () {
                    overlay.classList.remove('open');
                }, 1200);
            }, 600);
        }, 900);
    }

    // ── Get visible rows data ─────────────────────────────────────────────────────
    function getVisibleData() {
        var headers = ['ID Number', 'Name', 'Purpose', 'Laboratory', 'Login', 'Logout', 'Date'];
        var rows = [];
        allRows.forEach(function (r) {
            if (r.el.style.display !== 'none') {
                rows.push(r.cells);
            }
        });
        return { headers: headers, rows: rows };
    }

    // ── CSV Export ────────────────────────────────────────────────────────────────
    function exportCSV() {
        showDownload('CSV', function () {
            var d = getVisibleData();
            var csv = [d.headers.join(',')];
            d.rows.forEach(function (r) {
                csv.push(r.map(function (c) { return '"' + c.replace(/"/g, '""') + '"'; }).join(','));
            });
            var blob = new Blob([csv.join('\n')], { type: 'text/csv;charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url; a.download = 'sitin-reports-' + new Date().toISOString().split('T')[0] + '.csv';
            document.body.appendChild(a); a.click();
            document.body.removeChild(a); URL.revokeObjectURL(url);
        });
    }

    // ── Excel Export ──────────────────────────────────────────────────────────────
    function exportExcel() {
        showDownload('Excel', function () {
            var d = getVisibleData();
            var wsData = [d.headers].concat(d.rows);
            var ws = XLSX.utils.aoa_to_sheet(wsData);
            ws['!cols'] = [14, 20, 18, 12, 12, 12, 12].map(function (w) { return { wch: w }; });
            var wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Sit-in Reports');
            XLSX.writeFile(wb, 'sitin-reports-' + new Date().toISOString().split('T')[0] + '.xlsx');
        });
    }

    // ── PDF Export ────────────────────────────────────────────────────────────────
    function exportPDF() {
        showDownload('PDF', function () {
            var d = getVisibleData();
            var { jsPDF } = window.jspdf;
            var doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });

            doc.setFontSize(16);
            doc.setFont('helvetica', 'bold');
            doc.text('CCS Sit-in Monitoring Reports', 14, 16);
            doc.setFontSize(9);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(120);
            doc.text('Generated: ' + new Date().toLocaleString(), 14, 22);
            doc.text('Total records: ' + d.rows.length, 14, 27);

            doc.autoTable({
                head: [d.headers],
                body: d.rows,
                startY: 32,
                styles: { fontSize: 8, cellPadding: 3 },
                headStyles: { fillColor: [39, 63, 79], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [248, 249, 250] },
                columnStyles: {
                    0: { cellWidth: 22 },
                    1: { cellWidth: 40 },
                    2: { cellWidth: 32 },
                    3: { cellWidth: 22 },
                    4: { cellWidth: 24 },
                    5: { cellWidth: 24 },
                    6: { cellWidth: 22 }
                }
            });

            doc.save('sitin-reports-' + new Date().toISOString().split('T')[0] + '.pdf');
        });
    }

    // ── Print ─────────────────────────────────────────────────────────────────────
    function printReport() {
        document.getElementById('printDate').textContent = new Date().toLocaleString();
        document.getElementById('printTitle').style.display = 'block';
        window.print();
        document.getElementById('printTitle').style.display = 'none';
    }
</script>