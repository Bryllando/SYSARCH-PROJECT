<div style="padding:24px;max-width:760px;margin:0 auto;">
    <div style="background:#fff;border:1px solid #E8E3DD;border-radius:14px;overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid #F3F0EC;background:#FAFAF9;">
            <h2 style="margin:0;font-size:18px;color:#1C2B35;">Start Sit-In From Approved Reservation</h2>
            <p style="margin:6px 0 0;font-size:12px;color:#6B7280;">Set the manual start and end time before creating the sit-in session.</p>
        </div>
        <div style="padding:18px 20px;border-bottom:1px solid #F3F0EC;background:#FFF9F0;">
            <div style="font-size:12px;color:#374151;line-height:1.8;">
                <div><strong>Student:</strong> <%= student.last_name %>, <%= student.first_name %> (<%= student.id_number %>)</div>
                <div><strong>Lab / PC:</strong> Lab <%= reservation.lab_room %> · PC-<%= String(reservation.computer_number || 0).padStart(2, '0') %></div>
                <div><strong>Purpose:</strong> <%= reservation.purpose || '—' %></div>
                <div><strong>Reserved Slot:</strong> <%= reservation.date %> · <%= reservation.time_slot || '—' %></div>
            </div>
        </div>
        <form action="/admin/reservations/<%= reservation.id %>/sit-in" method="POST" style="padding:20px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div>
                    <label style="display:block;font-size:11px;font-weight:700;color:#6B7280;margin-bottom:6px;">Start Time</label>
                    <input type="datetime-local" name="start_time" required
                        value="<%= reservation.date ? reservation.date + 'T08:00' : '' %>"
                        style="width:100%;padding:10px;border:1.5px solid #D6D0CA;border-radius:8px;background:#fff;">
                </div>
                <div>
                    <label style="display:block;font-size:11px;font-weight:700;color:#6B7280;margin-bottom:6px;">End Time</label>
                    <input type="datetime-local" name="end_time" required
                        value="<%= reservation.date ? reservation.date + 'T10:00' : '' %>"
                        style="width:100%;padding:10px;border:1.5px solid #D6D0CA;border-radius:8px;background:#fff;">
                </div>
            </div>
            <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:16px;">
                <a href="/admin/reservations"
                    style="display:inline-flex;align-items:center;padding:10px 14px;border-radius:8px;text-decoration:none;background:#F3F0EC;color:#374151;font-size:12px;font-weight:700;border:1px solid #E8E3DD;">Cancel</a>
                <button type="submit"
                    style="display:inline-flex;align-items:center;padding:10px 14px;border-radius:8px;background:linear-gradient(135deg,#0F3E7D,#2A5AA0);color:#fff;border:none;font-size:12px;font-weight:700;cursor:pointer;">
                    Confirm Start Sit-In
                </button>
            </div>
        </form>
    </div>
</div>
