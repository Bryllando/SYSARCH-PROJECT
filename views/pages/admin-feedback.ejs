<!-- ══ REPLY MODAL ══ -->
<div id="replyModal" class="fb-modal-overlay" onclick="if(event.target===this) closeReplyModal()">
    <div class="reply-modal-card">
        <div
            style="background:linear-gradient(135deg,#059669,#047857);padding:18px 24px;display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:10px;">
                <div
                    style="width:36px;height:36px;border-radius:9px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:16px;">
                    💬</div>
                <div>
                    <div style="font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff;">Reply to
                        Student</div>
                    <div style="font-size:11px;color:rgba(255,255,255,0.6);">Student will receive a notification</div>
                </div>
            </div>
            <button onclick="closeReplyModal()"
                style="width:30px;height:30px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:8px;color:rgba(255,255,255,0.7);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;">✕</button>
        </div>

        <div id="replyStudentPreview" style="padding:14px 24px;background:#F9F8F6;border-bottom:1px solid #E8E3DD;">
        </div>
        <div id="replyFeedbackPreview" style="padding:12px 24px;background:#FFF7ED;border-bottom:1px solid #FDE68A;">
        </div>

        <form id="replyForm" method="POST" style="padding:20px 24px 0;">
            <input type="hidden" name="feedback_id" id="replyFeedbackId">
            <div style="margin-bottom:14px;">
                <label
                    style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6B7280;margin-bottom:8px;">Your
                    Reply Message <span style="color:#DC2626;">*</span></label>
                <textarea name="reply_message" id="replyMessage" rows="4" required
                    placeholder="Type your reply here... The student will receive a notification with your message."
                    style="width:100%;padding:12px 14px;border:1.5px solid #D6D0CA;border-radius:10px;background:#F9F8F6;font-size:13px;color:#1C2B35;outline:none;resize:vertical;font-family:'DM Sans',sans-serif;box-sizing:border-box;transition:border-color 0.15s;"
                    onfocus="this.style.borderColor='#059669';this.style.background='#fff';"
                    onblur="this.style.borderColor='#D6D0CA';this.style.background='#F9F8F6';"></textarea>
                <div id="replyCharCount" style="font-size:11px;color:#9CA3AF;margin-top:4px;text-align:right;">0 / 500
                </div>
            </div>
            <div
                style="background:#ECFDF5;border:1px solid #A7F3D0;border-radius:9px;padding:10px 14px;font-size:11px;color:#065F46;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14" height="14">
                    <path fill-rule="evenodd"
                        d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13ZM6.5 7.75A.75.75 0 0 1 7.25 7h1a.75.75 0 0 1 .75.75v2.75h.25a.75.75 0 0 1 0 1.5h-2a.75.75 0 0 1 0-1.5h.25v-2h-.25a.75.75 0 0 1-.75-.75ZM8 6a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"
                        clip-rule="evenodd" />
                </svg>
                The student will see your reply as a notification in their account.
            </div>
        </form>
        <div style="display:flex;gap:10px;padding:0 24px 22px;">
            <button onclick="closeReplyModal()"
                style="flex:1;padding:11px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">Cancel</button>
            <button onclick="submitReply()"
                style="flex:2;padding:11px;background:linear-gradient(135deg,#059669,#047857);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">📨
                Send Reply & Notify</button>
        </div>
    </div>
</div>

<script>
    // ── Tab switching (2 tabs only)
    function switchFbTab(tab) {
        ['feedback', 'analytics'].forEach(function (t) {
            document.getElementById('fbtab-' + t).classList.toggle('active', t === tab);
            document.getElementById('fbtab-btn-' + t).classList.toggle('active', t === tab);
        });
    }

    // ── Filters
    function applyFilters() {
        var q = document.getElementById('searchInput').value.toLowerCase();
        var rating = document.getElementById('ratingFilter').value;
        var count = 0;
        document.querySelectorAll('.fb-row').forEach(function (row) {
            var matchQ = !q || row.textContent.toLowerCase().includes(q);
            var matchRating = !rating || row.dataset.rating == rating;
            var show = matchQ && matchRating;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        document.getElementById('visibleCount').textContent = count;
    }

    // ── View Feedback Modal
    var currentFeedbackRow = null;
    var RATING_LABELS = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
    var RATING_COLORS = ['#6B7280', '#DC2626', '#F59E0B', '#3B82F6', '#059669', '#F59E0B'];

    function viewFeedback(row) {
        currentFeedbackRow = row;
        var name = row.dataset.name, id = row.dataset.studentId, course = row.dataset.course;
        var ratingVal = parseInt(row.dataset.ratingVal) || 0, ratingLabel = row.dataset.ratingLabel;
        var message = row.dataset.message, date = row.dataset.date, pic = row.dataset.pic;

        var avatarEl = document.getElementById('fbModalAvatar');
        if (pic) { avatarEl.innerHTML = '<img src="' + pic + '" style="width:100%;height:100%;object-fit:cover;">'; }
        else { var initials = name.split(', ').map(function (p) { return p[0] || ''; }).join(''); avatarEl.innerHTML = initials.toUpperCase(); }

        document.getElementById('fbModalName').textContent = name;
        document.getElementById('fbModalId').textContent = id;
        document.getElementById('fbModalCourse').textContent = course;
        document.getElementById('fbModalMessage').textContent = message || '(No message)';
        document.getElementById('fbModalDate').textContent = '📅 Submitted: ' + new Date(date).toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' });

        var starsHtml = '';
        if (ratingVal > 0) {
            for (var s = 1; s <= 5; s++) starsHtml += '<span class="fb-modal-star" style="color:' + (s <= ratingVal ? '#F59E0B' : '#D1D5DB') + '">' + (s <= ratingVal ? '★' : '☆') + '</span>';
        } else {
            starsHtml = '<span style="font-size:12px;color:#9CA3AF;font-style:italic;">No rating given</span>';
        }
        document.getElementById('fbModalStars').innerHTML = starsHtml;

        var ratingLabelEl = document.getElementById('fbModalRatingLabel');
        ratingLabelEl.textContent = ratingLabel;
        ratingLabelEl.style.color = RATING_COLORS[ratingVal] || '#6B7280';
        document.getElementById('fbModal').classList.add('open');
    }
    function closeFbModal() { document.getElementById('fbModal').classList.remove('open'); }

    // ── Reply Modal
    var currentReplyRow = null;
    function openReplyModal(row) { currentReplyRow = row; _setupReplyModal(row); }
    function openReplyModalById(row) { if (!row) return; currentReplyRow = row; _setupReplyModal(row); }

    function _setupReplyModal(row) {
        var feedbackId = row.dataset.id;
        var name = row.dataset.name;
        var studentId = row.dataset.studentId;
        var course = row.dataset.course;
        var message = row.dataset.message;
        var ratingVal = parseInt(row.dataset.ratingVal) || 0;
        var ratingLabel = row.dataset.ratingLabel;
        var pic = row.dataset.pic;

        document.getElementById('replyFeedbackId').value = feedbackId;
        document.getElementById('replyForm').action = '/admin/feedback/' + feedbackId + '/reply';
        document.getElementById('replyMessage').value = '';
        document.getElementById('replyCharCount').textContent = '0 / 500';

        var avatarHtml = pic
            ? '<img src="' + pic + '" style="width:38px;height:38px;border-radius:50%;object-fit:cover;">'
            : '<div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#273F4F,#5B0E14);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#F1E194;">' + name.split(', ').map(function (p) { return p[0] || ''; }).join('').toUpperCase() + '</div>';

        var ratingBg = ratingVal >= 4 ? '#DCFCE7' : ratingVal === 3 ? '#EFF6FF' : ratingVal > 0 ? '#FEF2F2' : '#F3F4F6';
        var ratingColor = ratingVal >= 4 ? '#065F46' : ratingVal === 3 ? '#1D4ED8' : ratingVal > 0 ? '#991B1B' : '#6B7280';
        var ratingText = ratingVal > 0 ? ('⭐'.repeat(ratingVal) + ' ' + ratingLabel) : 'No rating';

        document.getElementById('replyStudentPreview').innerHTML = '<div style="display:flex;align-items:center;gap:12px;">' + avatarHtml + '<div><div style="font-size:13px;font-weight:700;color:#1C2B35;">' + name + '</div><div style="display:flex;gap:6px;margin-top:3px;"><span style="font-family:monospace;font-size:11px;color:#6B7280;background:#F3F0EC;padding:2px 7px;border-radius:4px;">' + studentId + '</span><span style="font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;padding:2px 7px;border-radius:4px;">' + course + '</span><span style="font-size:11px;font-weight:700;background:' + ratingBg + ';color:' + ratingColor + ';padding:2px 7px;border-radius:4px;">' + ratingText + '</span></div></div></div>';

        var safeMsg = (message || '').replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"');
        document.getElementById('replyFeedbackPreview').innerHTML = '<div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#92400E;margin-bottom:6px;">Original Feedback:</div><div style="font-size:12px;color:#92400E;line-height:1.6;">"' + safeMsg.substring(0, 120) + (safeMsg.length > 120 ? '…' : '') + '"</div>';

        document.getElementById('replyModal').classList.add('open');
    }
    function closeReplyModal() { document.getElementById('replyModal').classList.remove('open'); }

    document.getElementById('replyMessage').addEventListener('input', function () {
        var len = this.value.length;
        var counter = document.getElementById('replyCharCount');
        counter.textContent = len + ' / 500';
        counter.style.color = len > 450 ? '#DC2626' : '#9CA3AF';
        if (len > 500) this.value = this.value.substring(0, 500);
    });

    function submitReply() {
        var msg = document.getElementById('replyMessage').value.trim();
        if (!msg) { if (window.showAppToast) window.showAppToast('warning', 'Please enter a reply message.'); return; }
        document.getElementById('replyForm').submit();
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { closeFbModal(); closeReplyModal(); }
    });
</script>
<script>
    (async function () {
        const el = document.getElementById('feedback-ai-insight');
        if (!el) return;
        try {
            const res = await fetch('/api/ai/admin-insights', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ refresh: false }) });
            const data = await res.json();
            if (!data.success || !data.insights) {
                el.textContent = 'No AI insight available right now.';
                return;
            }
            const i = data.insights;
            el.innerHTML = `
                <div style="margin-bottom:6px;"><strong>Feedback Summary:</strong> ${i.feedback_summary || '-'}</div>
                <div style="margin-bottom:6px;"><strong>Student Engagement:</strong> ${i.student_engagement || '-'}</div>
                <div><strong>Recommended Action:</strong> ${i.recommended_action || '-'}</div>
            `;
        } catch (_) {
            el.textContent = 'AI insight is temporarily unavailable.';
        }
    })();
</script>