<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .fb-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .fb-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .fb-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .fb-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .fb-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .fb-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .fb-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    /* Tabs */
    .fb-tabs {
        display: flex;
        gap: 0;
        background: #fff;
        border-bottom: 2px solid #E8E3DD;
        padding: 0 32px;
        justify-content: center;
    }

    .fb-tab-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 20px;
        font-size: 13px;
        font-weight: 700;
        color: #6B7280;
        cursor: pointer;
        border: none;
        background: transparent;
        border-bottom: 2.5px solid transparent;
        margin-bottom: -2px;
        transition: all 0.15s;
        font-family: 'DM Sans', sans-serif;
    }

    .fb-tab-btn:hover {
        color: #273F4F;
    }

    .fb-tab-btn.active {
        color: #5B0E14;
        border-bottom-color: #5B0E14;
    }

    .fb-tab-content {
        display: none;
    }

    .fb-tab-content.active {
        display: block;
    }

    /* Toolbar */
    .fb-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 32px;
        background: #F0EDE8;
        border-bottom: 1px solid #E2DDD8;
    }

    .fb-filter-select {
        padding: 8px 14px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }

    .fb-search-wrap {
        position: relative;
    }

    .fb-search-wrap input {
        padding: 8px 14px 8px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 200px;
        font-family: 'DM Sans', sans-serif;
    }

    /* Table */
    .fb-table-wrap {
        padding: 0 32px 32px;
        background: #F0EDE8;
    }

    .fb-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        border: 1px solid #E8E3DD;
    }

    table.fb-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .fb-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .fb-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .fb-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .fb-table tbody tr:last-child {
        border-bottom: none;
    }

    .fb-table tbody tr:hover {
        background: #FAF9F7;
    }

    .fb-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .star-display {
        display: inline-flex;
        gap: 2px;
    }

    .star-on {
        color: #F59E0B;
        font-size: 15px;
        line-height: 1;
    }

    .star-off {
        color: #D1D5DB;
        font-size: 15px;
        line-height: 1;
    }

    .name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .name-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .name-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .name-text {
        font-size: 13px;
        font-weight: 600;
        color: #1C2B35;
        white-space: nowrap;
    }

    .rating-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
    }

    .rating-5 {
        background: #FEF3C7;
        color: #92400E;
    }

    .rating-4 {
        background: #DCFCE7;
        color: #065F46;
    }

    .rating-3 {
        background: #EFF6FF;
        color: #1D4ED8;
    }

    .rating-2 {
        background: #FEF2F2;
        color: #991B1B;
    }

    .rating-1 {
        background: #FEF2F2;
        color: #991B1B;
    }

    .rating-0 {
        background: #F3F4F6;
        color: #6B7280;
    }

    .fb-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }

    .btn-view-fb {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
        border: 1.5px solid #BFDBFE;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .btn-view-fb:hover {
        background: #1D4ED8;
        color: #fff;
        border-color: #1D4ED8;
    }

    .btn-reply-fb {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        background: #ECFDF5;
        color: #065F46;
        border: 1.5px solid #A7F3D0;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .btn-reply-fb:hover {
        background: #059669;
        color: #fff;
        border-color: #059669;
    }

    /* Categories */
    .cat-section {
        padding: 0 32px 32px;
    }

    .cat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .cat-card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        border: 1px solid #E8E3DD;
        box-shadow: 0 2px 8px rgba(39, 63, 79, 0.06);
    }

    .cat-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 800;
        color: #1C2B35;
        margin: 0 0 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .cat-bar-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .cat-bar-label {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        min-width: 80px;
        text-align: right;
        flex-shrink: 0;
    }

    .cat-bar-track {
        flex: 1;
        background: #F3F0EC;
        border-radius: 999px;
        height: 9px;
        overflow: hidden;
    }

    .cat-bar-fill {
        height: 100%;
        border-radius: 999px;
        transition: width 0.6s ease;
    }

    .cat-bar-count {
        font-size: 11px;
        font-weight: 700;
        color: #6B7280;
        min-width: 28px;
        text-align: left;
        flex-shrink: 0;
    }

    /* Modals */
    .fb-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .fb-modal-overlay.open {
        display: flex;
    }

    .fb-modal-overlay.open .fb-modal-card {
        animation: fbModalIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes fbModalIn {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(16px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .fb-modal-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 520px;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
    }

    .fb-modal-header {
        background: linear-gradient(135deg, #273F4F, #1a2d38);
        padding: 18px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .fb-modal-close {
        width: 30px;
        height: 30px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        transition: all 0.15s;
    }

    .fb-modal-close:hover {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
    }

    .fb-modal-stars {
        display: flex;
        gap: 4px;
    }

    .fb-modal-star {
        font-size: 26px;
    }

    /* Reply modal */
    .reply-modal-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 480px;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
    }

    @media print {

        .fb-toolbar,
        .fb-header,
        .fb-tabs,
        aside,
        header,
        footer {
            display: none !important;
        }

        .fb-table-wrap {
            padding: 0 !important;
        }

        .fb-table-card {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>

<div class="fb-page">
    <!-- Header -->
    <div class="fb-header">
        <div class="fb-header-inner">
            <div>
                <p class="fb-eyebrow">Admin Panel</p>
                <h1>Feedback & Comments</h1>
                <p>Student feedback ratings and category analytics</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= feedbacks.length %> total feedbacks
            </span>
        </div>
    </div>

    <div style="margin:14px 32px;background:#fff;border:1px solid #E8E3DD;border-radius:14px;padding:14px 16px;box-shadow:0 1px 6px rgba(0,0,0,.04);">
        <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#1a2035;margin-bottom:8px;">AI Admin Insight</div>
        <div id="feedback-ai-insight" style="font-size:12px;color:#6B7280;">Loading insight...</div>
    </div>

    <% var totalFb=feedbacks.length; var rated=feedbacks.filter(function(f){ return parseInt(f.rating) > 0; });
        var avgRating = rated.length > 0 ? (rated.reduce(function(s,f){ return s + parseInt(f.rating); }, 0) /
        rated.length).toFixed(1) : '—';
        var fiveStars = feedbacks.filter(function(f){ return parseInt(f.rating) === 5; }).length;
        var lowRatings = feedbacks.filter(function(f){ var r = parseInt(f.rating); return r > 0 && r <= 2; }).length;
            var noRating=feedbacks.filter(function(f){ return parseInt(f.rating)===0; }).length; %>

            <!-- Tabs (centered) -->
            <div class="fb-tabs">
                <button class="fb-tab-btn active" onclick="switchFbTab('feedback')" id="fbtab-btn-feedback">
                    💬 Feedback Ratings
                </button>
                <button class="fb-tab-btn" onclick="switchFbTab('analytics')" id="fbtab-btn-analytics">
                    📊 Category Analytics
                </button>
            </div>

            <!-- ══ TAB 1: FEEDBACK RATINGS ══ -->
            <div id="fbtab-feedback" class="fb-tab-content active">
                <div class="fb-toolbar">
                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                        <select id="ratingFilter" class="fb-filter-select" onchange="applyFilters()">
                            <option value="">All Ratings</option>
                            <option value="5">⭐⭐⭐⭐⭐ Excellent (5)</option>
                            <option value="4">⭐⭐⭐⭐ Very Good (4)</option>
                            <option value="3">⭐⭐⭐ Good (3)</option>
                            <option value="2">⭐⭐ Fair (2)</option>
                            <option value="1">⭐ Poor (1)</option>
                            <option value="0">No Rating</option>
                        </select>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                        <div class="fb-search-wrap">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9CA3AF;width:14px;height:14px;">
                                <path fill-rule="evenodd"
                                    d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                                    clip-rule="evenodd" />
                            </svg>
                            <input type="text" id="searchInput" placeholder="Search feedback..."
                                oninput="applyFilters()">
                        </div>
                        <button
                            style="display:inline-flex;align-items:center;gap:5px;padding:8px 14px;border-radius:9px;font-size:12px;font-weight:700;background:#374151;color:#fff;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;"
                            onclick="window.print()">🖨 Print</button>
                    </div>
                </div>

                <div class="fb-table-wrap">
                    <div class="fb-table-card">
                        <div style="overflow-x:auto;">
                            <table class="fb-table">
                                <thead>
                                    <tr>
                                        <th>Student</th>
                                        <th>ID Number</th>
                                        <th>Course</th>
                                        <th>Rating</th>
                                        <th>Stars</th>
                                        <th>Feedback Message</th>
                                        <th>Date</th>
                                        <th style="text-align:center;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="fbBody">
                                    <% if (feedbacks && feedbacks.length > 0) { %>
                                        <% feedbacks.forEach(function(f) { var ratingVal=parseInt(f.rating) || 0; var
                                            initials=((f.first_name||'')[0]||'') + ((f.last_name||'')[0]||''); var
                                            ratingLabel=ratingVal===5?'Excellent':ratingVal===4?'Very Good':ratingVal===3?'Good':ratingVal===2?'Fair':ratingVal===1?'Poor':'No Rating'; var stars='' ; for(var s=1;s<=5;s++) stars +=s <= ratingVal
                                            ? '<span class="star-on">★</span>' : '<span class="star-off">★</span>' ; %>
                                            <tr class="fb-row" data-rating="<%= ratingVal %>"
                                                data-name="<%= f.last_name %>, <%= f.first_name %>"
                                                data-id="<%= f.id %>" data-user-id="<%= f.user_id %>"
                                                data-student-id="<%= f.id_number %>" data-course="<%= f.course %>"
                                                data-rating-val="<%= ratingVal %>"
                                                data-rating-label="<%= ratingLabel %>"
                                                data-message="<%= (f.message||'').replace(/" /g,'&quot;') %>"
                                                data-date="<%= f.created_at %>"
                                                    data-pic="<%= f.profile_picture||'' %>">
                                                        <td>
                                                            <div class="name-cell">
                                                                <div class="name-avatar">
                                                                    <% if (f.profile_picture && f.profile_picture !==''
                                                                        ) { %>
                                                                        <img src="<%= f.profile_picture %>">
                                                                        <% } else { %>
                                                                            <%= initials.toUpperCase() %>
                                                                                <% } %>
                                                                </div>
                                                                <span class="name-text">
                                                                    <%= f.last_name %>, <%= f.first_name %>
                                                                </span>
                                                            </div>
                                                        </td>
                                                        <td><span
                                                                style="font-family:monospace;font-size:11px;color:#4B5563;background:#F3F0EC;padding:3px 8px;border-radius:5px;">
                                                                <%= f.id_number %>
                                                            </span></td>
                                                        <td><span
                                                                style="display:inline-flex;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;">
                                                                <%= f.course %>
                                                            </span></td>
                                                        <td><span class="rating-badge rating-<%= ratingVal %>">
                                                                <%= ratingLabel %>
                                                            </span></td>
                                                        <td>
                                                            <% if (ratingVal > 0) { %>
                                                                <div class="star-display"><%- stars %></div>
                                                                <% } else { %>
                                                                    <span
                                                                        style="font-size:11px;color:#9CA3AF;font-style:italic;">No
                                                                        rating</span>
                                                                    <% } %>
                                                        </td>
                                                        <td style="max-width:220px;">
                                                            <p
                                                                style="font-size:12px;color:#4B5563;margin:0;line-height:1.5;word-break:break-word;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                                                <%= f.message %>
                                                            </p>
                                                        </td>
                                                        <td style="font-size:11px;color:#9CA3AF;white-space:nowrap;">
                                                            <%= new
                                                                Date(f.created_at).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'})
                                                                %>
                                                        </td>
                                                        <td style="text-align:center;">
                                                            <div
                                                                style="display:flex;gap:5px;justify-content:center;flex-wrap:nowrap;">
                                                                <button class="btn-view-fb"
                                                                    onclick="viewFeedback(this.closest('tr'))">
                                                                    👁 View
                                                                </button>
                                                                <button class="btn-reply-fb"
                                                                    onclick="openReplyModal(this.closest('tr'))">
                                                                    💬 Reply
                                                                </button>
                                                            </div>
                                                        </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="8">
                                                            <div
                                                                style="padding:64px 24px;text-align:center;color:#9CA3AF;font-size:13px;">
                                                                No feedback yet.</div>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                        <div class="fb-table-footer">
                            <span>Showing <strong id="visibleCount" style="color:#1C2B35;">
                                    <%= feedbacks.length %>
                                </strong> of <strong style="color:#1C2B35;">
                                    <%= feedbacks.length %>
                                </strong> records</span>
                            <span>CCS Laboratory Sit-in Monitoring System</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ══ TAB 2: CATEGORY ANALYTICS ══ -->
            <div id="fbtab-analytics" class="fb-tab-content">
                <div class="cat-section">
                    <% var dist={5:0, 4:0, 3:0, 2:0, 1:0, 0:0}; feedbacks.forEach(function(f){ var r=parseInt(f.rating)
                        || 0; if(dist[r] !==undefined) dist[r]++; }); var
                        maxDist=Math.max(dist[5],dist[4],dist[3],dist[2],dist[1],dist[0]) || 1; var byStudent={};
                        feedbacks.forEach(function(f){ if(!byStudent[f.id_number]) byStudent[f.id_number]={name:
                        f.last_name+', '+f.first_name, course: f.course, count:0, totalRating:0, ratedCount:0};
                    byStudent[f.id_number].count++;
                    if(parseInt(f.rating) > 0){ byStudent[f.id_number].totalRating += parseInt(f.rating); byStudent[f.id_number].ratedCount++; }
                });
                var topStudents = Object.values(byStudent).sort(function(a,b){return b.count-a.count;}).slice(0,5);
                var maxStudentCount = topStudents.length > 0 ? topStudents[0].count : 1;

                var satisfied = feedbacks.filter(function(f){ return parseInt(f.rating) >= 4; }).length;
                var neutral = feedbacks.filter(function(f){ return parseInt(f.rating) === 3; }).length;
                var dissatisfied = feedbacks.filter(function(f){ var r = parseInt(f.rating); return r > 0 && r <= 2; }).length;
                var satPct = totalFb > 0 ? Math.round((satisfied/totalFb)*100) : 0;
                var neuPct = totalFb > 0 ? Math.round((neutral/totalFb)*100) : 0;
                var disPct = totalFb > 0 ? Math.round((dissatisfied/totalFb)*100) : 0;
            %>

            <div class="cat-grid">
                <!-- Rating Distribution -->
                <div class="cat-card">
                    <p class="cat-card-title"><span style="font-size:20px;">⭐</span> Rating Distribution</p>
                    <% [
                        [5,' Excellent','#F59E0B'], [4,'Very Good','#059669'], [3,'Good','#3B82F6'],
                        [2,'Fair','#F97316'], [1,'Poor','#DC2626'], [0,'No Rating','#9CA3AF'] ].forEach(function(r){ var
                        pct=maxDist > 0 ? (dist[r[0]]/maxDist)*100 : 0;
                        %>
                        <div class="cat-bar-row">
                            <span class="cat-bar-label" style="font-size:10px;">
                                <%= r[1] %>
                            </span>
                            <div class="cat-bar-track">
                                <div class="cat-bar-fill" style="width:<%= pct %>%;background:<%= r[2] %>;"></div>
                            </div>
                            <span class="cat-bar-count" style="color:<%= r[2] %>;">
                                <%= dist[r[0]] %>
                            </span>
                        </div>
                        <% }); %>
                </div>

                <!-- Most Active Feedback -->
                <div class="cat-card">
                    <p class="cat-card-title"><span style="font-size:20px;">🏆</span> Most Active Feedback</p>
                    <% var purpColors2=['#F59E0B','#9CA3AF','#CD7F32','#273F4F','#5B0E14']; %>
                        <% topStudents.forEach(function(s, si){ var pct=Math.round((s.count/maxStudentCount)*100); var
                            avg=s.ratedCount > 0 ? (s.totalRating/s.ratedCount).toFixed(1) : 'N/A';
                            %>
                            <div class="cat-bar-row">
                                <span class="cat-bar-label"
                                    style="font-size:10px;max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                    title="<%= s.name %>">
                                    <%= s.name.split(',')[1]||s.name %>
                                </span>
                                <div class="cat-bar-track">
                                    <div class="cat-bar-fill"
                                        style="width:<%= pct %>%;background:<%= purpColors2[si] %>;"></div>
                                </div>
                                <span class="cat-bar-count">
                                    <%= s.count %> <span style="color:#C4BDB6;font-weight:400;">(avg <%= avg %>★)</span>
                                </span>
                            </div>
                            <% }); %>
                                <% if(topStudents.length===0){ %>
                                    <p style="text-align:center;color:#9CA3AF;font-size:12px;padding:12px 0;margin:0;">
                                        No data yet.</p>
                                    <% } %>
                </div>

                <!-- Satisfaction Overview -->
                <div class="cat-card">
                    <p class="cat-card-title"><span style="font-size:20px;">📊</span> Satisfaction Overview</p>
                    <div style="display:flex;flex-direction:column;gap:12px;">
                        <% [ ['Satisfied (4-5)','#059669',satPct,satisfied], ['Neutral (3)','#D97706',neuPct,neutral],
                            ['Dissatisfied (1-2)','#DC2626',disPct,dissatisfied] ].forEach(function(row){ %>
                            <div>
                                <div
                                    style="display:flex;justify-content:space-between;font-size:11px;font-weight:700;margin-bottom:5px;">
                                    <span style="color:<%= row[1] %>;">
                                        <%= row[0] %>
                                    </span>
                                    <span style="color:<%= row[1] %>;">
                                        <%= row[3] %> (<%= row[2] %>%)
                                    </span>
                                </div>
                                <div style="background:#F3F0EC;border-radius:999px;height:10px;overflow:hidden;">
                                    <div
                                        style="width:<%= row[2] %>%;height:100%;background:<%= row[1] %>;border-radius:999px;">
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                    </div>
                    <div
                        style="margin-top:14px;padding:10px 14px;background:#F7F5F2;border-radius:10px;font-size:11px;color:#6B7280;">
                        Overall Satisfaction Rate: <strong
                            style="color:<%= satPct >= 70?'#059669':satPct >= 50?'#D97706':'#DC2626' %>;font-size:16px;font-family:'Syne',sans-serif;">
                            <%= satPct %>%
                        </strong>
                    </div>
                </div>
            </div>

            <!-- All Feedback Summary Table -->
            <div class="fb-table-card">
                <div
                    style="padding:14px 20px;background:#F7F5F2;border-bottom:1px solid #E8E3DD;font-family:'Syne',sans-serif;font-size:14px;font-weight:800;color:#1C2B35;">
                    All Feedback Summary</div>
                <div style="overflow-x:auto;">
                    <table class="fb-table">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Course</th>
                                <th>Rating</th>
                                <th>Category</th>
                                <th>Message Preview</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% feedbacks.forEach(function(f){ var r=parseInt(f.rating) || 0; var
                                cat=r===5?'Excellent':r===4?'Very Good':r===3?'Good':r===2?'Fair':r===1?'Poor':'Unrated'; var catBg=r >=
                                4?'#DCFCE7':r===3?'#EFF6FF':r >= 1?'#FEF2F2':'#F3F4F6';
                                var catColor = r >= 4?'#065F46':r===3?'#1D4ED8':r >= 1?'#991B1B':'#6B7280';
                                var initials2 = ((f.first_name||'')[0]||'') + ((f.last_name||'')[0]||'');
                                var stars2 = ''; for(var s2=1;s2 <= 5;s2++) stars2 +=s2 <= r?'★':'☆'; %>
                                    <tr>
                                        <td>
                                            <div class="name-cell">
                                                <div class="name-avatar">
                                                    <% if(f.profile_picture&&f.profile_picture!=='' ){%><img
                                                            src="<%= f.profile_picture %>">
                                                        <%}else{%>
                                                            <%= initials2.toUpperCase() %>
                                                                <%}%>
                                                </div>
                                                <span class="name-text">
                                                    <%= f.last_name %>, <%= f.first_name %>
                                                </span>
                                            </div>
                                        </td>
                                        <td><span
                                                style="background:#EFF6FF;color:#1D4ED8;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;">
                                                <%= f.course %>
                                            </span></td>
                                        <td>
                                            <% if(r > 0){%><span
                                                    style="color:#F59E0B;font-size:14px;letter-spacing:1px;"><%-
                                                        stars2%></span>
                                                <%}else{%><span style="font-size:11px;color:#C4BDB6;">No rating</span>
                                                    <%}%>
                                        </td>
                                        <td><span
                                                style="background:<%= catBg %>;color:<%= catColor %>;padding:4px 9px;border-radius:6px;font-size:11px;font-weight:700;">
                                                <%= cat %>
                                            </span></td>
                                            <td style="max-width:220px;font-size:12px;color:#4B5563;">
                                                <%= (f.message||'').substring(0,80) %>
                                                    <%= f.message && f.message.length > 80?'…':'' %>
                                        </td>
                                        <td style="font-size:11px;color:#9CA3AF;white-space:nowrap;">
                                            <%= new
                                                Date(f.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})
                                                %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% if(!feedbacks||feedbacks.length===0){ %>
                                            <tr>
                                                <td colspan="6"
                                                    style="padding:48px;text-align:center;color:#9CA3AF;font-size:13px;">
                                                    No feedback data yet.</td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
</div>
</div>
</div>

<!-- ══ VIEW FEEDBACK MODAL ══ -->
