<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .fb-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .fb-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .fb-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .fb-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .fb-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .fb-header p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin: 0;
    }

    .fb-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    .fb-stats {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        flex-wrap: wrap;
    }

    .fb-stat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #E8E3DD;
        flex: 1;
        min-width: 120px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .fb-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .fb-stat-val {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        line-height: 1;
    }

    .fb-stat-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        margin-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .fb-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 32px;
        background: #F0EDE8;
        border-bottom: 1px solid #E2DDD8;
    }

    .fb-filter-select {
        padding: 8px 14px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        outline: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }

    .fb-search-wrap {
        position: relative;
    }

    .fb-search-wrap input {
        padding: 8px 14px 8px 32px;
        border: 1.5px solid #D6D0CA;
        border-radius: 9px;
        background: #fff;
        font-size: 12px;
        color: #1C2B35;
        outline: none;
        width: 200px;
        font-family: 'DM Sans', sans-serif;
    }

    .fb-table-wrap {
        padding: 0 32px 32px;
        background: #F0EDE8;
    }

    .fb-table-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
        border: 1px solid #E8E3DD;
    }

    table.fb-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .fb-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .fb-table th {
        padding: 13px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
        white-space: nowrap;
    }

    .fb-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .fb-table tbody tr:last-child {
        border-bottom: none;
    }

    .fb-table tbody tr:hover {
        background: #FAF9F7;
    }

    .fb-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .star-display {
        display: inline-flex;
        gap: 2px;
    }

    .star-on {
        color: #F59E0B;
        font-size: 16px;
        line-height: 1;
    }

    .star-off {
        color: #D1D5DB;
        font-size: 16px;
        line-height: 1;
    }

    .star-none {
        font-size: 11px;
        color: #9CA3AF;
        font-style: italic;
        padding: 4px 8px;
        background: #F3F4F6;
        border-radius: 6px;
    }

    .name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .name-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .name-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .name-text {
        font-size: 13px;
        font-weight: 600;
        color: #1C2B35;
        white-space: nowrap;
    }

    .rating-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
    }

    .rating-5 {
        background: #FEF3C7;
        color: #92400E;
    }

    .rating-4 {
        background: #DCFCE7;
        color: #065F46;
    }

    .rating-3 {
        background: #EFF6FF;
        color: #1D4ED8;
    }

    .rating-2 {
        background: #FEF2F2;
        color: #991B1B;
    }

    .rating-1 {
        background: #FEF2F2;
        color: #991B1B;
    }

    .rating-0 {
        background: #F3F4F6;
        color: #6B7280;
    }

    .fb-table-footer {
        padding: 12px 20px;
        border-top: 1px solid #F3F0EC;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: #9CA3AF;
        background: #FAFAF9;
        flex-wrap: wrap;
        gap: 8px;
    }

    .btn-view-fb {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        background: #EFF6FF;
        color: #1D4ED8;
        border: 1.5px solid #BFDBFE;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.15s;
    }

    .btn-view-fb:hover {
        background: #1D4ED8;
        color: #fff;
        border-color: #1D4ED8;
    }

    .btn-print-fb {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 14px;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 700;
        background: #374151;
        color: #fff;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.15s;
    }

    .btn-print-fb:hover {
        opacity: 0.88;
    }

    /* ── View Details Modal ── */
    .fb-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .fb-modal-overlay.open {
        display: flex;
    }

    .fb-modal-overlay.open .fb-modal-card {
        animation: fbModalIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes fbModalIn {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(16px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .fb-modal-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28);
        width: 100%;
        max-width: 520px;
        overflow: hidden;
        font-family: 'DM Sans', sans-serif;
    }

    .fb-modal-header {
        background: linear-gradient(135deg, #273F4F, #1a2d38);
        padding: 18px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .fb-modal-close {
        width: 30px;
        height: 30px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        transition: all 0.15s;
    }

    .fb-modal-close:hover {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
    }

    .fb-modal-stars {
        display: flex;
        gap: 4px;
    }

    .fb-modal-star {
        font-size: 28px;
    }

    @media print {

        .fb-toolbar,
        .fb-header,
        .fb-stats,
        aside,
        header,
        footer {
            display: none !important;
        }

        .fb-table-wrap {
            padding: 0 !important;
        }

        .fb-table-card {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>

<div class="fb-page">
    <!-- Header -->
    <div class="fb-header">
        <div class="fb-header-inner">
            <div>
                <p class="fb-eyebrow">Admin Panel</p>
                <h1>Feedback Reports</h1>
                <p>Student feedback and star ratings for laboratory sit-in sessions</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;letter-spacing:0.04em;">
                <%= feedbacks.length %> total feedbacks
            </span>
        </div>
    </div>

    <% var totalFb=feedbacks.length; var rated=feedbacks.filter(f=>parseInt(f.rating)>0);
        var avgRating=rated.length>0?(rated.reduce((s,f)=>s+parseInt(f.rating),0)/rated.length).toFixed(1):'—';
        var fiveStars=feedbacks.filter(f=>parseInt(f.rating)===5).length;
        var lowRatings=feedbacks.filter(f=>{var r=parseInt(f.rating);return r>0&&r<=2;}).length; var
            noRating=feedbacks.filter(f=>parseInt(f.rating)===0).length; %>

            <!-- Stats -->
            <div class="fb-stats">
                <div class="fb-stat">
                    <div class="fb-stat-icon" style="background:#E8EFF4;">💬</div>
                    <div>
                        <div class="fb-stat-val" style="color:#273F4F;">
                            <%= totalFb %>
                        </div>
                        <div class="fb-stat-label">Total</div>
                    </div>
                </div>
                <div class="fb-stat">
                    <div class="fb-stat-icon" style="background:#FEF3C7;"><span style="font-size:18px;">⭐</span></div>
                    <div>
                        <div class="fb-stat-val" style="color:#D97706;">
                            <%= avgRating %>
                        </div>
                        <div class="fb-stat-label">Avg Rating</div>
                    </div>
                </div>
                <div class="fb-stat">
                    <div class="fb-stat-icon" style="background:#ECFDF5;">❤️</div>
                    <div>
                        <div class="fb-stat-val" style="color:#059669;">
                            <%= fiveStars %>
                        </div>
                        <div class="fb-stat-label">5-Star</div>
                    </div>
                </div>
                <div class="fb-stat">
                    <div class="fb-stat-icon" style="background:#FEF2F2;">⚠️</div>
                    <div>
                        <div class="fb-stat-val" style="color:#DC2626;">
                            <%= lowRatings %>
                        </div>
                        <div class="fb-stat-label">Low (1-2★)</div>
                    </div>
                </div>
                <div class="fb-stat">
                    <div class="fb-stat-icon" style="background:#F3F4F6;">⭕</div>
                    <div>
                        <div class="fb-stat-val" style="color:#6B7280;">
                            <%= noRating %>
                        </div>
                        <div class="fb-stat-label">No Rating</div>
                    </div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="fb-toolbar">
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <select id="ratingFilter" class="fb-filter-select">
                        <option value="">All Ratings</option>
                        <option value="5">⭐⭐⭐⭐⭐ Excellent (5)</option>
                        <option value="4">⭐⭐⭐⭐ Very Good (4)</option>
                        <option value="3">⭐⭐⭐ Good (3)</option>
                        <option value="2">⭐⭐ Fair (2)</option>
                        <option value="1">⭐ Poor (1)</option>
                        <option value="0">No Rating (0)</option>
                    </select>
                </div>
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <div class="fb-search-wrap">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                            style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9CA3AF;width:14px;height:14px;">
                            <path fill-rule="evenodd"
                                d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                                clip-rule="evenodd" />
                        </svg>
                        <input type="text" id="searchInput" placeholder="Search feedback..." style="padding-left:30px;">
                    </div>
                    <button class="btn-print-fb" onclick="window.print()">🖨 Print</button>
                </div>
            </div>

            <!-- Table -->
            <div class="fb-table-wrap">
                <div class="fb-table-card">
                    <div style="overflow-x:auto;">
                        <table class="fb-table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>ID Number</th>
                                    <th>Course</th>
                                    <th>Rating</th>
                                    <th>Stars</th>
                                    <th>Feedback Message</th>
                                    <th>Date</th>
                                    <th style="text-align:center;">Action</th>
                                </tr>
                            </thead>
                            <tbody id="fbBody">
                                <% if (feedbacks && feedbacks.length> 0) { %>
                                    <% feedbacks.forEach(function(f) { var ratingVal=parseInt(f.rating)||0; var
                                        initials=(f.first_name?f.first_name[0]:'')+(f.last_name?f.last_name[0]:''); var
                                        ratingLabel=ratingVal===5?'Excellent':ratingVal===4?'Very
                                        Good':ratingVal===3?'Good':ratingVal===2?'Fair':ratingVal===1?'Poor':'No
                                        Rating'; var stars='' ; for(var s=1;s<=5;s++) stars +=s<=ratingVal
                                        ? '<span class="star-on">★</span>' : '<span class="star-off">★</span>' ; %>
                                        <tr class="fb-row" data-rating="<%= ratingVal %>"
                                            data-name="<%= f.last_name %>, <%= f.first_name %>"
                                            data-id="<%= f.id_number %>" data-course="<%= f.course %>"
                                            data-rating-val="<%= ratingVal %>" data-rating-label="<%= ratingLabel %>"
                                            data-message="<%= (f.message||'').replace(/" /g,'&quot;') %>"
                                            data-date="<%= f.created_at %>"
                                                data-pic="<%= f.profile_picture||'' %>">
                                                    <td>
                                                        <div class="name-cell">
                                                            <div class="name-avatar">
                                                                <% if (f.profile_picture && f.profile_picture !=='' ) {
                                                                    %><img src="<%= f.profile_picture %>">
                                                                    <% } else { %>
                                                                        <%= initials.toUpperCase() %>
                                                                            <% } %>
                                                            </div>
                                                            <span class="name-text">
                                                                <%= f.last_name %>, <%= f.first_name %>
                                                            </span>
                                                        </div>
                                                    </td>
                                                    <td><span
                                                            style="font-family:monospace;font-size:11px;color:#4B5563;background:#F3F0EC;padding:3px 8px;border-radius:5px;">
                                                            <%= f.id_number %>
                                                        </span></td>
                                                    <td><span
                                                            style="display:inline-flex;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;">
                                                            <%= f.course %>
                                                        </span></td>
                                                    <td><span class="rating-badge rating-<%= ratingVal %>">
                                                            <%= ratingLabel %>
                                                        </span></td>
                                                    <td>
                                                        <% if (ratingVal> 0) { %>
                                                            <div class="star-display"><%- stars %></div>
                                                            <% } else { %>
                                                                <span class="star-none">No rating</span>
                                                                <% } %>
                                                    </td>
                                                    <td style="max-width:240px;">
                                                        <p
                                                            style="font-size:12px;color:#4B5563;margin:0;line-height:1.5;word-break:break-word;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                                            <%= f.message %>
                                                        </p>
                                                    </td>
                                                    <td style="font-size:11px;color:#9CA3AF;white-space:nowrap;">
                                                        <%= new
                                                            Date(f.created_at).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'})
                                                            %>
                                                    </td>
                                                    <td style="text-align:center;">
                                                        <button class="btn-view-fb"
                                                            onclick="viewFeedback(this.closest('tr'))">
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                                fill="currentColor" width="11" height="11">
                                                                <path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" />
                                                                <path fill-rule="evenodd"
                                                                    d="M1.38 8.28a.87.87 0 0 1 0-.566 7.003 7.003 0 0 1 13.239.005.87.87 0 0 1 0 .566A7.003 7.003 0 0 1 1.379 8.28ZM11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                                                                    clip-rule="evenodd" />
                                                            </svg>
                                                            View
                                                        </button>
                                                    </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8">
                                                        <div
                                                            style="padding:64px 24px;text-align:center;color:#9CA3AF;font-size:13px;">
                                                            No feedback yet.</div>
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    <div class="fb-table-footer">
                        <span>Showing <strong id="visibleCount" style="color:#1C2B35;">
                                <%= feedbacks.length %>
                            </strong> of <strong style="color:#1C2B35;">
                                <%= feedbacks.length %>
                            </strong> records</span>
                        <span>CCS Laboratory Sit-in Monitoring System</span>
                    </div>
                </div>
            </div>
</div>

<!-- ══ VIEW DETAILS MODAL ══ -->
<div id="fbModal" class="fb-modal-overlay" onclick="if(event.target===this) closeFbModal()">
    <div class="fb-modal-card">
        <div class="fb-modal-header">
            <div style="display:flex;align-items:center;gap:10px;">
                <div
                    style="width:36px;height:36px;border-radius:9px;background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.25);display:flex;align-items:center;justify-content:center;font-size:16px;">
                    💬</div>
                <div>
                    <div style="font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff;">Feedback
                        Details</div>
                    <div style="font-size:11px;color:rgba(255,255,255,0.45);">Full student feedback and rating</div>
                </div>
            </div>
            <button class="fb-modal-close" onclick="closeFbModal()">✕</button>
        </div>

        <!-- Student info strip -->
        <div
            style="padding:14px 24px;background:linear-gradient(135deg,#F9F8F6,#F0EDE8);border-bottom:1px solid #E8E3DD;display:flex;align-items:center;gap:14px;">
            <div id="fbModalAvatar"
                style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,#273F4F,#5B0E14);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#F1E194;flex-shrink:0;overflow:hidden;">
            </div>
            <div>
                <div id="fbModalName" style="font-size:14px;font-weight:700;color:#1C2B35;"></div>
                <div style="display:flex;gap:6px;margin-top:4px;">
                    <span id="fbModalId"
                        style="font-family:monospace;font-size:11px;color:#6B7280;background:#F3F0EC;padding:2px 7px;border-radius:4px;"></span>
                    <span id="fbModalCourse"
                        style="font-size:11px;font-weight:700;background:#EFF6FF;color:#1D4ED8;padding:2px 7px;border-radius:4px;"></span>
                </div>
            </div>
        </div>

        <!-- Rating display -->
        <div style="padding:18px 24px;border-bottom:1px solid #F3F0EC;">
            <div
                style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6B7280;margin-bottom:8px;">
                Rating</div>
            <div style="display:flex;align-items:center;gap:12px;">
                <div id="fbModalStars" class="fb-modal-stars"></div>
                <span id="fbModalRatingLabel" style="font-size:13px;font-weight:700;"></span>
            </div>
        </div>

        <!-- Message -->
        <div style="padding:18px 24px;border-bottom:1px solid #F3F0EC;">
            <div
                style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#6B7280;margin-bottom:8px;">
                Feedback Message</div>
            <div id="fbModalMessage"
                style="font-size:14px;color:#374151;line-height:1.75;background:#F9F8F6;border-radius:12px;padding:16px;border:1.5px solid #E8E3DD;white-space:pre-wrap;word-break:break-word;max-height:180px;overflow-y:auto;">
            </div>
        </div>

        <!-- Date -->
        <div style="padding:12px 24px;background:#FAFAF9;">
            <span style="font-size:11px;color:#9CA3AF;" id="fbModalDate"></span>
        </div>

        <!-- Close button -->
        <div style="padding:0 24px 20px;">
            <button onclick="closeFbModal()"
                style="width:100%;padding:11px;background:#F3F0EC;color:#374151;border:1.5px solid #E8E3DD;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">Close</button>
        </div>
    </div>
</div>

<script>
    // ── Filters ────────────────────────────────────────────────────────────────
    const searchInput = document.getElementById('searchInput');
    const ratingFilter = document.getElementById('ratingFilter');
    const countEl = document.getElementById('visibleCount');

    function applyFilters() {
        const q = searchInput.value.toLowerCase();
        const rating = ratingFilter.value;
        let count = 0;
        document.querySelectorAll('.fb-row').forEach(row => {
            const matchQ = !q || row.textContent.toLowerCase().includes(q);
            const matchRating = !rating || row.dataset.rating == rating;
            const show = matchQ && matchRating;
            row.style.display = show ? '' : 'none';
            if (show) count++;
        });
        countEl.textContent = count;
    }

    searchInput.addEventListener('input', applyFilters);
    ratingFilter.addEventListener('change', applyFilters);

    // ── View Details Modal ─────────────────────────────────────────────────────
    const RATING_LABELS = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
    const RATING_COLORS = ['#6B7280', '#DC2626', '#F59E0B', '#3B82F6', '#059669', '#F59E0B'];

    function viewFeedback(row) {
        const name = row.dataset.name;
        const id = row.dataset.id;
        const course = row.dataset.course;
        const ratingVal = parseInt(row.dataset.ratingVal) || 0;
        const ratingLabel = row.dataset.ratingLabel;
        const message = row.dataset.message;
        const date = row.dataset.date;
        const pic = row.dataset.pic;

        // Avatar
        const avatarEl = document.getElementById('fbModalAvatar');
        if (pic) {
            avatarEl.innerHTML = `<img src="${pic}" style="width:100%;height:100%;object-fit:cover;">`;
        } else {
            const initials = name.split(', ').map(p => p[0] || '').join('');
            avatarEl.innerHTML = initials.toUpperCase();
        }

        document.getElementById('fbModalName').textContent = name;
        document.getElementById('fbModalId').textContent = id;
        document.getElementById('fbModalCourse').textContent = course;
        document.getElementById('fbModalMessage').textContent = message || '(No message)';
        document.getElementById('fbModalDate').textContent = '📅 Submitted: ' + new Date(date).toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' });

        // Stars
        let starsHtml = '';
        if (ratingVal > 0) {
            for (let s = 1; s <= 5; s++) {
                starsHtml += `<span class="fb-modal-star" style="color:${s <= ratingVal ? '#F59E0B' : '#D1D5DB'}">${s <= ratingVal ? '★' : '☆'}</span>`;
            }
        } else {
            starsHtml = '<span style="font-size:12px;color:#9CA3AF;font-style:italic;">No rating given</span>';
        }
        document.getElementById('fbModalStars').innerHTML = starsHtml;

        const ratingLabelEl = document.getElementById('fbModalRatingLabel');
        ratingLabelEl.textContent = ratingLabel;
        ratingLabelEl.style.color = RATING_COLORS[ratingVal] || '#6B7280';

        document.getElementById('fbModal').classList.add('open');
    }

    function closeFbModal() {
        document.getElementById('fbModal').classList.remove('open');
    }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeFbModal(); });
</script>