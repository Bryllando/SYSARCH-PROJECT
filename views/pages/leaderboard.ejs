<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    .lb-page {
        font-family: 'DM Sans', sans-serif;
        background: #F0EDE8;
        min-height: 100%;
    }

    .lb-header {
        background: linear-gradient(135deg, #1C2B35 0%, #273F4F 60%, #1a3040 100%);
        padding: 28px 32px 24px;
        position: relative;
        overflow: hidden;
    }

    .lb-header::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(241, 225, 148, 0.07);
        pointer-events: none;
    }

    .lb-header-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }

    .lb-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin: 0 0 4px;
    }

    .lb-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(241, 225, 148, 0.7);
        margin: 0 0 6px;
    }

    .lb-body {
        padding: 24px 32px 40px;
    }

    /* ── Formula Cards ── */
    .lb-formula {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 24px;
    }

    .lb-formula-card {
        background: #fff;
        border-radius: 16px;
        padding: 18px 20px;
        border: 1px solid #E8E3DD;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .lb-formula-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .lb-formula-pct {
        font-family: 'Syne', sans-serif;
        font-size: 26px;
        font-weight: 800;
        line-height: 1;
    }

    .lb-formula-label {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-top: 2px;
    }

    /* ── Top 3 Podium ── */
    .lb-podium {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: 12px;
        margin-bottom: 28px;
    }

    .podium-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .podium-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 800;
        overflow: hidden;
        border: 3px solid;
    }

    .podium-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .podium-item:nth-child(1) .podium-avatar {
        border-color: #C0C0C0;
        width: 56px;
        height: 56px;
    }

    .podium-item:nth-child(2) .podium-avatar {
        border-color: #F59E0B;
        width: 72px;
        height: 72px;
    }

    .podium-item:nth-child(3) .podium-avatar {
        border-color: #CD7F32;
        width: 56px;
        height: 56px;
    }

    .podium-name {
        font-size: 12px;
        font-weight: 700;
        color: #1C2B35;
        text-align: center;
        max-width: 90px;
        word-break: break-word;
    }

    .podium-pts {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 800;
    }

    .podium-block {
        border-radius: 10px 10px 0 0;
        width: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }

    .podium-item:nth-child(1) .podium-block {
        height: 60px;
        background: linear-gradient(135deg, #9CA3AF, #6B7280);
    }

    .podium-item:nth-child(2) .podium-block {
        height: 90px;
        background: linear-gradient(135deg, #F59E0B, #D97706);
    }

    .podium-item:nth-child(3) .podium-block {
        height: 48px;
        background: linear-gradient(135deg, #CD7F32, #A0522D);
    }

    /* ── Full Leaderboard Table ── */
    .lb-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #E8E3DD;
        box-shadow: 0 2px 16px rgba(39, 63, 79, 0.08);
    }

    .lb-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .lb-table thead tr {
        background: #F7F5F2;
        border-bottom: 2px solid #E8E3DD;
    }

    .lb-table th {
        padding: 12px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6B7280;
    }

    .lb-table tbody tr {
        border-bottom: 1px solid #F3F0EC;
        transition: background 0.12s;
    }

    .lb-table tbody tr:hover {
        background: #FAF9F7;
    }

    .lb-table tbody tr:last-child {
        border-bottom: none;
    }

    .lb-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .rank-badge {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
        flex-shrink: 0;
    }

    .rank-1 {
        background: linear-gradient(135deg, #F59E0B, #D97706);
        color: #fff;
    }

    .rank-2 {
        background: linear-gradient(135deg, #9CA3AF, #6B7280);
        color: #fff;
    }

    .rank-3 {
        background: linear-gradient(135deg, #CD7F32, #A0522D);
        color: #fff;
    }

    .rank-other {
        background: #F3F0EC;
        color: #6B7280;
    }

    /* ── Progress bars per score ── */
    .score-bar-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .score-bar {
        flex: 1;
        height: 6px;
        background: #F3F0EC;
        border-radius: 999px;
        overflow: hidden;
    }

    .score-bar-fill {
        height: 100%;
        border-radius: 999px;
    }
</style>

<div class="lb-page">
    <div class="lb-header">
        <div class="lb-header-inner">
            <div>
                <p class="lb-eyebrow">CCS Laboratory</p>
                <h1>🏆 Student Leaderboard</h1>
                <p style="font-size:13px;color:rgba(255,255,255,0.5);margin:0;">Rankings based on sessions, sit-ins, and
                    tasks completed</p>
            </div>
            <span
                style="background:rgba(241,225,148,0.15);border:1px solid rgba(241,225,148,0.3);color:#F1E194;font-size:12px;font-weight:700;padding:6px 14px;border-radius:999px;">
                Max 100 pts
            </span>
        </div>
    </div>

    <div class="lb-body">
        <!-- Formula explanation -->
        <div class="lb-formula">
            <div class="lb-formula-card">
                <div class="lb-formula-icon" style="background:#FFF7ED;">🎯</div>
                <div>
                    <div class="lb-formula-pct" style="color:#D97706;">50%</div>
                    <div class="lb-formula-label">Sessions Used</div>
                </div>
            </div>
            <div class="lb-formula-card">
                <div class="lb-formula-icon" style="background:#EFF6FF;">💻</div>
                <div>
                    <div class="lb-formula-pct" style="color:#1D4ED8;">30%</div>
                    <div class="lb-formula-label">Total Sit-ins</div>
                </div>
            </div>
            <div class="lb-formula-card">
                <div class="lb-formula-icon" style="background:#ECFDF5;">✅</div>
                <div>
                    <div class="lb-formula-pct" style="color:#059669;">20%</div>
                    <div class="lb-formula-label">Tasks / Feedback</div>
                </div>
            </div>
        </div>

        <!-- Full table -->
        <div class="lb-card">
            <div
                style="padding:14px 20px;background:#F7F5F2;border-bottom:1px solid #E8E3DD;font-family:'Syne',sans-serif;font-size:14px;font-weight:800;color:#1C2B35;">
                Full Rankings
            </div>
            <div style="overflow-x:auto;">
                <table class="lb-table" id="lbTable">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Year</th>
                            <th>Sit-ins</th>
                            <th>Feedback</th>
                            <th>Total Points</th>
                        </tr>
                    </thead>
                    <tbody id="lbBody">
                        <% if (students && students.length> 0) { %>
                            <% students.forEach(function(s, i) { var
                                rankClass=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other'; var
                                rankEmoji=i===0?'🥇':i===1?'🥈':i===2?'🥉':(i+1); var
                                initials=(s.first_name?s.first_name[0]:'')+(s.last_name?s.last_name[0]:''); var
                                pct=Math.min(s.points, 100); var barColor=pct>= 70 ? '#F59E0B' : pct >= 40 ? '#3B82F6' :
                                '#10B981';
                                %>
                                <tr>
                                    <td><span class="rank-badge <%= rankClass %>">
                                            <%= rankEmoji %>
                                        </span></td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:10px;">
                                            <div
                                                style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#273F4F,#5B0E14);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#F1E194;flex-shrink:0;overflow:hidden;">
                                                <% if (s.profile_picture && s.profile_picture !=='' ) { %>
                                                    <img src="<%= s.profile_picture %>"
                                                        style="width:100%;height:100%;object-fit:cover;">
                                                    <% } else { %>
                                                        <%= initials.toUpperCase() %>
                                                            <% } %>
                                            </div>
                                            <div>
                                                <div style="font-size:13px;font-weight:600;color:#1C2B35;">
                                                    <%= s.last_name %>, <%= s.first_name %>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span
                                            style="background:#EFF6FF;color:#1D4ED8;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;">
                                            <%= s.course %>
                                        </span></td>
                                    <td style="font-size:12px;color:#4B5563;">
                                        <%= s.year_level %>
                                    </td>
                                    <td><span
                                            style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#273F4F;">
                                            <%= s.total_sitins %>
                                        </span></td>
                                    <td><span
                                            style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#059669;">
                                            <%= s.feedback_count %>
                                        </span></td>
                                    <td>
                                        <div class="score-bar-wrap">
                                            <div class="score-bar">
                                                <div class="score-bar-fill"
                                                    style="width:<%= pct %>%;background:<%= barColor %>;"></div>
                                            </div>
                                            <span
                                                style="font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:<%= barColor %>;min-width:36px;text-align:right;">
                                                <%= s.points %>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" style="padding:56px;text-align:center;color:#9CA3AF;">No
                                                rankings yet. Start your first sit-in!</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
            <div
                style="padding:12px 20px;border-top:1px solid #F3F0EC;font-size:11px;color:#9CA3AF;background:#FAFAF9;">
                Points = (Sessions Used × 50%) + (Total Sit-ins, max 30 pts) + (Feedback × 4 pts, max 20 pts)
            </div>
        </div>
    </div>
</div>