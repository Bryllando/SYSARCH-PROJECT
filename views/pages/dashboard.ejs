<style>
    /* ── Avatar ── */
    .sic-avatar-wrap {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        padding: 3px;
        background: linear-gradient(135deg, #5B0E14, #C9953A);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .sic-avatar-inner {
        width: 94px;
        height: 94px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #fff;
        background: linear-gradient(135deg, #5B0E14, #273F4F);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sic-avatar-inner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .sic-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #E5E7EB 20%, #E5E7EB 80%, transparent);
        margin: 10px 0;
        border: none;
    }

    .sic-section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 0 6px;
    }

    .sic-section-label span {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9CA3AF;
    }

    .sic-section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #F0F0F0;
    }

    .sic-sessions {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        background: linear-gradient(135deg, #3A0910, #5B0E14, #7A1520);
        box-shadow: 0 6px 24px rgba(91, 14, 20, 0.35);
    }

    .sic-sessions::before {
        content: '';
        position: absolute;
        top: -30px;
        right: -30px;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.07);
        pointer-events: none;
    }

    .sic-sessions-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px;
    }

    .sic-sessions-label p:first-child {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
    }

    .sic-sessions-label p:last-child {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.4);
        margin: 3px 0 0;
    }

    .sic-sessions-count {
        font-size: 52px;
        font-weight: 900;
        color: #fff;
        line-height: 1;
        letter-spacing: -0.02em;
    }

    .sic-rule-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid #F5F5F5;
    }

    .sic-rule-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .sic-rule-num {
        width: 22px;
        height: 22px;
        min-width: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .sic-rule-text {
        font-size: 12px;
        color: #4B5563;
        line-height: 1.65;
        flex: 1;
        word-break: break-word;
        margin: 0;
    }

    /* ── Announcement card ── */
    .ann-feed-card {
        background: #fff;
        border: 1px solid #EDEDED;
        border-radius: 14px;
        margin-bottom: 12px;
        overflow: hidden;
        transition: box-shadow 0.15s;
    }

    .ann-feed-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
    }

    .ann-feed-head {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px 8px;
    }

    .ann-feed-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .ann-feed-from {
        font-size: 12px;
        font-weight: 700;
        color: #1C2B35;
    }

    .ann-feed-time {
        font-size: 10px;
        color: #9CA3AF;
    }

    .ann-feed-body {
        padding: 0 14px 10px;
        font-size: 13px;
        color: #374151;
        line-height: 1.65;
        white-space: pre-wrap;
    }

    .ann-feed-media {
        margin: 0 14px 10px;
        border-radius: 10px;
        overflow: hidden;
    }

    .ann-feed-media img {
        width: 100%;
        max-height: 280px;
        object-fit: cover;
        display: block;
        border-radius: 10px;
    }

    .ann-feed-media video {
        width: 100%;
        max-height: 280px;
        border-radius: 10px;
    }

    /* ── Reactions ── */
    .ann-reactions-bar {
        padding: 0 14px 4px;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .react-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 13px;
        border: 1.5px solid #E8E3DD;
        background: #F7F5F2;
        cursor: pointer;
        transition: all 0.15s;
        color: #6B7280;
        font-family: inherit;
    }

    .react-btn:hover {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
    }

    .react-btn.reacted {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.1);
        color: #5B0E14;
        font-weight: 600;
    }

    .react-btn .react-count {
        font-size: 11px;
        font-weight: 700;
        min-width: 12px;
    }

    .react-add-wrap {
        position: relative;
        display: inline-flex;
    }

    .react-add-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: 1.5px dashed #D6D0CA;
        background: transparent;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.15s;
    }

    .react-add-btn:hover {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
    }

    .react-picker {
        position: absolute;
        bottom: 36px;
        left: 0;
        background: #fff;
        border: 1.5px solid #E8E3DD;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        padding: 8px;
        display: none;
        z-index: 20;
    }

    .react-picker.open {
        display: block;
        animation: rpIn 0.15s ease;
    }

    @keyframes rpIn {
        from {
            opacity: 0;
            transform: translateY(4px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .react-picker-grid {
        display: flex;
        gap: 4px;
    }

    .react-pick-btn {
        font-size: 20px;
        padding: 4px 6px;
        border-radius: 8px;
        cursor: pointer;
        border: none;
        background: transparent;
        transition: background 0.1s;
        line-height: 1;
    }

    .react-pick-btn:hover {
        background: #F0EDE8;
        transform: scale(1.2);
    }

    /* ── Comments ── */
    .ann-comments-section {
        border-top: 1px solid #F0F0F0;
    }

    .ann-comments-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        font-size: 12px;
        font-weight: 600;
        color: #9CA3AF;
        cursor: pointer;
        background: none;
        border: none;
        width: 100%;
        text-align: left;
        font-family: inherit;
        transition: color 0.15s;
    }

    .ann-comments-toggle:hover {
        color: #5B0E14;
    }

    .ann-comments-body {
        padding: 4px 14px 14px;
        display: none;
        max-height: 300px;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .ann-comments-body::-webkit-scrollbar {
        display: none;
    }

    .ann-comments-body.open {
        display: block;
    }

    .ann-comment-item {
        display: flex;
        gap: 8px;
        margin-bottom: 10px;
    }

    .ann-comment-avatar {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: linear-gradient(135deg, #273F4F, #5B0E14);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
        overflow: hidden;
    }

    .ann-comment-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .ann-comment-bubble {
        background: #F7F5F2;
        border-radius: 0 10px 10px 10px;
        padding: 8px 12px;
        flex: 1;
    }

    .ann-comment-name {
        font-size: 11px;
        font-weight: 700;
        color: #1C2B35;
        margin-bottom: 2px;
    }

    .ann-comment-msg {
        font-size: 12px;
        color: #4B5563;
        line-height: 1.5;
    }

    .ann-comment-reply {
        margin-top: 8px;
        padding: 8px 12px;
        background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
        border-radius: 0 10px 10px 10px;
        border-left: 3px solid #059669;
    }
    .ann-comment-reply-header {
        font-size: 10px;
        font-weight: 700;
        color: #059669;
        margin-bottom: 4px;
    }
    .ann-comment-reply-msg {
        font-size: 12px;
        color: #065F46;
        line-height: 1.5;
    }

    .ann-comment-time {
        font-size: 10px;
        color: #C4BDB6;
        margin-top: 2px;
    }

    .ann-comment-form {
        display: flex;
        gap: 8px;
        margin-top: 8px;
    }

    .ann-comment-input {
        flex: 1;
        padding: 8px 12px;
        border: 1.5px solid #E2DDD8;
        border-radius: 20px;
        font-size: 12px;
        color: #1C2B35;
        background: #F9F8F6;
        outline: none;
        font-family: inherit;
        transition: border-color 0.15s;
    }

    .ann-comment-input:focus {
        border-color: #5B0E14;
        background: #fff;
    }

    .ann-comment-submit {
        padding: 7px 14px;
        border-radius: 20px;
        background: linear-gradient(135deg, #5B0E14, #7a131b);
        color: #fff;
        border: none;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        transition: opacity 0.15s;
    }

    .ann-comment-submit:hover {
        opacity: 0.88;
    }
</style>

<div class="p-6 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5" style="min-width:0;">

        <!-- ══ LEFT COLUMN ══ -->
        <div class="flex flex-col gap-4">

            <!-- Student Information Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-[#5B0E14] shrink-0"></div>
                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Student Information</h2>
                </div>
                <div class="p-5">
                    <div class="flex flex-col items-center gap-3 pb-4 mb-1">
                        <div class="sic-avatar-wrap">
                            <div class="sic-avatar-inner">
                                <% if (user.profile_picture && user.profile_picture !=='' ) { %>
                                    <img src="<%= user.profile_picture %>" alt="Profile Picture">
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"
                                            style="width:48px;height:48px;">
                                            <path fill-rule="evenodd"
                                                d="M18.685 19.097A9.723 9.723 0 0 0 21.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12a9.723 9.723 0 0 0 3.065 7.097A9.716 9.716 0 0 0 12 21.75a9.716 9.716 0 0 0 6.685-2.653Zm-12.54-1.348A7.698 7.698 0 0 1 12 15a7.693 7.693 0 0 1 5.855 2.749A8.217 8.217 0 0 1 12 20.25a8.216 8.216 0 0 1-5.855-2.401ZM9 9a3 3 0 1 1 6 0 3 3 0 0 1-6 0Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        <% } %>
                            </div>
                        </div>
                        <div class="text-center">
                            <p class="font-bold text-[#1A2733] text-base leading-snug">
                                <%= user.last_name %>, <%= user.first_name %>
                                        <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                            </p>
                            <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-semibold text-[#5B0E14]"
                                style="background:rgba(91,14,20,0.08);">
                                <%= user.course %> — Year <%= user.year_level %>
                            </span>
                        </div>
                    </div>
                    <hr class="sic-divider mb-4">
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Full Name</p>
                                <p class="text-sm font-semibold text-gray-700">
                                    <%= user.last_name %>, <%= user.first_name %>
                                            <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path fill-rule="evenodd"
                                        d="M4.5 2A1.5 1.5 0 0 0 3 3.5v9A1.5 1.5 0 0 0 4.5 14h7a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4.5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0 2.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Z"
                                        clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    ID Number</p>
                                <p class="text-sm font-semibold text-gray-700 font-mono tracking-wide">
                                    <%= user.id_number %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" />
                                    <path
                                        d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Email</p>
                                <p class="text-sm font-semibold text-gray-700 break-all">
                                    <%= user.email %>
                                </p>
                            </div>
                        </div>
                        <% if (user.address && user.address !=='' ) { %>
                            <div class="flex items-start gap-3">
                                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                    style="background:rgba(39,63,79,0.08);">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                        class="w-4 h-4">
                                        <path fill-rule="evenodd"
                                            d="M8 1.5a4.5 4.5 0 0 0-4.5 4.5c0 2.098 1.21 4.273 2.497 5.998a28.89 28.89 0 0 0 1.944 2.201.75.75 0 0 0 1.118 0 28.89 28.89 0 0 0 1.944-2.2C12.29 10.272 13.5 8.097 13.5 6A4.5 4.5 0 0 0 8 1.5Zm0 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0 mb-4">
                                    <p
                                        class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                        Address</p>
                                    <p class="text-sm font-semibold text-gray-700">
                                        <%= user.address %>
                                    </p>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>

            <!-- Sessions Badge -->
            <div class="sic-sessions">
                <div class="sic-sessions-inner">
                    <div class="sic-sessions-label">
                        <p>Remaining Sessions</p>
                        <p>Lab sit-in allowance</p>
                    </div>
                    <div class="sic-sessions-count">
                        <%= user.remaining_sessions ?? 30 %>
                    </div>
                </div>
            </div>
        </div>


        <!-- ══ ANNOUNCEMENTS FEED ══ -->
        <div
            class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col col-span-1 md:col-span-1">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F] shrink-0"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Announcements</h2>
                <span style="margin-left:auto;font-size:10px;color:#9CA3AF;">React or comment below</span>
            </div>

            <div class="flex-1 overflow-y-auto"
                style="max-height:600px;padding:12px;box-sizing:border-box;min-width:0;width:100%;">
                <% if (typeof announcements !=='undefined' && announcements && announcements.length> 0) { %>
                    <% announcements.forEach(function(ann) { %>
                        <div class="ann-feed-card">
                            <!-- Head -->
                            <div class="ann-feed-head">
                                <div class="ann-feed-avatar">A</div>
                                <div>
                                    <div class="ann-feed-from">CCS Admin</div>
                                    <div class="ann-feed-time">
                                        <%= new
                                            Date(ann.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'})
                                            %>
                                    </div>
                                </div>
                            </div>

                            <% if (ann.media_url && ann.media_url !=='' ) { %>
                                <div class="ann-feed-media">
                                    <% if (ann.media_type==='video' ) { %>
                                        <video controls>
                                            <source src="<%= ann.media_url %>">
                                        </video>
                                        <% } else { %>
                                            <img src="<%= ann.media_url %>" alt="Announcement media" loading="lazy">
                                            <% } %>
                                </div>
                                <% } %>

                                    <div class="ann-feed-body">
                                        <%= ann.message %>
                                    </div>

                                    <!-- Reactions -->
                                    <div class="ann-reactions-bar" id="reactions-<%= ann.id %>">
                                        <% var reactionEmojis=['👍','❤️','😂','😮','😢','👏']; %>
                                            <% reactionEmojis.forEach(function(emoji) { var count=(ann.reactions &&
                                                ann.reactions[emoji]) ? ann.reactions[emoji] : 0; var
                                                isReacted=ann.userReaction===emoji; %>
                                                <% if (count> 0 || isReacted) { %>
                                                    <button class="react-btn <%= isReacted ? 'reacted' : '' %>"
                                                        data-ann="<%= ann.id %>" data-emoji="<%= emoji %>"
                                                        onclick="sendReaction(<%= ann.id %>, '<%= emoji %>', this)">
                                                        <%= emoji %> <span class="react-count">
                                                                <%= count %>
                                                            </span>
                                                    </button>
                                                    <% } %>
                                                        <% }); %>
                                                            <div class="react-add-wrap">
                                                                <button class="react-add-btn"
                                                                    onclick="toggleReactPicker(<%= ann.id %>, event)"
                                                                    title="Add reaction">😊</button>
                                                                <div class="react-picker" id="rp-<%= ann.id %>">
                                                                    <div class="react-picker-grid">
                                                                        <% reactionEmojis.forEach(function(emoji) { %>
                                                                            <button class="react-pick-btn"
                                                                                onclick="sendReaction(<%= ann.id %>, '<%= emoji %>'); closeReactPicker(<%= ann.id %>)">
                                                                                <%= emoji %>
                                                                            </button>
                                                                            <% }); %>
                                                                    </div>
                                                                </div>
                                                            </div>
                                    </div>

                                    <!-- Comments -->
                                    <div class="ann-comments-section">
                                        <button class="ann-comments-toggle" onclick="toggleComments(<%= ann.id %>)">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"
                                                fill="currentColor" width="12" height="12">
                                                <path fill-rule="evenodd"
                                                    d="M1 8.74c0 .983.713 1.825 1.69 1.943L3 10.72v2.03a.75.75 0 0 0 1.28.53l1.5-1.5.31-.03H9a2.26 2.26 0 0 0 2.25-2.25v-5.5A2.25 2.25 0 0 0 9 1.75H4A2.25 2.25 0 0 0 1.75 4v4.74H1Z"
                                                    clip-rule="evenodd" />
                                            </svg>
                                            <span id="ctoggle-<%= ann.id %>">
                                                <%= ann.commentCount %> comment<%= ann.commentCount !==1 ? 's' : '' %>
                                            </span>
                                        </button>
                                        <div class="ann-comments-body" id="comments-body-<%= ann.id %>">
                                            <div id="comments-list-<%= ann.id %>"></div>
                                            <div class="ann-comment-form">
                                                <input type="text" class="ann-comment-input" id="cinput-<%= ann.id %>"
                                                    placeholder="Write a comment..."
                                                    onkeydown="if(event.key==='Enter')postComment(<%= ann.id %>)">
                                                <button class="ann-comment-submit"
                                                    onclick="postComment(<%= ann.id %>)">Post</button>
                                            </div>
                                        </div>
                                    </div>
                        </div>
                        <% }); %>
                            <% } else { %>
                                <div class="flex flex-col items-center justify-center py-16 gap-3">
                                    <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center"
                                        style="font-size:24px;">📢</div>
                                    <p class="text-sm font-medium text-gray-400">No announcements yet</p>
                                </div>
                                <% } %>
            </div>
        </div>


        <!-- ══ RULES & REGULATIONS ══ -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col"
            style="overflow:hidden;min-width:0;">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-amber-500 shrink-0"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Rules & Regulations</h2>
            </div>
            <div class="flex-1 overflow-y-auto"
                style="max-height:600px;padding:20px;box-sizing:border-box;min-width:0;width:100%;">
                <div class="text-center pb-4 mb-4" style="border-bottom:1px solid #F0F0F0;">
                    <div class="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center"
                        style="background:linear-gradient(135deg,#5B0E14,#273F4F);">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="white" class="w-5 h-5">
                            <path fill-rule="evenodd"
                                d="M4.5 2A1.5 1.5 0 0 0 3 3.5v9A1.5 1.5 0 0 0 4.5 14h7a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4.5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0 2.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Z"
                                clip-rule="evenodd" />
                        </svg>
                    </div>
                    <p class="text-xs font-bold text-[#273F4F] uppercase tracking-wide">University of Cebu</p>
                    <p class="text-xs text-gray-400 mt-0.5">College of Information & Computer Studies</p>
                </div>
                <div class="sic-section-label mb-3"><span>Laboratory Rules</span></div>
                <% var
                    labRules=[ 'Maintain silence, proper decorum, and discipline inside the laboratory. Mobile phones and personal devices must be switched off.'
                    , 'Games are not allowed inside the lab. This includes computer-related games and card games that may disturb operations.'
                    , 'Surfing the Internet is allowed only with the permission of the instructor. Downloading and installing software are strictly prohibited.'
                    , 'Getting access to websites not related to the course is strictly prohibited.'
                    , 'Deleting computer files and changing the set-up of the computer is a major offense.'
                    , 'Observe computer time. All times consumed beyond the allowable number of hours are charged accordingly.'
                    , 'No food and drinks are allowed inside the laboratory.'
                    , 'Students are not allowed to go outside during laboratory hours without permission.' ]; %>
                    <ol style="list-style:none;padding:0;margin:0;width:100%;">
                        <% labRules.forEach(function(rule, idx) { %>
                            <li class="sic-rule-item">
                                <span class="sic-rule-num">
                                    <%= idx + 1 %>
                                </span>
                                <p class="sic-rule-text">
                                    <%= rule %>
                                </p>
                            </li>
                            <% }); %>
                    </ol>
            </div>
        </div>

    </div>
</div>

<script>
    // ── Reactions ──────────────────────────────────────────────────
    async function sendReaction(annId, emoji, btn) {
        try {
            const res = await fetch(`/announcements/${annId}/react`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ emoji })
            });
            const data = await res.json();
            if (data.success) refreshReactions(annId, emoji, data.action);
        } catch (e) { }
    }

    function refreshReactions(annId, emoji, action) {
        const container = document.getElementById('reactions-' + annId);
        if (!container) return;
        const existingBtn = container.querySelector(`[data-emoji="${emoji}"][data-ann="${annId}"]`);
        const addWrap = container.querySelector('.react-add-wrap');

        if (action === 'removed') {
            if (existingBtn) {
                const count = parseInt(existingBtn.querySelector('.react-count').textContent) - 1;
                if (count <= 0) existingBtn.remove();
                else { existingBtn.querySelector('.react-count').textContent = count; existingBtn.classList.remove('reacted'); }
            }
        } else if (action === 'added') {
            container.querySelectorAll('.react-btn.reacted').forEach(b => b.classList.remove('reacted'));
            if (existingBtn) {
                existingBtn.querySelector('.react-count').textContent = parseInt(existingBtn.querySelector('.react-count').textContent) + 1;
                existingBtn.classList.add('reacted');
            } else {
                const newBtn = document.createElement('button');
                newBtn.className = 'react-btn reacted';
                newBtn.dataset.ann = annId;
                newBtn.dataset.emoji = emoji;
                newBtn.onclick = function () { sendReaction(annId, emoji, this); };
                newBtn.innerHTML = `${emoji} <span class="react-count">1</span>`;
                container.insertBefore(newBtn, addWrap);
            }
        } else if (action === 'changed') {
            container.querySelectorAll('.react-btn').forEach(b => b.classList.remove('reacted'));
            if (existingBtn) {
                existingBtn.querySelector('.react-count').textContent = parseInt(existingBtn.querySelector('.react-count').textContent || '0') + 1;
                existingBtn.classList.add('reacted');
            }
        }
    }

    function toggleReactPicker(annId, e) {
        e.stopPropagation();
        const picker = document.getElementById('rp-' + annId);
        const wasOpen = picker.classList.contains('open');
        document.querySelectorAll('.react-picker.open').forEach(p => p.classList.remove('open'));
        if (!wasOpen) picker.classList.add('open');
    }
    function closeReactPicker(annId) { document.getElementById('rp-' + annId)?.classList.remove('open'); }
    document.addEventListener('click', () => document.querySelectorAll('.react-picker.open').forEach(p => p.classList.remove('open')));

    // ── Comments ──────────────────────────────────────────────────
    const commentsLoaded = {};

    async function toggleComments(annId) {
        const body = document.getElementById('comments-body-' + annId);
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open');
        if (!isOpen && !commentsLoaded[annId]) {
            await loadComments(annId);
            commentsLoaded[annId] = true;
        }
    }

    async function loadComments(annId) {
        try {
            const res = await fetch(`/announcements/${annId}/comments`);
            const comments = await res.json();
            renderComments(annId, comments);
        } catch (e) { }
    }

    function renderComments(annId, comments) {
        const list = document.getElementById('comments-list-' + annId);
        if (!list) return;
        list.innerHTML = comments.map(c => {
            const initials = ((c.first_name || '')[0] || '') + ((c.last_name || '')[0] || '');
            const avatarHtml = c.profile_picture ? `<img src="${c.profile_picture}">` : initials.toUpperCase();
            const commentText = c.comment || c.message || '';
            const replyHtml = c.reply ? `<div class="ann-comment-reply"><div class="ann-comment-reply-header">↳ Admin Reply</div><div class="ann-comment-reply-msg">${escHtml(c.reply)}</div></div>` : '';
            return `<div class="ann-comment-item">
            <div class="ann-comment-avatar">${avatarHtml}</div>
            <div class="ann-comment-bubble">
                <div class="ann-comment-name">${c.first_name} ${c.last_name}</div>
                <div class="ann-comment-msg">${escHtml(commentText)}</div>
                <div class="ann-comment-time">${new Date(c.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</div>
                ${replyHtml}
            </div>
        </div>`;
        }).join('');
    }

    async function postComment(annId) {
        const input = document.getElementById('cinput-' + annId);
        const message = input.value.trim();
        if (!message) {
            alert('Please enter a comment message.');
            return;
        }
        
        console.log('Posting comment for announcement:', annId, 'message:', message);
        
        try {
            const res = await fetch(`/announcements/${annId}/comment`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            
            console.log('Response status:', res.status);
            const data = await res.json();
            console.log('Response data:', data);
            
            if (data.error) {
                alert(data.error);
                return;
            }
            if (data.success && data.comment) {
                input.value = '';
                const c = data.comment;
                const list = document.getElementById('comments-list-' + annId);
                const initials = ((c.first_name || '')[0] || '') + ((c.last_name || '')[0] || '');
                const avatarHtml = c.profile_picture ? `<img src="${c.profile_picture}">` : initials.toUpperCase();
                const commentText = c.comment || c.message || '';
                const div = document.createElement('div');
                div.className = 'ann-comment-item';
                div.innerHTML = `<div class="ann-comment-avatar">${avatarHtml}</div><div class="ann-comment-bubble"><div class="ann-comment-name">${c.first_name} ${c.last_name}</div><div class="ann-comment-msg">${escHtml(commentText)}</div><div class="ann-comment-time">Just now</div></div>`;
                list.appendChild(div);
                const toggle = document.getElementById('ctoggle-' + annId);
                if (toggle) {
                    const current = parseInt(toggle.textContent) || 0;
                    const newCount = current + 1;
                    toggle.textContent = `${newCount} comment${newCount !== 1 ? 's' : ''}`;
                }
            }
        } catch (e) {
            console.error('Comment error:', e);
            alert('Failed to post comment. Please try again.');
        }
    }

    function escHtml(str) {
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
</script>