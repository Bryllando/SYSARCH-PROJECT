<script>
    const AI_INITIAL = <%- JSON.stringify(initialAiRecommendation || null) %>;

    function renderAiRecommendation(rec) {
        const target = document.getElementById('ai-rec-content');
        if (!target) return;
        if (!rec) {
            target.innerHTML = '<div class="ai-rec-empty">No recommendations available yet.</div>';
            return;
        }
        const alertHtml = rec.alert ? `<div class="ai-alert">Alert: ${escHtml(rec.alert)}</div>` : '';
        target.innerHTML = `
            <article class="ai-rec-item">
                <p class="ai-rec-kicker ai-c-maroon"><span class="dot">📅</span> SCHEDULE TIP</p>
                <div class="ai-rec-value">${formatAIText(rec.schedule_tip || 'No AI schedule tip returned yet.')}</div>
            </article>
            <article class="ai-rec-item">
                <p class="ai-rec-kicker ai-c-green"><span class="dot">🖥</span> RESOURCE TIP</p>
                <div class="ai-rec-value">${formatAIText(rec.resource_tip || 'No AI resource tip returned yet.')}</div>
            </article>
            <article class="ai-rec-item">
                <p class="ai-rec-kicker ai-c-amber"><span class="dot">📊</span> BEHAVIOR INSIGHT</p>
                <div class="ai-rec-value">${formatAIText(rec.behavior_insight || 'No AI behavior insight returned yet.')}</div>
            </article>
            <article class="ai-rec-item">
                <p class="ai-rec-kicker ai-c-blue"><span class="dot">🏆</span> LEADERBOARD TIP</p>
                <div class="ai-rec-value">${formatAIText(rec.leaderboard_tip || 'No AI leaderboard tip returned yet.')}</div>
            </article>
            <article class="ai-rec-item full">
                <p class="ai-rec-kicker ai-c-gray"><span class="dot">💬</span> FEEDBACK INSIGHT</p>
                <div class="ai-rec-value">${formatAIText(rec.feedback_insight || 'No AI feedback insight returned yet.')}</div>
            </article>
            ${alertHtml}
        `;
    }

    function renderAiLoading() {
        const target = document.getElementById('ai-rec-content');
        if (!target) return;
        target.innerHTML = `
            <div class="ai-skel"></div>
            <div class="ai-skel"></div>
            <div class="ai-skel"></div>
            <div class="ai-skel"></div>
            <div class="ai-skel full"></div>
        `;
    }

    async function loadAiRecommendation(force = false) {
        renderAiLoading();
        if (!force && AI_INITIAL) {
            renderAiRecommendation(AI_INITIAL);
        }
        try {
            const res = await fetch('/api/ai/student-recommendation', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ refresh: force })
            });
            const data = await res.json();
            if (!data.success) {
                if (!AI_INITIAL) renderAiRecommendation(null);
                return;
            }
            if (force && data.meta && data.meta.fallback) {
                if (window.showAppToast) window.showAppToast('warning', 'AI API offline. Showing backup offline data.');
            }
            if (data.message && window.showAppToast) {
                window.showAppToast('info', data.message);
            }
            const updatedEl = document.getElementById('ai-rec-updated');
            if (updatedEl) {
                if (data.meta && Number.isFinite(data.meta.minutes_ago)) {
                    const totalSeconds = data.meta.minutes_ago * 60;
                    updatedEl.dataset.seconds = totalSeconds;
                    updatedEl.dataset.fetchedAt = Date.now();
                    updatedEl.textContent = 'Last updated: ' + formatTimestamp(totalSeconds);
                } else {
                    updatedEl.textContent = 'Live Summary';
                }
            }
            renderAiRecommendation(data.recommendation);
        } catch (_) {
            if (!AI_INITIAL) document.getElementById('ai-rec-content').innerHTML = '<div class="ai-rec-empty" style="color:#991B1B;">AI recommendation is temporarily unavailable.</div>';
        }
    }

    loadAiRecommendation();
    const refreshBtn = document.getElementById('ai-refresh-btn');
    if (refreshBtn) {
        refreshBtn.addEventListener('click', () => loadAiRecommendation(true));
    }

    const tipBtn = document.getElementById('ai-tip-btn');
    const tipPanel = document.getElementById('user-tip-panel');
    const tipClose = document.getElementById('user-tip-close');
    const tipBody = document.getElementById('user-tip-body');

    async function loadUserTip() {
        if (!tipBody) return;
        tipBody.innerHTML = 'Loading your personal study tip...';
        try {
            const res = await fetch('/ai-study-tip');
            const data = await res.json();
            if (!data.success || !data.tip) throw new Error('No data');
            const t = data.tip;
            tipBody.innerHTML = `
                <div class="user-tip-row"><b>${formatAIText(t.badge || 'Best Week')}</b></div>
                <div class="user-tip-row"><b>Best Week:</b> ${formatAIText(t.best_week || 'No data yet')}</div>
                <div class="user-tip-row"><b>Best Day:</b> ${formatAIText(t.best_day || 'No data yet')}</div>
                <div class="user-tip-row"><b>Busiest Day:</b> ${formatAIText(t.busiest_day || 'No data yet')}</div>
                <div class="user-tip-row"><b>Most Available Lab:</b> ${formatAIText(t.best_lab || 'No data yet')}</div>
                <div class="user-tip-row"><b>Best Time:</b> ${formatAIText(t.best_time || 'No data yet')}</div>
                <div class="user-tip-row" style="color:#9CA3AF;font-style:italic;">${formatAIText(t.note || '')}</div>
            `;
        } catch (_) {
            tipBody.innerHTML = '<div class="user-tip-row">No study tip available yet. Complete sit-ins first.</div>';
        }
    }

    if (tipBtn && tipPanel) {
        tipBtn.addEventListener('click', async () => {
            tipPanel.classList.add('open');
            await loadUserTip();
        });
    }
    if (tipClose && tipPanel) {
        tipClose.addEventListener('click', () => tipPanel.classList.remove('open'));
    }

    function formatAIText(str) {
        if (!str) return '';
        
        // Handle arrays or objects returned by AI
        if (typeof str === 'object' && str !== null) {
            if (Array.isArray(str)) {
                str = str.map(item => {
                    if (typeof item === 'object' && item !== null) {
                        return '- ' + Object.entries(item).map(([k, v]) => {
                            let keyName = k.charAt(0).toUpperCase() + k.slice(1).replace(/_/g, ' ');
                            return `**${keyName}:** ${String(v).replace(/\n/g, ' ')}`;
                        }).join(' | ');
                    }
                    return '- ' + String(item).replace(/\n/g, ' ');
                }).join('\n');
            } else {
                str = Object.entries(str).map(([k, v]) => {
                    let keyName = k.charAt(0).toUpperCase() + k.slice(1).replace(/_/g, ' ');
                    let val = typeof v === 'object' && v !== null ? JSON.stringify(v) : String(v).replace(/\n/g, ' ');
                    return `- **${keyName}:** ${val}`;
                }).join('\n');
            }
        }
        
        let s = String(str)
            .replace(/&/g,'&amp;')
            .replace(/</g,'&lt;')
            .replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;');
        
        // Convert Markdown bold to strong
        s = s.replace(/\*\*(.*?)\*\*/g, '<strong style="color: #1C2B35;">$1</strong>');
        // Convert Markdown italics
        s = s.replace(/\*(.*?)\*/g, '<em>$1</em>');
        // Convert Markdown list items
        s = s.replace(/^[-*]\s+(.*)$/gm, '<li style="margin-left:14px; margin-bottom:6px; list-style-type:disc;">$1</li>');
        // Convert newlines to breaks
        s = s.replace(/\n/g, '<br>');
        // Clean up multiple line breaks
        s = s.replace(/(<br>\s*){2,}/g, '<br><br>');
        // Clean up breaks around list items
        s = s.replace(/(<br>)*<li/g, '<li');
        s = s.replace(/<\/li>(<br>)*/g, '</li>');
        // Wrap list items in ul
        s = s.replace(/(<li[\s\S]*?<\/li>)+/g, '<ul style="padding:0; margin: 4px 0;">$&</ul>');
        
        return s;
    }

    // ── Human-readable timestamp helper ──
    function formatTimestamp(totalSeconds) {
        if (totalSeconds < 60) {
            return Math.round(totalSeconds) + ' second' + (Math.round(totalSeconds) !== 1 ? 's' : '') + ' ago';
        } else if (totalSeconds < 3600) {
            const m = Math.round(totalSeconds / 60);
            return m + ' minute' + (m !== 1 ? 's' : '') + ' ago';
        } else if (totalSeconds < 86400) {
            const h = Math.round(totalSeconds / 3600);
            return h + ' hour' + (h !== 1 ? 's' : '') + ' ago';
        } else {
            const d = Math.round(totalSeconds / 86400);
            return d + ' day' + (d !== 1 ? 's' : '') + ' ago';
        }
    }

    // ── Auto-refresh the "Last updated" label every 30s ──
    setInterval(() => {
        const updatedEl = document.getElementById('ai-rec-updated');
        if (!updatedEl || !updatedEl.dataset.seconds || !updatedEl.dataset.fetchedAt) return;
        const elapsedSec = (Date.now() - Number(updatedEl.dataset.fetchedAt)) / 1000;
        const totalSec = Number(updatedEl.dataset.seconds) + elapsedSec;
        updatedEl.textContent = 'Last updated: ' + formatTimestamp(totalSec);
    }, 30000);
</script>