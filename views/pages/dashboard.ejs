<style>
    /* ── Avatar ── */
    .sic-avatar-wrap {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        padding: 3px;
        background: linear-gradient(135deg, #5B0E14, #C9953A);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .sic-avatar-inner {
        width: 94px;
        height: 94px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #fff;
        background: linear-gradient(135deg, #5B0E14, #273F4F);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sic-avatar-inner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* ── Divider ── */
    .sic-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #E5E7EB 20%, #E5E7EB 80%, transparent);
        margin: 0;
        margin-bottom: 10px;
        margin-top: 10px;
        border: none;
    }

    /* ── Section label inside cards ── */
    .sic-section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 0 6px;
    }

    .sic-section-label span {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9CA3AF;
    }

    .sic-section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #F0F0F0;
    }

    /* ── Sessions card ── */
    .sic-sessions {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        background: linear-gradient(135deg, #3A0910 0%, #5B0E14 60%, #7A1520 100%);
        box-shadow: 0 6px 24px rgba(91, 14, 20, 0.35);
    }

    .sic-sessions::before {
        content: '';
        position: absolute;
        top: -30px;
        right: -30px;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.07);
        pointer-events: none;
    }

    .sic-sessions::after {
        content: '';
        position: absolute;
        bottom: -28px;
        left: 5px;
        width: 85px;
        height: 85px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        pointer-events: none;
    }

    .sic-sessions-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px;
    }

    .sic-sessions-label p:first-child {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
    }

    .sic-sessions-label p:last-child {
        font-size: 11px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.4);
        margin-top: 3px;
        margin-bottom: 0;
    }

    .sic-sessions-count {
        font-size: 52px;
        font-weight: 900;
        color: #fff;
        line-height: 1;
        letter-spacing: -0.02em;
    }

    /* ── Announcement item ── */
    .sic-ann-item {
        border-radius: 12px;
        border: 1px solid #EDEDED;
        background: #FAFAFA;
        overflow: hidden;
        transition: border-color 0.15s, background 0.15s;
    }

    .sic-ann-item:hover {
        border-color: rgba(91, 14, 20, 0.2);
        background: #fff;
    }

    .sic-ann-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 14px 10px;
        border-bottom: 1px solid #F0F0F0;
    }

    .sic-ann-dot {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .sic-ann-from {
        font-size: 11px;
        font-weight: 600;
        color: #9CA3AF;
    }

    .sic-ann-from strong {
        color: #5B0E14;
    }

    .sic-ann-body {
        padding: 10px 14px 12px;
    }

    .sic-ann-msg {
        font-size: 13px;
        color: #4B5563;
        line-height: 1.65;
        margin: 0;
    }

    /* ── Rules ── */
    .sic-rule-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid #F5F5F5;
    }

    .sic-rule-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .sic-rule-num {
        width: 22px;
        height: 22px;
        min-width: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .sic-rule-text {
        font-size: 12px;
        color: #4B5563;
        line-height: 1.65;
        flex: 1;
        word-break: break-word;
        overflow-wrap: break-word;
        min-width: 0;
        margin: 0;
    }
</style>

<div class="p-6 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5" style="min-width:0;">

        <!-- ══ LEFT COLUMN ══ -->
        <div class="flex flex-col gap-4">

            <!-- Student Information Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-[#5B0E14] shrink-0"></div>
                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Student Information</h2>
                </div>

                <div class="p-5">

                    <!-- Avatar + Name -->
                    <div class="flex flex-col items-center gap-3 pb-4 mb-1">
                        <div class="sic-avatar-wrap">
                            <div class="sic-avatar-inner">
                                <% if (user.profile_picture && user.profile_picture !=='' ) { %>
                                    <img src="<%= user.profile_picture %>" alt="Profile Picture">
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"
                                            style="width:48px;height:48px;">
                                            <path fill-rule="evenodd"
                                                d="M18.685 19.097A9.723 9.723 0 0 0 21.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12a9.723 9.723 0 0 0 3.065 7.097A9.716 9.716 0 0 0 12 21.75a9.716 9.716 0 0 0 6.685-2.653Zm-12.54-1.348A7.698 7.698 0 0 1 12 15a7.693 7.693 0 0 1 5.855 2.749A8.217 8.217 0 0 1 12 20.25a8.216 8.216 0 0 1-5.855-2.401ZM9 9a3 3 0 1 1 6 0 3 3 0 0 1-6 0Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        <% } %>
                            </div>
                        </div>
                        <div class="text-center">
                            <p class="font-bold text-[#1A2733] text-base leading-snug">
                                <%= user.last_name %>, <%= user.first_name %>
                                        <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                            </p>
                            <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-semibold text-[#5B0E14]"
                                style="background:rgba(91,14,20,0.08);">
                                <%= user.course %> — Year <%= user.year_level %>
                            </span>
                        </div>
                    </div>

                    <!-- Divider after avatar -->
                    <hr class="sic-divider mb-4">

                    <!-- Info Rows -->
                    <div class="space-y-4">

                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Full Name</p>
                                <p class="text-sm font-semibold text-gray-700">
                                    <%= user.last_name %>, <%= user.first_name %>
                                            <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M7.702 1.368a.75.75 0 0 1 .597 0c2.098.91 4.105 1.99 6.004 3.223a.75.75 0 0 1 0 1.276 37.9 37.9 0 0 0-1.778 1.175V9.5a.75.75 0 0 1-.08.34l-.002.004A37.996 37.996 0 0 1 8.5 11.98a.75.75 0 0 1-.997 0 37.998 37.998 0 0 1-3.943-2.456l-.002-.004A.75.75 0 0 1 3.475 9.5V7.042a37.9 37.9 0 0 0-1.778-1.175.75.75 0 0 1 0-1.276 37.89 37.89 0 0 1 6.005-3.223ZM3.999 8.809A37.43 37.43 0 0 0 7.5 11.1v-2.6A37.43 37.43 0 0 0 3.999 6.2v2.609ZM8.5 11.1a37.43 37.43 0 0 0 3.5-2.291V6.2A37.43 37.43 0 0 0 8.5 8.5v2.6Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Course & Year</p>
                                <p class="text-sm font-semibold text-gray-700">
                                    <%= user.course %> — Year <%= user.year_level %>
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path fill-rule="evenodd"
                                        d="M4.5 2A1.5 1.5 0 0 0 3 3.5v9A1.5 1.5 0 0 0 4.5 14h7a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4.5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0 2.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0-5a.5.5 0 0 0 0 1h2a.5.5 0 0 0 0-1h-2Z"
                                        clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    ID Number</p>
                                <p class="text-sm font-semibold text-gray-700 font-mono tracking-wide">
                                    <%= user.id_number %>
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" />
                                    <path
                                        d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Email</p>
                                <p class="text-sm font-semibold text-gray-700 break-all">
                                    <%= user.email %>
                                </p>
                            </div>
                        </div>

                        <% if (user.address && user.address !=='' ) { %>
                            <div class="flex items-start gap-3">
                                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                    style="background:rgba(39,63,79,0.08);">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                        class="w-4 h-4">
                                        <path fill-rule="evenodd"
                                            d="M8 1.5a4.5 4.5 0 0 0-4.5 4.5c0 2.098 1.21 4.273 2.497 5.998a28.89 28.89 0 0 0 1.944 2.201.75.75 0 0 0 1.118 0 28.89 28.89 0 0 0 1.944-2.2C12.29 10.272 13.5 8.097 13.5 6A4.5 4.5 0 0 0 8 1.5Zm0 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0 mb-4">
                                    <p
                                        class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                        Address</p>
                                    <p class="text-sm font-semibold text-gray-700">
                                        <%= user.address %>
                                    </p>
                                </div>
                            </div>
                            <% } %>

                    </div>
                </div>
            </div>

            <!-- Sessions Badge -->
            <div class="sic-sessions">
                <div class="sic-sessions-inner">
                    <div class="sic-sessions-label">
                        <p>Remaining Sessions</p>
                        <p>Lab sit-in allowance</p>
                    </div>
                    <div class="sic-sessions-count">
                        <%= user.remaining_sessions ?? 30 %>
                    </div>
                </div>
            </div>

        </div>


        <!-- ══ ANNOUNCEMENTS ══ -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F] shrink-0"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Announcements</h2>

            </div>


            <div class="flex-1 overflow-y-auto space-y-3"
                style="max-height:520px; padding:15px; box-sizing:border-box; min-width:0; width:100%;">
                <% if (typeof announcements !=='undefined' && announcements && announcements.length> 0) { %>
                    <% announcements.forEach(function(ann) { %>
                        <div class="sic-ann-item">
                            <!-- Header row with divider below -->
                            <div class="sic-ann-header">
                                <div class="sic-ann-dot">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="white"
                                        style="width:10px;height:10px;">
                                        <path fill-rule="evenodd"
                                            d="M7.198 2.869a.75.75 0 0 1 1.08-.041l.002.002 4.57 4.57a.75.75 0 0 1 0 1.06l-4.57 4.57a.75.75 0 0 1-1.06-1.06l3.289-3.29H2.75a.75.75 0 0 1 0-1.5h8.759l-3.29-3.29a.75.75 0 0 1-.02-1.02Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <span class="sic-ann-from">
                                    <strong>CCS Admin</strong> · <%= new
                                        Date(ann.created_at).toLocaleDateString('en-US', {year:'numeric', month:'short',
                                        day:'numeric'}) %>
                                </span>
                            </div>
                            <!-- Message body below the line -->
                            <div class="sic-ann-body">
                                <p class="sic-ann-msg">
                                    <%= ann.message %>
                                </p>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="flex flex-col items-center justify-center py-16 gap-3">
                                    <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                            class="w-7 h-7 text-gray-300">
                                            <path fill-rule="evenodd"
                                                d="M12 2.25A6.75 6.75 0 0 0 5.25 9v.75a8.217 8.217 0 0 1-2.119 5.52.75.75 0 0 0 .298 1.206c1.544.57 3.16.99 4.831 1.243a3.75 3.75 0 1 0 7.48 0 24.583 24.583 0 0 0 4.83-1.244.75.75 0 0 0 .298-1.205 8.217 8.217 0 0 1-2.118-5.52V9A6.75 6.75 0 0 0 12 2.25ZM9.75 18c0-.034 0-.067.002-.1a25.05 25.05 0 0 0 4.496 0l.002.1a2.25 2.25 0 1 1-4.5 0Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                    </div>
                                    <p class="text-sm font-medium text-gray-400">No announcements yet</p>
                                    <p class="text-xs text-gray-300">Check back later for updates.</p>
                                </div>
                                <% } %>
            </div>
        </div>


        <!-- ══ RULES & REGULATIONS ══ -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col"
            style="overflow:hidden; min-width:0;">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-amber-500 shrink-0"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Rules & Regulations</h2>
            </div>

            <div class="flex-1 overflow-y-auto"
                style="max-height:520px; padding:20px; box-sizing:border-box; min-width:0; width:100%;">

                <!-- Org header -->
                <div class="text-center pb-4 mb-4" style="border-bottom:1px solid #F0F0F0;">
                    <div class="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center"
                        style="background:linear-gradient(135deg,#5B0E14,#273F4F);">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="white" class="w-5 h-5">
                            <path fill-rule="evenodd"
                                d="M4.5 2A1.5 1.5 0 0 0 3 3.5v9A1.5 1.5 0 0 0 4.5 14h7a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4.5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0 2.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0-5a.5.5 0 0 0 0 1h2a.5.5 0 0 0 0-1h-2Z"
                                clip-rule="evenodd" />
                        </svg>
                    </div>
                    <p class="text-xs font-bold text-[#273F4F] uppercase tracking-wide">University of Cebu</p>
                    <p class="text-xs text-gray-400 mt-0.5">College of Information & Computer Studies</p>
                </div>

                <!-- Section label with trailing line -->
                <div class="sic-section-label mb-3">
                    <span>Laboratory Rules</span>
                </div>

                <!-- Rules list — each item separated by a bottom border -->
                <ol style="list-style:none; padding:0; margin:0; width:100%;">
                    <% var
                        rules=[ 'Maintain silence, proper decorum, and discipline inside the laboratory. Mobile phones, walkmans and other personal pieces of equipment must be switched off.'
                        , 'Games are not allowed inside the lab. This includes computer-related games, card games and other games that may disturb the operation of the lab.'
                        , 'Surfing the Internet is allowed only with the permission of the instructor. Downloading and installing of software are strictly prohibited.'
                        , 'Getting access to other websites not related to the course is strictly prohibited.'
                        , 'Deleting computer files and changing the set-up of the computer is a major offense.'
                        , 'Observe computer time. All times consumed beyond the allowable number of hours are charged accordingly.'
                        , 'No food and drinks are allowed inside the laboratory.'
                        , 'Students are not allowed to go outside during laboratory hours without permission.' ]; %>
                        <% rules.forEach(function(rule, idx) { %>
                            <li class="sic-rule-item">
                                <span class="sic-rule-num">
                                    <%= idx + 1 %>
                                </span>
                                <p class="sic-rule-text">
                                    <%= rule %>
                                </p>
                            </li>
                            <% }) %>
                </ol>

            </div>
        </div>

    </div>
</div>