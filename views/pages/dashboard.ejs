<style>
    /* ── Avatar ── */
    .sic-avatar-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        padding: 3px;
        background: linear-gradient(135deg, #5B0E14, #C9953A);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    @media (min-width: 768px) {
        .sic-avatar-wrap {
            width: 100px;
            height: 100px;
        }
    }

    .sic-avatar-inner {
        width: 74px;
        height: 74px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #fff;
        background: linear-gradient(135deg, #5B0E14, #273F4F);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @media (min-width: 768px) {
        .sic-avatar-inner {
            width: 94px;
            height: 94px;
        }
    }

    .sic-avatar-inner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .sic-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #E5E7EB 20%, #E5E7EB 80%, transparent);
        margin: 10px 0;
        border: none;
    }

    .sic-section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 0 6px;
    }

    .sic-section-label span {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9CA3AF;
    }

    .sic-section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #F0F0F0;
    }

    .sic-sessions {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        background: linear-gradient(135deg, #3A0910, #5B0E14, #7A1520);
        box-shadow: 0 6px 24px rgba(91, 14, 20, 0.35);
    }

    .sic-sessions::before {
        content: '';
        position: absolute;
        top: -30px;
        right: -30px;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.07);
        pointer-events: none;
    }

    .sic-sessions-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
    }

    @media (min-width: 768px) {
        .sic-sessions-inner {
            padding: 20px 24px;
        }
    }

    .sic-sessions-label p:first-child {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
    }

    @media (min-width: 768px) {
        .sic-sessions-label p:first-child {
            font-size: 11px;
        }
    }

    .sic-sessions-label p:last-child {
        font-size: 10px;
        color: rgba(255, 255, 255, 0.4);
        margin: 3px 0 0;
    }

    @media (min-width: 768px) {
        .sic-sessions-label p:last-child {
            font-size: 11px;
        }
    }

    .sic-sessions-count {
        font-size: 36px;
        font-weight: 900;
        color: #fff;
        line-height: 1;
        letter-spacing: -0.02em;
    }

    @media (min-width: 768px) {
        .sic-sessions-count {
            font-size: 52px;
        }
    }

    .sic-rule-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid #F5F5F5;
    }

    .sic-rule-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .sic-rule-num {
        width: 22px;
        height: 22px;
        min-width: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .sic-rule-text {
        font-size: 12px;
        color: #4B5563;
        line-height: 1.65;
        flex: 1;
        word-break: break-word;
        margin: 0;
    }

    /* ── Announcement card ── */
    .ann-feed-card {
        background: #fff;
        border: 1px solid #EDEDED;
        border-radius: 14px;
        margin-bottom: 12px;
        overflow: hidden;
        transition: box-shadow 0.15s;
        max-width: 100%;
    }

    .ann-feed-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
    }

    .ann-feed-head {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px 8px;
    }

    .ann-feed-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .ann-feed-from {
        font-size: 12px;
        font-weight: 700;
        color: #1C2B35;
    }

    .ann-feed-time {
        font-size: 10px;
        color: #9CA3AF;
    }

    .ann-feed-body {
        padding: 0 14px 10px;
        font-size: 12px;
        color: #374151;
        line-height: 1.65;
        white-space: pre-wrap;
        word-wrap: break-word;
        overflow-wrap: break-word;
        max-width: 100%;
    }

    @media (min-width: 768px) {
        .ann-feed-body {
            font-size: 13px;
        }
    }

    .ann-feed-media {
        margin: 0 14px 10px;
        border-radius: 10px;
        overflow: hidden;
        max-width: 100%;
    }

    .ann-feed-media img {
        width: 100%;
        max-width: 100%;
        height: auto;
        max-height: 280px;
        object-fit: contain;
        display: block;
        border-radius: 10px;
    }

    .ann-feed-media video {
        width: 100%;
        max-width: 100%;
        height: auto;
        max-height: 280px;
        border-radius: 10px;
    }

    .ann-feed-media video {
        width: 100%;
        max-height: 280px;
        border-radius: 10px;
    }

    /* ── Reactions ── */
    .ann-reactions-bar {
        padding: 0 14px 4px;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .react-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 13px;
        border: 1.5px solid #E8E3DD;
        background: #F7F5F2;
        cursor: pointer;
        transition: all 0.15s;
        color: #6B7280;
        font-family: inherit;
    }

    .react-btn:hover {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
    }

    .react-btn.reacted {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.1);
        color: #5B0E14;
        font-weight: 600;
    }

    .react-btn .react-count {
        font-size: 11px;
        font-weight: 700;
        min-width: 12px;
    }

    .react-add-wrap {
        position: relative;
        display: inline-flex;
    }

    .react-add-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: 1.5px dashed #D6D0CA;
        background: transparent;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.15s;
    }

    .react-add-btn:hover {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
    }

    .react-picker {
        position: absolute;
        bottom: 36px;
        left: 0;
        background: #fff;
        border: 1.5px solid #E8E3DD;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        padding: 8px;
        display: none;
        z-index: 20;
    }

    .react-picker.open {
        display: block;
        animation: rpIn 0.15s ease;
    }

    @keyframes rpIn {
        from {
            opacity: 0;
            transform: translateY(4px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .react-picker-grid {
        display: flex;
        gap: 4px;
    }

    .react-pick-btn {
        font-size: 20px;
        padding: 4px 6px;
        border-radius: 8px;
        cursor: pointer;
        border: none;
        background: transparent;
        transition: background 0.1s;
        line-height: 1;
    }

    .react-pick-btn:hover {
        background: #F0EDE8;
        transform: scale(1.2);
    }

    /* ── Comments ── */
    .ann-comments-section {
        border-top: 1px solid #E8E3DD;
        padding: 8px 14px 12px;
        background: #fff;
    }

    .ann-comments-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 600;
        color: #65676B;
        cursor: pointer;
        background: #F0F2F5;
        border: none;
        width: 100%;
        text-align: left;
        font-family: inherit;
        transition: all 0.15s;
        border-radius: 8px;
        margin-bottom: 8px;
    }

    .ann-comments-toggle:hover {
        background: #E8EAED;
        color: #5B0E14;
    }

    /* Expandable comments section */
    .ann-comments-body {
        display: block;
        padding: 0 0 8px 0;
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transition: all 0.3s ease-in-out;
    }

    .ann-comments-body.expanded {
        max-height: 400px;
        opacity: 1;
        overflow-y: auto;
    }

    .comments-list {
        max-height: 200px;
        overflow-y: auto;
        margin-bottom: 10px;
        padding-right: 4px;
    }

    @media (min-width: 768px) {
        .comments-list {
            max-height: 250px;
        }
    }

    @media (min-width: 768px) {
        .ann-comments-body {
            padding: 10px 14px 14px;
        }
    }

    /* No comments placeholder */
    .no-comments {
        color: #65676B;
        font-size: 12px;
        padding: 8px 0;
        text-align: center;
    }

    @keyframes slideDown {
        from { opacity: 0; max-height: 0; }
        to   { opacity: 1; max-height: 260px; }
    }

    .ann-comment-item {
        display: flex;
        gap: 10px;
        margin-bottom: 12px;
        align-items: flex-start;
    }

    .ann-comment-avatar {
        width: 32px;
        height: 32px;
        min-width: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #8B1A24);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
        overflow: hidden;
    }

    .ann-comment-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .ann-comment-bubble {
        background: #F0F2F5;
        border-radius: 18px;
        padding: 8px 12px;
        flex: 1;
        max-width: calc(100% - 44px);
    }

    @media (min-width: 768px) {
        .ann-comment-bubble {
            max-width: calc(100% - 50px);
        }
    }

    .ann-comment-name {
        font-size: 12px;
        font-weight: 600;
        color: #050505;
        margin-bottom: 2px;
    }

    .ann-comment-msg {
        font-size: 13px;
        color: #050505;
        line-height: 1.4;
    }

    .ann-comment-reply {
        margin-top: 8px;
        padding: 8px 12px;
        background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
        border-radius: 0 10px 10px 10px;
        border-left: 3px solid #059669;
    }
    .ann-comment-reply-header {
        font-size: 10px;
        font-weight: 700;
        color: #059669;
        margin-bottom: 4px;
    }
    .ann-comment-reply-msg {
        font-size: 12px;
        color: #065F46;
        line-height: 1.5;
    }

    .ann-comment-time {
        font-size: 10px;
        color: #C4BDB6;
        margin-top: 2px;
    }

    .ann-comment-form {
        display: flex;
        gap: 8px;
        margin-top: 10px;
        align-items: center;
    }

    .ann-comment-input {
        flex: 1;
        padding: 10px 14px;
        border: 1px solid #CCD0D5;
        border-radius: 20px;
        font-size: 13px;
        color: #050505;
        background: #F0F2F5;
        outline: none;
        font-family: inherit;
        transition: all 0.15s;
    }

    .ann-comment-input:focus {
        background: #fff;
        border-color: #5B0E14;
        box-shadow: 0 0 0 2px rgba(91, 14, 20, 0.1);
    }

    .ann-comment-input::placeholder {
        color: #8A8D91;
    }

    .ann-comment-submit {
        padding: 8px 16px;
        border-radius: 18px;
        background: #5B0E14;
        color: #fff;
        border: none;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: all 0.15s;
    }

    .ann-comment-submit:hover {
        background: #7a131b;
    }

    /* Responsive announcement container */
    .ann-feed-container {
        height: auto !important;
        min-height: 200px !important;
        max-height: 70vh !important;
        overflow-y: auto !important;
    }
    @media (min-width: 768px) {
        .ann-feed-container {
            max-height: 600px !important;
            min-height: 300px !important;
        }
    }

    /* Facebook-style comment header */
    .ann-comments-header {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 14px;
        font-size: 13px;
        font-weight: 600;
        color: #5B0E14;
        cursor: pointer;
        background: #F0F2F5;
        border: none;
        width: 100%;
        text-align: left;
        font-family: inherit;
        transition: all 0.15s;
        border-top: 1px solid #E8E3DD;
        margin-top: 4px;
    }

    .ann-comments-header:hover {
        background: #E8EAED;
    }
</style>

<div class="p-4 md:p-6 space-y-4 md:space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5" style="min-width:0;">

        <!-- ══ LEFT COLUMN ══ -->
        <div class="flex flex-col gap-4">

            <!-- Student Information Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-[#5B0E14] shrink-0"></div>
                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Student Information</h2>
                </div>
                <div class="p-5">
                    <div class="flex flex-col items-center gap-3 pb-4 mb-1">
                        <div class="sic-avatar-wrap">
                            <div class="sic-avatar-inner">
                                <% if (user.profile_picture && user.profile_picture !=='' ) { %>
                                    <img src="<%= user.profile_picture %>" alt="Profile Picture">
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"
                                            style="width:48px;height:48px;">
                                            <path fill-rule="evenodd"
                                                d="M18.685 19.097A9.723 9.723 0 0 0 21.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12a9.723 9.723 0 0 0 3.065 7.097A9.716 9.716 0 0 0 12 21.75a9.716 9.716 0 0 0 6.685-2.653Zm-12.54-1.348A7.698 7.698 0 0 1 12 15a7.693 7.693 0 0 1 5.855 2.749A8.217 8.217 0 0 1 12 20.25a8.216 8.216 0 0 1-5.855-2.401ZM9 9a3 3 0 1 1 6 0 3 3 0 0 1-6 0Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        <% } %>
                            </div>
                        </div>
                        <div class="text-center">
                            <p class="font-bold text-[#1A2733] text-base leading-snug">
                                <%= user.last_name %>, <%= user.first_name %>
                                        <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                            </p>
                            <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-semibold text-[#5B0E14]"
                                style="background:rgba(91,14,20,0.08);">
                                <%= user.course %> — Year <%= user.year_level %>
                            </span>
                        </div>
                    </div>
                    <hr class="sic-divider mb-4">
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Full Name</p>
                                <p class="text-sm font-semibold text-gray-700">
                                    <%= user.last_name %>, <%= user.first_name %>
                                            <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path fill-rule="evenodd"
                                        d="M4.5 2A1.5 1.5 0 0 0 3 3.5v9A1.5 1.5 0 0 0 4.5 14h7a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4.5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0 2.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Z"
                                        clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    ID Number</p>
                                <p class="text-sm font-semibold text-gray-700 font-mono tracking-wide">
                                    <%= user.id_number %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" />
                                    <path
                                        d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Email</p>
                                <p class="text-sm font-semibold text-gray-700 break-all">
                                    <%= user.email %>
                                </p>
                            </div>
                        </div>
                        <% if (user.address && user.address !=='' ) { %>
                            <div class="flex items-start gap-3">
                                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                    style="background:rgba(39,63,79,0.08);">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                        class="w-4 h-4">
                                        <path fill-rule="evenodd"
                                            d="M8 1.5a4.5 4.5 0 0 0-4.5 4.5c0 2.098 1.21 4.273 2.497 5.998a28.89 28.89 0 0 0 1.944 2.201.75.75 0 0 0 1.118 0 28.89 28.89 0 0 0 1.944-2.2C12.29 10.272 13.5 8.097 13.5 6A4.5 4.5 0 0 0 8 1.5Zm0 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0 mb-4">
                                    <p
                                        class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                        Address</p>
                                    <p class="text-sm font-semibold text-gray-700">
                                        <%= user.address %>
                                    </p>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>

            <!-- Sessions Badge -->
            <div class="sic-sessions">
                <div class="sic-sessions-inner">
                    <div class="sic-sessions-label">
                        <p>Remaining Sessions</p>
                        <p>Lab sit-in allowance</p>
                    </div>
                    <div class="sic-sessions-count">
                        <%= user.remaining_sessions ?? 30 %>
                    </div>
                </div>
            </div>
        </div>


<!-- ══ ANNOUNCEMENTS FEED (Facebook-style) ══ -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col col-span-1 md:col-span-1">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F] shrink-0"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Announcements</h2>
                <span style="margin-left:auto;font-size:10px;color:#9CA3AF;">React or comment below</span>
            </div>

            <div id="ann-feed-scroll" class="flex-1" style="height:auto;max-height:80vh;min-height:300px;overflow-y:auto;padding:10px 0;background:#F0F2F5;">
                <% if (typeof announcements !== 'undefined' && announcements && announcements.length > 0) { %>
                    <% announcements.forEach(function(ann) { %>
                        <!-- ── Announcement Card ── -->
                        <div class="ann-fb-card" style="background:#fff;border-radius:10px;margin:0 8px 10px;box-shadow:0 1px 2px rgba(0,0,0,0.1);">
                            <!-- Post Header -->
                            <div style="display:flex;align-items:center;gap:10px;padding:12px 14px 8px;">
                                <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#5B0E14,#3A0910);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#F1E194;flex-shrink:0;">A</div>
                                <div>
                                    <div style="font-size:13px;font-weight:700;color:#050505;">CCS Admin</div>
                                    <div style="font-size:11px;color:#65676B;">
                                        <%= new Date(ann.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                                        · <span style="font-size:10px;">🌐</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Post Content -->
                            <div style="padding:0 14px 10px;font-size:14px;color:#050505;line-height:1.65;white-space:pre-wrap;word-wrap:break-word;">
                                <%= ann.message %>
                            </div>

                            <!-- Media -->
                            <% if (ann.media_url && ann.media_url !== '') { %>
                                <div style="border-top:1px solid #E4E6EB;border-bottom:1px solid #E4E6EB;margin-bottom:0;">
                                    <% if (ann.media_type === 'video') { %>
                                        <video controls style="width:100%;max-height:300px;object-fit:cover;display:block;"><source src="<%= ann.media_url %>"></video>
                                    <% } else { %>
                                        <img src="<%= ann.media_url %>" alt="" loading="lazy" style="width:100%;max-height:400px;object-fit:cover;display:block;">
                                    <% } %>
                                </div>
                            <% } %>

                            <!-- Reaction Summary Row -->
                            <% var totalReactions = 0; if (ann.reactions) { Object.values(ann.reactions).forEach(function(c){ totalReactions += c; }); } %>
                            <% if (totalReactions > 0 || ann.commentCount > 0) { %>
                                <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 14px;border-bottom:1px solid #E4E6EB;">
                                    <% if (totalReactions > 0) { %>
                                        <div style="display:flex;align-items:center;gap:4px;font-size:13px;color:#65676B;">
                                            <div style="display:flex;gap:-2px;">
                                                <% var topEmojis = Object.keys(ann.reactions || {}).slice(0,3); %>
                                                <% topEmojis.forEach(function(emoji){ %>
                                                    <span style="font-size:14px;"><%= emoji %></span>
                                                <% }); %>
                                            </div>
                                            <span style="font-size:12px;color:#65676B;"><%= totalReactions %></span>
                                        </div>
                                    <% } else { %>
                                        <div></div>
                                    <% } %>
                                    <% if (ann.commentCount > 0) { %>
                                        <button onclick="scrollToComments('<%= ann.id %>')" style="font-size:12px;color:#65676B;background:none;border:none;cursor:pointer;padding:0;">
                                            <%= ann.commentCount %> comment<%= ann.commentCount !== 1 ? 's' : '' %>
                                        </button>
                                    <% } %>
                                </div>
                            <% } %>

                            <!-- Action Buttons (Like / Comment) -->
                            <div style="display:flex;align-items:center;padding:2px 8px;border-bottom:1px solid #E4E6EB;">
                                <div style="position:relative;flex:1;">
                                    <button id="like-btn-<%= ann.id %>"
                                        onmousedown="startLikeHold('<%= ann.id %>')"
                                        onmouseup="cancelLikeHold()"
                                        onmouseleave="cancelLikeHold()"
                                        ontouchstart="startLikeHold('<%= ann.id %>')"
                                        ontouchend="cancelLikeHold()"
                                        onclick="quickLike('<%= ann.id %>', this)"
                                        style="width:100%;display:flex;align-items:center;justify-content:center;gap:6px;padding:8px;border:none;background:none;cursor:pointer;border-radius:6px;font-size:13px;font-weight:600;color:<%= ann.userReaction ? '#1877F2' : '#65676B' %>;"
                                        onmouseover="this.style.background='#F2F2F2'" onmouseout="this.style.background='none'">
                                        <% if (ann.userReaction) { %>
                                            <span style="font-size:16px;"><%= ann.userReaction %></span>
                                            <span style="color:#1877F2;">Liked</span>
                                        <% } else { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14Z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                                            <span>Like</span>
                                        <% } %>
                                    </button>
                                    <div id="emoji-picker-<%= ann.id %>" style="display:none;position:absolute;bottom:44px;left:0;background:#fff;border-radius:30px;box-shadow:0 4px 16px rgba(0,0,0,0.2);padding:6px 10px;z-index:100;gap:4px;align-items:center;">
                                        <% ['👍','❤️','😂','😮','😢','😡','👏'].forEach(function(emoji){ %>
                                            <button onclick="sendReaction(<%= ann.id %>, '<%= emoji %>', this)" 
                                                style="font-size:22px;border:none;background:none;cursor:pointer;padding:2px 4px;border-radius:50%;transition:transform 0.1s;line-height:1;"
                                                onmouseover="this.style.transform='scale(1.3)';this.style.background='#F0F2F5'" 
                                                onmouseout="this.style.transform='scale(1)';this.style.background='none'"
                                                title="<%= emoji %>"><%= emoji %></button>
                                        <% }); %>
                                    </div>
                                </div>
                                <button onclick="focusCommentInput('<%= ann.id %>')"
                                    style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:8px;border:none;background:none;cursor:pointer;border-radius:6px;font-size:13px;font-weight:600;color:#65676B;"
                                    onmouseover="this.style.background='#F2F2F2'" onmouseout="this.style.background='none'">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                    <span>Comment</span>
                                </button>
                            </div>

                            <!-- Comments Section -->
                            <div id="comments-section-<%= ann.id %>" style="padding:8px 12px 10px;">
                                <div id="comments-list-<%= ann.id %>" style="max-height:280px;overflow-y:auto;padding-right:2px;"></div>
                                <div style="display:flex;gap:8px;align-items:flex-start;margin-top:8px;" id="comment-input-row-<%= ann.id %>">
                                    <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#5B0E14,#8B1A24);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden;">
                                        <% if (user.profile_picture && user.profile_picture !== '') { %>
                                            <img src="<%= user.profile_picture %>" style="width:100%;height:100%;object-fit:cover;">
                                        <% } else { %>
                                            <%= ((user.first_name||'')[0]||'') + ((user.last_name||'')[0]||'') %>
                                        <% } %>
                                    </div>
                                    <div style="flex:1;position:relative;">
                                        <div style="background:#F0F2F5;border-radius:20px;display:flex;align-items:center;padding:0 10px 0 14px;">
                                            <input type="text" id="cinput-<%= ann.id %>"
                                                placeholder="Write a comment…"
                                                style="flex:1;border:none;background:none;font-size:13px;padding:9px 0;outline:none;color:#050505;font-family:inherit;"
                                                onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();postComment(<%= ann.id %>)}"
                                                onfocus="document.getElementById('comment-send-<%= ann.id %>').style.opacity='1'"
                                                onblur="setTimeout(function(){document.getElementById('comment-send-<%= ann.id %>').style.opacity='0'},200)">
                                            <button id="comment-send-<%= ann.id %>" 
                                                onclick="postComment(<%= ann.id %>)"
                                                style="opacity:0;border:none;background:none;cursor:pointer;padding:4px;border-radius:50%;transition:opacity 0.15s,background 0.15s;"
                                                onmouseover="this.style.background='#E4E6EB'" onmouseout="this.style.background='none'">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#5B0E14" width="20" height="20"><path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z"/></svg>
                                            </button>
                                        </div>
                                        <div style="font-size:11px;color:#65676B;padding:2px 14px 0;">Press Enter to post</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="padding:48px 24px;text-align:center;color:#65676B;">
                        <div style="font-size:32px;margin-bottom:8px;">📢</div>
                        <p style="font-size:14px;font-weight:600;color:#4B5563;margin:0;">No announcements yet</p>
                    </div>
                <% } %>
            </div>
</div>


        <!-- ══ RULES & REGULATIONS ══ -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col"
            style="overflow:hidden;min-width:0;">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-amber-500 shrink-0"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Rules & Regulations</h2>
            </div>
            <div class="flex-1 overflow-y-auto"
                style="max-height:600px;padding:20px;box-sizing:border-box;min-width:0;width:100%;">
                <div class="text-center pb-4 mb-4" style="border-bottom:1px solid #F0F0F0;">
                    <div class="w-10 h-10 rounded-xl mx-auto mb-3 flex items-center justify-center"
                        style="background:linear-gradient(135deg,#5B0E14,#273F4F);">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="white" class="w-5 h-5">
                            <path fill-rule="evenodd"
                                d="M4.5 2A1.5 1.5 0 0 0 3 3.5v9A1.5 1.5 0 0 0 4.5 14h7a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4.5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0 2.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Z"
                                clip-rule="evenodd" />
                        </svg>
                    </div>
                    <p class="text-xs font-bold text-[#273F4F] uppercase tracking-wide">University of Cebu</p>
                    <p class="text-xs text-gray-400 mt-0.5">College of Information & Computer Studies</p>
                </div>
                <div class="sic-section-label mb-3"><span>Laboratory Rules</span></div>
                <% var
                    labRules=[ 'Maintain silence, proper decorum, and discipline inside the laboratory. Mobile phones and personal devices must be switched off.'
                    , 'Games are not allowed inside the lab. This includes computer-related games and card games that may disturb operations.'
                    , 'Surfing the Internet is allowed only with the permission of the instructor. Downloading and installing software are strictly prohibited.'
                    , 'Getting access to websites not related to the course is strictly prohibited.'
                    , 'Deleting computer files and changing the set-up of the computer is a major offense.'
                    , 'Observe computer time. All times consumed beyond the allowable number of hours are charged accordingly.'
                    , 'No food and drinks are allowed inside the laboratory.'
                    , 'Students are not allowed to go outside during laboratory hours without permission.' ]; %>
                    <ol style="list-style:none;padding:0;margin:0;width:100%;">
                        <% labRules.forEach(function(rule, idx) { %>
                            <li class="sic-rule-item">
                                <span class="sic-rule-num">
                                    <%= idx + 1 %>
                                </span>
                                <p class="sic-rule-text">
                                    <%= rule %>
                                </p>
                            </li>
                            <% }); %>
                    </ol>
            </div>
        </div>

    </div>
</div>

<script>
    // ── Reactions ──────────────────────────────────────────────────
    async function sendReaction(annId, emoji, btn) {
        try {
            const res = await fetch(`/announcements/${annId}/react`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ emoji })
            });
            const data = await res.json();
            if (data.success) refreshReactions(annId, emoji, data.action);
        } catch (e) { }
    }

    function refreshReactions(annId, emoji, action) {
        const container = document.getElementById('reactions-' + annId);
        if (!container) return;
        const existingBtn = container.querySelector(`[data-emoji="${emoji}"][data-ann="${annId}"]`);
        const addWrap = container.querySelector('.react-add-wrap');

        if (action === 'removed') {
            if (existingBtn) {
                const count = parseInt(existingBtn.querySelector('.react-count').textContent) - 1;
                if (count <= 0) existingBtn.remove();
                else { existingBtn.querySelector('.react-count').textContent = count; existingBtn.classList.remove('reacted'); }
            }
        } else if (action === 'added') {
            container.querySelectorAll('.react-btn.reacted').forEach(b => b.classList.remove('reacted'));
            if (existingBtn) {
                existingBtn.querySelector('.react-count').textContent = parseInt(existingBtn.querySelector('.react-count').textContent) + 1;
                existingBtn.classList.add('reacted');
            } else {
                const newBtn = document.createElement('button');
                newBtn.className = 'react-btn reacted';
                newBtn.dataset.ann = annId;
                newBtn.dataset.emoji = emoji;
                newBtn.onclick = function () { sendReaction(annId, emoji, this); };
                newBtn.innerHTML = `${emoji} <span class="react-count">1</span>`;
                container.insertBefore(newBtn, addWrap);
            }
        } else if (action === 'changed') {
            container.querySelectorAll('.react-btn').forEach(b => b.classList.remove('reacted'));
            if (existingBtn) {
                existingBtn.querySelector('.react-count').textContent = parseInt(existingBtn.querySelector('.react-count').textContent || '0') + 1;
                existingBtn.classList.add('reacted');
            }
        }
    }

    function toggleReactPicker(annId, e) {
        e.stopPropagation();
        const picker = document.getElementById('rp-' + annId);
        const wasOpen = picker.classList.contains('open');
        document.querySelectorAll('.react-picker.open').forEach(p => p.classList.remove('open'));
        if (!wasOpen) picker.classList.add('open');
    }
    function closeReactPicker(annId) { document.getElementById('rp-' + annId)?.classList.remove('open'); }
    document.addEventListener('click', () => document.querySelectorAll('.react-picker.open').forEach(p => p.classList.remove('open')));

    // ── Comments ──────────────────────────────────────────────────
    const commentsLoaded = {};

    // Load ALL comments when page loads - always visible
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Loading all comments on page load...');
        document.querySelectorAll('[id^="comments-list-"]').forEach(function(listEl) {
            const annId = listEl.id.replace('comments-list-', '');
            loadComments(annId).then(function() {
                commentsLoaded[annId] = true;
            }).catch(function(err) {
                console.error('Error loading comments:', err);
            });
        });
    });

    // No toggle needed - comments are always visible now

    async function loadComments(annId) {
        try {
            console.log('Fetching comments for annId:', annId);
            const res = await fetch(`/announcements/${annId}/comments`);
            const comments = await res.json();
            console.log('Got comments:', comments);
            renderComments(annId, comments);
        } catch (e) {
            console.error('Error fetching comments:', e);
        }
    }

    function renderComments(annId, comments) {
        const list = document.getElementById('comments-list-' + annId);
        if (!list) return;
        
        if (!comments || comments.length === 0) {
            list.innerHTML = '<div style="color:#65676B;font-size:12px;padding:16px;text-align:center;">No comments yet. Be the first to comment!</div>';
            return;
        }
        
        let html = '';
        comments.forEach(c => {
            const initials = ((c.first_name || '')[0] || '') + ((c.last_name || '')[0] || '');
            const commentText = c.comment || c.message || '';
            const timeAgo = getTimeAgo(c.created_at);
            const replyHtml = c.reply ? `<div style="margin-top:8px;padding:8px 12px;background:#ECFDF5;border-radius:0 10px 10px 10px;border-left:3px solid #059669;font-size:12px;color:#065F46;">↳ <strong>Admin:</strong> ${escHtml(c.reply)}</div>` : '';
            
            html += `<div style="display:flex;gap:8px;margin-bottom:12px;">
                <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#5B0E14,#8B1A24);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;">
                    ${initials.toUpperCase()}
                </div>
                <div style="flex:1;">
                    <div style="background:#F0F2F5;border-radius:18px;padding:8px 12px;display:inline-block;max-width:100%;">
                        <div style="font-size:12px;font-weight:600;color:#050505;margin-bottom:2px;">${c.first_name || 'User'} ${c.last_name || ''}</div>
                        <div style="font-size:13px;color:#050505;line-height:1.4;">${escHtml(commentText)}</div>
                    </div>
                    <div style="display:flex;gap:12px;padding:4px 8px;font-size:11px;font-weight:600;">
                        <span style="color:#65676B;cursor:pointer;" onclick="likeComment(${annId}, ${c.id})">Like</span>
                        <span style="color:#65676B;cursor:pointer;" onclick="showReplyInput(${annId}, ${c.id})">Reply</span>
                        <span style="color:#65676B;">${timeAgo}</span>
                    </div>
                    ${replyHtml}
                    <!-- Reply input -->
                    <div id="reply-input-${annId}-${c.id}" style="display:none;margin-top:8px;margin-left:40px;">
                        <input type="text" placeholder="Write a reply..."
                            style="width:calc(100% - 80px);padding:6px 10px;border:1px solid #CCD0D5;border-radius:14px;font-size:12px;background:#F0F2F5;outline:none;"
                            onkeydown="if(event.key==='Enter')postReply(${annId}, ${c.id})">
                        <button onclick="postReply(${annId}, ${c.id})" style="padding:6px 10px;background:#5B0E14;color:#fff;border:none;border-radius:14px;font-size:11px;font-weight:600;cursor:pointer;margin-left:4px;">Reply</button>
                    </div>
                </div>
            </div>`;
        });
        list.innerHTML = html;
    }

    function getTimeAgo(dateStr) {
        if (!dateStr) return '';
        const now = new Date();
        const date = new Date(dateStr);
        const seconds = Math.floor((now - date) / 1000);
        if (seconds < 60) return 'Just now';
        if (seconds < 3600) return Math.floor(seconds / 60) + 'm';
        if (seconds < 86400) return Math.floor(seconds / 3600) + 'h';
        if (seconds < 604800) return Math.floor(seconds / 86400) + 'd';
        return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function likeComment(annId, commentId) {
        // Toggle like - for now just alert
        console.log('Like comment:', commentId);
    }

    function showReplyInput(annId, commentId) {
        const replyInput = document.getElementById('reply-input-' + annId + '-' + commentId);
        if (replyInput) {
            replyInput.style.display = replyInput.style.display === 'none' ? 'block' : 'none';
        }
    }

    function focusReply(annId) {
        const input = document.getElementById('cinput-' + annId);
        if (input) input.focus();
    }

    function postReply(annId, commentId) {
        const replyInput = document.querySelector('#reply-input-' + annId + '-' + commentId + ' input');
        const message = replyInput.value.trim();
        if (!message) return;
        
        // For now, just close the input
        replyInput.value = '';
        document.getElementById('reply-input-' + annId + '-' + commentId).style.display = 'none';
        alert('Reply submitted! (Admin reply feature coming soon)');
    }

    async function postComment(annId) {
        const input = document.getElementById('cinput-' + annId);
        const message = input.value.trim();
        if (!message) {
            alert('Please enter a comment message.');
            return;
        }
        
        console.log('Posting comment for announcement:', annId, 'message:', message);
        
        try {
            const res = await fetch(`/announcements/${annId}/comment`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            
            console.log('Response status:', res.status);
            const data = await res.json();
            console.log('Response data:', data);
            
            if (data.error) {
                alert(data.error);
                return;
            }
            if (data.success && data.comment) {
                input.value = '';
                const c = data.comment;
                const list = document.getElementById('comments-list-' + annId);
                const initials = ((c.first_name || '')[0] || '') + ((c.last_name || '')[0] || '');
                const avatarHtml = c.profile_picture ? `<img src="${c.profile_picture}">` : initials.toUpperCase();
                const commentText = c.comment || c.message || '';
                const div = document.createElement('div');
                div.className = 'ann-comment-item';
                div.innerHTML = `<div class="ann-comment-avatar">${avatarHtml}</div><div class="ann-comment-bubble"><div class="ann-comment-name">${c.first_name} ${c.last_name}</div><div class="ann-comment-msg">${escHtml(commentText)}</div><div class="ann-comment-time">Just now</div></div>`;
                list.appendChild(div);
                const body = document.getElementById('comments-body-' + annId);
                body.scrollTop = body.scrollHeight;
                const toggle = document.getElementById('ctoggle-' + annId);
                if (toggle) {
                    const current = parseInt(toggle.textContent) || 0;
                    const newCount = current + 1;
                    toggle.textContent = `${newCount} comment${newCount !== 1 ? 's' : ''}`;
                }
            }
        } catch (e) {
            console.error('Comment error:', e);
            alert('Failed to post comment. Please try again.');
        }
    }

    function escHtml(str) {
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // Facebook-style functions
    (function(){
        // Load all comments on page load
        var annIds = [<% if (typeof announcements !== 'undefined' && announcements) { announcements.forEach(function(a,i){ %><%= a.id %><%= i < announcements.length-1 ? ',' : '' %><% }); } %>];
        annIds.forEach(function(id){ loadComments(id); });

        window.loadComments = async function(annId) {
            try {
                const res = await fetch('/announcements/' + annId + '/comments');
                const comments = await res.json();
                renderComments(annId, comments);
            } catch(e) { console.error('Error loading comments', e); }
        };

        window.renderComments = function(annId, comments) {
            const list = document.getElementById('comments-list-' + annId);
            if (!list) return;
            if (!comments || comments.length === 0) {
                list.innerHTML = '';
                return;
            }
            const userAvatar = '<% if (user.profile_picture && user.profile_picture !== "") { %><img src="<%= user.profile_picture %>"><% } else { %><%= ((user.first_name||"")[0]||"") + ((user.last_name||"")[0]||"") %><% } %>';
            
            list.innerHTML = comments.map(function(c) {
                const initials = ((c.first_name||'')[0]||'') + ((c.last_name||'')[0]||'');
                const avatarContent = c.profile_picture ? '<img src="' + c.profile_picture + '">' : initials.toUpperCase();
                const commentText = c.message || c.comment || '';
                const timeAgo = getTimeAgo(c.created_at);
                const replyHtml = c.reply
                    ? '<div style="margin-top:6px;margin-left:8px;padding:7px 12px;background:linear-gradient(135deg,#ECFDF5,#D1FAE5);border-radius:0 12px 12px 12px;border-left:3px solid #059669;"><div style="font-size:10px;font-weight:700;color:#059669;">↳ Admin replied</div><div style="font-size:12px;color:#065F46;margin-top:3px;">' + esc(c.reply) + '</div></div>'
                    : '';
                
                return '<div style="display:flex;gap:8px;margin-bottom:6px;align-items:flex-start;">' +
                    '<div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#5B0E14,#8B1A24);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden;">' + avatarContent + '</div>' +
                    '<div style="flex:1;min-width:0;">' +
                        '<div style="background:#F0F2F5;border-radius:0 18px 18px 18px;padding:8px 12px;display:inline-block;max-width:100%;">' +
                            '<div style="font-size:12px;font-weight:700;color:#050505;margin-bottom:2px;">' + esc(c.first_name) + ' ' + esc(c.last_name) + '</div>' +
                            '<div style="font-size:13px;color:#050505;line-height:1.4;word-break:break-word;">' + esc(commentText) + '</div>' +
                        '</div>' +
                        '<div style="display:flex;gap:12px;padding:3px 6px 0;font-size:11px;font-weight:700;">' +
                            '<button style="background:none;border:none;cursor:pointer;font-size:11px;font-weight:700;color:#65676B;padding:0;font-family:inherit;" onclick="this.style.color=this.style.color===\'#1877F2\'?\'#65676B\':\'#1877F2\'">Like</button>' +
                            '<button style="background:none;border:none;cursor:pointer;font-size:11px;font-weight:700;color:#65676B;padding:0;font-family:inherit;" onclick="toggleReplyInput(' + c.id + ', \'' + annId + '\')">Reply</button>' +
                            '<span style="color:#A8AAAD;font-weight:400;">' + timeAgo + '</span>' +
                        '</div>' +
                        replyHtml +
                        '<div id="reply-wrap-' + c.id + '" style="display:none;margin-top:6px;margin-left:40px;align-items:flex-start;gap:7px;">' +
                            '<div style="width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#5B0E14,#8B1A24);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden;">' + userAvatar + '</div>' +
                            '<input id="reply-input-' + c.id + '" placeholder="Write a reply…" style="flex:1;border:none;background:#F0F2F5;border-radius:15px;padding:7px 12px;font-size:12px;outline:none;font-family:inherit;color:#050505;" onkeydown="if(event.key===\'Enter\'&&!event.shiftKey){event.preventDefault();postReply(' + c.id + ',\'' + annId + '\')}">' +
                            '<button onclick="postReply(' + c.id + ',\'' + annId + '\')" style="border:none;background:none;cursor:pointer;padding:4px;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#5B0E14" width="18" height="18"><path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z"/></svg></button>' +
                        '</div>' +
                    '</div>' +
                '</div>';
            }).join('');
        };

        window.toggleReplyInput = function(commentId, annId) {
            const wrap = document.getElementById('reply-wrap-' + commentId);
            if (!wrap) return;
            const isActive = wrap.style.display === 'flex';
            document.querySelectorAll('[id^="reply-wrap-"]').forEach(function(w) { w.style.display = 'none'; });
            if (!isActive) {
                wrap.style.display = 'flex';
                const inp = document.getElementById('reply-input-' + commentId);
                if (inp) inp.focus();
            }
        };

        window.postReply = async function(commentId, annId) {
            const input = document.getElementById('reply-input-' + commentId);
            const msg = input.value.trim();
            if (!msg) return;
            input.value = '';
            document.getElementById('reply-wrap-' + commentId).style.display = 'none';
            try {
                const res = await fetch('/announcements/' + annId + '/comment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg })
                });
                const data = await res.json();
                if (data.success) { loadComments(annId); }
            } catch(e) {}
        };

        var _holdTimer = null;
        window.startLikeHold = function(annId) {
            _holdTimer = setTimeout(function() {
                showEmojiPicker(annId);
                _holdTimer = null;
            }, 500);
        };
        window.cancelLikeHold = function() {
            if (_holdTimer) { clearTimeout(_holdTimer); _holdTimer = null; }
        };
        window.quickLike = async function(annId, btn) {
            if (_holdTimer === null && document.getElementById('emoji-picker-' + annId).style.display === 'flex') return;
            await sendReaction(annId, '👍', btn);
        };

        window.showEmojiPicker = function(annId) {
            document.querySelectorAll('[id^="emoji-picker-"]').forEach(function(p) { p.style.display = 'none'; });
            const picker = document.getElementById('emoji-picker-' + annId);
            if (picker) { picker.style.display = 'flex'; }
        };
        document.addEventListener('click', function(e) {
            if (!e.target.closest('[id^="emoji-picker-"]') && !e.target.closest('[id^="like-btn-"]')) {
                document.querySelectorAll('[id^="emoji-picker-"]').forEach(function(p) { p.style.display = 'none'; });
            }
        });

        window.sendReaction = async function(annId, emoji, btn) {
            document.querySelectorAll('[id^="emoji-picker-"]').forEach(function(p) { p.style.display = 'none'; });
            try {
                const res = await fetch('/announcements/' + annId + '/react', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ emoji: emoji })
                });
                const data = await res.json();
                if (data.success) {
                    const likeBtn = document.getElementById('like-btn-' + annId);
                    if (likeBtn) {
                        if (data.action === 'removed') {
                            likeBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14Z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg><span>Like</span>';
                            likeBtn.style.color = '#65676B';
                        } else {
                            likeBtn.innerHTML = '<span style="font-size:16px;">' + emoji + '</span><span style="color:#1877F2;">Liked</span>';
                            likeBtn.style.color = '#1877F2';
                        }
                    }
                }
            } catch(e) {}
        };

        window.focusCommentInput = function(annId) {
            const input = document.getElementById('cinput-' + annId);
            if (input) { input.focus(); input.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
            const btn = document.getElementById('comment-send-' + annId);
            if (btn) btn.style.opacity = '1';
        };

        window.scrollToComments = function(annId) {
            const section = document.getElementById('comments-section-' + annId);
            if (section) section.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        };

        window.esc = function(str) {
            if (!str) return '';
            return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        };
        window.getTimeAgo = function(dateStr) {
            if (!dateStr) return '';
            var secs = Math.floor((Date.now() - new Date(dateStr)) / 1000);
            if (secs < 60) return 'Just now';
            if (secs < 3600) return Math.floor(secs/60) + 'm';
            if (secs < 86400) return Math.floor(secs/3600) + 'h';
            if (secs < 604800) return Math.floor(secs/86400) + 'd';
            return new Date(dateStr).toLocaleDateString('en-US',{month:'short',day:'numeric'});
        };
    })();
</script>