<div class="p-6 space-y-6">

    <!-- 3-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <div>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-[#5B0E14]"></div>
                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Student Information</h2>
                </div>
                <div class="p-5 space-y-4">

                    <!-- Avatar / Profile Picture - Circular with Border -->
                    <div class="flex justify-center mb-2">
                        <div class="relative w-20 h-20 rounded-full overflow-hidden border-4 shadow-lg flex-shrink-0"
                            style="border-color: #5B0E14;">
                            <% if (user.profile_picture && user.profile_picture !=='' ) { %>
                                <img src="<%= user.profile_picture %>" alt="Profile Picture"
                                    class="w-full h-full object-cover">
                                <% } else { %>
                                    <div class="w-full h-full flex items-center justify-center"
                                        style="background: linear-gradient(135deg, #5B0E14, #273F4F);">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                            class="size-10 text-white">
                                            <path fill-rule="evenodd"
                                                d="M18.685 19.097A9.723 9.723 0 0 0 21.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12a9.723 9.723 0 0 0 3.065 7.097A9.716 9.716 0 0 0 12 21.75a9.716 9.716 0 0 0 6.685-2.653Zm-12.54-1.348A7.698 7.698 0 0 1 12 15a7.693 7.693 0 0 1 5.855 2.749A8.217 8.217 0 0 1 12 20.25a8.216 8.216 0 0 1-5.855-2.401ZM9 9a3 3 0 1 1 6 0 3 3 0 0 1-6 0Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                    </div>
                                    <% } %>
                        </div>
                    </div>

                    <!-- Personal Information Section - Clean Layout -->
                    <div class="space-y-3 border-t pt-4">

                        <!-- Full Name -->
                        <div>
                            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Full Name</p>
                            <p class="font-semibold text-gray-700 text-sm mt-1">
                                <%= user.last_name %>, <%= user.first_name %>
                                        <%= user.middle_initial ? user.middle_initial + '.' : '' %>
                            </p>
                        </div>

                        <!-- Course & Year -->
                        <div>
                            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Course & Year</p>
                            <p class="font-semibold text-gray-700 text-sm mt-1">
                                <%= user.course %> — Year <%= user.year_level %>
                            </p>
                        </div>

                        <!-- ID Number -->
                        <div>
                            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">ID Number</p>
                            <p class="font-semibold text-gray-700 text-sm mt-1">
                                <%= user.id_number %>
                            </p>
                        </div>

                        <!-- Email -->
                        <div>
                            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Email</p>
                            <p class="font-semibold text-gray-700 text-sm mt-1 break-all">
                                <%= user.email %>
                            </p>
                        </div>

                        <!-- Address (only shown if set) -->
                        <% if (user.address && user.address !=='' ) { %>
                            <div>
                                <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Address</p>
                                <p class="font-semibold text-gray-700 text-sm mt-1">
                                    <%= user.address %>
                                </p>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>
            <!-- Session Badge -->
            <div class="mt-3 pt-3 border-t rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="flex items-center justify-between rounded-xl px-4 py-3"
                    style="background: linear-gradient(135deg, #FFF8DC, #FFF3C4);">
                    <div>
                        <p class="text-xs font-bold text-[#5B0E14] uppercase tracking-widest">Remaining
                            Sessions</p>
                        <p class="text-gray-500 text-xs mt-0.5">Lab sit-in allowance</p>
                    </div>
                    <span class="text-3xl font-extrabold text-[#5B0E14]">
                        <%= user.remaining_sessions ?? 30 %>
                    </span>
                </div>
            </div>
        </div>
        <!-- Student Information Card -->

        <!-- Announcements -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F]"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Announcements</h2>
            </div>
            <div class="flex-1 overflow-y-auto p-5 space-y-4 max-h-96">
                <% if (typeof announcements !=='undefined' && announcements && announcements.length> 0) { %>
                    <% announcements.forEach(function(ann) { %>
                        <div class="border-l-4 border-[#5B0E14] pl-4 py-1">
                            <p class="text-xs text-gray-400 mb-1 font-medium">
                                CCS Admin | <%= new Date(ann.created_at).toLocaleDateString('en-US', {year:'numeric',
                                    month:'short', day:'numeric'}) %>
                            </p>
                            <p class="text-sm text-gray-700 leading-relaxed">
                                <%= ann.message %>
                            </p>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="text-center py-8">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                        class="size-10 text-gray-200 mx-auto mb-3">
                                        <path fill-rule="evenodd"
                                            d="M12 2.25A6.75 6.75 0 0 0 5.25 9v.75a8.217 8.217 0 0 1-2.119 5.52.75.75 0 0 0 .298 1.206c1.544.57 3.16.99 4.831 1.243a3.75 3.75 0 1 0 7.48 0 24.583 24.583 0 0 0 4.83-1.244.75.75 0 0 0 .298-1.205 8.217 8.217 0 0 1-2.118-5.52V9A6.75 6.75 0 0 0 12 2.25ZM9.75 18c0-.034 0-.067.002-.1a25.05 25.05 0 0 0 4.496 0l.002.1a2.25 2.25 0 1 1-4.5 0Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                    <p class="text-sm text-gray-400">No announcements yet</p>
                                </div>
                                <% } %>
            </div>
        </div>

        <!-- Rules & Regulations -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-amber-500"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-widest">Rules & Regulations</h2>
            </div>
            <div class="flex-1 overflow-y-auto p-5 max-h-96">
                <p class="text-xs font-bold text-center text-[#273F4F] uppercase tracking-widest mb-1">University of
                    Cebu</p>
                <p class="text-xs text-center text-gray-500 mb-4">College of Information & Computer Studies</p>
                <p class="text-xs font-bold text-[#5B0E14] uppercase mb-3">Laboratory Rules and Regulations</p>
                <ol class="space-y-3 text-xs text-gray-600 leading-relaxed list-decimal ml-4">
                    <li>Maintain silence, proper decorum, and discipline inside the laboratory. Mobile phones, walkmans
                        and other personal pieces of equipment must be switched off.</li>
                    <li>Games are not allowed inside the lab. This includes computer-related games, card games and other
                        games that may disturb the operation of the lab.</li>
                    <li>Surfing the Internet is allowed only with the permission of the instructor. Downloading and
                        installing of software are strictly prohibited.</li>
                    <li>Getting access to other websites not related to the course is strictly prohibited.</li>
                    <li>Deleting computer files and changing the set-up of the computer is a major offense.</li>
                    <li>Observe computer time. All times consumed beyond the allowable number of hours are charged
                        accordingly.</li>
                    <li>No food and drinks are allowed inside the laboratory.</li>
                    <li>Students are not allowed to go outside during laboratory hours without permission.</li>
                </ol>
            </div>
        </div>

    </div>
</div>