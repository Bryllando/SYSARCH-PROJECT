<style>
    /* ── Avatar ── */
    .sic-avatar-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        padding: 3px;
        background: linear-gradient(135deg, #5B0E14, #C9953A);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    @media (min-width: 768px) {
        .sic-avatar-wrap {
            width: 100px;
            height: 100px;
        }
    }

    .sic-avatar-inner {
        width: 74px;
        height: 74px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #fff;
        background: linear-gradient(135deg, #5B0E14, #273F4F);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @media (min-width: 768px) {
        .sic-avatar-inner {
            width: 94px;
            height: 94px;
        }
    }

    .sic-avatar-inner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .sic-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #E5E7EB 20%, #E5E7EB 80%, transparent);
        margin: 10px 0;
        border: none;
    }

    .sic-section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 0 6px;
    }

    .sic-section-label span {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9CA3AF;
    }

    .sic-section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #F0F0F0;
    }

    .sic-sessions {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        background: linear-gradient(135deg, #3A0910, #5B0E14, #7A1520);
        box-shadow: 0 6px 24px rgba(91, 14, 20, 0.35);
    }

    .sic-sessions::before {
        content: '';
        position: absolute;
        top: -30px;
        right: -30px;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.07);
        pointer-events: none;
    }

    .sic-sessions-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
    }

    @media (min-width: 768px) {
        .sic-sessions-inner {
            padding: 20px 24px;
        }
    }

    .sic-sessions-label p:first-child {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
    }

    @media (min-width: 768px) {
        .sic-sessions-label p:first-child {
            font-size: 11px;
        }
    }

    .sic-sessions-label p:last-child {
        font-size: 10px;
        color: rgba(255, 255, 255, 0.4);
        margin: 3px 0 0;
    }

    @media (min-width: 768px) {
        .sic-sessions-label p:last-child {
            font-size: 11px;
        }
    }

    .sic-sessions-count {
        font-size: 36px;
        font-weight: 900;
        color: #fff;
        line-height: 1;
        letter-spacing: -0.02em;
    }

    @media (min-width: 768px) {
        .sic-sessions-count {
            font-size: 52px;
        }
    }

    .sic-rule-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid #F5F5F5;
    }

    .sic-rule-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .sic-rule-num {
        width: 22px;
        height: 22px;
        min-width: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .sic-rule-text {
        font-size: 12px;
        color: #4B5563;
        line-height: 1.65;
        flex: 1;
        word-break: break-word;
        margin: 0;
    }

    /* ── Announcement card ── */
    .ann-feed-card {
        background: #fff;
        border: 1px solid #EDEDED;
        border-radius: 14px;
        margin-bottom: 12px;
        overflow: hidden;
        transition: box-shadow 0.15s;
        max-width: 100%;
    }

    .ann-feed-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
    }

    .ann-feed-head {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px 8px;
    }

    .ann-feed-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #5B0E14, #3A0910);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #F1E194;
        flex-shrink: 0;
    }

    .ann-feed-from {
        font-size: 12px;
        font-weight: 700;
        color: #1C2B35;
    }

    .ann-feed-time {
        font-size: 10px;
        color: #9CA3AF;
    }

    .ann-feed-body {
        padding: 0 14px 10px;
        font-size: 12px;
        color: #374151;
        line-height: 1.65;
        text-align: left;
        white-space: pre-wrap;
        word-wrap: break-word;
        overflow-wrap: break-word;
        max-width: 100%;
    }

    @media (min-width: 768px) {
        .ann-feed-body {
            font-size: 13px;
        }
    }

    .ann-feed-media {
        margin: 0 14px 10px;
        border-radius: 10px;
        overflow: hidden;
        max-width: 100%;
    }

    .ann-feed-media img {
        width: 100%;
        max-width: 100%;
        height: auto;
        max-height: 280px;
        object-fit: contain;
        display: block;
        border-radius: 10px;
    }

    .ann-feed-media video {
        width: 100%;
        max-width: 100%;
        height: auto;
        max-height: 280px;
        border-radius: 10px;
    }

    .ann-feed-media video {
        width: 100%;
        max-height: 280px;
        border-radius: 10px;
    }

    .ann-feed-scroll {
        height: auto;
        max-height: 78vh;
        min-height: 300px;
        overflow-y: auto;
        padding: 10px 0;
        background: #F0F2F5;
    }

    .ann-feed-media-frame {
        border-top: 1px solid #E4E6EB;
        border-bottom: 1px solid #E4E6EB;
        background: #F8FAFC;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        min-height: 140px;
    }

    .ann-feed-media-frame img,
    .ann-feed-media-frame video {
        width: auto;
        max-width: 100%;
        max-height: min(48vh, 360px);
        object-fit: contain;
        display: block;
        margin: 0 auto;
        background: #F8FAFC;
    }

    .ann-feed-meta {
        font-size: 11px;
        color: #65676B;
        line-height: 1.35;
    }

    /* Responsive announcement container */
    .ann-feed-container {
        height: auto !important;
        min-height: 200px !important;
        max-height: 70vh !important;
        overflow-y: auto !important;
    }
    @media (min-width: 768px) {
        .ann-feed-container {
            max-height: 600px !important;
            min-height: 300px !important;
        }
    }

    .ai-rec-wrap {
        background: #F0EDE8;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(28,43,53,0.08);
        border: 1px solid #E8E3DD;
    }

    .ai-rec-head {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        color: #fff;
        padding: 11px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .ai-rec-title {
        font-size: 12px;
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #fff;
    }

    .ai-rec-refresh {
        font-size: 11px;
        font-weight: 700;
        background: #F1E194;
        color: #1C2B35;
        border: none;
        border-radius: 999px;
        padding: 6px 11px;
        cursor: pointer;
    }

    .ai-tip-btn {
        font-size: 11px;
        font-weight: 700;
        background: #5B0E14;
        color: #F1E194;
        border: none;
        border-radius: 999px;
        padding: 6px 10px;
        cursor: pointer;
    }

    .user-tip-panel {
        position: fixed;
        top: 76px;
        right: 18px;
        width: 320px;
        max-width: calc(100vw - 24px);
        background: #fff;
        border: 1px solid #E8E3DD;
        border-radius: 14px;
        box-shadow: 0 8px 32px rgba(28,43,53,0.15);
        z-index: 130;
        display: none;
        overflow: hidden;
    }

    .user-tip-panel.open { display: block; animation: tipIn .2s ease-out both; }
    @keyframes tipIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    .user-tip-head {
        background: linear-gradient(135deg, #1C2B35, #273F4F);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 9px 10px;
    }
    .user-tip-head strong { font-size: 12px; color: #F1E194; }
    .user-tip-close {
        width: 24px; height: 24px; border-radius: 6px;
        border: 1px solid rgba(255,255,255,.2); background: rgba(255,255,255,.12); color: #fff; cursor: pointer;
    }
    .user-tip-body { padding: 10px; font-size: 12px; color: #374151; }
    .user-tip-row { padding: 7px 0; border-bottom: 1px solid #F1EEEA; }
    .user-tip-row:last-child { border-bottom: none; }
    .user-tip-row b { color: #1C2B35; }

    .ai-rec-body {
        padding: 12px;
        background: #F0EDE8;
    }

    .ai-rec-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .ai-rec-item {
        background: #FFFFFF;
        border: 1px solid #E8E3DD;
        border-radius: 12px;
        padding: 14px 16px;
        transition: background .15s ease, border-color .15s ease;
    }

    .ai-rec-item:hover {
        background: #FAF9F7;
        border-color: #D8D1C9;
    }

    .ai-rec-item.full {
        grid-column: 1 / -1;
    }

    .ai-rec-kicker {
        display: flex;
        align-items: center;
        gap: 7px;
        margin: 0 0 6px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .ai-rec-kicker .dot {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
    }

    .ai-rec-value {
        margin: 0;
        font-size: 13px;
        color: #374151;
        font-weight: 400;
        line-height: 1.6;
    }

    .ai-c-maroon { color: #5B0E14; }
    .ai-c-maroon .dot { background: rgba(91,14,20,.10); }
    .ai-c-green { color: #059669; }
    .ai-c-green .dot { background: rgba(5,150,105,.10); }
    .ai-c-amber { color: #D97706; }
    .ai-c-amber .dot { background: rgba(217,119,6,.10); }
    .ai-c-blue { color: #2563EB; }
    .ai-c-blue .dot { background: rgba(37,99,235,.10); }
    .ai-c-gray { color: #6B7280; }
    .ai-c-gray .dot { background: rgba(107,114,128,.10); }

    .ai-alert {
        grid-column: 1 / -1;
        background: #FEF2F2;
        border: 1px solid #FECACA;
        color: #991B1B;
        border-radius: 12px;
        padding: 11px 12px;
        font-size: 13px;
        font-weight: 600;
    }

    .ai-rec-empty {
        text-align: center;
        color: #9CA3AF;
        font-size: 12px;
        padding: 20px 8px;
        background: #fff;
        border: 1px dashed #E8E3DD;
        border-radius: 12px;
        grid-column: 1 / -1;
    }

    .ai-skel {
        height: 88px;
        border-radius: 12px;
        background: linear-gradient(90deg, #f7f5f2 25%, #eee8df 37%, #f7f5f2 63%);
        background-size: 400% 100%;
        animation: aiShimmer 1.2s infinite;
        border: 1px solid #E8E3DD;
    }

    .ai-skel.full { grid-column: 1 / -1; }

    @keyframes aiShimmer {
        0% { background-position: 100% 0; }
        100% { background-position: -100% 0; }
    }

    @media (max-width: 768px) {
        .ai-rec-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="p-4 md:p-6 space-y-4 md:space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5" style="min-width:0;">

        <!-- ══ LEFT COLUMN ══ -->
        <div class="flex flex-col gap-4">

            <!-- Student Information Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-[#5B0E14] shrink-0"></div>
                    <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Student Information</h2>
                </div>
                <div class="p-5">
                    <div class="flex flex-col items-center gap-3 pb-4 mb-1">
                        <div class="sic-avatar-wrap">
                            <div class="sic-avatar-inner">
                                <% if (user.profile_picture && user.profile_picture !=='' ) { %>
                                    <img src="<%= user.profile_picture %>" alt="Profile Picture">
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"
                                            style="width:48px;height:48px;">
                                            <path fill-rule="evenodd"
                                                d="M18.685 19.097A9.723 9.723 0 0 0 21.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12a9.723 9.723 0 0 0 3.065 7.097A9.716 9.716 0 0 0 12 21.75a9.716 9.716 0 0 0 6.685-2.653Zm-12.54-1.348A7.698 7.698 0 0 1 12 15a7.693 7.693 0 0 1 5.855 2.749A8.217 8.217 0 0 1 12 20.25a8.216 8.216 0 0 1-5.855-2.401ZM9 9a3 3 0 1 1 6 0 3 3 0 0 1-6 0Z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        <% } %>
                            </div>
                        </div>
                        <div class="text-center">
                            <p class="font-bold text-[#1A2733] text-base leading-snug">
                                <%= user.last_name %>, <%= user.first_name %>
                                        <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                            </p>
                            <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-semibold text-[#5B0E14]"
                                style="background:rgba(91,14,20,0.08);">
                                <%= user.course %> — Year <%= user.year_level %>
                            </span>
                        </div>
                    </div>
                    <hr class="sic-divider mb-4">
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Full Name</p>
                                <p class="text-sm font-semibold text-gray-700">
                                    <%= user.last_name %>, <%= user.first_name %>
                                            <%= user.middle_initial ? ' ' + user.middle_initial + '.' : '' %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path fill-rule="evenodd"
                                        d="M4.5 2A1.5 1.5 0 0 0 3 3.5v9A1.5 1.5 0 0 0 4.5 14h7a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4.5Zm1 5.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Zm0 2.5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5Z"
                                        clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    ID Number</p>
                                <p class="text-sm font-semibold text-gray-700 font-mono tracking-wide">
                                    <%= user.id_number %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                style="background:rgba(39,63,79,0.08);">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                    class="w-4 h-4">
                                    <path
                                        d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" />
                                    <path
                                        d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                    Email</p>
                                <p class="text-sm font-semibold text-gray-700 break-all">
                                    <%= user.email %>
                                </p>
                            </div>
                        </div>
                        <% if (user.address && user.address !=='' ) { %>
                            <div class="flex items-start gap-3">
                                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0"
                                    style="background:rgba(39,63,79,0.08);">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#273F4F"
                                        class="w-4 h-4">
                                        <path fill-rule="evenodd"
                                            d="M8 1.5a4.5 4.5 0 0 0-4.5 4.5c0 2.098 1.21 4.273 2.497 5.998a28.89 28.89 0 0 0 1.944 2.201.75.75 0 0 0 1.118 0 28.89 28.89 0 0 0 1.944-2.2C12.29 10.272 13.5 8.097 13.5 6A4.5 4.5 0 0 0 8 1.5Zm0 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0 mb-4">
                                    <p
                                        class="text-xs text-gray-400 font-semibold uppercase tracking-wide leading-none mb-1">
                                        Address</p>
                                    <p class="text-sm font-semibold text-gray-700">
                                        <%= user.address %>
                                    </p>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>

            <!-- Sessions Badge -->
            <div class="sic-sessions">
                <div class="sic-sessions-inner">
                    <div class="sic-sessions-label">
                        <p>Remaining Sessions</p>
                        <p>Lab sit-in allowance</p>
                    </div>
                    <div class="sic-sessions-count">
                        <%= user.remaining_sessions ?? 30 %>
                    </div>
                </div>
            </div>

            <div class="ai-rec-wrap">
                <div class="ai-rec-head">
                    <div class="ai-rec-title">✨ AI Recommendation</div>
                    <div style="display:flex;align-items:center;gap:6px;">
                        <span id="ai-rec-updated" style="font-size:10px;color:rgba(255,255,255,.75);font-weight:700;">Live Summary</span>
                        <button type="button" id="ai-tip-btn" class="ai-tip-btn">AI Study Tip</button>
                        <button type="button" id="ai-refresh-btn" class="ai-rec-refresh">Refresh</button>
                    </div>
                </div>
                <div class="ai-rec-body">
                    <div id="ai-rec-content" class="ai-rec-grid">
                        <div class="ai-skel"></div>
                        <div class="ai-skel"></div>
                        <div class="ai-skel"></div>
                        <div class="ai-skel"></div>
                        <div class="ai-skel full"></div>
                    </div>
                </div>
            </div>
        </div>


<!-- ══ ANNOUNCEMENTS FEED (Facebook-style) ══ -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col col-span-1 md:col-span-1">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-[#273F4F] shrink-0"></div>
                <h2 class="font-bold text-[#273F4F] text-sm uppercase tracking-wide">Announcements</h2>
                <span style="margin-left:auto;font-size:10px;color:#9CA3AF;">Admin announcements only</span>
            </div>

            <div id="ann-feed-scroll" class="flex-1 ann-feed-scroll">
                <% if (typeof announcements !== 'undefined' && announcements && announcements.length > 0) { %>
                    <% announcements.forEach(function(ann) { %>
                        <!-- ── Announcement Card ── -->
                        <article class="ann-feed-card" style="margin:0 8px 12px;border-radius:16px;overflow:hidden;border:1px solid #EDEDED;">
                            <% if (ann.is_pinned) { %>
                                <div style="background:linear-gradient(135deg,#273F4F,#1C2B35);color:#F1E194;padding:8px 14px;font-size:10px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;">
                                    📌 Pinned announcement
                                </div>
                            <% } %>

                            <header class="ann-feed-head" style="padding:14px 14px 10px;">
                                <!-- Fixed: avatar was red/maroon, changed to neutral teal per fixing bugs.md design rule -->
                                <div class="ann-feed-avatar" style="width:40px;height:40px;font-size:13px;background:linear-gradient(135deg,#273F4F,#1C2B35);">
                                    <%= ann.first_name ? ann.first_name[0].toUpperCase() : 'A' %>
                                </div>
                                <div style="flex:1;min-width:0;">
                                    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                        <span class="ann-feed-from" style="font-size:13px;color:#1C2B35;">
                                            <%= ann.first_name ? (ann.first_name + ' ' + (ann.last_name || '')) : 'CCS Admin' %>
                                        </span>
                                        <span style="display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:999px;font-size:9px;font-weight:700;background:rgba(39,63,79,0.08);color:#273F4F;letter-spacing:0.04em;text-transform:uppercase;">
                                            👤 Admin
                                        </span>
                                    </div>
                                    <div class="ann-feed-meta" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:2px;">
                                        <span>
                                            <%= new Date(ann.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                                        </span>
                                        <span style="font-size:10px;">🌐 Public</span>
                                    </div>
                                </div>
                            </header>

                            <div class="ann-feed-body" style="padding:0 14px 12px;font-size:14px;color:#374151;line-height:1.7;"><%= String(ann.message || '').trimStart() %></div>

                            <% if (ann.media_url && ann.media_url !== '') { %>
                                <div style="padding:0 14px 14px;">
                                    <div style="border-radius:12px;overflow:hidden;border:1px solid #EDEDED;background:#F8FAFC;">
                                        <% if (ann.media_type === 'video') { %>
                                            <video controls style="width:100%;max-height:400px;display:block;"><source src="<%= ann.media_url %>"></video>
                                        <% } else { %>
                                            <img src="<%= ann.media_url %>" alt="Announcement media" loading="lazy" style="width:100%;max-height:400px;object-fit:cover;display:block;">
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        </article>
                    <% }); %>
                <% } else { %>
                    <div style="padding:48px 24px;text-align:center;color:#65676B;">
                        <div style="font-size:32px;margin-bottom:8px;">📢</div>
                        <p style="font-size:14px;font-weight:600;color:#4B5563;margin:0;">No announcements yet</p>
                    </div>
                <% } %>
            </div>
</div>

