        <button id="user-tip-close" class="user-tip-close">×</button>
    </div>
    <div class="user-tip-body" id="user-tip-body">
        Loading your personal study tip...
    </div>
</aside>


        <!-- ══ RULES & REGULATIONS ══ -->
