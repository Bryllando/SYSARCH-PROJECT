<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <style>
            /* Ensure no background image bleeds into the dashboard from cached/guest styles */
            html,
            body {
                background: #f3f4f6 !important;
                background-image: none !important;
            }
        </style>
</head>

<body style="background:#f3f4f6; background-image:none;" class="min-h-screen flex flex-col">

    <%- include('../partials/navbar-dashboard') %>

        <div class="flex flex-1 overflow-hidden">
            <%- include('../partials/sidebar') %>
                <main class="flex-1 overflow-y-auto bg-gray-100">
                    <%- body %>
                </main>
        </div>

        <footer class="bg-[#3A0910] text-white/50 text-center py-3 text-xs shrink-0">
            &copy; <%= new Date().getFullYear() %> University of Cebu — College of Computer Studies. All rights
                reserved.
        </footer>

</body>

</html>