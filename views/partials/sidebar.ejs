    }

    #sidebar.collapsed .sidebar-text {
        opacity: 0;
        width: 0;
        overflow: hidden;
        white-space: nowrap;
        pointer-events: none;
    }

    #sidebar.collapsed .sidebar-link {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
    }

    #sidebar.collapsed #sidebarNav {
        padding-left: 0.5rem;
        padding-right: 0.5rem;
    }

    #sidebar.collapsed #sidebarLogout {
        padding-left: 0.5rem;
        padding-right: 0.5rem;
    }

    #sidebar.collapsed #sidebarLogout a {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
    }

    .sidebar-link.active {
        background: rgba(241, 225, 148, 0.15);
        color: #F1E194;
