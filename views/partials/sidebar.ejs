<script>
    (function () {
        const sidebar = document.getElementById('sidebar');
        const iconCollapse = document.getElementById('iconCollapse');
        const iconExpand = document.getElementById('iconExpand');

        function applyState(collapsed) {
            if (collapsed) {
                sidebar.classList.add('collapsed');
                iconCollapse.style.display = 'none';
                iconExpand.style.display = 'block';
            } else {
                sidebar.classList.remove('collapsed');
                iconCollapse.style.display = 'block';
                iconExpand.style.display = 'none';
            }
        }

        // Restore saved state (default: expanded)
        applyState(localStorage.getItem('sidebarCollapsed') === 'true');

        document.getElementById('sidebarToggle').addEventListener('click', () => {
            const willCollapse = !sidebar.classList.contains('collapsed');
            applyState(willCollapse);
            localStorage.setItem('sidebarCollapsed', String(willCollapse));
        });

        // Highlight active link
        const currentPath = window.location.pathname;
        document.querySelectorAll('.sidebar-link').forEach(link => {
            const href = link.getAttribute('href');
            if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href) && href.length > 1))) {
                link.classList.add('active');
            }
        });
    })();
</script>