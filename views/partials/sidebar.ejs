<style>
    #sidebar {
        width: 220px;
        min-height: 100%;
        background: #273F4F;
        color: white;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
    }

    #sidebar.collapsed {
        width: 56px;
    }

    #sidebar.collapsed .sidebar-text {
        opacity: 0;
        width: 0;
        overflow: hidden;
        pointer-events: none;
    }

    #sidebar.collapsed .sidebar-link {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
    }

    #sidebar.collapsed #sidebarNav {
        padding-left: 0.5rem;
        padding-right: 0.5rem;
    }

    #sidebar.collapsed #sidebarLogout {
        padding-left: 0.5rem;
        padding-right: 0.5rem;
    }

    #sidebar.collapsed #sidebarLogout a {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
    }

    .sidebar-text {
        transition: opacity 0.2s ease, width 0.2s ease;
        white-space: nowrap;
        overflow: hidden;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.75);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        font-family: inherit;
    }

    .sidebar-link:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
    }

    .sidebar-link.active {
        background: rgba(241, 225, 148, 0.15);
        color: #F1E194;
    }

    #sidebarHeader {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 10px 8px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        min-height: 48px;
    }

    #sidebarHeader .header-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        white-space: nowrap;
        overflow: hidden;
        transition: opacity 0.2s ease, width 0.2s ease;
    }

    #sidebar.collapsed #sidebarHeader .header-label {
        opacity: 0;
        width: 0;
    }

    #sidebarToggle {
        width: 28px;
        height: 28px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.15s, border-color 0.15s;
    }

    #sidebarToggle:hover {
        background: rgba(91, 14, 20, 0.6);
        border-color: rgba(241, 225, 148, 0.3);
    }

    #sidebarLogout a {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.45);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
    }

    #sidebarLogout a:hover {
        background: rgba(220, 38, 38, 0.25);
        color: rgba(255, 255, 255, 0.85);
    }

    .sidebar-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }

    .sidebar-modal-overlay.open {
        display: flex;
    }

    .sidebar-modal-overlay.open .sidebar-modal-card {
        animation: sidebarModalIn 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes sidebarModalIn {
        from {
            opacity: 0;
            transform: scale(0.94) translateY(8px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    /* ── PC grid (sidebar sitin modal) ── */
    .sb-pc-grid {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 5px;
        margin-bottom: 4px;
    }

    .sb-pc-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        cursor: pointer;
        padding: 5px 2px;
        border-radius: 7px;
        border: 2px solid transparent;
        transition: all 0.15s;
        position: relative;
    }

    .sb-pc-unit:hover:not(.sb-pc-inuse):not(.sb-pc-defect) {
        border-color: #5B0E14;
        background: rgba(91, 14, 20, 0.07);
    }

    .sb-pc-unit.sb-selected {
        border-color: #5B0E14 !important;
        background: rgba(91, 14, 20, 0.1) !important;
    }

    .sb-pc-unit.sb-pc-inuse,
    .sb-pc-unit.sb-pc-defect {
        cursor: not-allowed;
        opacity: 0.65;
    }

    .sb-pc-icon {
        width: 30px;
        height: 25px;
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border: 1.5px solid;
    }

    .sb-pc-avail .sb-pc-icon {
        background: #ECFDF5;
        border-color: #A7F3D0;
    }

    .sb-pc-inuse .sb-pc-icon {
        background: #FFF7ED;
        border-color: #FDE68A;
    }

    .sb-pc-defect .sb-pc-icon {
        background: #FEF2F2;
        border-color: #FECACA;
    }

    .sb-pc-reserved .sb-pc-icon {
        background: #EFF6FF;
        border-color: #BFDBFE;
    }

    .sb-pc-dot {
        position: absolute;
        top: -3px;
        right: -3px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1.5px solid #fff;
    }

    .sb-pc-avail .sb-pc-dot {
        background: #10B981;
    }

    .sb-pc-inuse .sb-pc-dot {
        background: #F59E0B;
    }

    .sb-pc-defect .sb-pc-dot {
        background: #DC2626;
    }

    .sb-pc-reserved .sb-pc-dot {
        background: #3B82F6;
    }

    .sb-pc-num {
        font-size: 8px;
        font-weight: 700;
    }

    .sb-pc-avail .sb-pc-num {
        color: #065F46;
    }

    .sb-pc-inuse .sb-pc-num {
        color: #92400E;
    }

    .sb-pc-defect .sb-pc-num {
        color: #991B1B;
    }

    .sb-pc-reserved .sb-pc-num {
        color: #1D4ED8;
    }
</style>

