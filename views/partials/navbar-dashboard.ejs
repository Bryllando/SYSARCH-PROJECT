<style>
    .notif-dropdown {
        position: absolute;
        right: 0;
        top: calc(100% + 10px);
        width: 320px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.14), 0 2px 8px rgba(0, 0, 0, 0.08);
        border: 1px solid #F0F0F0;
        overflow: hidden;
        z-index: 50;
        display: none;
        flex-direction: column;
    }

    .notif-dropdown.open {
        display: flex;
    }

    .notif-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        border-bottom: 1px solid #F3F4F6;
        flex-shrink: 0;
        gap: 12px;
    }

    .notif-header-title {
        font-weight: 700;
        font-size: 13px;
        color: #273F4F;
        white-space: nowrap;
    }

    .notif-mark-read {
        font-size: 11px;
        font-weight: 600;
        color: #5B0E14;
        background: none;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        padding: 4px 8px;
        border-radius: 6px;
        transition: background 0.15s;
        flex-shrink: 0;
    }

    .notif-mark-read:hover {
        background: rgba(91, 14, 20, 0.07);
    }

    .notif-list {
        max-height: 300px;
        overflow-y: auto;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .notif-list::-webkit-scrollbar {
        width: 4px;
    }

    .notif-list::-webkit-scrollbar-track {
        background: transparent;
    }

    .notif-list::-webkit-scrollbar-thumb {
        background: #E5E7EB;
        border-radius: 4px;
    }

    .notif-empty {
        padding: 32px 16px;
        text-align: center;
        font-size: 13px;
        color: #9CA3AF;
    }

    .notif-item {
        padding: 12px 16px;
        border-bottom: 1px solid #F9FAFB;
        font-size: 12px;
        line-height: 1.5;
        transition: background 0.12s;
    }

    .notif-item:last-child {
        border-bottom: none;
    }

    .notif-item.unread {
        background: #EFF6FF;
        font-weight: 600;
        color: #1D4ED8;
    }

    .notif-item.admin-unread {
        background: #FFF7ED;
        font-weight: 600;
        color: #92400E;
    }

    .notif-item.read {
        color: #6B7280;
    }

    .notif-item p {
        margin: 0 0 2px;
    }

    .notif-item .notif-time {
        font-size: 11px;
        color: #9CA3AF;
        font-weight: 400;
    }
</style>

<header class="bg-[#5B0E14] px-6 py-3 flex justify-between items-center shadow-lg z-40 relative shrink-0">

    <!-- Left: Logos + Title -->
    <div class="flex items-center gap-3">
        <div class="flex items-center gap-2">
            <img src="/images/uclogo.png" alt="UC Logo"
                class="h-10 w-10 object-contain mix-blend-lighten drop-shadow-md">
            <img src="/images/ucmainccslogopreview.png" alt="CCS Logo"
                class="h-10 w-10 object-contain mix-blend-lighten drop-shadow-md">
        </div>
        <div class="w-px h-10 bg-white/30 hidden sm:block"></div>
        <h1 class="text-white font-semibold text-sm leading-tight hidden sm:block">
            College of Computer Studies<br>
            <span style="color:#F1E194; font-weight:700;">Sit-in Monitoring System</span>
        </h1>
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-4">

        <!-- ── USER Notification Bell ── -->
        <% if (user && user.role==='user' ) { %>
            <div style="position:relative;">
                <button id="notifBtn"
                    class="relative text-white/80 hover:text-white transition-colors focus:outline-none cursor-pointer p-1">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                        <path fill-rule="evenodd"
                            d="M5.25 9a6.75 6.75 0 0 1 13.5 0v.75c0 2.123.8 4.057 2.118 5.52a.75.75 0 0 1-.297 1.206c-1.544.57-3.16.99-4.831 1.243a3.75 3.75 0 1 1-7.48 0 24.585 24.585 0 0 1-4.831-1.244.75.75 0 0 1-.298-1.205A8.217 8.217 0 0 0 5.25 9.75V9Zm4.502 8.9a2.25 2.25 0 1 0 4.496 0 25.057 25.057 0 0 1-4.496 0Z"
                            clip-rule="evenodd" />
                    </svg>
                    <span id="notifBadge"
                        style="position:absolute;top:-2px;right:-2px;background:#F1E194;color:#5B0E14;font-size:9px;font-weight:800;border-radius:999px;width:16px;height:16px;display:none;align-items:center;justify-content:center;line-height:1;">
                    </span>
                </button>

                <div id="notifDropdown" class="notif-dropdown">
                    <div class="notif-header">
                        <span class="notif-header-title">Notifications</span>
                        <button id="markAllRead" class="notif-mark-read">Mark all read</button>
                    </div>
                    <ul id="notifList" class="notif-list">
                        <li class="notif-empty">Loading...</li>
                    </ul>
                </div>
            </div>
            <% } %>

                <!-- ── ADMIN Notification Bell ── -->
                <% if (user && user.role==='admin' ) { %>
                    <div style="position:relative;">
                        <button id="adminNotifBtn"
                            class="relative text-white/80 hover:text-white transition-colors focus:outline-none cursor-pointer p-1"
                            title="Notifications">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                class="size-6">
                                <path fill-rule="evenodd"
                                    d="M5.25 9a6.75 6.75 0 0 1 13.5 0v.75c0 2.123.8 4.057 2.118 5.52a.75.75 0 0 1-.297 1.206c-1.544.57-3.16.99-4.831 1.243a3.75 3.75 0 1 1-7.48 0 24.585 24.585 0 0 1-4.831-1.244.75.75 0 0 1-.298-1.205A8.217 8.217 0 0 0 5.25 9.75V9Zm4.502 8.9a2.25 2.25 0 1 0 4.496 0 25.057 25.057 0 0 1-4.496 0Z"
                                    clip-rule="evenodd" />
                            </svg>
                            <span id="adminNotifBadge"
                                style="position:absolute;top:-2px;right:-2px;background:#F1E194;color:#5B0E14;font-size:9px;font-weight:800;border-radius:999px;width:16px;height:16px;display:none;align-items:center;justify-content:center;line-height:1;">
                            </span>
                        </button>

                        <div id="adminNotifDropdown" class="notif-dropdown">
                            <div class="notif-header">
                                <span class="notif-header-title">Admin Notifications</span>
                                <button id="adminMarkAllRead" class="notif-mark-read">Mark all read</button>
                            </div>
                            <ul id="adminNotifList" class="notif-list">
                                <li class="notif-empty">Loading...</li>
                            </ul>
                        </div>
                    </div>
                    <% } %>

                        <!-- Name + Role -->
                        <div class="flex items-center gap-3">
                            <div class="text-right hidden sm:block">
                                <p class="text-white font-semibold text-sm leading-none">
                                    <%= user ? user.first_name + ' ' + user.last_name : '' %>
                                </p>
                                <p class="text-white/50 text-xs mt-0.5 capitalize text-center">
                                    <%= user ? user.role : '' %>
                                </p>
                            </div>
                        </div>

    </div>
</header>

<!-- ── USER notifications script ── -->
<% if (user && user.role==='user' ) { %>
    <script>
        (function () {
            const notifBtn = document.getElementById('notifBtn');
            const notifDropdown = document.getElementById('notifDropdown');
            const notifBadge = document.getElementById('notifBadge');
            const notifList = document.getElementById('notifList');

            async function loadNotifications() {
                try {
                    const res = await fetch('/notifications');
                    const data = await res.json();
                    const unread = data.filter(n => !n.is_read).length;
                    notifBadge.textContent = unread > 9 ? '9+' : unread;
                    notifBadge.style.display = unread === 0 ? 'none' : 'inline-flex';
                    if (data.length === 0) {
                        notifList.innerHTML = '<li class="notif-empty">No notifications yet</li>';
                    } else {
                        notifList.innerHTML = data.map(n => `
                    <li class="notif-item ${n.is_read ? 'read' : 'unread'}">
                        <p>${n.message}</p>
                        <p class="notif-time">${new Date(n.created_at).toLocaleString()}</p>
                    </li>`).join('');
                    }
                } catch (e) {
                    notifList.innerHTML = '<li class="notif-empty">Could not load notifications</li>';
                }
            }

            notifBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                const isOpen = notifDropdown.classList.toggle('open');
                if (isOpen) loadNotifications();
            });

            document.getElementById('markAllRead').addEventListener('click', async function () {
                await fetch('/notifications/read', { method: 'POST' });
                notifBadge.style.display = 'none';
                loadNotifications();
            });

            document.addEventListener('click', function (e) {
                if (!notifDropdown.contains(e.target) && e.target !== notifBtn) {
                    notifDropdown.classList.remove('open');
                }
            });

            loadNotifications();
            setInterval(loadNotifications, 30000);
        })();
    </script>
    <% } %>

        <!-- ── ADMIN notifications script ── -->
        <% if (user && user.role==='admin' ) { %>
            <script>
                (function () {
                    const btn = document.getElementById('adminNotifBtn');
                    const dropdown = document.getElementById('adminNotifDropdown');
                    const badge = document.getElementById('adminNotifBadge');
                    const list = document.getElementById('adminNotifList');

                    async function loadAdminNotifications() {
                        try {
                            const res = await fetch('/admin/notifications');
                            const data = await res.json();
                            const unread = data.filter(n => !n.is_read).length;
                            badge.textContent = unread > 9 ? '9+' : unread;
                            badge.style.display = unread === 0 ? 'none' : 'inline-flex';
                            if (data.length === 0) {
                                list.innerHTML = '<li class="notif-empty">No notifications yet</li>';
                            } else {
                                list.innerHTML = data.map(n => {
                                    const icon = n.type === 'reservation'
                                        ? '📅'
                                        : '🔔';
                                    return `<li class="notif-item ${n.is_read ? 'read' : 'admin-unread'}">
                        <p>${icon} ${n.message}</p>
                        <p class="notif-time">${new Date(n.created_at).toLocaleString()}</p>
                    </li>`;
                                }).join('');
                            }
                        } catch (e) {
                            list.innerHTML = '<li class="notif-empty">Could not load notifications</li>';
                        }
                    }

                    btn.addEventListener('click', function (e) {
                        e.stopPropagation();
                        const isOpen = dropdown.classList.toggle('open');
                        if (isOpen) loadAdminNotifications();
                    });

                    document.getElementById('adminMarkAllRead').addEventListener('click', async function () {
                        await fetch('/admin/notifications/read', { method: 'POST' });
                        badge.style.display = 'none';
                        loadAdminNotifications();
                    });

                    document.addEventListener('click', function (e) {
                        if (!dropdown.contains(e.target) && e.target !== btn) {
                            dropdown.classList.remove('open');
                        }
                    });

                    loadAdminNotifications();
                    // Poll every 20 seconds for new reservation notifications
                    setInterval(loadAdminNotifications, 20000);
                })();
            </script>
            <% } %>