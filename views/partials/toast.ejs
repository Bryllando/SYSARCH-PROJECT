<div id="app-toast-host"></div>
<style>
    #app-toast-host {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
    }

    .app-toast {
        pointer-events: auto;
        position: relative;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.18);
        min-width: 280px;
        max-width: 380px;
        font-family: ui-sans-serif, system-ui, sans-serif;
        animation: toastSlideIn 0.25s ease both;
        border: 1.5px solid #cbd5e1;
    }

    .app-toast--success { border-color: #86efac; }
    .app-toast--error { border-color: #fca5a5; }
    .app-toast--warning { border-color: #fcd34d; }
    .app-toast--info { border-color: #60a5fa; }

    .app-toast-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        color: #fff;
        font-size: 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .app-toast--success .app-toast-icon { background: linear-gradient(135deg, #16a34a, #22c55e); }
    .app-toast--error .app-toast-icon { background: linear-gradient(135deg, #dc2626, #ef4444); }
    .app-toast--warning .app-toast-icon { background: linear-gradient(135deg, #d97706, #f59e0b); }
    .app-toast--info .app-toast-icon { background: linear-gradient(135deg, #1a2035, #1d4ed8); }

    .app-toast-title {
        margin: 0 0 2px;
        font-size: 13px;
        font-weight: 700;
        color: #1f2937;
    }

    .app-toast-message {
        margin: 0;
        font-size: 12px;
        color: #4b5563;
        line-height: 1.45;
    }

    @keyframes toastSlideIn {
        from { opacity: 0; transform: translateX(32px) scale(0.96); }
        to { opacity: 1; transform: translateX(0) scale(1); }
    }
</style>
<script>
    (function () {
        const host = document.getElementById('app-toast-host');
        if (!host || window.showAppToast) return;

        const TYPE_META = {
            success: { icon: '✓', title: 'Success' },
            error: { icon: '!', title: 'Error' },
            warning: { icon: '!', title: 'Warning' },
            info: { icon: 'i', title: 'Info' }
        };

        window.showAppToast = function (type, message, title) {
            const safeType = TYPE_META[type] ? type : 'info';
            const meta = TYPE_META[safeType];
            const node = document.createElement('div');
            node.className = `app-toast app-toast--${safeType}`;
            node.innerHTML = `
                <div class="app-toast-icon">${meta.icon}</div>
                <div style="flex:1;min-width:0;">
                    <p class="app-toast-title">${title || meta.title}</p>
                    <p class="app-toast-message">${String(message || '')}</p>
                </div>
            `;
            host.appendChild(node);
            setTimeout(() => {
                node.style.opacity = '0';
                node.style.transform = 'translateX(20px)';
                node.style.transition = 'all .2s ease';
                setTimeout(() => node.remove(), 220);
            }, 3500);
        };

        <% if (locals.toast) { %>
            window.showAppToast('<%= locals.toast.type || "info" %>', <%- JSON.stringify(String(locals.toast.message || "")) %>);
        <% } %>
    })();
</script>